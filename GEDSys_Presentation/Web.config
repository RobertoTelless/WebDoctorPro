  <system.diagnostics>
    <trace autoflush="true" indentsize="4">
      <listeners>
        <add name="myFileListener" type="System.Diagnostics.TextWriterTraceListener" initializeData=".\Log\MinhaAplicacao.log" />
        </listeners>
    </trace>
