@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.SolicitacaoAlteracaoPlanoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Assinantes</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralAssinante", "Assinantes")">Central do Assinante</a>
            </li>
            <li class="active">
                <strong>Assinante - Solicitação de Alteração de Plano</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Assinante - Solicitação de Alteração de Plano</h5>
                </div>
                @using (Html.BeginForm("SolicitarAlteracaoPlano", "Assinante", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group">
                            @Html.ButtonActionSubmit(text: "Confirma Envio da Mensagem", htmlAttributes: new { id = "basictoast" })
                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoAssinante", controller: "Assinante")
                        </div>
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Assinante</h4>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_NM_NOME)
                                    @Html.HiddenFor(m => m.SOPL_DT_CONTATO)
                                    @Html.HiddenFor(m => m.PLAN_CD_ID_ATUAL)
                                    @Html.HiddenFor(m => m.SOPL_NM_PLANO_ATUAL)
                                    @Html.HiddenFor(m => m.SOPL_DT_VALIDADE)
                                    Nome do Assinante
                                    @Html.TextBoxFor(m => m.ASSI_NM_NOME, new { @class = "form-control", @readonly="readonly", @style = "color:green; font-weight:bold"})
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data da Solicitação
                                    @Html.TextBoxFor(m => m.SOPL_DT_CONTATO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly="readonly" })
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Plano Ativo
                                    @Html.TextBoxFor(m => m.SOPL_NM_PLANO_ATUAL, new { @class = "form-control", @readonly="readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Encerramento
                                    @Html.TextBoxFor(m => m.SOPL_DT_VALIDADE, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly="readonly" })
                                </div>
                            </div>

                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Plano Solicitado</h4>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Novo Plano*
                                    @Html.DropDownListFor(m => m.PLAN_CD_ID, (SelectList)ViewBag.Planos, "Selecionar", new { @class = "form-control", autofocus = true, id = "plano", onchange="GetPlano($(this).val())" })
                                    @Html.ValidationMessageFor(m => m.PLAN_CD_ID, "", new { @style = "color:red" })
                                </div>
                                <div style="display: none;" id="nome" class="col-lg-3 col-md-3 col-xs-12">
                                    Nome do Plano
                                    <input class="form-control" type="text" readonly="readonly" />
                                </div>
                                <div style="display: none;" id="peri" class="col-lg-2 col-md-2 col-xs-12">
                                    Periodicidade
                                    <input class="form-control" type="text" readonly="readonly" />
                                </div>
                                <div style="display: none;" id="valor" class="col-lg-2 col-md-2 col-xs-12">
                                    Valor
                                    <input class="form-control" type="text" readonly="readonly" />
                                </div>
                            </div>

                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Preferências de Resposta</h4>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Prioridade*
                                    @Html.DropDownListFor(m => m.SOPL_IN_PRIORIDADE, (SelectList)ViewBag.Prioridade, "Selecionar", new { @class = "form-control", autofocus = true, id = "prior" })
                                    @Html.ValidationMessageFor(m => m.SOPL_IN_PRIORIDADE, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Forma de Resposta*
                                    @Html.DropDownListFor(m => m.SOPL_IN_RESPOSTA, (SelectList)ViewBag.Resposta, "Selecionar", new { @class = "form-control", autofocus = true, id = "resposta", onchange = "ValidaDiv($(this).val())" })
                                    @Html.ValidationMessageFor(m => m.SOPL_IN_RESPOSTA, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Horário*
                                    @Html.DropDownListFor(m => m.SOPL_IN_HORARIO, (SelectList)ViewBag.Horario, "Selecionar", new { @class = "form-control", autofocus = true })
                                    @Html.ValidationMessageFor(m => m.SOPL_IN_HORARIO, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Motivo da Solicitação*
                                    @Html.DropDownListFor(m => m.SOPL_NM_MOTIVO, (SelectList)ViewBag.Motivo, "Selecionar", new { @class = "form-control", autofocus = true })
                                    @Html.ValidationMessageFor(m => m.SOPL_NM_MOTIVO, "", new { @style = "color:red" })
                                </div>
                            </div>

                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Contatos</h4>
                                <div class="col-lg-3 col-md-3 col-xs-12" >
                                    E-Mail
                                    @Html.TextBoxFor(m => m.SOPL_EM_MAIL, new { @class = "form-control", autofocus = true, @readonly="readonly" })
                                    @Html.ValidationMessageFor(m => m.SOPL_EM_MAIL, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Telefone
                                    @Html.TextBoxFor(m => m.SOPL_NR_TELEFONE, new { @class = "form-control", autofocus = true, @id= "tel", @readonly="readonly" })
                                    @Html.ValidationMessageFor(m => m.SOPL_NR_TELEFONE, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Celular
                                    @Html.TextBoxFor(m => m.SOPL_NR_CELULAR, new { @class = "form-control", autofocus = true, @id= "cel", @readonly="readonly" })
                                    @Html.ValidationMessageFor(m => m.SOPL_NR_CELULAR, "", new { @style = "color:red" })
                                </div>
                            </div>

                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Mensagem</h4>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    Texto da Solicitação*
                                    @Html.TextAreaFor(m => m.SOPL_TX_MENSAGEM, new { @class = "form-control", style = "width: 100%; height: 300px;", autofocus = true, @id = "texto" })
                                    @Html.ValidationMessageFor(m => m.SOPL_TX_MENSAGEM, "", new { @style = "color:red" })
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

