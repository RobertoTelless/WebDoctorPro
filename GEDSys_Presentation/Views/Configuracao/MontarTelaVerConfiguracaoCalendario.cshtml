@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.ConfiguracaoCalendarioViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Configuração - Calendário";
    ViewBag.MetaDescription = "WebDoctor - Visualização de Configurações de Calendário";
    ViewBag.MetaKeywords = "WebDoctor, Configuracao, Calendario, Calendário";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
