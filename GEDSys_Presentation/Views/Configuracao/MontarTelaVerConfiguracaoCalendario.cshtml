                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "IncluirConsulta", controller: "Paciente")
                        }
                        else if ((Int32)Session["VoltaInfoConsulta"] == 2)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "EditarConsulta", routeValues: new { id = (Int32)Session["IdConsulta"] })
                        }
