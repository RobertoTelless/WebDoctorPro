                                                        @Html.DropDownListFor(m => m.CONF_IN_ENVIA_EXAME_ZAP, (SelectList)ViewBag.Zap, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Define se o paciente poderá enviar os seus exames antecipadamente pelo WhatsApp", data_trigger="hover", data_placement="top" })
                                                        @Html.ValidationMessageFor(m => m.CONF_IN_ENVIA_EXAME_ZAP, "", new { @style = "color:red" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
