                                                        @Html.TextBoxFor(m => m.CONF_NR_WHAPSAPP, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Define o número do WhatsApp que será informado ao paciente na mensagem de confirmação de consulta", data_trigger="hover", data_placement="top", @id = "cel" })
