                                    {
                                        @Html.DropDownListFor(m => m.COCA_IN_SEGUNDA_FEIRA, (SelectList)ViewBag.Segunda, "Selecionar", new { @class = "form-control", autofocus = true, @id = "segVal", onchange = "ValidaSeg($(this).val())" })
                                    }
                                    else
                                    {
                                        @Html.DropDownListFor(m => m.COCA_IN_SEGUNDA_FEIRA, (SelectList)ViewBag.Segunda, "Selecionar", new { @class = "form-control", autofocus = true, style = "background-color: lightgray", @id = "segVal", onchange = "ValidaSeg($(this).val())" })
                                    }
                                    @Html.ValidationMessageFor(m => m.COCA_IN_SEGUNDA_FEIRA, "", new { @style = "color:red" })
