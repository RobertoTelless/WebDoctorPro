@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.TemplateEMailViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Modelos de E-Mails - Visualização";
    ViewBag.MetaDescription = "WebDoctor - Visualização de modelos de e-mails";
    ViewBag.MetaKeywords = "WebDoctor, modelos, template, e-mail";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Modelos de E-Mails</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaTemplateEMail", "TemplateEMail")">Modelos de E-Mails</a>
            </li>
            <li class="active">
                <strong>Modelos de E-Mails - Consulta</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Modelos de E-Mails - Consulta</h5>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="tabs-container">
                        @using (Html.BeginForm("VerTemplateEMail", "TemplateEMail", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                        {
                            <div class="form-group">
                                <br />
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div style="display: inline-block;">
                                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBaseTemplateEMail", controller: "TemplateEMail",  htmlAttributes: new { @class = "btn-loading" })
                                        <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                        <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                            <i class="fa fa-spinner fa-spin"></i> Processando...
                                        </span>
                                    </div>
                                </div>
                            </div>
                            
                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#tab-1">Dados Gerais</a></li>
                            </ul>

                            <div class="tab-content">
                                @*Dados Gerais*@
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                            @Html.HiddenFor(m => m.TEEM_IN_ATIVO)
                                            @Html.HiddenFor(m => m.TEEM_IN_ROBOT)
                                            @Html.HiddenFor(m => m.TEEM_IN_FIXO)
                                            @Html.HiddenFor(m => m.TEEM_CD_ID)
                                            @Html.HiddenFor(m => m.TEEM_IN_HTML)
                                            @Html.HiddenFor(m => m.TEEM_IN_IMAGEM)
                                            @Html.HiddenFor(m => m.EMPR_CD_ID)
                                            @Html.HiddenFor(m => m.TEEM_IN_SISTEMA)
                                            @Html.HiddenFor(m => m.TEEM_SG_SIGLA)
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Sigla do Modelo
                                                    @Html.TextBoxFor(m => m.TEEM_SG_SIGLA, new { @class = "form-control", @id = "sigla", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Nome do Modelo
                                                    @Html.TextBoxFor(m => m.TEEM_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @id = "nome", data_toggle = "popover", data_content = "Especifique um nome que irá identificar este modelo de E-Mail", data_trigger="hover", data_placement="top" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Editável
                                                    @Html.TextBoxFor(m => m.Editavel, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Indica se este modelo pode ou não ser alterado posteriormente", data_trigger="hover", data_placement="top" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Fixo
                                                    @Html.TextBoxFor(m => m.Fixo, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Indica se este modelo pode ou não ser excluído posteriormente", data_trigger="hover", data_placement="top" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Aniversário
                                                    @Html.TextBoxFor(m => m.Aniversario, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Indica se o modelo será pelo mecanismo de mensagens de aniversário", data_trigger="hover", data_placement="top" })
                                                </div>
                                            </div>
                                        </div>
                                        @if (Model.TEEM_IN_HTML == 1)
                                        {
                                            <div class="row" id="EM">
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                                        Cabeçalho
                                                        @Html.TextAreaFor(m => m.TEEM_TX_CABECALHO, new { @class = "form-control summernote", style = "width: 100%; height: 200px;", @tabindex = "-1", @readonly = "readonly", @id = "cab" })
                                                    </div>
                                                </div>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                                        Corpo
                                                        @Html.TextAreaFor(m => m.TEEM_TX_CORPO, new { @class = "form-control summernote", style = "width: 100%; height: 400px;", @tabindex = "-1", @readonly = "readonly", @id = "corpo" })
                                                    </div>
                                                </div>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                                        Rodapé
                                                        @Html.TextAreaFor(m => m.TEEM_TX_DADOS, new { @class = "form-control summernote", style = "width: 100%; height: 200px;", @tabindex = "-1", @readonly = "readonly", @id = "rodape" })
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Styles.Render("~/plugins/summernoteStyles")
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote.min.css" rel="stylesheet">
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    @Scripts.Render("~/plugins/summernote")

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>


    <script type="text/javascript">
        $(document).ready(function () {

            //$('.summernote').summernote();
            $('.summernote').summernote(
            {
              toolbar: [
                  ['view', ['fullscreen', 'codeview']],
                ],
            });
            $('#cab').summernote('disable');
            $('#corpo').summernote('disable');
            $('#rodape').summernote('disable');
        });

        var edit = function () {
            $('.click2edit').summernote({ focus: true });
        };

        var save = function () {
            var aHTML = $('.click2edit').code(); //save HTML If you need(aHTML: array).
            $('.click2edit').destroy();
        };
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
