@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.PACIENTE_ANAMNESE
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Anamnese - Anotação";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Anamnese - Anotação - Visualiação de anotação da anamnese do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, anexo";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarProcederConsulta", "Paciente")">Consulta - Procedimento</a>
            </li>
            <li class="active">
                <strong>Anamnese - Acompanhamento</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                <div class="col-lg-12 col-md-12 col-xs-12">
                    @if ((Int32)Session["VoltaAnotacaoAnamnese"] == 1)
                    {
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta")
                    }
                    else if ((Int32)Session["VoltaAnotacaoAnamnese"] == 2)
                    {
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarEditarUltimaAnamnese")
                    }
                    else if ((Int32)Session["VoltaAnotacaoAnamnese"] == 4)
                    {
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarEditarUltimoFisico")
                    }
                    else if ((Int32)Session["VoltaAnotacaoAnamnese"] == 3)
                    {
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarAnexoPaciente")
                    }
                </div>
            </div>
        </div>
    </div>
    <br />
    <div class="row">
        <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
        <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
            <div class="col-lg-4 col-md-4 col-xs-12">
                Nome do Paciente
                @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: blue; font-weight: bold" })
            </div>
            <div class="col-lg-2 col-md-2 col-xs-12">
                Data Nascimento
                @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
            </div>
            @if (Model.PACIENTE.PACI_NR_CPF != null)
            {
                <div class="col-lg-2 col-md-2 col-xs-12">
                    CPF
                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                </div>
            }
            @if (Model.PACIENTE.PACI_NR_CELULAR != null)
            {
                <div class="col-lg-2 col-md-2 col-xs-12">
                    Celular
                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly"  })
                </div>
            }
            @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
            {
                <div class="col-lg-2 col-md-2 col-xs-12">
                    Telefone
                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly"  })
                </div>
            }
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Anamnese - Acompanhamento</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }

                    <div class="row">
                        <div class="col-lg-12">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Anotações</h4>
                            <br />
                            <div class="form-group">
                                @Html.ButtonLinkIndex(text: "Incluir Novo Acompanhamentoo", action: "IncluirAnotacaoAnamnese", controller: "Paciente2")
                            </div>
                            @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_ANAMNESE_ANOTACAO>).Count > 0)
                            {
                                foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_ANAMNESE_ANOTACAO>).OrderByDescending(p => p.PAAA_DT_ANOTACAO.Value.Date))
                                {
                                    <div class="social-feed-box">
                                        <div class="social-avatar">
                                            <a href="" class="pull-left">
                                                <img src="@Url.Content(cond.USUARIO.USUA_AQ_FOTO)" style="width: auto; height: auto; max-height: 110px; max-width: 90px;">
                                            </a>
                                            <span style="color: #337ab7; cursor:pointer;" alt="Excluir" class="tbl-link fa-lg fa fa-trash-o" onclick="ShowModalExcluirAnotacao('/Paciente2/ExcluirAnotacaoAnamnese/@cond.PAAA_CD_ID')" title="Excluir Anotação"></span>
                                            <div class="media-body">
                                                <a href="@Url.Action("EditarAnotacaoAnamnese", "Paciente2", new { id = cond.PAAA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição da anotação">
                                                    @cond.USUARIO.USUA_NM_NOME
                                                </a>
                                                <small class="text-muted">@cond.PAAA_DT_ANOTACAO.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>
                                        </div>
                                        <div class="social-body">
                                            <p>
                                                <span style="white-space: pre-wrap;">@cond.PAAA_TX_ANOTACAO</span>
                                            </p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-2 col-md-2 col-xs-2">
                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                        <h2 style="font-weight: bold">Nenhum acompanhamento cadastrado nessa anamnese</h2>
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-2">
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirAnotacao(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Acompanhamento?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
    </script>

}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

