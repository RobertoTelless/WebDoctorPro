@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Anexo";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Visualiação de anexo do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, anexo";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal inmodal fade" id="modalConfirmacaoExclusaoAnexo" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content animated bounceInRight">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-trash-o modal-icon text-danger" style="display: block;"></i>
                    <h4 class="modal-title">Confirmação de Exclusão de Anexo</h4>
                    <small class="font-bold">WebDoctorPro - Gestão de Anexos</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3>Deseja realmente excluir este anexo?</h3>
                    <p>Esta ação removerá o arquivo permanentemente do prontuário do paciente.</p>
                    <input type="hidden" id="urlExclusaoTemp" value="" />
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmarExclusaoAnexo">Confirmar Exclusão</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarProcederConsulta", "Paciente")">Consulta</a>
            </li>
            <li class="active">
                <strong>Anexos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Consulta - Anexos</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Paciente
                                @Html.TextBoxFor(m => m.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Nascimento
                                @Html.TextBoxFor(m => m.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                            </div>
                            @if (Model.PACI_NR_CPF != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    CPF
                                    @Html.TextBoxFor(m => m.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                            @if (Model.PACI_NR_CELULAR != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Celular
                                    @Html.TextBoxFor(m => m.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                            @if (Model.PACI_NR_TELEFONE != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Telefone
                                    @Html.TextBoxFor(m => m.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                <h4 style="margin-left: 0px; margin-right: 0px;color:green; background-color: beige; font-weight:bold">Anexos</h4>
                                <br />
                                <div class="form-group">
                                    @using (Html.BeginForm("UploadFilePaciente2", "Paciente2", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                    {
                                        var listaAnexos = Model.PACIENTE_ANEXO.Where(p => p.PAAX_IN_ATIVO == 1).ToList();

                                        <div class="text-center" style="margin-top: 15px;">
                                            <div class="toggle-container" id="viewToggle">
                                                <div class="toggle-option active" data-target="sectionList">
                                                    <i class="fa fa-list"></i> Ver lista
                                                </div>
                                                <div class="toggle-option" data-target="sectionIcons">
                                                    <i class="fa fa-th"></i> Ver ícones
                                                </div>
                                            </div>
                                        </div>

                                        if (listaAnexos.Count > 0)
                                        {
                                            <div id="sectionList" class="view-section active">
                                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th>Título</th>
                                                            <th>Data</th>
                                                            <th>Tipo</th>
                                                            <th class="td-one-action">Ações</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in listaAnexos)
                                                        {
                                                            <tr>
                                                                <td style="width: auto">
                                                                    @if (cond.PAAX_IN_TIPO == 1 || cond.PAAX_IN_TIPO == 2)
                                                                    {
                                                                        <a href="@Url.Action("VerAnexoPaciente", "Paciente2", new { id = cond.PAAX_CD_ID })">@cond.PAAX_NM_TITULO</a>
                                                                    }
                                                                    else if (cond.PAAX_IN_TIPO == 4)
                                                                    {
                                                                        <a href="@Url.Action("VerAnexoPacienteAudio", "Paciente2", new { id = cond.PAAX_CD_ID })">@cond.PAAX_NM_TITULO</a>
                                                                    }
                                                                    else if (cond.PAAX_IN_TIPO == 3)
                                                                    {
                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.PAAX_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank">@cond.PAAX_NM_TITULO</a>
                                                                    }
                                                                    else { @cond.PAAX_NM_TITULO }
                                                                </td>
                                                                <td>@cond.PAAX_DT_ANEXO.ToShortDateString()</td>
                                                                <td>@(cond.PAAX_IN_TIPO == 1 ? "Imagem" : cond.PAAX_IN_TIPO == 2 ? "Vídeo" : cond.PAAX_IN_TIPO == 3 ? "PDF" : "Outros")</td>
                                                                <td class="td-one-action">
                                                                    <span class="fa fa-trash-o" onclick="PrepararExclusaoAnexo('/Paciente/ExcluirAnexo/@cond.PAAX_CD_ID')" style="cursor:pointer; color:#337ab7"></span>
                                                                    @Html.TableLinkDetails(cond.PAAX_CD_ID, "DownloadPaciente", "fa-download", "Download")
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>

                                            <div id="sectionIcons" class="view-section">
                                                <div class="row" style="display: flex; flex-wrap: wrap; justify-content: flex-start; margin-bottom: 20px;">
                                                    @foreach (var cond in listaAnexos)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-sm-3 col-xs-4 text-center" style="margin-bottom: 25px; min-width: 130px;">
                                                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: space-between; height: 100%;">
                    
                                                                @* Container de Mídia (Altura fixa para alinhamento) *@
                                                                <div style="height: 80px; display: flex; align-items: center; justify-content: center; width: 100%;">
                        
                                                                    @if (cond.PAAX_IN_TIPO == 1) // IMAGEM - Abre na mesma aba
                                                                    {
                                                                        <a href="@Url.Action("VerAnexoPaciente", "Paciente2", new { id = cond.PAAX_CD_ID })" title="Visualizar Imagem">
                                                                            <img src="@Url.Content(cond.PAAX_AQ_ARQUIVO)" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; border: 1px solid #ddd;" />
                                                                        </a>
                                                                    }
                                                                    else if (cond.PAAX_IN_TIPO == 2) // VÍDEO - Abre na mesma aba (Ícone comum)
                                                                    {
                                                                        <a href="@Url.Action("VerAnexoPaciente", "Paciente2", new { id = cond.PAAX_CD_ID })" title="Visualizar Vídeo">
                                                                            <i class="fa fa-video-camera fa-4x text-navy"></i>
                                                                        </a>
                                                                    }
                                                                    else if (cond.PAAX_IN_TIPO == 3) // PDF - ÚNICO QUE ABRE EM NOVA ABA
                                                                    {
                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.PAAX_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank" title="Visualizar PDF">
                                                                            <i class="fa fa-file-pdf-o fa-5x text-danger"></i>
                                                                        </a>
                                                                    }
                                                                    else if (cond.PAAX_IN_TIPO == 4) // ÁUDIO - Abre na mesma aba
                                                                    {
                                                                        <a href="@Url.Action("VerAnexoPacienteAudio", "Paciente", new { id = cond.PAAX_CD_ID })" title="Ouvir Áudio">
                                                                            <i class="fa fa-volume-up fa-4x text-info"></i>
                                                                        </a>
                                                                    }
                                                                    else // PADRÃO PARA OUTROS
                                                                    {
                                                                        <i class="fa fa-file-o fa-4x text-muted"></i>
                                                                    }
                                                                </div>

                                                                @* Nome do Arquivo *@
                                                                <div style="font-size: 11px; margin-top: 8px; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%;" title="@cond.PAAX_NM_TITULO">
                                                                    @cond.PAAX_NM_TITULO
                                                                </div>

                                                                @* Botões de Ação (Excluir e Download) *@
                                                                <div style="margin-top: 5px; display: flex; gap: 12px; justify-content: center;">
                                                                    <span style="cursor:pointer;" onclick="PrepararExclusaoAnexo('/Paciente/ExcluirAnexo/@cond.PAAX_CD_ID')" title="Excluir">
                                                                        <i class="fa fa-trash-o fa-lg text-navy"></i>
                                                                    </span>
                                                                    <a href="@Url.Action("DownloadPaciente", "Paciente2", new { id = cond.PAAX_CD_ID })" title="Download">
                                                                        <i class="fa fa-download fa-lg text-navy"></i>
                                                                    </a>
                                                                </div>

                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>

                                        }

                                        <div class="form-group" style="margin-top: 20px;">
                                            <div class="col-lg-12">
                                                <input type="file" name="file" id="file" class="btn btn-sm btn-warning" style="float: left; margin-right: 5px;" />
                                                <input type="submit" value="Incluir Anexo" class="btn btn-sm btn-success" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
        /* Container externo (o fundo da "pílula") */
        .toggle-container {
            background-color: #ebf9eb; /* Verde bem claro */
            border-radius: 20px;
            display: inline-flex;
            padding: 4px;
            margin-bottom: 20px;
            border: 1px solid #d0e9d0; /* Borda verde suave */
        }

        /* Opções de texto */
        .toggle-option {
            padding: 6px 20px;
            border-radius: 18px;
            cursor: pointer;
            font-weight: bold;
            color: #5cb85c; /* Verde padrão (Success) */
            transition: all 0.3s ease;
            user-select: none;
        }

        /* Opção selecionada (a "pílula" branca que corre) */
        .toggle-option.active {
            background-color: #ffffff; /* Fundo branco para destacar a opção ativa */
            color: #28a745; /* Verde mais escuro para o texto ativo */
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        /* Efeito de hover para melhorar a UX */
        .toggle-option:not(.active):hover {
            background-color: rgba(255, 255, 255, 0.5);
            color: #1e7e34;
        }
        .view-section {
            display: none !important;
        }

        .view-section.active {
            display: block !important;
        }


    </style>

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirAnexo(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Anexo do Paciente?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-exame').DataTable({
                pageLength: 10,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Anexos_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });
    </script>

    <script type="text/javascript">
        // 1. FUNÇÃO GLOBAL (Define O QUE o alerta faz)
        function ExibirMensagem(tipo, mensagem, titulo) {
            titulo = titulo || 'WebDoctor';
            
            // Mapeamento de tipos (aceita nomes ou números do C#)
            if (tipo === 'sucesso' || tipo === 1) {
                toastr.success(mensagem, titulo);
            } else if (tipo === 'erro' || tipo === 2) {
                toastr.error(mensagem, titulo);
            } else if (tipo === 'aviso' || tipo === 3) {
                toastr.warning(mensagem, titulo);
            } else {
                toastr.info(mensagem, titulo);
            }
        }

        $(document).ready(function () {
            // 2. CONFIGURAÇÕES GLOBAIS DO TOASTR (Define COMO o alerta aparece)
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "preventDuplicates": false,
                "positionClass": "toast-top-right",
                "showDuration": "400",
                "hideDuration": "1000",
                "timeOut": "15000",
                "extendedTimeOut": "5000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };

            // 3. CAPTURA MENSAGENS DO SERVIDOR (TempData do C#)
            var msgSucesso = '@TempData["MensagemAcerto"]';
            if (msgSucesso != '') ExibirMensagem('sucesso', msgSucesso, 'Sucesso!');

            var msgErro = '@TempData["MensagemErro"]';
            if (msgErro != '') ExibirMensagem('erro', msgErro, 'Erro!');

            // 4. VALIDAÇÃO DO ARQUIVO (Evento disparado pelo input id="file")
            $('#file').on('change', function () {
                var arquivo = this.files[0];
                var limiteTamanho = 50 * 1024 * 1024; // 50MB (Conforme seu código)
                var extensoesPermitidas = ['pdf', 'jpg', 'jpeg', 'png', 'mp3', 'mp4', 'webp', 'xlsx'];

                if (arquivo) {
                    var nomeArquivo = arquivo.name;
                    var extensao = nomeArquivo.split('.').pop().toLowerCase();

                    // Validação de Extensão
                    if ($.inArray(extensao, extensoesPermitidas) == -1) {
                        ExibirMensagem('erro', 'A extensão .' + extensao + ' não é permitida.', 'Arquivo Inválido');
                        $(this).val(''); 
                        return false;
                    }

                    // Validação de Tamanho
                    if (arquivo.size > limiteTamanho) {
                        ExibirMensagem('aviso', 'O arquivo excede o limite de 50MB.', 'Arquivo muito pesado');
                        $(this).val(''); 
                        return false;
                    }

                    // Sucesso na validação local
                    ExibirMensagem('sucesso', 'Arquivo "' + nomeArquivo + '" pronto para upload.', 'Validado');
                }
            });
        });
    </script>

    <script>
        $(document).ready(function () {
            $('.toggle-option').click(function () {
                // Remove 'active' de todos os botões e adiciona no clicado
                $('.toggle-option').removeClass('active');
                $(this).addClass('active');

                // Esconde todas as seções e mostra a selecionada
                var targetSection = $(this).data('target');
                $('.view-section').removeClass('active');
                $('#' + targetSection).addClass('active');
            });
        });
    </script>
    <script type="text/javascript">
        // 1. Prepara a URL e abre a modal
        function PrepararExclusaoAnexo(url) {
            $('#urlExclusaoTemp').val(url); // Armazena a URL no campo hidden da modal
            $('#modalConfirmacaoExclusaoAnexo').modal('show');
        }

        $(document).ready(function () {
            // 2. Ação do botão Confirmar dentro da modal
            $('#btnConfirmarExclusaoAnexo').click(function () {
                var urlFinal = $('#urlExclusaoTemp').val();
                var $btn = $(this);

                if (urlFinal !== "") {
                    // Feedback visual
                    $btn.prop('disabled', true).addClass('disabled');
                    $btn.html('<i class="fa fa-spinner fa-spin"></i> Excluindo...');

                    // Fecha a modal e redireciona
                    $('#modalConfirmacaoExclusaoAnexo').modal('hide');
                
                    setTimeout(function () {
                        $('.modal-backdrop').remove();
                        $('#loadingIndicator').show();
                        window.location.href = urlFinal;
                    }, 400);
                }
            });

            // Limpeza de segurança ao fechar
            $('#modalConfirmacaoExclusaoAnexo').on('hidden.bs.modal', function () {
                $('#urlExclusaoTemp').val("");
                $('#btnConfirmarExclusaoAnexo').prop('disabled', false).removeClass('disabled').html('Confirmar Exclusão');
            });
        });
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
