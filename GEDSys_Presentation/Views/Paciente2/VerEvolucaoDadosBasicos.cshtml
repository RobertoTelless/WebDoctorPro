@using Presentation.Extensions
@model EntitiesServices.Model.PACIENTE
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Atestados";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Exame Físico ";
    ViewBag.MetaKeywords = "WebDoctor, paciente, exame, fisico";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("EditarPaciente", "Paciente")">Paciente - Edição</a>
            </li>
            <li>
                <a href="@Url.Action("EditarExameFisico", "Paciente")">Exame Físico - Edição</a>
            </li>
            <li class="active">
                <strong>Evolução</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                       <h5>Paciente - Exame Físico - Evolução</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("VerEvolucaoDadosBasicos", "Paciente2", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Mensagens:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @if ((Int32)Session["VoltarEvolucao"] == 1)
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarAnexoPaciente")
                                    }
                                    else if ((Int32)Session["VoltarEvolucao"] == 2)
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta")
                                    }
                                    else if ((Int32)Session["VoltarEvolucao"] == 4)
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarEditarUltimoFisico")
                                    }
                                    else
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarAnexoPaciente")
                                    }
                                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                <h4 style="margin-left: 0px; margin-right: 0px;color:green; background-color: beige; font-weight:bold">Evolução do Exame Físico</h4>
                                <div class="col-lg-8 col-md-8 col-xs-12">
                                    <div class="row">
                                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_DADOS_EXAME_FISICO>).Count > 0)
                                        {
                                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                                <thead style="background-color:lightsteelblue">
                                                    <tr>
                                                        <th style="width: auto">Data/Hora do Exame</th>
                                                        <th style="width: auto">Peso (kg)</th>
                                                        <th style="width: auto">Altura (cm)</th>
                                                        <th style="width: auto">Pressão Diastólica (mmHg)</th>
                                                        <th style="width: auto">Pressão Sistólica  (mmHg)       </th>
                                                        <th style="width: auto">Frequencia Cardíaca (bpm)</th>
                                                        <th style="width: auto">Temperatura (oC)</th>
                                                        <th style="width: 0.01px"></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_DADOS_EXAME_FISICO>).OrderByDescending(p => p.PDEF_DT_DATA.Value.Date))
                                                    {
                                                        <tr>
                                                            <td style="width: auto">@cond.PDEF_DT_DATA.Value.ToShortDateString() @cond.PDEF_DT_DATA.Value.ToShortTimeString()</td>
                                                            @if (cond.PDEF_IN_PESO != null)
                                                            {
                                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.PDEF_IN_PESO.Value)</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.PDEF_IN_ALTURA != null)
                                                            {
                                                                <td style="width: auto">@cond.PDEF_IN_ALTURA.Value</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.PDEF_IN_PRESSAO_ALTA != null)
                                                            {
                                                                <td style="width: auto">@cond.PDEF_IN_PRESSAO_ALTA.Value</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.PDEF_IN_PRESSAO_BAIXA != null)
                                                            {
                                                                <td style="width: auto">@cond.PDEF_IN_PRESSAO_BAIXA.Value</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.PDEF_IN_FREQUENCIA != null)
                                                            {
                                                                <td style="width: auto">@cond.PDEF_IN_FREQUENCIA.Value</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.PDEF_IN_TEMPERATURA != null)
                                                            {
                                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.PDEF_IN_TEMPERATURA.Value)</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                            }
                                                            <td style="width: 0.01px"></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div class="row">
                                                <div class="col-lg-1 col-md-1 col-xs-2">
                                                </div>
                                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-10">
                                                    <h2 style="font-weight: bold">Nenhuma informação de exame físico para este paciente</h2>
                                                </div>
                                                <div class="col-lg-1 col-md-1 col-xs-2">
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    <h4 style="margin-left: 0px; margin-right: -15px;color:green; background-color: beige; font-weight:bold">Evolução do Peso</h4>
                                    <div class="row">
                                        <canvas id="lineChartPeso" height="80"></canvas>
                                    </div>
                                    <br />
                                    <h4 style="margin-left: 0px; margin-right: -15px;color:green; background-color: beige; font-weight:bold">Evolução da Pressão Arterial</h4>
                                    <div class="row">
                                        <canvas id="lineChartPressao" height="80"></canvas>
                                    </div>
                                    <br />
                                    <h4 style="margin-left: 0px; margin-right: -15px;color:green; background-color: beige; font-weight:bold">Evolução da Frequencia Cardíaca (bpm)</h4>
                                    <div class="row">
                                        <canvas id="lineChartFrequencia" height="80"></canvas>
                                    </div>
                                    <br />
                                    <h4 style="margin-left: 0px; margin-right: -15px;color:green; background-color: beige; font-weight:bold">Evolução da Temperatura (oC)</h4>
                                    <div class="row">
                                        <canvas id="lineChartTemperatura" height="80"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-atestado').DataTable({
                pageLength: 10,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Evolução_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/Paciente2/GetDadosPeso'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Peso (kg)",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valoresPeso
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartPeso").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/Paciente2/GetDadosPressao'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Diastólica (mmHg)",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valoresDiastolica
                            }, {
                                label: "Sistólica (mmHg)",
                                backgroundColor: 'rgba(225, 133, 6, 0.5)',
                                borderColor: "rgba(225, 133, 6,0.7)",
                                pointBackgroundColor: "rgba(225, 133, 6,1)",
                                pointBorderColor: "#fff",
                                data: result.valoresSistolica
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartPressao").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/Paciente2/GetDadosFrequencia'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Frequencia Cardíaca (bpm)",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valoresFreq
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartFrequencia").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/Paciente2/GetDadosTemperatura'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Temperatura (oC)",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valoresTemp
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartTemperatura").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
