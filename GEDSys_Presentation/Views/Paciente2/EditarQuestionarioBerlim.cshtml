@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.QuestionarioBerlimViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Questionarios - Edição";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Questionarios - Editar questionario Berlim";
    ViewBag.MetaKeywords = "WebDoctor, paciente, questionario";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("EditarPaciente", "Paciente")">Paciente - Edição</a>
            </li>
            <li class="active">
                <strong>Questionário Berlim - Edição</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Questionário Berlim - Edição</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME</span>
                    </div>
                </div>
                @using (Html.BeginForm("EditarQuestionarioBerlim", "Paciente2", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;"> 
                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente")
                            <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                        </div>

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>


                        @*Questionario*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Questionário de Berlim</h4>
                            <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">                
                                @Html.ButtonActionSubmit(text: "Confirma Edição do Questionário de Berlim", htmlAttributes: new { id = "basictoast" })
                            </div>
                            <div class="row">
                                @*<div class="col-lg-12">*@
                                    <div class="form-group" style=" margin-left: 0px; margin-right: 0   px;">
                                        <h5 style="margin-left: 15px; color:brown; background-color: beige; font-weight:bold">Categoria 1</h5>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                            @Html.HiddenFor(m => m.PACI_CD_ID)
                                            @Html.HiddenFor(m => m.QUBE_CD_ID)
                                            Você ronca?
                                            @Html.DropDownListFor(m => m.QUBE_IN_RONCO, (SelectList)ViewBag.Ronco, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_RONCO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Seu ronco é?
                                            @Html.DropDownListFor(m => m.QUBE_IN_TIPO_RONCO, (SelectList)ViewBag.TipoRonco, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_RONCO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                            Com que frequencia ronca?
                                            @Html.DropDownListFor(m => m.QUBE_IN_FREQUENCIA_RONCO, (SelectList)ViewBag.FreqRonco, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_FREQUENCIA_RONCO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                @*</div>*@
                            </div>

                            <div class="row">
                                @*<div class="col-lg-12">*@
                                    <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            O seu ronco incomoda alguem??
                                            @Html.DropDownListFor(m => m.QUBE_IN_INCOMODA_RONCO, (SelectList)ViewBag.Incomoda, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_INCOMODA_RONCO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Alguem notou que voce para de respirar enquanto dorme?
                                            @Html.DropDownListFor(m => m.QUBE_IN_PARA_RESPIRA, (SelectList)ViewBag.Respira, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_PARA_RESPIRA, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                @*</div>*@
                            </div>
                            <div class="row">
                                @*<div class="col-lg-12">*@
                                    <h5 style="margin-left: 15px; color:brown; background-color: beige; font-weight:bold">Categoria 2</h5>
                                    <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Quantas vezes voce se sente cansado ou com fadiga depois de acordar?
                                            @Html.DropDownListFor(m => m.QUBE_IN_CANSACO, (SelectList)ViewBag.Cansaco, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_CANSACO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Quando acordado, voce se sente cansado, fatigado ou não se sente bem
                                            @Html.DropDownListFor(m => m.QUBE_IN_CANSACO_ACORDADO, (SelectList)ViewBag.Acordado, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_CANSACO_ACORDADO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Alguma vez voce cochilou ou caiu no sono enquanto dirigia?
                                            @Html.DropDownListFor(m => m.QUBE_IN_COCHILO, (SelectList)ViewBag.Cochilo, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_COCHILO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                @*</div>*@
                            </div>
                            <div class="row">
                                @*<div class="col-lg-12">*@
                                    <h5 style="margin-left: 15px; color:brown; background-color: beige; font-weight:bold">Categoria 3</h5>
                                    <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Voce tem pressao alta?
                                            @Html.DropDownListFor(m => m.QUBE_IN_PRESSAO, (SelectList)ViewBag.Pressao, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_IN_PRESSAO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                @*</div>*@
                            </div>
                            <div class="row">
                                @*<div class="col-lg-12">*@
                                    <h5 style="margin-left: 15px; color:brown; background-color: beige; font-weight:bold">IMC</h5>
                                    <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Valor do IMC?
                                            @Html.TextBoxFor(m => m.QUBE_NR_IMC, new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.QUBE_NR_IMC, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                @*</div>*@
                            </div>  
                        </div>

                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Edição em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
