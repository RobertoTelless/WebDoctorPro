@using Presentation.Extensions
@model EntitiesServices.Model.PACIENTE
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("IncluirPaciente", "Paciente")">Pacientes - Inclusão</a>
            </li>
            <li class="active">
                <strong>Pacientes - Captura de Foto</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Paciente - Captura de Foto</h5>
                </div>
                @using (Html.BeginForm("CapturaFotoCamera", "Paciente2", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group">
                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarCapturaFoto", controller: "Paciente2")
                        </div>

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-1 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-1 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Captura de Foto</h4>
                            <div class="col-lg-6 col-md-6 col-xs-12">
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <video id="video" autoplay style="height: 400px; width: 200px"></video>
                                </div>
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <button id="capture" class="btnSubmit btn btn-sm btn-success" type="button">Capturar Imagem</button>
                                </div>
                            </div>
                            <div class="col-lg-6 col-md-6 col-xs-12">
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <canvas id="canvas" style="display:none; height: 400px; width: 200px"></canvas>
                                </div>
                                <form id="imageForm" method="post" enctype="multipart/form-data">
                                    <input type="hidden" id="imageData" name="imageData" />
                                </form>                            
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
   
    <script>
        // Seleciona elementos
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const captureButton = document.getElementById('capture');
        const imageDataInput = document.getElementById('imageData');

        // Obtem acesso à camera
        navigator.mediaDevices.getUserMedia({ video: true })
            .then(stream => {
                video.srcObject = stream;
            })
            .catch(error => {
                console.error("Erro no acesso à câmera: ", error);
            });

        // Captura a imagem no click
        captureButton.addEventListener('click', () => {
            const context = canvas.getContext('2d');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            // Converte a imagem em Base64 string
            const imageData = canvas.toDataURL('image/png');

            // Coloca a imagem em um campo oculto
            imageDataInput.value = imageData;

            // Submit via AJAX
            fetch('/Paciente2/GravaImagem', {
                method: 'POST',
                body: new FormData(document.getElementById('imageForm'))
            })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
            })
            .catch(error => {
                console.error("Erro na gravação: ", error);
            });
        });
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
