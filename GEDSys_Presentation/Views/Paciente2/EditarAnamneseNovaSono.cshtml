                                        @Html.HiddenFor(m => m.PAAM_NM_CAMPO_6)
                                        @Html.HiddenFor(m => m.PAAM_NM_CAMPO_7)
                                        @Html.HiddenFor(m => m.PAAM_NM_CAMPO_8)
                                        @Html.HiddenFor(m => m.PAAM_NM_CAMPO_9)
                                        @Html.HiddenFor(m => m.PAAM_NM_CAMPO_10)
                                        @Html.HiddenFor(m => m.PAAM_DT_ORIGINAL)
                                        Principal queixa do sono - Histórico
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_PRINCIPAL_QUEIXA_OLD, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Principal queixa do sono - Consulta Atual/Revisão
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_PRINCIPAL_QUEIXA, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.PAAM_DS_SONO_PRINCIPAL_QUEIXA, "", new { @style = "color:red" })
                                    </div>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Sintomas - Histórico
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_SINTOMAS_OLD, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Sintomas - Consulta Atual/Revisão
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_SINTOMAS, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.PAAM_DS_SONO_SINTOMAS, "", new { @style = "color:red" })
                                    </div>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                         Horário regulares para dormir e acordar - Histórico
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_HORARIO_REGULAR_NOVO_OLD, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                         Horário regulares para dormir e acordar - Consulta Atual/Revisão
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_HORARIO_REGULAR_NOVO, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.PAAM_DS_SONO_HORARIO_REGULAR_NOVO, "", new { @style = "color:red" })
                                    </div>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                         Latência para o início do sono - Histórico
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_LATENCIA_NOVO_OLD, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Latência para o início do sono - Consulta Atual/Revisão
                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_LATENCIA_NOVO, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
