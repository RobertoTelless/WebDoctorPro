                                        @Html.TextAreaFor(m => m.PAAM_DS_SONO_DURACAO_OLD, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
