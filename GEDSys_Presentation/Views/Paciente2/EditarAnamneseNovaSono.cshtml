                                    </div>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Manutenção da rotina nos fins de semana - Consulta Atual/Revisão
                                        @Html.DropDownListFor(m => m.PAAM_DS_SONO_ROTINA_FDS, (SelectList)ViewBag.SimNao, "Selecionar", new { @class = "form-control", autofocus = true, @id = "menor", onchange = "ValidaMenor($(this).val())" })
                                        @Html.ValidationMessageFor(m => m.PAAM_DS_SONO_ROTINA_FDS, "", new { @style = "color:red" })
                                    </div>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Cochilos diurnos - Consulta Atual/Revisão
                                        @Html.DropDownListFor(m => m.PAAM_DS_SONO_COCHILOS, (SelectList)ViewBag.SimNao, "Selecionar", new { @class = "form-control", autofocus = true, @id = "menor", onchange = "ValidaMenor($(this).val())" })
                                        @Html.ValidationMessageFor(m => m.PAAM_DS_SONO_COCHILOS, "", new { @style = "color:red" })
