@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteAnamneseViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Anamneses - Edição";
    ViewBag.MetaDescription = "WebDoctor - Anamneses - Edição";
    ViewBag.MetaKeywords = "WebDoctor, anamnese";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarProcederConsulta", "Paciente")">Consulta - Proceder</a>
            </li>
            <li class="active">
                <strong>Pacientes - Anamneses</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Anamnese - Alteração</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME.ToUpper()</span>
                    </div>
                </div>
                @using (Html.BeginForm("EditarAnamneseNovaSono", "Paciente2", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group">
                            @Html.ButtonActionSubmit(text: "Confirma Edição da Anamnese", htmlAttributes: new { id = "basictoast",  @class = "btn-loading1"  })
                            @Html.ButtonLinkIndex(text: "Ver Anamnese Completa", action: "VerAnamneseCompletaChamadaSono", controller: "Paciente2", htmlAttributes: new { @class = "btn-loading" })
                            @Html.ButtonLinkIndex(text: "Acompanhamento", action: "VerAnotacaoAnamneseBase", controller: "Paciente2", htmlAttributes: new { @class = "btn-loading" })
                            @Html.ButtonLinkIndex(text: "Exame Físico", action: "VerExameFisicoBase", controller: "Paciente2", htmlAttributes: new { @class = "btn-loading" })
                            @Html.ButtonLinkIndex(text: "Imprimir Anamnese", action: "GerarAnamnesePDFNovaSono", controller: "Paciente2")
                            @Html.ButtonLinkIndex(text: "Acerto", action: "AcertoCampo", controller: "Paciente2", htmlAttributes: new { @class = "btn-loading" })
                            @if ((Int32)Session["VoltarPesquisa"] == 44)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "PesquisarTudo", controller: "BaseAdmin", htmlAttributes: new { @class = "btn-loading" })
                            }
                            else
                            {
                                if ((Int32)Session["VoltaAnamnese"] == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["VoltaAnamnese"] == 2)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarProcederConsulta", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                            }
                            <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                            <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                <i class="fa fa-spinner fa-spin"></i> Processando...
                            </span>
                        </div>

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold", tabindex = "-1" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-1 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-1 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Consulta</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_CD_ID)
                                    @Html.HiddenFor(m => m.PAAM_DT_DATA)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PAAM_IN_ATIVO)
                                    @Html.HiddenFor(m => m.PAAM_CD_ID)
                                    @Html.HiddenFor(m => m.PAAM_DT_COPIA)
                                    @Html.HiddenFor(m => m.PAAM_IN_CAMPO_1)
                                    @Html.HiddenFor(m => m.PAAM_IN_CAMPO_2)
                                    @Html.HiddenFor(m => m.PAAM_IN_CAMPO_3)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_ABDOMEM)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_AVALIACAO_CARDIOLOGICA)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_DIAGNOSTICO_1)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_DIAGNOSTICO_2)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_HISTORIA_DOENCA_ATUAL)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_HISTORIA_PROGRESSIVA)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_HISTORIA_SOCIAL)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_MEMBROS_INFERIORES)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_MOTIVO_CONSULTA)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_QUEIXA_PRINCIPAL)
                                    @Html.HiddenFor(m => m.PAAM_IN_FLAG_RESPIRATORIO)
                                    @Html.HiddenFor(m => m.PAAM_IN_PREENCHIDA)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_1)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_2)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_3)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_4)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_5)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_6)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_7)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_8)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_9)
                                    @Html.HiddenFor(m => m.PAAM_NM_CAMPO_10)
                                    @Html.HiddenFor(m => m.PAAM_DT_ORIGINAL)
                                    Data da Consulta
                                    @Html.TextBoxFor(m => m.PAAM_DT_DATA, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: darkblue; font-weight: bold", tabindex = "-1" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Consulta
                                    @Html.TextBoxFor(m => m.PACIENTE_CONSULTA.VALOR_CONSULTA.VACO_NM_NOME, new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Rotina do Sono</h4>
                            <div class="col-lg-6 col-md-6 col-xs-12">
                                <h4 style="margin-left: 0px; color:white; background-color: darkseagreen; font-weight:bold">Rotina do Sono</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        @Html.HiddenFor(m => m.PACI_CD_ID)
                                        @Html.HiddenFor(m => m.PACO_CD_ID)
                                        @Html.HiddenFor(m => m.PAAM_DT_DATA)
                                        @Html.HiddenFor(m => m.USUA_CD_ID)
                                        @Html.HiddenFor(m => m.ASSI_CD_ID)
                                        @Html.HiddenFor(m => m.PAAM_IN_ATIVO)
                                        @Html.HiddenFor(m => m.PAAM_CD_ID)
                                        @Html.HiddenFor(m => m.PAAM_DT_COPIA)
