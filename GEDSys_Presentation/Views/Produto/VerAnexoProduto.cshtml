@using Presentation.Extensions
@model EntitiesServices.Model.PRODUTO_ANEXO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Materiais/Produtos</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaProduto", "Produto")">Materiais/Produtos</a>
            </li>
            <li>
                <a href="@Url.Action("EditarProduto", "Produto")">Materiais/Produtos - Alteração</a>
            </li>
            <li class="active">
                <strong>Materiais/Produtos - Anexo</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Materiais/Produtos - Ver Anexo</h5>
                </div>
                @using (Html.BeginForm("VerAnexoProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Titulo
                                    @Html.TextBoxFor(m => m.PRAN_NM_TITULO, new { @class = "form-control", @readonly="readonly"})
                                </div>
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Data
                                    @Html.TextBoxFor(m => m.PRAN_DT_ANEXO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly="readonly"})
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoProduto", controller: "Produto")
                        </div>
                        <div class="form-group">
                            @if (Model.PRAN_IN_TIPO == 1)
                            {
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="col-lg-12 col-md-12 col-sm-12">
                                        @*<img src="@Url.Content(Model.PAAX_AQ_ARQUIVO)" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Clique Ctrl+Ctrl para ampliar a fotografia" style="width: auto; height: auto; max-height: 1530px; max-width: 1530px;">*@
                                        <img src="@("https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + Model.PRAN_AQ_ARQUIVO.Replace("~/", "").Replace("~", ""))" 
                                             data-toggle="popover" 
                                             data-trigger="hover" 
                                             data-placement="top" 
                                             data-content="Clique Ctrl+Ctrl para ampliar a fotografia" 
                                             style="width: auto; height: auto; max-height: 1530px; max-width: 1530px;"
                                             onerror="this.onerror=null;this.src='@Url.Content("~/Images/icone_imagem.jpg")';">
                                    </div>
                                </div>
                            }
                            @if (Model.PRAN_IN_TIPO == 2)
                            {
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <figure>
                                        @{
                                            var urlVideoAzure = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + Model.PRAN_AQ_ARQUIVO.Replace("~/", "").Replace("~", "");
                                        }
                                        <video width="900" height="600" controls style="background: #000;">
                                            <source src="@urlVideoAzure" type="video/mp4">
                                            Seu navegador não suporta a tag de vídeo.
                                        </video>
                                    </figure>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
}
@section Scripts {
   
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    @Scripts.Render("~/plugins/videoResponsible")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script type="text/javascript">
        $(document).on('webkitfullscreenchange mozfullscreenchange fullscreenchange', function (e) {
            $('body').hasClass('fullscreen-video') ? $('body').removeClass('fullscreen-video') : $('body').addClass('fullscreen-video')
        });
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}

