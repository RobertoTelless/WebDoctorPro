@using Presentation.Extensions
@using CrossCutting
@model EntitiesServices.Model.USUARIO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>

<div id="content" class="wraper container-fluid">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="col-lg-12 col-md-12 col-sm-12">
            @*Atalhos*@
            <div class="row">
                <h3 style="color:olivedrab; font-weight:bold">Dashboard - Produtos</h3>
                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                    <br />
                    <div class="col-lg-12 col-md-12 col-xs-12">
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Produto", action: "VoltarBaseProduto")
                    </div>
                    <br /><br />
                </div>
            </div>

            @*Estatísticas*@
            <div class="row">
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Produtos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.Produtos</h1>
                            <small>Produtos Cadastrados</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "Produto", action: "MontarTelaProduto", buttonClass: "white", htmlAttributes: new { @id = "cad", OnClick = "Fade1()" })
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Produtos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ProdutosAcima</h1>
                            <small>Estoque Acima do Máximo</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "Produto", action: "MontarTelaProdutoAcima", buttonClass: "white", htmlAttributes: new { @id = "aci", OnClick = "Fade1()" })
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Produtos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ProdutosAbaixo</h1>
                            <small>Estoque Abaixo do Mínimo</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "Produto", action: "MontarTelaProdutoAbaixo", buttonClass: "white", htmlAttributes: new { @id = "aba", OnClick = "Fade1()" })
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Produtos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ProdutosZerado</h1>
                            <small>Estoque Zerado</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "Produto", action: "MontarTelaProdutoZerado", buttonClass: "white", htmlAttributes: new { @id = "zero", OnClick = "Fade1()" })
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Produtos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ProdutosEsgota</h1>
                            <small>Esgotando até 30 dias</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "Produto", action: "MontarTelaProdutoEsgota", buttonClass: "white", htmlAttributes: new { @id = "esg", OnClick = "Fade1()" })
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div style="display: none; background-color: transparent; z-index:1000" class="dotContainer1">
                        <div class="spiner-example">
                            <div class="sk-spinner sk-spinner-three-bounce">
                                <div class="sk-bounce1"></div>
                                <div class="sk-bounce2"></div>
                                <div class="sk-bounce3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @*Widgets*@
            <br />
