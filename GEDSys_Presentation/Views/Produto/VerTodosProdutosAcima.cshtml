@using Presentation.Extensions
@using CrossCutting;
@using EntitiesServices.Work_Classes;
@model ERP_Condominios_Solution.ViewModels.ModeloViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Materiais/Produtos</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaProduto", "Produto")">Materiais/Produtos</a>
            </li>
            <li class="active">
                <strong>Materiais/Produtos - Relatórios</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12"  id="Lista">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Produtos/Materiais com Estoque acima do máximo</h5>
                </div>
                <div class="ibox-content">
                    <div class="form-group">
                        @Html.ButtonLinkIndex(text: "Gerar Listagem", controller: "Produto", action: "GerarRelatorioListaAcima")
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Produto", action: "MontarTelaProduto")
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            @if (ViewBag.Lista != null && (ViewBag.Lista as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Produto</th>
                                            <th style="width: auto">Est.Atual</th>
                                            <th style="width: auto">Est.Máximo</th>
                                            <th style="width: auto">Categoria</th>
                                            <th style="width: auto">Sub-Categoria</th>
                                            <th style="width: auto">Código</th>
                                            <th style="width: auto">Modelo</th>
                                            <th style="width: auto">Marca</th>
                                            <th style="width: auto">Diferença (%)</th>
                                            <th style="width: auto">Tipo</th>
                                            <th style="width: auto"></th>
                                            <th style="width: auto" class="td-one-action">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (ViewBag.Lista as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderByDescending(p => p.Valor).ThenBy(p => p.Nome))
                                        {
                                            <tr>
                                                <td style="width: auto">@cond.Nome</td>
                                                <td style="width: auto">@cond.ValorDec1</td>
                                                <td style="width: auto">@cond.ValorDec2</td>
                                                <td style="width: auto">@cond.Nome6</td>
                                                <td style="width: auto">@cond.Nome7</td>
                                                <td style="width: auto">@cond.Nome1</td>
                                                <td style="width: auto">@cond.Nome3</td>
                                                <td style="width: auto">@cond.Nome5</td>
                                                <td>@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec3)</td>
                                                <td style="width: auto">@cond.Nome8</td>
                                                @if (!String.IsNullOrEmpty(cond.Nome9))
                                                {
                                                    <td><img src="@Url.Content(cond.Nome9)" style="width: auto; height: auto; max-height: 55px; max-width: 45px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@cond.Nome', '@Url.Content(cond.Nome9)')"></td>
                                                }
                                                else
                                                {
                                                    <td><img src="~/Images/icone_imagem.jpg" style="width: auto; height: auto; max-height: 55px; max-width: 45px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@cond.Nome', '/Images/icone_imagem.jpg')"></td>
                                                }
                                                <td style="width: auto" class="td-one-action">
                                                    @Html.TableLinkDetails(cond.Valor1, "EditarProduto", "fa-search", "Ver")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                        <h4 style="font-weight: bold">Nenhum Produto com estoque acima do máximo</h4>
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    <link href="~/Content/jquery.datetimepicker.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    <link href="~/Content/jquery-ui-timepicker-addon.min.css" rel="stylesheet" />
    <link href="~/Content/plugins/select2/select2.min.css" rel="stylesheet" />
    @Styles.Render("~/plugins/summernoteStyles")
}
@section Scripts {
    <script src="~/Scripts/jquery.datetimepicker.full.min.js"></script>
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.datetimepicker"></script>
    <script src="~/Scripts/jquery-ui-timepicker-addon.min.js"></script>
    <script src="~/Scripts/jquery-3.1.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    @Scripts.Render("~/plugins/sparkline")
    <script src="~/Scripts/plugins/select2/select2.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    
    <script src="~/Scripts/uploadAnexo.js"></script>
    @Scripts.Render("~/plugins/summernote")
    
    
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Produtos_Acima_Planilha' },

                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]

            });      
        });
    </script>


}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

