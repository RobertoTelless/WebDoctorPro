                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12" style="color: brown; font-weight: bold">
                                                            Diferença (%)
                                                            @Html.TextBoxFor(m => m.Diferenca, "{0:n2}", new { @class = "form-control", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            <br />
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Descrição</h4>
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Descrição
                                                    @Html.TextAreaFor(m => m.PROD_DS_DESCRICAO, new { @class = "form-control", style = "width: 100%; height: 100px;", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PROD_DS_DESCRICAO, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Informações do Produto
                                                    @Html.TextAreaFor(m => m.PROD_DS_INFORMACOES, new { @class = "form-control", style = "width: 100%; height: 100px;", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PROD_DS_INFORMACOES, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <br />
                                        }
                                    </div>
                                </div>
                            }

