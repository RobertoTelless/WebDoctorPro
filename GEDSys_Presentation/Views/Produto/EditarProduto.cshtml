                                                    Estoque Mínimo
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_MINIMO, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold", @id = "precoEmb" })
                                                </div>
                                            </div>
                                            <br />
                                            if (Model.PROD_IN_LOCACAO == 1)
	                                        {
