                                                    </div>
                                                </div>
                                                <br />
	                                        }
                                            if (Model.PROD_IN_TIPO_PRODUTO == 2)
                                            {
                                                <div class="row">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Concorrência</h4>
                                                    <div class="col-lg-2 col-md-2 col-xs-12" style="color: darkblue; font-weight: bold">
                                                        Preço Médio Concorrência (R$)
                                                        @Html.TextBoxFor(m => m.CustoMedioConcorrencia, new { @class = "form-control", @readonly = "readonly" })
                                                    </div>
                                                    @if (Model.Diferenca >= 0)
