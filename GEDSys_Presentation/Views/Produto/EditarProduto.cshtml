    <script type="text/javascript">
        function ValidaLocacao(valTipo) {
            if (valTipo == '1') {
                $("#valorLoc").show();
                $("#descLoc").show();
                $("#jurosloc").show();
                $("#taxasLoc").show();
            } else if (valTipo == '0') {
                $("#valorLoc").hide();
                $("#descLoc").hide();
                $("#jurosloc").hide();
                $("#taxasLoc").hide();
            }
        }
