                            @*Anexos*@
                            @if ((Int32)Session["AbaProduto"] == 5)
                            {
                                <div id="tab-4" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                <h4>Anexos</h4>
                                                <br />
                                                <div class="form-group">
                                                    @using (Html.BeginForm("UploadFileProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                                    {
                                                        var listaAnexos = Model.PRODUTO_ANEXO.Where(p => p.PRAN_IN_ATIVO == 1).ToList();

                                                        <div class="text-center" style="margin-top: 15px;">
                                                            <div class="toggle-container" id="viewToggle">
                                                                <div class="toggle-option active" data-target="sectionList">
                                                                    <i class="fa fa-list"></i> Ver lista
                                                                </div>
                                                                <div class="toggle-option" data-target="sectionIcons">
                                                                    <i class="fa fa-th"></i> Ver ícones
                                                                </div>
                                                            </div>
                                                        </div>



                                                        if (listaAnexos.Count > 0)
                                                        {
                                                            <div id="sectionList" class="view-section active">
                                                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                                                    <thead style="background-color:lightsteelblue">
                                                                        <tr>
                                                                            <th>Título</th>
                                                                            <th>Data</th>
                                                                            <th>Tipo</th>
                                                                            <th class="td-one-action">Ações</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var cond in listaAnexos)
                                                                        {
                                                                            <tr>
                                                                                <td style="width: auto">
                                                                                    @if (cond.PRAN_IN_TIPO == 1 || cond.PRAN_IN_TIPO == 2)
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoProduto", "Produto", new { id = cond.PRAN_CD_ID })">@cond.PRAN_NM_TITULO</a>
                                                                                    }
                                                                                    else if (cond.PRAN_IN_TIPO == 4)
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoProdutoAudio", "Produto", new { id = cond.PRAN_CD_ID })">@cond.PRAN_NM_TITULO</a>
                                                                                    }
                                                                                    else if (cond.PRAN_IN_TIPO == 3)
                                                                                    {
                                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.PRAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank">@cond.PRAN_NM_TITULO</a>
                                                                                    }
                                                                                    else { @cond.PRAN_NM_TITULO }
                                                                                </td>
                                                                                <td>@cond.PRAN_DT_ANEXO.ToShortDateString()</td>
                                                                                <td>@(cond.PRAN_IN_TIPO == 1 ? "Imagem" : cond.PRAN_IN_TIPO == 2 ? "Vídeo" : cond.PRAN_IN_TIPO == 3 ? "PDF" : "Outros")</td>
                                                                                <td class="td-one-action">
                                                                                    <span class="fa fa-trash-o" onclick="PrepararExclusaoAnexo('/Produto/ExcluirAnexo/@cond.PRAN_CD_ID')" style="cursor:pointer; color:#337ab7"></span>
                                                                                    @Html.TableLinkDetails(cond.PRAN_CD_ID, "DownloadProduto", "fa-download", "Download")
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>

                                                            <div id="sectionIcons" class="view-section">
                                                                <div class="row" style="display: flex; flex-wrap: wrap; justify-content: flex-start; margin-bottom: 20px;">
                                                                    @foreach (var cond in listaAnexos)
                                                                    {
                                                                        <div class="col-lg-2 col-md-2 col-sm-3 col-xs-4 text-center" style="margin-bottom: 25px; min-width: 130px;">
                                                                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: space-between; height: 100%;">
                    
                                                                                @* Container de Mídia (Altura fixa para alinhamento) *@
                                                                                <div style="height: 80px; display: flex; align-items: center; justify-content: center; width: 100%;">
                        
                                                                                    @if (cond.PRAN_IN_TIPO == 1) // IMAGEM - Abre na mesma aba
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoProduto", "Produto", new { id = cond.PRAN_CD_ID })" title="Visualizar Imagem">
                                                                                            <img src="@Url.Content(cond.PRAN_AQ_ARQUIVO)" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; border: 1px solid #ddd;" />
                                                                                        </a>
                                                                                    }
                                                                                    else if (cond.PRAN_IN_TIPO == 2) // VÍDEO - Abre na mesma aba (Ícone comum)
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoProduto", "Produto", new { id = cond.PRAN_CD_ID })" title="Visualizar Vídeo">
                                                                                            <i class="fa fa-video-camera fa-4x text-navy"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else if (cond.PRAN_IN_TIPO == 3) // PDF - ÚNICO QUE ABRE EM NOVA ABA
                                                                                    {
                                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.PRAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank" title="Visualizar PDF">
                                                                                            <i class="fa fa-file-pdf-o fa-5x text-danger"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else if (cond.PRAN_IN_TIPO == 4) // ÁUDIO - Abre na mesma aba
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoProdutoAudio", "Produto", new { id = cond.PRAN_CD_ID })" title="Ouvir Áudio">
                                                                                            <i class="fa fa-volume-up fa-4x text-info"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else // PADRÃO PARA OUTROS
                                                                                    {
                                                                                        <i class="fa fa-file-o fa-4x text-muted"></i>
                                                                                    }
                                                                                </div>

                                                                                @* Nome do Arquivo *@
                                                                                <div style="font-size: 11px; margin-top: 8px; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%;" title="@cond.PRAN_NM_TITULO">
                                                                                    @cond.PRAN_NM_TITULO
                                                                                </div>

                                                                                @* Botões de Ação (Excluir e Download) *@
                                                                                <div style="margin-top: 5px; display: flex; gap: 12px; justify-content: center;">
                                                                                    <span style="cursor:pointer;" onclick="PrepararExclusaoAnexo('/Produto/ExcluirAnexo/@cond.PRAN_CD_ID')" title="Excluir">
                                                                                        <i class="fa fa-trash-o fa-lg text-navy"></i>
                                                                                    </span>
                                                                                    <a href="@Url.Action("DownloadProduto", "Produto", new { id = cond.PRAN_CD_ID })" title="Download">
                                                                                        <i class="fa fa-download fa-lg text-navy"></i>
                                                                                    </a>
                                                                                </div>

                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>

                                                        }

                                                        <div class="form-group" style="margin-top: 20px;">
                                                            <div class="col-lg-12">
                                                                <input type="file" name="file" id="file" class="btn btn-sm btn-warning" style="float: left; margin-right: 5px;" />
                                                                <input type="submit" value="Incluir Anexo" class="btn btn-sm btn-success" />
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div id="tab-4" class="tab-pane">
                                    <div class="panel-body">
                                        <div class="row">
                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                <h4>Anexos</h4>
                                                <br />
                                                <div class="form-group">
                                                    @using (Html.BeginForm("UploadFileProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                                    {
                                                        var listaAnexos = Model.PRODUTO_ANEXO.Where(p => p.PRAN_IN_ATIVO == 1).ToList();

                                                        <div class="text-center" style="margin-top: 15px;">
                                                            <div class="toggle-container" id="viewToggle">
                                                                <div class="toggle-option active" data-target="sectionList">
                                                                    <i class="fa fa-list"></i> Ver lista
                                                                </div>
                                                                <div class="toggle-option" data-target="sectionIcons">
                                                                    <i class="fa fa-th"></i> Ver ícones
                                                                </div>
