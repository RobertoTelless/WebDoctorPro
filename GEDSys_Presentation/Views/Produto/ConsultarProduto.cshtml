                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Estoque</h4>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Estoque Total
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_TOTAL, new { @class = "form-control", @style = "color: brown; font-weight: bold", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Estoque Atual
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_ATUAL, new { @class = "form-control", @style = "color: brown; font-weight: bold", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Estoque Reservado
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_RESERVA, new { @class = "form-control", @style = "color: brown; font-weight: bold", @readonly = "readonly" })
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Estoque Mínimo
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_MINIMO, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Estoque Máximo
                                                    @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_MAXIMO, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Status do Estoque
                                                    @if (Model.PROD_VL_ESTOQUE_ATUAL < Model.PROD_VL_ESTOQUE_MINIMO)
                                                    {
                                                        @Html.TextBoxFor(m => m.StatusEstoque, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold"})
                                                    }
                                                    else if (Model.PROD_VL_ESTOQUE_ATUAL > Model.PROD_VL_ESTOQUE_MAXIMO)
                                                    {
                                                        @Html.TextBoxFor(m => m.StatusEstoque, new { @class = "form-control", @readonly = "readonly", @style = "color: blue; font-weight: bold"})
                                                    }
                                                    else if (Model.PROD_VL_ESTOQUE_ATUAL <= 0)
                                                    {
                                                        @Html.TextBoxFor(m => m.StatusEstoque, new { @class = "form-control", @readonly = "readonly", @style = "color: red; font-weight: bold"})
                                                    }
                                                    else
                                                    {
                                                        @Html.TextBoxFor(m => m.StatusEstoque, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold"})
                                                    }
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                @if (Model.PROD_IN_TIPO_PRODUTO == 2)
