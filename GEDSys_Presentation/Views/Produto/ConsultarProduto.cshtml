@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.ProdutoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<style>
    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Materiais/Produtos</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaProduto", "Produto")">Materiais/Produtos</a>
            </li>
            <li class="active">
                <strong>Materiais/Produtos - Consulta</strong>
            </li>
        </ol>
        <br />
    </div>

    @*TABS - PRINCIPAL*@
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div class="row">
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Material/Produto - Consulta</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PROD_NM_NOME</span>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-group">
                        @Html.ButtonLinkIndex(text: "Relatório Detalhes", action: "GerarRelatorioDetalhe", controller: "Produto")
                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBaseProduto", controller: "Produto")
                    </div>

                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            <li class="active"><a data-toggle="tab" href="#tab-1">Dados Gerais</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-7">Custo & Preço</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-8">Evolução de Custo & Preço</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-12">Estoque</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-2">Imagem</a></li>                                
                            <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>                                
                            <li class=""><a data-toggle="tab" href="#tab-4">Anexos</a></li>                               
                            <li class=""><a data-toggle="tab" href="#tab-5">Observações</a></li>                               
                        </ul>

                        <div class="tab-content">
                            @*Dados Gerais*@
                            <div id="tab-1" class="tab-pane active">
                                <div class="panel-body">
                                    @using (Html.BeginForm("ConsultarProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                    {                                        
                                        <div class="row" style="width: 100%;">
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                <div style="text-align: center; margin-top: 25px; line-height: 10px;">
                                                    @Html.HiddenFor(x => x.PROD_AQ_FOTO)
                                                    @Html.HiddenFor(x => x.PROD_CD_ID)
                                                    @Html.HiddenFor(x => x.ASSI_CD_ID)
                                                    @Html.HiddenFor(x => x.PROD_DT_CADASTRO)
                                                    @Html.HiddenFor(x => x.PROD_IN_ATIVO)
                                                    @Html.HiddenFor(x => x.PROD_IN_AVISA_MINIMO)
                                                    @Html.HiddenFor(x => x.PROD_IN_TIPO_PRODUTO)
                                                    @Html.HiddenFor(x => x.PROD_IN_COMPOSTO)
                                                    @Html.HiddenFor(x => x.PROD_TX_OBSERVACOES)
                                                    @Html.HiddenFor(x => x.PROD_VL_MARGEM_CONTRIBUICAO)
                                                    @Html.HiddenFor(x => x.PROD_VL_PRECO_ANTERIOR)
                                                    @Html.HiddenFor(x => x.PROD_VL_PRECO_MINIMO)
                                                    @Html.HiddenFor(x => x.PROD_VL_CVM_PESO)
                                                    @Html.HiddenFor(x => x.PROD_VL_CVM_RECEITA)
                                                    @Html.HiddenFor(x => x.PROD_VL_CVM_UNITARIO)
                                                    @if (!String.IsNullOrEmpty(Model.PROD_AQ_FOTO))
                                                    {
                                                        <img src="@Url.Content(Model.PROD_AQ_FOTO)" style="width: auto; height: auto; max-height: 220px; max-width: 190px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@Model.PROD_NM_NOME', '@Url.Content(Model.PROD_AQ_FOTO)')">
                                                    }
                                                    else
                                                    {
                                                        <img src="~/Images/icone_imagem.jpg" style="width: auto; height: auto; max-height: 110px; max-width: 90px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@Model.PROD_NM_NOME', '/Images/icone_imagem.jpg')">
                                                    }
                                                    <br />
                                                    <br />
                                                    <br />
                                                    <br />
                                                    <br />
                                                </div>
                                            </div>

                                            <div class="col-md-10">
                                                <div class="row">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação</h4>
                                                    <div class="col-lg-8 col-md-8 col-xs-12">
                                                        Nome
                                                        @Html.TextBoxFor(m => m.PROD_NM_NOME, new { @class = "form-control", @style = "color: green; font-wheight: bold", @readonly = "readonly"  })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Data de Inclusão
                                                        @Html.TextBoxFor(m => m.PROD_DT_CADASTRO,"{0:dd/MM/yyyy}", new { @class = "form-control", @style = "color: green; font-wheight: bold", @readonly = "readonly"  })
                                                    </div>
                                                </div>
                                                <br /><br />

                                                <div class="row">
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Tipo
                                                        @Html.TextBoxFor(m => m.Tipo, new { @class = "form-control", @style = "color: green; font-wheight: bold", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                                        Categoria
                                                        @Html.TextBoxFor(m => m.CATEGORIA_PRODUTO.CAPR_NM_NOME, new { @class = "form-control",  @style = "color: green; font-wheight: bold", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                                        Subcategoria
                                                        @Html.TextBoxFor(m => m.SUBCATEGORIA_PRODUTO.SCPR_NM_NOME, new { @class = "form-control",  @style = "color: green; font-wheight: bold", @readonly = "readonly" })
                                                    </div>
                                                </div>

                                                <br /><br />
                                                <div class="row">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação</h4>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Código (SKU)
                                                        @Html.TextBoxFor(m => m.PROD_CD_CODIGO, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Código de Barras
                                                        @Html.TextBoxFor(m => m.PROD_NR_BARCODE, new { @class = "form-control", @readonly = "readonly", @style = "color: blue; font-wheight: bold" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Unidade
                                                        @Html.TextBoxFor(m => m.UNIDADE.UNID_NM_NOME, new { @class = "form-control", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                                        Fornecedor
                                                        @Html.TextBoxFor(m => m.PROD_NM_FORNECEDOR, new { @class = "form-control", @readonly = "readonly", data_toggle = "popover", data_content = "Informe o nome do fornecedor deste produto/material == OPCIONAL", data_trigger="hover", data_placement="top" })
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Alterações</h4>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Última Alteração
                                                        @Html.TextBoxFor(m => m.PROD_DT_ALTERACAO,"{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-wheight: bold" })
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                                        Alterado Por
                                                        @Html.TextBoxFor(m => m.USUARIO.USUA_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-wheight: bold"  })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <br />
                                        <div class="row">
                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                Marca
                                                @Html.TextBoxFor(m => m.PROD_NM_MARCA, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                Modelo
                                                @Html.TextBoxFor(m => m.PROD_NM_MODELO, new { @class = "form-control", @readonly = "readonly"})
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                Fabricante
                                                @Html.TextBoxFor(m => m.PROD_NM_FABRICANTE, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                Referência
                                                @Html.TextBoxFor(m => m.PROD_NR_REFERENCIA, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <br />
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Preços</h4>
                                            @if (Model.PROD_IN_TIPO_PRODUTO ==  2)
                                            {
                                                <div class="col-lg-2 col-md-2 col-xs-12" style="color: darkblue; font-weight: bold">
                                                    Preço Venda (R$)
                                                    @Html.TextBoxFor(m => m.PrecoVenda, new { @class = "form-control", @id = "venda", @readonly = "readonly", @style = "color: green; font-wheight: bold" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Preço Promoção (R$)
                                                    @Html.TextBoxFor(m => m.PrecoPromocao, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Desconto (%)
                                                    @Html.TextBoxFor(m => m.Desconto, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Preço Anterior (R$)
                                                    @Html.TextBoxFor(m => m.PROD_VL_PRECO_ANTERIOR, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold"  })
                                                </div>
                                            }
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: darkgoldenrod; font-weight: bold">
                                                Último Custo (R$)
                                                @Html.TextBoxFor(m => m.UltimoCusto, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <br />
                                        <div class="row">
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Estimativa de Venda ou Consumo/Mês
                                                @Html.TextBoxFor(m => m.PROD_VL_MEDIA_VENDA_MENSAL, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <br />
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Estoque</h4>
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: green; font-weight: bold">
                                                Estoque Atual
                                                @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_ATUAL, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold", @id = "precoEmb" })
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: green; font-weight: bold">
                                                Estoque Reservado Total
                                                @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_RESERVA, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold", @id = "precoEmb" })
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: green; font-weight: bold">
                                                Estoque Máximo
                                                @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_MAXIMO, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold", @id = "precoEmb" })
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: green; font-weight: bold">
                                                Estoque Mínimo
                                                @Html.TextBoxFor(m => m.PROD_VL_ESTOQUE_MINIMO, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-wheight: bold", @id = "precoEmb" })
                                            </div>
                                        </div>
                                        <br />
                                        if (Model.PROD_IN_TIPO_PRODUTO == 2)
                                        {
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Concorrência</h4>
                                                <div class="col-lg-2 col-md-2 col-xs-12" style="color: darkblue; font-weight: bold">
                                                    Preço Médio Concorrência (R$)
                                                    @Html.TextBoxFor(m => m.CustoMedioConcorrencia, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                @if (Model.Diferenca >= 0)
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12" style="color: darkblue; font-weight: bold">
                                                        Diferença (%)
                                                        @Html.TextBoxFor(m => m.Diferenca, "{0:n2}", new { @class = "form-control", @readonly = "readonly" })
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12" style="color: brown; font-weight: bold">
                                                        Diferença (%)
                                                        @Html.TextBoxFor(m => m.Diferenca, "{0:n2}", new { @class = "form-control", @readonly = "readonly" })
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <br />
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Descrição</h4>
                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                Descrição
                                                @Html.TextAreaFor(m => m.PROD_DS_DESCRICAO, new { @class = "form-control", style = "width: 100%; height: 100px;", @readonly = "readonly" })
                                                @Html.ValidationMessageFor(m => m.PROD_DS_DESCRICAO, "", new { @style = "color:red" })
                                            </div>
                                        </div>
                                        <br />
                                        <div class="row">
                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                Informações do Material/Produto
                                                @Html.TextAreaFor(m => m.PROD_DS_INFORMACOES, new { @class = "form-control", style = "width: 100%; height: 100px;", @readonly = "readonly" })
                                                @Html.ValidationMessageFor(m => m.PROD_DS_INFORMACOES, "", new { @style = "color:red" })
                                            </div>
                                        </div>
                                        <br />
                                    }
                                </div>
                            </div>

                            @*Imagens*@
                            <div id="tab-2" class="tab-pane active">
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-lg-5 col-md-5 col-xs-12">
                                            <div class="form-group">
                                                <div class="col-lg-12 col-md-12 col-sm-12">
                                                    <br />
                                                    @if (!String.IsNullOrEmpty(Model.PROD_AQ_FOTO))
                                                    {
                                                        <img src="@Url.Content(Model.PROD_AQ_FOTO)" style="width: auto; height: auto; max-height: 1000px; max-width: 1000px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@Model.PROD_NM_NOME', '@Url.Content(Model.PROD_AQ_FOTO)')">
                                                    }
                                                    else
                                                    {
                                                        <img src="~/Images/icone_imagem.jpg" style="width: auto; height: auto; max-height: 110px; max-width: 90px;" data-toggle="modal" data-target="#fotoModal" onclick="CriaModal('@Model.PROD_NM_NOME', '/Images/icone_imagems.jpg')">
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @*Anexos*@
                            <div id="tab-4" class="tab-pane active">
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            <h4>Anexos</h4>
                                            <br />
                                            <div class="form-group">
                                                @using (Html.BeginForm("UploadFileProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                                {
                                                <div class="ibox-content">
                                                    @if (Model.PRODUTO_ANEXO != null && Model.PRODUTO_ANEXO.Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-example">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th>Título</th>
                                                                    <th>Data</th>
                                                                    <th>Tipo</th>
                                                                    <th class="td-one-action">Ações</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.PRODUTO_ANEXO))
                                                                {
                                                                    <tr>
                                                                        <td>@cond.PRAN_NM_TITULO</td>
                                                                        <td>@cond.PRAN_DT_ANEXO.ToShortDateString()</td>
                                                                        @if (cond.PRAN_IN_TIPO == 1)
                                                                        {
                                                                            <td>Imagem</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td>Arquivo</td>
                                                                        }
                                                                        <td class="td-one-action">
                                                                            @if (cond.PRAN_IN_TIPO == 1)
                                                                            {
                                                                                @Html.TableLinkDetails(cond.PRAN_CD_ID, "VerAnexoProduto", "fa-camera", "Visualizar")
                                                                            }
                                                                            @if (cond.PRAN_IN_TIPO == 3)
                                                                            {
                                                                                <a title="Visualizar" class="fa fa-camera fa-lg" href="~/PdfViewer/web/viewer.html?file=@(cond.PRAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank"></a>
                                                                            }
                                                                            @Html.TableLinkDetails(cond.PRAN_CD_ID, "DownloadProduto", "fa-download", "Download")
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @*Anotações*@
                            <div id="tab-3" class="tab-pane active">
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <h4>Anotações</h4>
                                            @if (Model.PRODUTO_ANOTACAO.Count > 0)
                                            {
                                                foreach (var item in (Model.PRODUTO_ANOTACAO).OrderByDescending(a => a.PRAT_DT_ANOTACAO))
                                                {
                                                    <div class="social-feed-box">
                                                        <div class="social-avatar">
                                                            <a href="" class="pull-left">
                                                                <img src="@Url.Content(item.USUARIO.USUA_AQ_FOTO)" style="width: auto; height: auto; max-height: 110px; max-width: 90px;">
                                                            </a>
                                                            <div class="media-body">
                                                                <a href="#">
                                                                    @item.USUARIO.USUA_NM_NOME
                                                                </a>
                                                                <small class="text-muted">@item.PRAT_DT_ANOTACAO.ToString("dd/MM/yyyy HH:mm")</small>
                                                            </div>
                                                        </div>
                                                        <div class="social-body">
                                                            <p>
                                                                @item.PRAT_DS_ANOTACAO
                                                            </p>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <br />
                                    <div class="form-group">
                                        @Html.ButtonLinkIndex(text: "Nova Anotação", action: "IncluirAnotacaoProduto", controller: "Produto")
                                    </div>
                                </div>
                            </div>
                       
                            @*Históricos*@
                            <div id="tab-7" class="tab-pane active">
                                <div class="panel-body">
                                    @if (Model.PROD_IN_TIPO_PRODUTO == 2)
                                    {
                                        <div class="row">
                                            <hr />
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    <h4>Histórico de Preços de Venda</h4>
                                                    <br />
                                                    @if (Model.PRODUTO_PRECO_VENDA.Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-example">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th>Data</th>
                                                                    <th>Preço de Venda (R$)</th>
                                                                    <th>Desconto (%)</th>
                                                                    <th>Preço Promoção (R$)</th>
                                                                    @if (Model.PROD_IN_COMPOSTO == 1)
                                                                    {
                                                                        <th>Tipo de Embalagem</th>
                                                                        <th>Preço c/Embalagem (R$)</th>
                                                                    }
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.PRODUTO_PRECO_VENDA))
                                                                {
                                                                    <tr>
