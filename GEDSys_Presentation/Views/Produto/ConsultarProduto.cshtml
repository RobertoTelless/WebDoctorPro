                                                </div>
                                                <div class="ibox-content">
                                                    <div class="row">
                                                        <canvas id="lineChartEstoqueTotal" height="90"></canvas>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Estoque por Matriz/Filial</h4>
                                            <br />
                                            @if (Model.PRODUTO_ESTOQUE_FILIAL.Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th style="width: auto">Local</th>
                                                            <th style="width: auto">Estoque</th>
                                                            <th style="width: auto">Estoque Reservado</th>
                                                            <th style="width: auto">Última Movimentação</th>
                                                            @if (Model.PROD_IN_TIPO_PRODUTO != 3 & Model.PROD_IN_COMPOSTO == 0)
	                                                        {
                                                                <th style="width: auto">Situação</th>
	                                                        }
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (Model.PRODUTO_ESTOQUE_FILIAL.Where(p => p.PREF_IN_ATIVO == 1)))
                                                        {
                                                            <tr>
                                                                <td style="width: auto">@cond.EMPRESA_FILIAL.EMFI_NM_APELIDO</td>
                                                                <td style="width: auto">@cond.PREF_QN_ESTOQUE</td>
                                                                <td style="width: auto">@cond.PREF_QN_QUANTIDADE_RESERVADA</td>
                                                                <td style="width: auto">@cond.PREF_DT_ULTIMO_MOVIMENTO.Value.ToShortDateString()</td>
                                                                @if (Model.PROD_IN_TIPO_PRODUTO != 3 & Model.PROD_IN_COMPOSTO == 0)
                                                                {
                                                                    if (cond.PREF_QN_ESTOQUE < Model.PROD_VL_ESTOQUE_MINIMO)
                                                                    {
                                                                        <td style="width: auto"><span class="badge badge-warning">Abaixo do Mínimo</span></td>
                                                                    }
                                                                    else if (cond.PREF_QN_ESTOQUE > Model.PROD_VL_ESTOQUE_MAXIMO)
                                                                    {
                                                                        <td style="width: auto"><span class="badge badge-success">Acima do Máximo</span></td>
                                                                    }
                                                                    else if (cond.PREF_QN_ESTOQUE <= 0)
                                                                    {
                                                                        <td style="width: auto"><span class="badge badge-danger">Zerado</span></td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td style="width: auto"><span class="badge badge-primary">Normal</span></td>
                                                                    }
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                        </div>
                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                                <div class="ibox-title">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Total Movimentado / Data</h4>
                                                </div>
                                                <div class="ibox-content">
                                                    <div class="row">
                                                        <canvas id="lineChartEstoque" height="90"></canvas>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>                   
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

