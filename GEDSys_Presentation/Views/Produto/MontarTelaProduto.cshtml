@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.PRODUTO
@{ Layout = "~/Views/Shared/_Layout_Admin.cshtml"; }
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="containerModalDesc">
        <div class="modal fade" id="modalDesc" tabindex="-1" role="dialog" aria-labelledby="modalDesc" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalDesc">Descrição do Produto</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div id="modalDescBody" class="modal-body">

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Materiais/Produtos</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Materiais / Produtos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página da central de produtos do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Exibe os materiais e produtoa cadastrados.</li>
                        <li>Localizar (filtrar) um produto e acessar a sua página principal.</li>
                        <li>Acessar a página de inclusão de produtos.</li>
                        <li>Acessar a página de alteração de produtos.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>

    <div class="row">
        <div class="col-lg-10 col-md-10 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarProdutoBase", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo 
                                @Html.DropDownListFor(m => m.PROD_IN_TIPO_PRODUTO, (SelectList)ViewBag.Tipos, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Categoria do Material/Produto
                                @Html.DropDownListFor(m => m.CAPR_CD_ID, (SelectList)ViewBag.Cats, "Selecionar", new { @class = "form-control", autofocus = true, onchange = "FiltrarSubCategoriaProduto($(this).val())", id = "catProd" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Subcategoria do Material/Produto
                                @Html.DropDownListFor(m => m.SCPR_CD_ID, (SelectList)ViewBag.Subs, "Selecionar", new { @class = "form-control", autofocus = true, id = "subCatProd" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data de Alteração 
                                @Html.TextBoxFor(m => m.PROD_DT_ALTERACAO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", id = "data", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Código (SKU)
                                @Html.TextBoxFor(m => m.PROD_CD_CODIGO, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Material/Produto
                                @Html.TextBoxFor(m => m.PROD_NM_NOME, new { @class = "form-control", autofocus = true, @id = "txtNomeProduto"  })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Marca
                                @Html.TextBoxFor(m => m.PROD_NM_MARCA, new { @class = "form-control", autofocus = true, @id = "txtMarca"  })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Situação do Estoque
                                @Html.DropDownListFor(m => m.PROD_IN_PECA, (SelectList)ViewBag.Sits, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Produto", action: "RetirarFiltroProduto", buttonClass: "success", htmlAttributes: new { @class = "btn-loading" })
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUSAO_PROD == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Novo Produto", controller: "Produto", action: "IncluirProduto", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })
                                }
                                @Html.ButtonLinkIndex(text: "Imprimir Produtos", controller: "Produto", action: "GerarRelatorioLista")
                                @Html.ButtonLinkIndex(text: "Dashboard", controller: "Produto", action: "MontarTelaDashboardProduto", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-2 col-md-2 col-xs-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: cornsilk; color:darkgreen">
                    <h5>Relatórios</h5>
                </div>
                <div class="ibox-content">
                    @using (Html.BeginForm("ProcessaRelatorioProduto", "Produto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", autofocus = true }))
                    {
                        @Html.DropDownList("TIPO_RELATORIO", (SelectList)ViewBag.Relatorio, "Selecionar", new { @class = "form-control", autofocus = true })
                        <small>Selecione o Relatório</small>
                        <br />
                        <small>(*) Sensivel ao filtro especificado</small>
                        <br />
                        <br />
                        @Html.ButtonActionSubmit(text: "Gerar Relatório")
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Materiais / Produtos</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.PRODUTO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Tipo</th>
                                        <th style="width: auto">Nome</th>
                                        <th style="width: auto">Categoria</th>
                                        <th style="width: auto">Subcategoria</th>
                                        <th style="width: auto">Marca</th>
                                        <th style="width: auto">Modelo</th>
                                        <th style="width: auto">Código</th>
                                        <th style="width: auto">Preço Venda (R$)</th>
                                        <th style="width: auto">Último Custo (R$)</th>
                                        <th style="width: auto">Estoque</th>
                                        <th style="width: auto"></th>
                                        <th style="width: auto" class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PRODUTO>))
                                    {
                                        <tr>
                                            <td style="width: auto">
                                                @if (cond.PROD_IN_TIPO_PRODUTO == 1) // ATIVA
                                                {
                                                    <span class="status-badge status-active">Material</span>
                                                }
                                                else if (cond.PROD_IN_TIPO_PRODUTO == 2)
                                                {
                                                    <span class="status-badge status-finish">Produto</span>
                                                }
                                            </td>

                                            @*@if (cond.PROD_IN_TIPO_PRODUTO == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Material</span></td>
                                            }
                                            else if (cond.PROD_IN_TIPO_PRODUTO == 2)
                                            {
                                                <td style="width: auto"><span class="badge badge-warning">Produto</span></td>
                                            }*@

                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EDICAO_PROD == 1)
                                            {
                                                <td><a href="@Url.Action("EditarProduto", "Produto", new { id = cond.PROD_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição de dados do produto" />@cond.PROD_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td><a href="@Url.Action("ConsultarProduto", "Produto", new { id = cond.PROD_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de consulta de dados do produto" />@cond.PROD_NM_NOME</td>
                                            }

                                            @if (cond.CATEGORIA_PRODUTO != null)
                                            {
                                                <td style="width: auto">@cond.CATEGORIA_PRODUTO.CAPR_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }

                                            @if (cond.SUBCATEGORIA_PRODUTO != null)
                                            {
                                                <td style="width: auto">@cond.SUBCATEGORIA_PRODUTO.SCPR_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }

                                            <td style="width: auto">@cond.PROD_NM_MARCA</td>
                                            <td style="width: auto">@cond.PROD_NM_MODELO</td>
                                            <td style="width: auto">@cond.PROD_CD_CODIGO</td>

                                            @if (cond.PROD_VL_PRECO_VENDA != null)
                                            {
                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.PROD_VL_PRECO_VENDA.Value)</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }

                                            @if (cond.PROD_VL_ULTIMO_CUSTO != null)
                                            {
                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.PROD_VL_ULTIMO_CUSTO.Value)</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }

                                            @if (cond.PROD_VL_ESTOQUE_ATUAL != null)
                                            {
                                                <td style="width: auto">@cond.PROD_VL_ESTOQUE_ATUAL</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">0</td>
                                            }

                                            @if (!String.IsNullOrEmpty(cond.PROD_AQ_FOTO))
                                            {
                                                // Tratamento manual da URL dentro do loop
                                                var caminhoLimpo = cond.PROD_AQ_FOTO.Replace("~/", "").Replace("~", "");
                                                var urlFinal = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + caminhoLimpo;

                                                <td style="width: auto">
                                                    <img src="@urlFinal" 
                                                            style="width: auto; height: auto; max-height: 75px; max-width: 65px;" 
                                                            data-toggle="popover" data-trigger="hover" data-placement="top" 
                                                            data-content="Clique Ctrl+Ctrl para ampliar a fotografia"
                                                            onerror="this.onerror=null;this.src='@Url.Content("~/Imagens/Base/icone_imagem.jpg")';">
                                                </td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">
                                                    <img src="~/Imagens/Base/icone_imagem.jpg" style="width: auto; height: auto; max-height: 65px; max-width: 55px;">
                                                </td>
                                            }


                                            <td style="width: auto" class="td-one-action">
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EDICAO_PROD == 1)
                                                {
                                                    @Html.TableLinkDetails(cond.PROD_CD_ID, "EditarProduto", "fa-edit btn-loading", "Editar")
                                                }
                                                else
                                                {
                                                    @Html.TableLinkDetails(cond.PROD_CD_ID, "ConsultarProduto", "fa-search btn-loading", "Consultar")
                                                }
                                                @if (cond.PROD_IN_ATIVO == 1)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EXCLUSAO_PROD == 1)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Excluir" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Produto/ExcluirProduto/@cond.PROD_CD_ID')" title="Excluir"></span>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>}
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Nenhum produto cadastrado ou sua pesquisa não retornou nenhum resultado</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Produto", action: "RetirarFiltroProduto", htmlAttributes: new { @class = "btn-loading" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

        <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>

    <style>
        /* Estilo Base */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-badge::before {
            content: "";
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-right: 6px;
        }

        /* PENDING (Gold) - Status 0 */
        .status-pending { background-color: #fef9c3; color: #a16207; }
        .status-pending::before { background-color: #ca8a04; }

        /* ACTIVE (Green) - Status 1 */
        .status-active { background-color: #dcfce7; color: #15803d; }
        .status-active::before { background-color: #16a34a; }

        /* CANCEL (Red) - Status 4 */
        .status-cancel { background-color: #fee2e2; color: #b91c1c; }
        .status-cancel::before { background-color: #dc2626; }

        /* FINISH (Dark Blue) - Status 2 */
        .status-finish { background-color: #dbeafe; color: #1e40af; }
        .status-finish::before { background-color: #2563eb; }

        /* OVERDUE (Gray) - Status 3 */
        .status-overdue { background-color: #f3f4f6; color: #4b5563; }
        .status-overdue::before { background-color: #6b7280; }
    </style>


}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    
    <script src="~/Scripts/uploadAnexo.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>


    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtNomeProduto').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetProdutoNome", "Produto")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtMarca').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetMarcaNome", "Produto")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
            .css("display", "normal")
            .next("button").button({
                icons: { primary: "ui-icon-calendar" },
                label: "Selecione uma data",
                text: false 
            });
        });
    </script>  

    <script type="text/javascript">
        $(function () {
            $('.date-picker').mask('99/99/9999');
