@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.LocacaoParcelaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Locação - Parcelas - Edição";
    ViewBag.MetaDescription = "WebDoctor - Locação - Parcelas - Editar parcela";
    ViewBag.MetaKeywords = "WebDoctor, locacao, parcela";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Locação</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaLocacao", "Locacao")">Locação</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarAnexoLocacao", "Locacao")">Locação - Edição</a>
            </li>
            <li class="active">
                <strong>Parcela - Quitação</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Locação - Parcela - Quitação</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("EditarParcela", "Locacao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;"> 
                            @if ((Int32)Session["VoltaLocacaoParcela"] == 2)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VerParcelasLocacoes", controller: "Locacao", htmlAttributes: new { @class = "btn-loading" })
                            }
                            else
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoParcela", controller: "Locacao", htmlAttributes: new { @class = "btn-loading" })
                            }
                            <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                            <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                <i class="fa fa-spinner fa-spin"></i> Processando...
                            </span>
                        </div>

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.LOCACAO.PACIENTE.PACI_NM_NOME, new { @class = "form-control", autofocus = true, @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.LOCACAO.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                @if (Model.LOCACAO.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.LOCACAO.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.LOCACAO.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.LOCACAO.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.LOCACAO.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.LOCACAO.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>

                        @*Produto*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Produto</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Produto
                                    @Html.TextBoxFor(m => m.LOCACAO.PRODUTO.PROD_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Marca
                                    @Html.TextBoxFor(m => m.LOCACAO.PRODUTO.PROD_NM_MARCA, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Modelo
                                    @Html.TextBoxFor(m => m.LOCACAO.PRODUTO.PROD_NM_MODELO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Valor da Parcela (R$)
                                    @Html.TextBoxFor(m => m.LOCACAO.PRODUTO.PROD_VL_LOCACAO, "{0:n2}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                            </div>
                        </div>

                        @*Locação*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Locação</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Identificador
                                    @Html.TextBoxFor(m => m.LOCACAO.LOCA_GU_GUID, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Inicial
                                    @Html.TextBoxFor(m => m.LOCACAO.LOCA_DT_INICIO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Final
                                    @Html.TextBoxFor(m => m.LOCACAO.LOCA_DT_FINAL, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Título
                                    @Html.TextBoxFor(m => m.LOCACAO.LOCA_NM_TITULO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                            </div>
                        </div>

                        @*Parcela*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Parcela</h4>
                            @if (Model.LOPA_IN_QUITADA == 0)
                            {
                                <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">                
                                    @Html.ButtonActionSubmit(text: "Confirma Quitação da Parcela", htmlAttributes: new { id = "basictoast", @class = "btn-loading1" })
                                </div>
                            }
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.LOCA_CD_ID)
                                    @Html.HiddenFor(m => m.LOPA_CD_ID)
                                    @Html.HiddenFor(m => m.LOPA_DT_VENCIMENTO)
                                    @Html.HiddenFor(m => m.LOPA_IN_ATIVO)
                                    @Html.HiddenFor(m => m.LOPA_IN_ATRASO)
                                    @Html.HiddenFor(m => m.LOPA_IN_PARCELA)
                                    @Html.HiddenFor(m => m.LOPA_IN_STATUS)
                                    @Html.HiddenFor(m => m.LOPA_NM_PARCELAS)
                                    @Html.HiddenFor(m => m.LOPA_NR_PACELAS)
                                    @Html.HiddenFor(m => m.LOPA_VL_DESCONTO)
                                    @Html.HiddenFor(m => m.LOPA_VL_JUROS)
                                    @Html.HiddenFor(m => m.LOPA_VL_TAXAS)
                                    @Html.HiddenFor(m => m.LOPA_VL_VALOR)
                                    @Html.HiddenFor(m => m.LOPA_DS_DESCRICAO)
                                    Parcela
                                    @Html.TextBoxFor(m => m.LOPA_NM_PARCELAS, new { @class = "form-control", @readonly = "readonly", @tabindex = "-1" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Vencimento
                                    @Html.TextBoxFor(m => m.LOPA_DT_VENCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Valor (R$)
                                    @Html.TextBoxFor(m => m.LOPA_VL_VALOR, "{0:n2}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Juros (R$)
                                    @Html.TextBoxFor(m => m.LOPA_VL_JUROS, "{0:n2}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    Descrição da Parcela
                                    @Html.TextBoxFor(m => m.LOPA_DS_DESCRICAO, new { @class = "form-control", @readonly = "readonly", @tabindex = "-1" })
                                </div>
                            </div>
                        </div>

                        @*Quitação*@
                        @if (Model.LOCACAO.LOCA_IN_STATUS > 0)
                        {
                            if (Model.LOPA_IN_QUITADA == 0 & (Model.LOCACAO.LOCA_IN_STATUS == 1 || Model.LOCACAO.LOCA_IN_STATUS == 3))
                            {
                                <div class="row">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Quitação</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">  
                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                            Vai Quitar?
                                            @Html.DropDownListFor(m => m.LOPA_IN_QUITADA, (SelectList)ViewBag.Quitada, "Selecionar", new { @class = "form-control", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.LOPA_IN_QUITADA, "", new { @style = "color:red" })
                                        </div>
                                        @if (Model.LOPA_IN_ATRASO > 0)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Atraso (Dias)
                                                @Html.TextBoxFor(m => m.LOPA_IN_ATRASO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: red; font-weight: bold"  })
                                            </div>
                                        }
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Data do Pagamento*
                                            @Html.TextBoxFor(m => m.LOPA_DT_PAGAMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                            @Html.ValidationMessageFor(m => m.LOPA_DT_PAGAMENTO, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Valor Pago (R$)*
                                            @Html.TextBoxFor(m => m.LOPA_VL_VALOR_PAGO, new { @class = "form-control", autofocus = true, @style = "color: green; font-weight: bold" })
                                            @Html.ValidationMessageFor(m => m.LOPA_VL_VALOR_PAGO, "", new { @style = "color:red" })
                                        </div>
                                        @if ((Int32)Session["PermFinanceiro"] == 1)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Gera Lançamento de Recebimento
                                                @Html.DropDownListFor(m => m.LOPA_IN_LANCAMENTO, (SelectList)ViewBag.Gera, "Selecionar", new { @class = "form-control", autofocus = true })
                                                @Html.ValidationMessageFor(m => m.LOPA_IN_LANCAMENTO, "", new { @style = "color:red" })
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="row">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Quitação</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                            @Html.HiddenFor(m => m.LOPA_IN_QUITADA)
                                            @Html.HiddenFor(m => m.LOPA_DT_PAGAMENTO)
                                            @Html.HiddenFor(m => m.LOPA_VL_VALOR_PAGO)
                                            Quitada
                                            @Html.TextBoxFor(m => m.Quitada, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                        </div>
                                        @if (Model.LOPA_IN_ATRASO > 0)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Atraso (Dias)
                                                @Html.TextBoxFor(m => m.LOPA_IN_ATRASO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: red; font-weight: bold"  })
                                            </div>
                                        }
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Data de Pagamento
                                            @Html.TextBoxFor(m => m.LOPA_DT_PAGAMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Valor Pago (R$)
                                            @Html.TextBoxFor(m => m.LOPA_VL_VALOR_PAGO, "{0:n2}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                        @if ((Int32)Session["PermFinanceiro"] == 1)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Gera Lançamento de Recebimento
                                                @Html.TextBoxFor(m => m.Lancamento, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            @Html.HiddenFor(m => m.LOPA_IN_QUITADA)
                        }
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Edição em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
