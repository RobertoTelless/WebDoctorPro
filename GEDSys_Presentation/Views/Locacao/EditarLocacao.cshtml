    <script type="text/javascript">
        // 1. FUNÇÃO GLOBAL (Define O QUE o alerta faz)
        function ExibirMensagem(tipo, mensagem, titulo) {
            titulo = titulo || 'WebDoctor';
            
            // Mapeamento de tipos (aceita nomes ou números do C#)
            if (tipo === 'sucesso' || tipo === 1) {
                toastr.success(mensagem, titulo);
            } else if (tipo === 'erro' || tipo === 2) {
                toastr.error(mensagem, titulo);
            } else if (tipo === 'aviso' || tipo === 3) {
                toastr.warning(mensagem, titulo);
            } else {
                toastr.info(mensagem, titulo);
            }
        }

        $(document).ready(function () {
            // 2. CONFIGURAÇÕES GLOBAIS DO TOASTR (Define COMO o alerta aparece)
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "preventDuplicates": false,
                "positionClass": "toast-top-right",
                "showDuration": "400",
                "hideDuration": "1000",
                "timeOut": "15000",
                "extendedTimeOut": "5000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };

            // 3. CAPTURA MENSAGENS DO SERVIDOR (TempData do C#)
            var msgSucesso = '@TempData["MensagemAcerto"]';
            if (msgSucesso != '') ExibirMensagem('sucesso', msgSucesso, 'Sucesso!');

            var msgErro = '@TempData["MensagemErro"]';
            if (msgErro != '') ExibirMensagem('erro', msgErro, 'Erro!');

            // 4. VALIDAÇÃO DO ARQUIVO (Evento disparado pelo input id="file")
            $('#file').on('change', function () {
                var arquivo = this.files[0];
                var limiteTamanho = 50 * 1024 * 1024; // 50MB (Conforme seu código)
                var extensoesPermitidas = ['pdf', 'jpg', 'jpeg', 'png', 'mp3', 'mp4', 'webp', 'xlsx'];

                if (arquivo) {
                    var nomeArquivo = arquivo.name;
                    var extensao = nomeArquivo.split('.').pop().toLowerCase();

                    // Validação de Extensão
                    if ($.inArray(extensao, extensoesPermitidas) == -1) {
                        ExibirMensagem('erro', 'A extensão .' + extensao + ' não é permitida.', 'Arquivo Inválido');
                        $(this).val(''); 
                        return false;
                    }

                    // Validação de Tamanho
                    if (arquivo.size > limiteTamanho) {
                        ExibirMensagem('aviso', 'O arquivo excede o limite de 50MB.', 'Arquivo muito pesado');
                        $(this).val(''); 
                        return false;
                    }

                    // Sucesso na validação local
                    ExibirMensagem('sucesso', 'Arquivo "' + nomeArquivo + '" pronto para upload.', 'Validado');
                }
            });
        });
    </script>
    <script>
        $(document).ready(function () {
            $('.toggle-option').click(function () {
                // Remove 'active' de todos os botões e adiciona no clicado
                $('.toggle-option').removeClass('active');
                $(this).addClass('active');

                // Esconde todas as seções e mostra a selecionada
                var targetSection = $(this).data('target');
                $('.view-section').removeClass('active');
                $('#' + targetSection).addClass('active');
            });
        });
    </script>
    <script type="text/javascript">
        // 1. Prepara a URL e abre a modal
        function PrepararExclusaoAnexo(url) {
            $('#urlExclusaoTemp').val(url); // Armazena a URL no campo hidden da modal
            $('#modalConfirmacaoExclusaoAnexo').modal('show');
        }

        $(document).ready(function () {
            // 2. Ação do botão Confirmar dentro da modal
            $('#btnConfirmarExclusaoAnexo').click(function () {
                var urlFinal = $('#urlExclusaoTemp').val();
                var $btn = $(this);

                if (urlFinal !== "") {
                    // Feedback visual
                    $btn.prop('disabled', true).addClass('disabled');
                    $btn.html('<i class="fa fa-spinner fa-spin"></i> Excluindo...');

                    // Fecha a modal e redireciona
                    $('#modalConfirmacaoExclusaoAnexo').modal('hide');
                
                    setTimeout(function () {
                        $('.modal-backdrop').remove();
                        $('#loadingIndicator').show();
                        window.location.href = urlFinal;
                    }, 400);
                }
            });

            // Limpeza de segurança ao fechar
            $('#modalConfirmacaoExclusaoAnexo').on('hidden.bs.modal', function () {
                $('#urlExclusaoTemp').val("");
                $('#btnConfirmarExclusaoAnexo').prop('disabled', false).removeClass('disabled').html('Confirmar Exclusão');
            });
        });
    </script>



    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}

