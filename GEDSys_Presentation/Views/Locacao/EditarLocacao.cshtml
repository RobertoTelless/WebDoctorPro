                                                                                    {
                                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.LOAX_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank">@cond.LOAX_NM_TITULO</a>
                                                                                    }
