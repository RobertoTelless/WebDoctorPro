                                                                                        <a href="~/PdfViewer/web/viewer.html?file=@(cond.LOAX_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank" title="Visualizar PDF">
                                                                                            <i class="fa fa-file-pdf-o fa-5x text-danger"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else if (cond.LOAX_IN_TIPO == 4) // ÁUDIO - Abre na mesma aba
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoLocacaoAudio", "Locacao", new { id = cond.LOAX_CD_ID })" title="Ouvir Áudio">
                                                                                            <i class="fa fa-volume-up fa-4x text-info"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else // PADRÃO PARA OUTROS
