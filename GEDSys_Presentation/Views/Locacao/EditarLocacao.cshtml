                                                                <div class="toggle-option active" data-target="sectionList">
                                                                    <i class="fa fa-list"></i> Ver lista
                                                                </div>
                                                                <div class="toggle-option" data-target="sectionIcons">
                                                                    <i class="fa fa-th"></i> Ver ícones
                                                                </div>
                                                            </div>
                                                        </div>



                                                        if (listaAnexos.Count > 0)
                                                        {
                                                            <div id="sectionList" class="view-section active">
                                                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                                                    <thead style="background-color:lightsteelblue">
                                                                        <tr>
                                                                            <th>Título</th>
                                                                            <th>Data</th>
                                                                            <th>Tipo</th>
                                                                            <th class="td-one-action">Ações</th>
                                                                        </tr>
                                                                    </thead>
