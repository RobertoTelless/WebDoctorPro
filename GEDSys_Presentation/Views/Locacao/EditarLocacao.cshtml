                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoLocacao", "Locacao", new { id = cond.LOAX_CD_ID })">@cond.LOAX_NM_TITULO</a>
                                                                                    }
                                                                                    else if (cond.LOAX_IN_TIPO == 4)
                                                                                    {
                                                                                        <a href="@Url.Action("VerAnexoLocacaoAudio", "Locacao", new { id = cond.LOAX_CD_ID })">@cond.LOAX_NM_TITULO</a>
                                                                                    }
