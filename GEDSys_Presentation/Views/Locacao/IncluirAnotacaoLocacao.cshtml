@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.LocacaoAnotacaoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Locacao - Anotação";
    ViewBag.MetaDescription = "WebDoctor - Locacao - Incluir anotação na locacao";
    ViewBag.MetaKeywords = "WebDoctor, locacao, anotacao";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Locação</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaLocacao", "Locacao")">Locação</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarAnexoLocacao", "Locacao")">Locação - Edição</a>
            </li>
            <li class="active">
                <strong>Locação - Anotação</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Locação - Anotação</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("IncluirAnotacaoLocacao", "Locacao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="form-group">
                            @Html.ButtonActionSubmit(text: "Confirma Criação de Anotação")
                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoLocacao", controller: "Locacao")
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <br />
                                    @if (!String.IsNullOrEmpty(Model.USUARIO.USUA_AQ_FOTO))
	                                {
                                        <img src="@Url.Content(Model.USUARIO.USUA_AQ_FOTO)" style = "width: auto; height: auto; max-height: 110px; max-width: 90px;">
                                    }
                                    else
                                    {
                                        <img src="~/Imagens/Base/icone_morador.png" style = "width: auto; height: auto; max-height: 110px; max-width: 90px;">
                                    }
                                </div>                       
                            </div>
                            <div class="form-group">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="col-lg-2 col-md-2 col-sm-12">
                                        @Html.HiddenFor(m => m.LOAN_IN_ATIVO)
                                        @Html.HiddenFor(m => m.LOCA_CD_ID)
                                        @Html.HiddenFor(m => m.USUA_CD_ID)
                                        Data
                                        @Html.TextBoxFor(m => m.LOAN_DT_ANOTACAO, "{0:dd/MM/yyyy HH:mm}", new { @class = "form-control", @tabindex = "-1", @readonly="readonly"})
                                    </div>
                                    <div class="col-lg-5 col-md-5 col-sm-12">
                                        Nome 
                                        @Html.TextBoxFor(m => m.USUARIO.USUA_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly="readonly"})
                                    </div>
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;"> 
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    Texto da Anotação*
                                    @Html.TextAreaFor(m => m.LOAN_TX_ANOTACAO, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", autofocus = true })
                                    @Html.ValidationMessageFor(m => m.LOAN_TX_ANOTACAO, "", new { @style = "color:red" })
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/Content/plugins/iCheck/iCheckStyles")
}
@section Scripts {
   
    <script src="~/Scripts/jquery-3.1.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>  

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
