                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Data Nascimento
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                    @if (Model.PACIENTE.PACI_NR_CPF != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            CPF
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                    @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Celular
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                    @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Telefone
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                </div>
                                            </div>

                                            <div class="row" style="width: 100%;">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Informações do Envio</h4>
                                                <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">                
                                                    @Html.ButtonActionSubmit(text: "Confirma edição deste Envio", htmlAttributes: new { id = "basictoast"})
