@using Presentation.Extensions
@using EntitiesServices.Model
@model ERP_Condominios_Solution.ViewModels.MedicoEnvioViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Medico - Envio";
    ViewBag.MetaDescription = "WebDoctor - Medico - Envio";
    ViewBag.MetaKeywords = "WebDoctor, medico, envio";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaMedico", "Medico")">Médicos</a>
            </li>
            <li>
                <a href="@Url.Action("EditarMedico", "Medico")">Médicos - Edição</a>
            </li>
            <li class="active">
                <strong>Médicos - Envio</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Médicos - Envio - Edição</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomeMedico</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @*@if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }*@                    
                    <div class="form-group" style=" margin-left: 5px; margin-right: 5px;"> 
                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoMedico", controller: "Medico")
                        <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                    </div>
                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            @if ((Int32)Session["NivelEnvio"] == 1)
                            {
                                <li class="active"><a data-toggle="tab" href="#tab-1">Informações do Envio</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                            @if ((Int32)Session["NivelEnvio"] == 2)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Informações do Envio</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                            @if ((Int32)Session["NivelEnvio"] == 3)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Informações do Envio</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                        </ul>
                        <div class="tab-content">
                            @*Dados Gerais*@
                            @if ((Int32)Session["NivelEnvio"] == 1)
                            {
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        @using (Html.BeginForm("EditarEnvio", "Medico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Médico</h4>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Nome do Médico
                                                        @Html.TextBoxFor(m => m.MEDICOS.MEDC_NM_MEDICO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        CRM
                                                        @Html.TextBoxFor(m => m.MEDICOS.MEDC_NR_CRM, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        E-Mail
                                                        @Html.TextBoxFor(m => m.MEDICOS.MEDC_EM_EMAIL, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Nome do Paciente
