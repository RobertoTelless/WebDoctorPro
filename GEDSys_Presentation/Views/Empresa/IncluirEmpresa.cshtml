                                                    @Html.TextBoxFor(m => m.EMPR_NR_INSCRICAO_MUNICIPAL, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NR_INSCRICAO_MUNICIPAL, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Matriz
