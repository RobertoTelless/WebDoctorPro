                                                    @Html.HiddenFor(m => m.EMPR_VL_COMISSAO_OUTROS)
                                                    @Html.HiddenFor(m => m.EMPR_VL_ROYALTIES)
                                                    @Html.HiddenFor(m => m.EMPR_DT_CADASTRO)
                                                    @Html.HiddenFor(m => m.EMPR_VL_FUNDO_PROPAGANDA)
                                                    @Html.HiddenFor(m => m.EMPR_VL_FUNDO_SEGURANCA)
                                                    @Html.HiddenFor(m => m.EMPR_AQ_LOGO)
