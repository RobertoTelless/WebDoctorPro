                                                    @Html.ValidationMessageFor(m => m.EMPR_IN_MATRIZ, "", new { @style = "color:red" })
                                                </div>
                                            </div>

                                            <div class="form-group" style="margin: 30px -15px 0 -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Gerente
                                                    @Html.TextBoxFor(m => m.EMPR_NM_GERENTE, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_GERENTE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Telefone
                                                    @Html.TextBoxFor(m => m.EMPR_NR_TELEFONE, new { @class = "form-control", autofocus = true, @id = "tel" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NR_TELEFONE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Celular
                                                    @Html.TextBoxFor(m => m.EMPR_NR_CELULAR, new { @class = "form-control", autofocus = true,  @id = "cel" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NR_CELULAR, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    E-Mail
                                                    @Html.TextBoxFor(m => m.EMPR_NM_EMAIL, new { @class = "form-control", autofocus = true})
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_EMAIL, "", new { @style = "color:red" })
                                                </div>
                                            </div>

                                            <div class="form-group" style="margin: 0 -15px 0 -15px;" id="containerCep">
                                                <div class="col-lg-1 col-md-1 col-xs-12">
                                                    CEP
                                                    @Html.TextBoxFor(m => m.EMPR_NR_CEP, new { @class = "form-control", autofocus = true, @id = "cep" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NR_CEP, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    <span class="btn btn-warning btn-sm" style="margin-bottom: -45px;" id="btnBuscaCep" onclick="PesquisaCep($('#cep').val(), $(this), 1)">Buscar CEP</span>
                                                </div>
                                            </div>

                                            <div class="form-group" style="margin: 30px -15px 0 -15px;" id="containerEnd">
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Endereço
                                                    @Html.TextBoxFor(m => m.EMPR_NM_ENDERECO, new { @class = "form-control", autofocus = true, @id = "endereco" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_ENDERECO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Número/Complemento
                                                    @Html.TextBoxFor(m => m.EMPR_NM_NUMERO, new { @class = "form-control", autofocus = true, @id = "numero" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_NUMERO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Bairro
                                                    @Html.TextBoxFor(m => m.EMPR_NM_BAIRRO, new { @class = "form-control", autofocus = true, @id = "bairro" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_BAIRRO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Cidade
                                                    @Html.TextBoxFor(m => m.EMPR_NM_CIDADE, new { @class = "form-control", autofocus = true, @id = "cidade" })
                                                    @Html.ValidationMessageFor(m => m.EMPR_NM_CIDADE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    UF
                                                    @Html.DropDownListFor(m => m.UF_CD_ID, (SelectList)ViewBag.UF, "Selecionar", new { @class = "form-control", autofocus = true, @id = "uf" })
                                                    @Html.ValidationMessageFor(m => m.UF_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @*Imagens - Foto e Anexos*@
                                @*<div id="tab-2" class="tab-pane">
                                    <div class="panel-body">
                                        <div class="row">
                                            <div style="margin-left: 15px;" class="col-lg-12 col-md-12 col-xs-12">
                                                <div class="form-group">
