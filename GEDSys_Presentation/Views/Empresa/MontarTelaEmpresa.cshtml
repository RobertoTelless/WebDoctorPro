                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                                Cidade
                                                                @Html.TextBoxFor(m => m.EMPR_NM_CIDADE, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                UF
                                                                @Html.TextBoxFor(m => m.UF.UF_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                CEP
                                                                @Html.TextBoxFor(m => m.EMPR_NR_CEP, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                        </div>
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Para alterar as  informações do assinante entre em contato com a Rti através de um dos canais disponíveis na página Fale Conosco</h4>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div id="tab-1" class="tab-pane">
                                    <div class="panel-body">
                                        @using (Html.BeginForm("MontarTelaEmpresa", "Empresa", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                        {
                                            <div class="row" style="width: 100%;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    <div style="text-align: center; margin-top: 20px; line-height: 10px;">
                                                        @if (!String.IsNullOrEmpty(Model.EMPR_AQ_LOGO))
                                                        {
                                                            <img src="@Url.Content(Model.EMPR_AQ_LOGO)" style="width: auto; height: auto; max-height: 180px; max-width: 180px;">
                                                        }
                                                        else
                                                        {
                                                            <img src="~/Images/Prontuario/prontuario_icon_3.png" style="width: auto; height: auto; max-height: 180px; max-width: 120px;">
                                                        }
                                                        <br />
                                                        <br />
                                                        <br />
                                                        <br />
                                                        <br />
                                                    </div>
                                                </div>
                                                <div class="col-lg-10 col-md-10 col-xs-12">
                                                    <div class="row">
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Tipo de Assinante
                                                                @Html.TextBoxFor(m => m.TIPO_PESSOA.TIPE_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-4 col-md-4 col-xs-12">
                                                                @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                                @Html.HiddenFor(m => m.EMPR_IN_ATIVO)
                                                                @Html.HiddenFor(m => m.EMPR_DT_CADASTRO)
                                                                @Html.HiddenFor(m => m.EMPR_CD_ID)
                                                                @Html.HiddenFor(m => m.EMPR_AQ_LOGO)
                                                                @Html.HiddenFor(m => m.TIPE_CD_ID)
                                                                @Html.HiddenFor(m => m.EMPR_NM_GUERRA)
                                                                Nome
                                                                @Html.TextBoxFor(m => m.EMPR_NM_NOME, new { @class = "form-control", @style = "color: green; font-weight: bold", @readonly="readonly" })
                                                            </div>
                                                            @if (Model.TIPE_CD_ID == 2)
                                                            {
                                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                                    Razão Social
                                                                    @Html.TextBoxFor(m => m.EMPR_NM_RAZAO, new { @class = "form-control", @readonly="readonly" })
                                                                </div>
                                                            }
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Nome de Guerra
                                                                @Html.TextBoxFor(m => m.EMPR_NM_GUERRA, new { @class = "form-control", @readonly="readonly" , @style = "color: brown; font-weight: bold" })
                                                                @Html.ValidationMessageFor(m => m.EMPR_NM_GUERRA, "", new { @style = "color:red" })
                                                            </div>
                                                        </div>

                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            @if (Model.TIPE_CD_ID == 2)
                                                            {
                                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                                    CNPJ
                                                                    @Html.TextBoxFor(m => m.EMPR_NR_CNPJ, new { @class = "form-control", @id = "cnpj", @readonly="readonly" })
                                                                </div>
                                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                                    Insc.Estadual
                                                                    @Html.TextBoxFor(m => m.EMPR_NR_INSCRICAO_ESTADUAL, new { @class = "form-control", @readonly="readonly" })
                                                                </div>
                                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                                    Insc.Municipal
                                                                    @Html.TextBoxFor(m => m.EMPR_NR_INSCRICAO_MUNICIPAL, new { @class = "form-control", @readonly="readonly" })
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                                    CPF
                                                                    @Html.TextBoxFor(m => m.EMPR_NR_CPF, new { @class = "form-control", @id = "cnpj", @readonly="readonly" })
                                                                </div>
                                                            }
                                                        </div>

                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-5 col-md-5 col-xs-12">
                                                                Endereço
                                                                @Html.TextBoxFor(m => m.EMPR_NM_ENDERECO, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Número
                                                                @Html.TextBoxFor(m => m.EMPR_NM_NUMERO, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Complemento
                                                                @Html.TextBoxFor(m => m.EMPR_NM_COMPLEMENTO, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                                Bairro
                                                                @Html.TextBoxFor(m => m.EMPR_NM_BAIRRO, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                        </div>

                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                                Cidade
                                                                @Html.TextBoxFor(m => m.EMPR_NM_CIDADE, new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                UF
                                                                @Html.TextBoxFor(m => m.UF.UF_NM_NOME, new { @class = "form-control", @readonly="readonly" })
