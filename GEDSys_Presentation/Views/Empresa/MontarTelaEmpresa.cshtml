@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.EmpresaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Assinante";
    ViewBag.MetaDescription = "WebDoctor - Assinante - Informações do assinante";
    ViewBag.MetaKeywords = "WebDoctor, Assinante";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div id="containerModalDesc">
        <div class="modal fade" id="modalDesc" tabindex="-1" role="dialog" aria-labelledby="modalDesc" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalDesc">Descrição do Plano</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div id="modalDescBody" class="modal-body">

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Assinante</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Assinante - Configuração</h5>
                </div>

                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-group">
                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarDash", controller: "Empresa")
                        <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                    </div>
                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            @if ((Int32)Session["NivelEmpresa"] == 1)
                            {
                                <li class="active"><a data-toggle="tab" href="#tab-1">Dados Gerais</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Logotipo</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Plano de Assinatura</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-5">Consumos do Plano</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-9">Pagamentos</a></li>
                            }
                            @if ((Int32)Session["NivelEmpresa"] == 2)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Dados Gerais</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Logotipo</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Plano de Assinatura</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-5">Consumos do Plano</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-9">Pagamentos</a></li>
                            }
                            @if ((Int32)Session["NivelEmpresa"] == 3)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Dados Gerais</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-3">Logotipo</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Plano de Assinatura</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-5">Consumos do Plano</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-9">Pagamentos</a></li>
                            }
                            @if ((Int32)Session["NivelEmpresa"] == 4)
