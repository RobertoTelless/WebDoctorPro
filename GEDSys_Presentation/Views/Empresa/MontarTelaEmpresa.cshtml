                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto">0,00</td>
                                                                        }
                                                                        
                                                                        @if (cond.ASPA_DT_PAGAMENTO == null)
                                                                        {
                                                                            if (cond.ASPA_NR_ATRASO > 0)
                                                                            {
