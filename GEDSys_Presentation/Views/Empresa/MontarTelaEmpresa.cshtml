                                                                        @if (cond.ASPA_IN_PAGO == 0 & cond.ASPA_DT_VENCIMENTO < DateTime.Today.Date)
                                                                        {
                                                                            <td style="width: auto; color: brown; font-weight: bold ">@cond.ASPA_DT_VENCIMENTO.Value.ToShortDateString()</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto">@cond.ASPA_DT_VENCIMENTO.Value.ToShortDateString()</td>
                                                                        }

                                                                        <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.ASPA_VL_VALOR.Value)</td>
                                                                        
                                                                        @if (cond.ASPA_DT_PAGAMENTO != null)
                                                                        {
                                                                            <td style="width: auto">@cond.ASPA_DT_PAGAMENTO.Value.ToShortDateString()</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto; color: brown">Em Aberto</td>
                                                                        }
                                                                       
