                                                                                {
                                                                                    <td style="width: auto; color: brown; font-weight: bold; background-color: beige">@cond.ASPA_NR_ATRASO</td>
                                                                                }
                                                                                else if (cond.ASPA_NR_ATRASO < 90)
                                                                                {
                                                                                    <td style="width: auto; color: brown; font-weight: bold; background-color: antiquewhite">@cond.ASPA_NR_ATRASO</td>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <td style="width: auto; color: brown; font-weight: bold; background-color: navajowhite">@cond.ASPA_NR_ATRASO</td>
                                                                                }
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="width: auto">-</td>
                                                                            }
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto">-</td>
                                                                        }

