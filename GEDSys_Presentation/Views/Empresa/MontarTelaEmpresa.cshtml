                            @*Imagens - Anexos*@
                            @if ((Int32)Session["NivelEmpresa"] == 2)
                            {
                                <div id="tab-2" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Anexos</h4>
                                            <br />
                                            <div class="form-group">
                                                @using (Html.BeginForm("UploadFileEmpresa", "Empresa", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                                {
                                                    if (Model.EMPRESA_ANEXO.Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-example">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th>Nome do Anexo</th>
                                                                    <th>Data do Anexo</th>
                                                                    <th>Tipo de Arquivo</th>
                                                                    <th class="td-one-action">Ações</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.EMPRESA_ANEXO.Where(p => p.EMAN_IN_ATIVO == 1)))
                                                                {
                                                                    <tr>
                                                                        @if (cond.EMAN_IN_TIPO == 1 || cond.EMAN_IN_TIPO == 2)
                                                                        {
                                                                            <td style="width: auto"><a href="@Url.Action("VerAnexoEmpresa", "Empresa", new { id = cond.EMAN_CD_ID })" />@cond.EMAN_NM_TITULO</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 4)
                                                                        {
                                                                            <td style="width: auto"><a href="@Url.Action("VerAnexoEmpresaAudio", "Empresa", new { id = cond.EMAN_CD_ID })" />@cond.EMAN_NM_TITULO</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 3)
                                                                        {
                                                                            <td style="width: auto"><a href="~/PdfViewer/web/viewer.html?file=@(cond.EMAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank" />@cond.EMAN_NM_TITULO</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto">@cond.EMAN_NM_TITULO</td>
                                                                        }
                                                                        <td>@cond.EMAN_DT_ANEXO.ToShortDateString()</td>
                                                                        @if (cond.EMAN_IN_TIPO == 1)
                                                                        {
                                                                            <td>Imagem</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 2)
                                                                        {
                                                                            <td>Vídeo</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 3)
                                                                        {
                                                                            <td>PDF</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 4)
                                                                        {
                                                                            <td>Audio</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 5)
                                                                        {
                                                                            <td>Documento/Word</td>
                                                                        }
                                                                        else if (cond.EMAN_IN_TIPO == 6)
                                                                        {
                                                                            <td>Planilha/Excel</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td>Outros</td>
                                                                        }
                                                                        <td class="td-one-action">
                                                                            @if (cond.EMAN_IN_TIPO == 1 || cond.EMAN_IN_TIPO == 2)
                                                                            {
                                                                                @Html.TableLinkDetails(cond.EMAN_CD_ID, "VerAnexoEmpresa", "fa-camera", "Visualizar")
                                                                            }
                                                                            @if (cond.EMAN_IN_TIPO == 4)
	                                                                        {
                                                                                @Html.TableLinkDetails(cond.EMAN_CD_ID, "VerAnexoEmpresaAudio","fa-volume-up", "Visualizar")
	                                                                        }
                                                                            @if (cond.EMAN_IN_TIPO == 3)
                                                                            {
                                                                                <a title="Visualizar" class="fa fa-camera fa-lg" href="~/PdfViewer/web/viewer.html?file=@(cond.EMAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank" ></a>
                                                                            }
                                                                            @Html.TableLinkDetails(cond.EMAN_CD_ID, "DownloadEmpresa", "fa-download", "Download")
                                                                            @if (cond.EMAN_IN_ATIVO == 1)
	                                                                        {
