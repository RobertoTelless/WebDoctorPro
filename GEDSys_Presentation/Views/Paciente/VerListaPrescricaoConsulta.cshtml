@using Presentation.Extensions
@using CrossCutting;
@model ERP_Condominios_Solution.ViewModels.PacienteConsultaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Prescrição";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Prescrição - Lista das prescrições do paciente ";
    ViewBag.MetaKeywords = "WebDoctor, paciente, prescricao";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("ProcederConsulta", "Paciente")">Consulta</a>
            </li>
            <li class="active">
                <strong>Prescrições</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Paciente - Prescrições</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }                    
                    <div class="row">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @if (ViewBag.Classe == 0)
                                {
                                    @*@Html.ButtonLinkIndex(text: "Nova Prescrição", controller: "Paciente", action: "IncluirPrescricaoNova", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })*@
                                    <a href="@Url.Action("IncluirPrescricaoNova", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Cria nova prescrição para o paciente" class="btn btn-sm btn-primary btn-loading" OnClick = "Fade()">Nova Prescrição</a>                

                                }
                                @if (ViewBag.ClasseLK == 0)
                                {
                                    <button style="margin-left: 0px;" class="btn btn-sm btn-primary" id="buttonLab" type="button" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Página de Prescrições de seu órgão de classe">Nova Prescrição - Classe</button>
                                }
                                @*@Html.ButtonLinkIndex(text: "Ver Todas Prescrições", controller: "Paciente", action: "MontarTelaPrescricoes", htmlAttributes: new { @class = "btn-loading" })*@
                                <a href="@Url.Action("MontarTelaPrescricoes", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Visualizar todas as prescrições cadastradas" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Ver Todas Prescrições</a>                
                                <a href="@Url.Action("VerMedicamentosBase", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Visualizar os medicamentos prescritos para este paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Ver Medicamentos</a>                
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta", htmlAttributes: new { @class = "btn-loading" }) 
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Paciente
                                @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Nascimento
                                @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                            </div>
                            @if (Model.PACIENTE.PACI_NR_CPF != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    CPF
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                            @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Celular
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                            @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                            {
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Telefone
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                            }
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Dados da Consulta</h4>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Consulta
                                @Html.TextBoxFor(m => m.TipoConsulta, new { @class = "form-control", @readonly = "readonly"})
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                @Html.HiddenFor(m => m.PACI_CD_ID)
                                @Html.HiddenFor(m => m.PACO_IN_ATIVO)
                                @Html.HiddenFor(m => m.PACO_IN_ENCERRADA)
                                @Html.HiddenFor(m => m.USUA_CD_ID)
                                @Html.HiddenFor(m => m.ASSI_CD_ID)
                                @Html.HiddenFor(m => m.PACO_CD_ID)
                                Data da Consulta
                                @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Início
                                @Html.TextBoxFor(m => m.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Final
                                @Html.TextBoxFor(m => m.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                            </div>
                        </div>
                    </div>
                    <br />
                   
                    <div class="row">
                        <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Prescrições da Consulta</h4>
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_PRESCRICAO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Data da Emissão</th>
                                        <th style="width: auto">Tipo de Controle</th>
                                        <th style="width: auto">Nome do Paciente</th>
                                        <th style="width: auto">Identificador</th>
                                        <th style="width: auto">Enviada</th>
                                        <th style="width: auto">Último Envio</th>
                                        <th style="width: auto">Num. Envios</th>
                                        <th style="width: auto">Num. Itens</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_PRESCRICAO>).Where(p => p.PAPR_IN_ATIVO == 1).OrderByDescending(p => p.PAPR_DT_EMISSAO))
                                    {
                                        <tr>
                                            <td style="width: auto">@cond.PAPR_DT_EMISSAO.Value.Date.ToShortDateString() @cond.PAPR_DT_EMISSAO.Value.ToShortTimeString()</td>
                                            @if (cond.TICO_CD_ID == 3)
                                            {
                                                <td style="width: auto"><span class="badge badge-success">@cond.TIPO_CONTROLE.TICO_NM_NOME</span></td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">@cond.TIPO_CONTROLE.TICO_NM_NOME</td>
                                            }
                                            <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ALTERAR == 1)
                                            {
                                                if (cond.PAPR_IN_ENVIADO == 0)
                                                {                                                                              
                                                    <td style="width: auto"><a href="@Url.Action("EditarPrescricaoCompleta", "Paciente", new { id = cond.PAPR_CD_ID })" class="btn-loading" />@cond.PAPR_GU_GUID</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><a href="@Url.Action("VerPrescricaoCompleta", "Paciente", new { id = cond.PAPR_CD_ID })" class="btn-loading" />@cond.PAPR_GU_GUID</td>
                                                }
                                            }
                                            else
                                            {
                                                <td style="width: auto"><a href="@Url.Action("VerPrescricaoCompleta", "Paciente", new { id = cond.PAPR_CD_ID })" class="btn-loading" />@cond.PAPR_GU_GUID</td>
                                            }
                                            @if (cond.PAPR_IN_ENVIADO == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                            }
                                            else
                                            {
                                                <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                            }
                                            @if (cond.PAPR_DT_ENVIO != null)
                                            {
                                                <td style="width: auto">@cond.PAPR_DT_ENVIO.Value.ToShortDateString()</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }
                                            <td style="width: auto">@cond.PAPR_NR_ENVIOS</td>
                                            <td style="width: auto">@cond.PACIENTE_PRESCRICAO_ITEM.Where(p => p.PAPI_IN_ATIVO == 1).Count()</td>

                                            <td style="width: auto" class="td-one-action">                                                                            
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ALTERAR == 1)
                                                {
                                                    if (cond.PAPR_IN_ENVIADO == 0)
                                                    {
                                                        @Html.TableLinkDetails(cond.PAPR_CD_ID, "EditarPrescricaoCompleta", "fa-edit btn-loading", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PAPR_CD_ID, "VerPrescricaoCompleta", "fa-search btn-loading", "Consultar")
                                                    }
                                                }
                                                else
                                                {
                                                    @Html.TableLinkDetails(cond.PAPR_CD_ID, "VerPrescricaoCompleta", "fa-search btn-loading", "Consultar")
                                                }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ENVIAR == 1)
                                                {
                                                    if (cond.PAPR_IN_ATIVO == 1 )
                                                    {
                                                        @Html.TableLinkDetails(cond.PAPR_CD_ID, "EnviarPrescricaoEMail", "fa-send-o btn-loading", "Enviar Prescrição")
                                                    }
	                                            }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ENVIAR == 1)
                                                {
                                                    if (cond.PAPR_IN_ATIVO == 1 )
                                                    {
                                                        @Html.TableLinkDetails(cond.PAPR_CD_ID, "ImprimirPrescricao", "fa-print", "Imprimir")
                                                    }
	                                            }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_EXCLUIR == 1)
                                                {
                                                    if (cond.PAPR_IN_ENVIADO == 0)
                                                    {
                                                        if (cond.PAPR_IN_ATIVO == 1)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluirPrescricao('/Paciente/ExcluirPrescricao/@cond.PAPR_CD_ID')" title="Excluir"></span>
                                                        }
                                                    }
	                                            }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-3 col-md-3 col-xs-2">
                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                    <h2 style="font-weight: bold">Nenhuma prescrição cadastrada para essa consulta</h2>
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
   
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
        });
    </script>

    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirPrescricao(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Prescrição?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }

        function ShowModalConfirmarEnvio(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Reativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma envio da Prescrição?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Envio</h5>');
            $('#modal').modal('show');
        }
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#buttonLab').click(function () {
                $.ajax({
                    url: '@Url.Action("RedirecionarClasse", "Paciente2")',
                    type: 'POST',
                    success: function (response) {
                        if (response.success) {
                            window.open(response.url, '_blank');
                        }
                        else {
                            alert("Error calling method.");
                        }
                    },
                    error: function () {
                        alert("Error calling method.");
                    }
                });
            });
        }); 
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                order: [[0, 'desc'],
                columnDefs: [
                                {
                                    // Aplicar o tipo de ordenação de data na Coluna 0
                                    "type": "datetime-moment", 
                                    "targets": 0 
                                },
                                {
                                    // As colunas de Ações, Tipo, Situação, etc., podem ter elementos HTML 
                                    // que atrapalham a ordenação. Usamos "html-num" (ou customizado)
                                    // ou simplesmente garantir que não tente ordenar o conteúdo do link da data.
                                    "orderable": false, // Desabilita ordenação para a coluna Ações
                                    "targets": 7 
                                }
                ],
                // ---------------------------------     
                buttons: [
                    { extend: 'excel', title: 'Prescricoes_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });         
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

