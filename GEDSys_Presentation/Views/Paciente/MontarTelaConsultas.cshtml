@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.PACIENTE_CONSULTA
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Consulta";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Consultas - Lista de consultas";
    ViewBag.MetaKeywords = "WebDoctor, paciente, consulta";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal fade" id="modalCancelar" tabindex="-1" role="dialog" aria-labelledby="modalCancelarLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalCancelarLabel">Justificar Cancelamento</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="textoJustificativa">Justificativa do Cancelamento:</label>
                        <textarea class="form-control" id="textoJustificativa" rows="5" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmarCancelamento">Confirmar Cancelamento</button>
                </div>
            </div>
        </div>
    </div>    
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Central de Consultas</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarConsultas", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Consulta
                                @Html.DropDownListFor(m => m.VACO_CD_ID, (SelectList)ViewBag.TipoConsulta, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Nome do Paciente ou Fragmento do nome
                                @Html.TextBoxFor(m => m.PACO_TX_RESUMO, new { @class = "form-control", autofocus = true, @id = "txtNomePaciente"  })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.PACO_DT_DUMMY, new { @class = "form-control date-picker", autofocus = true, @id = "dn", data_toggle = "popover", data_content = "Informe a data inicial da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.PACO_DT_PROXIMA, new { @class = "form-control date-picker", autofocus = true, @id = "dn1", data_toggle = "popover", data_content = "Informe a data final da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Profissional
                                @Html.DropDownListFor(m => m.USUA_CD_ID, (SelectList)ViewBag.Usuario, "Selecionar", new { @class = "form-control", autofocus = true})
                            </div>
                        </div>

                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                @Html.ButtonLinkIndex(text: "Nova Consulta", controller: "Paciente", action: "IncluirConsultaCompleta", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Hoje", controller: "Paciente", action: "VerConsultasHoje", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Mês Atual", controller: "Paciente", action: "VerConsultasMes", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Futuras", controller: "Paciente", action: "VerConsultasFuturas", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Anteriores", controller: "Paciente", action: "VerConsultasAnteriores", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action("VerCalendarioConsulta", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Ver as consultas marcadas em formato de calendário" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Ver Calendário</a>                
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_CONF_CANC_CONSULTA == 1)
                                {
                                    <a href="@Url.Action("ConfirmarCancelarConsulta", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à página de confirmação/cancelamento de consultas" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Confirmação</a>                
                                }
                                <a href="@Url.Action("MontarTelaEncerrarConsulta", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à página de encerramento de consultas" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Encerramento</a>                
                                @Html.ButtonLinkIndex(text: "Imprimir", controller: "Paciente", action: "GerarRelatorioConsultas")
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarCentrais", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Central de Consultas</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @*@if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }*@                    
                    <div class="row">
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_CONSULTA>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Data da Consulta</th>
                                        <th style="width: auto">Hora de Início</th>
                                        <th style="width: auto">Hora de Término</th>
                                        <th style="width: auto">Nome do Paciente </th>
                                        <th style="width: auto">Tipo de Consulta</th>
                                        <th style="width: auto">Situação</th>
                                        <th style="width: auto">Profissional</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_CONSULTA>).OrderByDescending(p => p.PACO_DT_CONSULTA.Date).ThenBy(p => p.PACO_HR_INICIO))
                                    {   
                                        if (cond.PACO_DT_CONSULTA > DateTime.Today.Date)
                                        {
                                            <tr  style="background-color: aliceblue">
                                                <td>
                                                    <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date & cond.PACO_IN_CONFIRMADA < 2)
                                                        {
                                                            <a href="@Url.Action("EditarConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                            <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                    }
                                                </td>
                                                <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                @if (cond.VALOR_CONSULTA != null)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">@cond.VALOR_CONSULTA.VACO_NM_NOME</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">-</span></td>
                                                }

                                                @if (cond.PACO_IN_CONFIRMADA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Confirmada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 2)
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Cancelada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 0)
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Pendente</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">Encerrada</span></td>
                                                }

                                                <td style="width: auto; color: green; font-weight: bold">@cond.USUARIO.USUA_NM_NOME</td>
                                                <td style="width: auto" class="td-one-action">
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date & cond.PACO_IN_CONFIRMADA < 2)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "EditarConsultaCompleta", "fa-edit btn-loading", "Remarcar")
                                                        }
                                                        else
                                                        {
                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search btn-loading", "Ver")
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search btn-loading", "Ver")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_EXCLUIR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1)
                                                        {
                                                            if (cond.PACO_DT_CONSULTA.Date > DateTime.Today.Date)
                                                            {
                                                                <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluirConsulta('/Paciente/ExcluirConsulta/@cond.PACO_CD_ID')" title="Excluir"></span>
                                                            }
                                                        }
	                                                }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & (cond.PACO_IN_CONFIRMADA == 1 || cond.PACO_IN_CONFIRMADA == 3))
                                                        {
                                                            if (cond.PACO_DT_CONSULTA.Date == DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-clock-o btn-loading", "Proceder Consulta")
                                                            }
                                                            else if (cond.PACO_DT_CONSULTA.Date < DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-history btn-loading", "Rever Consulta")
                                                            }
                                                        }
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Confirmar" class="tbl-link fa-lg fa fa-check btn-loading" onclick="ShowModalConfirmar('/Paciente/ConfirmarConsulta/@cond.PACO_CD_ID')" title="Confirmar Consulta"></span>
                                                        }
                                                        if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA < 2)
                                                        {

                                                            <span style="color: #337ab7; cursor:pointer;" alt="Mensagem" class="tbl-link fa-lg fa fa-times btn-loading" onclick="ShowModalCancelar('/Paciente2/CancelarConsulta/@cond.PACO_CD_ID')" title="Cancelar Consulta"></span>     
                                                        }
                                                    }
                                                    @if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA == 0)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Mensagem" class="tbl-link fa-lg fa fa-mail-forward btn-loading" onclick="ShowModalEnviar('/Paciente2/EnviarEMailConfirmacao/@cond.PACO_CD_ID')" title="Enviar Confirmação"></span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                        else if (cond.PACO_DT_CONSULTA < DateTime.Today.Date)
                                        {
                                            <tr style="background-color: floralwhite">
                                                <td>
                                                    <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                    <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                        @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                    </a>
                                                </td>
                                                <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                @if (cond.VALOR_CONSULTA != null)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">@cond.VALOR_CONSULTA.VACO_NM_NOME</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">-</span></td>
                                                }

                                                @if (cond.PACO_IN_CONFIRMADA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Confirmada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 2)
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Cancelada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 0)
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Pendente</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">Encerrada</span></td>
                                                }

                                                <td style="width: auto; color: green; font-weight: bold">@cond.USUARIO.USUA_NM_NOME</td>
                                                <td style="width: auto" class="td-one-action">
                                                    @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search btn-loading", "Ver")
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & (cond.PACO_IN_CONFIRMADA == 1 || cond.PACO_IN_CONFIRMADA == 3 || cond.PACO_IN_ENCERRADA == 1))
                                                        {
                                                            if (cond.PACO_DT_CONSULTA.Date == DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-clock-o btn-loading", "Proceder Consulta")
                                                            }
                                                            else if (cond.PACO_DT_CONSULTA.Date < DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-history btn-loading", "Rever Consulta")
                                                            }
                                                        }
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA < 2 & cond.PACO_IN_ENCERRADA == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Mensagem" class="tbl-link fa-lg fa fa-times btn-loading" onclick="ShowModalCancelar('/Paciente2/CancelarConsulta/@cond.PACO_CD_ID')" title="Cancelar Consulta"></span>     
                                                        }
                                                    }
                                                </td>
                                                <td style="width: 0.05px"></td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>
                                                    <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date & cond.PACO_IN_CONFIRMADA < 2)
                                                        {
                                                            <a href="@Url.Action("EditarConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                            <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading">
                                                                @cond.PACO_DT_CONSULTA.ToShortDateString()
                                                            </a>
                                                    }
                                                </td>
                                                <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                @if (cond.VALOR_CONSULTA != null)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">@cond.VALOR_CONSULTA.VACO_NM_NOME</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">-</span></td>
                                                }

                                                @if (cond.PACO_IN_CONFIRMADA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Confirmada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 2)
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Cancelada</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 0)
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Pendente</span></td>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">Encerrada</span></td>
                                                }

                                                <td style="width: auto; color: green; font-weight: bold">@cond.USUARIO.USUA_NM_NOME</td>
                                                <td style="width: auto" class="td-one-action">
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date & cond.PACO_IN_CONFIRMADA < 2)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "EditarConsultaCompleta", "fa-edit btn-loading", "Remarcar")
                                                        }
                                                        else
                                                        {
                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search btn-loading", "Ver")
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search btn-loading", "Ver")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_EXCLUIR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1)
                                                        {
                                                            if (cond.PACO_DT_CONSULTA.Date > DateTime.Today.Date)
                                                            {
                                                                <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluirConsulta('/Paciente/ExcluirConsulta/@cond.PACO_CD_ID')" title="Excluir"></span>
                                                            }
                                                        }
	                                                }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & (cond.PACO_IN_CONFIRMADA == 1 || cond.PACO_IN_CONFIRMADA == 3))
                                                        {
                                                            if (cond.PACO_DT_CONSULTA.Date == DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-clock-o btn-loading", "Proceder Consulta")
                                                            }
                                                            else if (cond.PACO_DT_CONSULTA.Date < DateTime.Today.Date)
                                                            {
                                                                @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-history btn-loading", "Rever Consulta")
                                                            }
                                                        }
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                    {
                                                        if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Confirmar" class="tbl-link fa-lg fa fa-check btn-loading" onclick="ShowModalConfirmar('/Paciente/ConfirmarConsulta/@cond.PACO_CD_ID')" title="Confirmar Consulta"></span>
                                                        }
                                                        if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA < 2)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Mensagem" class="tbl-link fa-lg fa fa-times btn-loading" onclick="ShowModalCancelar('/Paciente2/CancelarConsulta/@cond.PACO_CD_ID')" title="Cancelar Consulta"></span>     
                                                        }
                                                    }
                                                    @if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA == 0)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Mensagem" class="tbl-link fa-lg fa fa-mail-forward btn-loading" onclick="ShowModalEnviar('/Paciente2/EnviarEMailConfirmacao/@cond.PACO_CD_ID')" title="Enviar Confirmação"></span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-12">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhuma consulta cadastrada</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Paciente", action: "VerConsultasHoje" , htmlAttributes: new { @class = "btn-loading" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    <link href="~/Content/jquery.datetimepicker.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>


}
