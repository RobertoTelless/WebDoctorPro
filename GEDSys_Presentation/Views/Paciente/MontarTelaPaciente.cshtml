    <script type="text/javascript">
        var idAvisoAtual = 0;
        const COOKIE_NAME = "WebDoctor_AvisosLidos";

        $(document).ready(function () {
            filtrarAvisosLidos();
        });

        function abrirModalAviso(id, titulo, texto, icone, arquivoPdf) {
            // CORREÇÃO: Atualiza a variável global com o ID do aviso clicado
            idAvisoAtual = id;

            // Preenche título e o conteúdo do texto na modal
            $('#modalTitle').text(titulo);
            $('#modalBodyContent').html(texto); // Aqui exibe o conteúdo do campo MEFA_TX_TEXTO
    
            // Configura o ícone dinâmico
            $('#modalIconeDinamico').attr('class', 'fa modal-icon ' + icone);

            // Lógica do botão PDF
            var btnPdf = $('#btnVerPdf');
            if (arquivoPdf && arquivoPdf.trim() !== "") {
                // Remove o til (~) e limpa a URL
                var caminhoTratado = arquivoPdf.replace(/^~/, '');
                if (!caminhoTratado.startsWith('/')) {
                    caminhoTratado = '/' + caminhoTratado;
                }

                var urlFinal = window.location.origin + caminhoTratado;
                btnPdf.attr('href', urlFinal);
                btnPdf.show();
            } else {
                btnPdf.hide();
            }

            // Abre a modal (usando as classes do Inspinia)
            $('#modalAviso').modal('show');
        }

        function confirmarLeitura() {
            if (idAvisoAtual === 0) return;

            let lidos = getLidos();
        
            if (!lidos.includes(idAvisoAtual.toString())) {
                lidos.push(idAvisoAtual.toString());
            }

            localStorage.setItem(COOKIE_NAME, JSON.stringify(lidos));

            $('#modalAviso').modal('hide');
            toastr.success("Aviso arquivado.");

            filtrarAvisosLidos();
        }

        function getLidos() {
            let lidos = localStorage.getItem(COOKIE_NAME);
            return lidos ? JSON.parse(lidos) : [];
        }

        function filtrarAvisosLidos() {
            let lidos = getLidos();
            let possuiAvisosVisiveis = false;

            $('.marquee-msg').each(function () {
                let id = $(this).data('id').toString();
                if (lidos.includes(id)) {
                    $(this).remove(); 
                } else {
                    possuiAvisosVisiveis = true;
                }
            });

            if (!possuiAvisosVisiveis) {
                $('.marquee-text-container').hide();
            }
        }
    </script>
    <script type="text/javascript">
        function limparHistoricoAvisos() {
            // 1. Prepara o conteúdo da modal para "Modo de Confirmação"
            $('#modalTitle').text("Restaurar Avisos");
            $('#modalBodyContent').html("<p>Deseja voltar a exibir todos os avisos que você marcou como lidos?</p>");
        
            // 2. Ajusta o ícone para um ponto de interrogação ou refresh
            var $icone = $('#modalIconeDinamico');
            $icone.removeClass().addClass('fa fa-refresh modal-icon text-warning');

            // 3. Altera o botão "Entendi" para atuar como "Confirmar Restauração"
            // Mudamos o texto e a função que ele chama
            var btnConfirmar = $('#modalAviso .btn-primary');
            btnConfirmar.text("Sim, Restaurar");
            btnConfirmar.attr("onclick", "executarLimpeza()");

            // 4. Abre a modal
            $('#modalAviso').modal('show');
        }

        function executarLimpeza() {
            // Remove os dados do LocalStorage
            localStorage.removeItem("WebDoctor_AvisosLidos");

            if (typeof toastr !== 'undefined') {
                toastr.success("Histórico de avisos limpo com sucesso!");
            }

            // Fecha a modal e recarrega
            $('#modalAviso').modal('hide');
        
            setTimeout(function() {
                location.reload();
            }, 800);
        }
    </script>


