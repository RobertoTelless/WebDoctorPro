@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }

        .marquee-text-container {
                width: 100%;
                overflow: hidden;
                /*background: #fdfdfd;*/ /* Fundo suave */
                background: #f1f9f2; /* Fundo suave */
                border-bottom: 1px solid #e7eaec;
                padding: 10px 0;
                display: flex;
                user-select: none;
            }

        .marquee-text-content {
            display: flex;
            gap: 80px; /* Grande espaçamento entre as mensagens */
            animation: scroll-text 40s linear infinite; /* 40 segundos para leitura confortável */
            white-space: nowrap;
        }

        /* Pausa a animação ao passar o mouse para facilitar a leitura */
        .marquee-text-container:hover .marquee-text-content {
            animation-play-state: paused;
            cursor: default;
        }

        .marquee-msg {
            font-size: 13px;
            color: #676a6c; /* Cor do texto padrão Inspinia */
            font-weight: 500;
            display: flex;
            align-items: center;
        }

        .marquee-msg i {
            margin-right: 8px;
            color: #1ab394; /* Verde Inspinia nos ícones */
        }

        /* Variante: Azul Informativo (Info) */
        .marquee-info {
            background-color: #d9edf7 !important; /* Azul claro */
            border-bottom: 1px solid #bce8f1;
        }
        .marquee-info .marquee-msg {
            color: #31708f !important;
        }
        .marquee-info .marquee-msg i {
            color: #31708f !important;
        }

        /* Variante: Amarelo Atenção (Warning) */
        .marquee-warning {
            background-color: #fcf8e3 !important; /* Amarelo claro */
            border-bottom: 1px solid #faebcc;
        }
        .marquee-warning .marquee-msg {
            color: #8a6d3b !important;
        }
        .marquee-warning .marquee-msg i {
            color: #8a6d3b !important;
        }

        /* Ajuste de animação para garantir suavidade */
        .marquee-text-content {
            display: flex;
            gap: 80px;
            animation: scroll-text 45s linear infinite;
            white-space: nowrap;
        }
        .marquee-msg {
            cursor: pointer;
            text-decoration: none !important;
            transition: transform 0.2s;
        }
        .marquee-msg:hover {
            transform: scale(1.05);
            font-weight: bold;
        }

        /* Estilos para itens individuais */
        .marquee-info-item { color: #31708f !important; margin-right: 40px; }
        .marquee-warning-item { color: #8a6d3b !important; font-weight: bold; margin-right: 40px; }
    
        .marquee-warning-item i { color: #8a6d3b !important; }
        .marquee-info-item i { color: #31708f !important; }

        /* Garante que o fundo do container seja neutro para aceitar as duas cores */
        .marquee-text-container { background: #f8f9fa !important; border-bottom: 1px solid #e7eaec; }

        /* Animação para mover exatamente 50% (o primeiro grupo de mensagens) */
        @@keyframes scroll-text {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        #modalBodyContent {
            white-space: pre-line;
            line-height: 1.6; /* Melhora a leitura como na imagem */
        }
    </style>

    <style>
        /* Força a modal a ficar à frente do backdrop e de outros elementos do Inspinia */
        #modalAviso {
            z-index: 2050 !important;
        }
        .modal-backdrop {
            z-index: 2040 !important;
        }
    
        /* Garante que o letreiro não sobreponha a modal se ela abrir */
        .marquee-text-container {
            z-index: 1000;
            position: relative;
        }
    </style>
}

@section Scripts {
