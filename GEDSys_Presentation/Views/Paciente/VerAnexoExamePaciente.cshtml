    <script>
        $(document).ready(function () {
            const paeoId = @Model.PAEO_CD_ID;
            let tempX = 0; // Armazena X temporariamente enquanto a modal abre
            let tempY = 0; // Armazena Y temporariamente enquanto a modal abre

            loadPins();

            // 1. Evento de clique no overlay da imagem
            $('#pins-overlay').click(function (e) {
                const $overlay = $(this);
                const offset = $overlay.offset();
            
                // Calcula e guarda as coordenadas
                tempX = ((e.pageX - offset.left) / $overlay.width()) * 100;
                tempY = ((e.pageY - offset.top) / $overlay.height()) * 100;

                // Limpa o campo e abre a modal
                $('#txtAnotacaoModal').val('');
                $('#modalAnotacao').modal('show');
            });

            // 2. Evento do botão "Salvar" dentro da modal
            $('#btnSalvarAnotacaoModal').click(function () {
                const texto = $('#txtAnotacaoModal').val();

                if (texto.trim() === "") {
                    alert("Por favor, digite um texto para a anotação.");
                    return;
                }

                // Chama a função de salvar usando as coordenadas guardadas
                savePin(tempX, tempY, texto);
            
                // Fecha a modal
                $('#modalAnotacao').modal('hide');
            });

            function savePin(x, y, texto) {
                $.post('@Url.Action("SalvarAnotacaoPonto", "Paciente")', {
                    paeoId: paeoId,
                    x: x,
                    y: y,
                    texto: texto
                }, function (response) {
                    if (response.success) {
                        renderPin(x, y, texto, response.id);
                    } else {
                        alert("Erro ao salvar anotação.");
                    }
                });
            }

            function renderPin(x, y, texto, id) {
                const pin = $('<div class="pin"></div>');
                pin.css({
                    'position': 'absolute',
                    'left': x + '%',
                    'top': y + '%',
                    'width': '12px',
                    'height': '12px',
                    'background-color': 'red',
                    'border-radius': '50%',
                    'border': '2px solid white',
                    'transform': 'translate(-50%, -50%)',
                    'cursor': 'pointer',
                    'z-index': 1000
                });

                $('#pins-overlay').append(pin);

                pin.popover({
                    trigger: 'hover',
                    placement: 'top',
                    content: texto,
                    container: 'body'
                });
            }

            function loadPins() {
                $.getJSON('@Url.Action("ListarAnotacoesPonto", "Paciente")', { paeoId: paeoId }, function (data) {
                    data.forEach(p => renderPin(p.x, p.y, p.texto, p.id));
                });
            }
        });
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
