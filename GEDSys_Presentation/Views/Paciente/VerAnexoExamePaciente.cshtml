@using Presentation.Extensions
@model EntitiesServices.Model.PACIENTE_EXAME_ANEXO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Exame - Anexo";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Exame - Anexo - Visualização de anexo";
    ViewBag.MetaKeywords = "WebDoctor, paciente, exame, anexo";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal inmodal fade" id="modalAnotacao" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="padding: 20px 15px;">
                    <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span><span class="sr-only">Fechar</span></button>
                    <i class="fa fa-pencil-square-o modal-icon text-primary"></i>
                    <h4 class="modal-title">Nova Anotação na Imagem</h4>
                    <small class="font-bold">WebDoctorPro - Anotação em Imagem de Exame</small>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Digite a anotação para este ponto da imagem:</label>
                        <textarea id="txtAnotacaoModal" class="form-control" rows="4" placeholder="Ex: Mancha identificada na região lateral..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnSalvarAnotacaoModal">Salvar Anotação</button>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
            </li>
            <li>
                <a href="@Url.Action("EditarPaciente", "Paciente")">Pacientes - Alteração</a>
            </li>
            <li>
                <a href="@Url.Action("EditarExame", "Paciente")">Pacientes - Exames - Alteração</a>
            </li>
            <li class="active">
                <strong>Pacientes - Exames - Anexos</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página de visualização de anexos (imagens ou vídeos) de resultados de exames do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Visualizar uma imagem anexada com recursos de ampliação e anotação na prória imagem</li>
                        <li>Visualizar um vídeo anexado com recursos de velocidade de exibição, baixa (download), tela cheia e PiP (picture in picture)</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Resultado de Exame - Ver Anexo</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME</span>
                    </div>
                </div>
                @using (Html.BeginForm("VerAnexoExamePaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                {
                    <div class="ibox-content">
                        <div class="form-group">
                            @if ((Int32)Session["VoltaAnexoExame"] == 2)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VerAnexoExamesPaciente", controller: "Paciente", routeValues: new { id = Model.PAEX_CD_ID }, htmlAttributes: new { @class = "btn-loading" })
                            }
                            else
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarEditarExame", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                            }
                            <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                <i class="fa fa-spinner fa-spin"></i> Processando...
                            </span>
                        </div>
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Anexo</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Titulo
                                    @Html.TextBoxFor(m => m.PAEO_NM_TITULO, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data
                                    @Html.TextBoxFor(m => m.PAEO_DT_ANEXO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly"})
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            @if (Model.PAEO_IN_TIPO == 1)
                            {
                                <!--<div class="col-lg-12">
                                    <p class="alert alert-info"><i class="fa fa-info-circle"></i> Clique em qualquer lugar da imagem para adicionar uma anotação ou passe o mouse para visualizar uma anotação já existente</p>-->
        
                                    @* Container para posicionamento absoluto dos Pins *@
                                    <!--<div id="image-container" style="position: relative; display: inline-block; cursor: crosshair;">
                                        <img id="img-exame" src="@Url.Content(Model.PAEO_AQ_ARQUIVO)" class="img-responsive" style="max-height: 1530px; max-width: 100%;">
    
                                        <div id="pins-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: crosshair;"></div>
                                    </div> 
                               </div>-->
                                <div class="col-lg-12">
                                    <p class="alert alert-info">
                                        <i class="fa fa-info-circle"></i> Clique em qualquer lugar da imagem para adicionar uma anotação ou passe o mouse para visualizar uma anotação já existente
                                    </p>

                                    @* Container para posicionamento absoluto dos Pins *@
                                    <div id="image-container" style="position: relative; display: inline-block; cursor: crosshair;">
        
                                        <img id="img-exame" 
                                             src="@("https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + Model.PAEO_AQ_ARQUIVO.Replace("~/", "").Replace("~", ""))" 
                                             class="img-responsive" 
                                             style="max-height: 1530px; max-width: 100%;"
                                             onerror="this.onerror=null;this.src='@Url.Content("~/Images/icone_imagem.jpg")';">

                                        <div id="pins-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: crosshair;"></div>
                                    </div> 
                                </div>
                            }

                            @if (Model.PAEO_IN_TIPO == 2)
                            {
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <figure>
                                        @{
                                            var urlVideoAzure = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + Model.PAEO_AQ_ARQUIVO.Replace("~/", "").Replace("~", "");
                                        }
                                        <video width="900" height="600" controls style="background: #000;">
                                            <source src="@urlVideoAzure" type="video/mp4">
                                            Seu navegador não suporta a tag de vídeo.
                                        </video>
                                    </figure>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
}
@section Scripts {

    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    @Scripts.Render("~/plugins/videoResponsible")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script type="text/javascript">
        $(document).on('webkitfullscreenchange mozfullscreenchange fullscreenchange', function (e) {
            $('body').hasClass('fullscreen-video') ? $('body').removeClass('fullscreen-video') : $('body').addClass('fullscreen-video')
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

