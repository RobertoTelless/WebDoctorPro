                                            @Html.TextAreaFor(m => m.PAAN_NM_AVALIACAO_CARDIOLOGICA_LONG, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.PAAN_NM_AVALIACAO_CARDIOLOGICA_LONG, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                }
                                @if (Model.PAAM_IN_FLAG_RESPIRATORIO == 1)
                                {
