                                {
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Avaliação Cardiológica - Histórico
                                            @Html.TextAreaFor(m => m.PAAN_NM_AVALIACAO_CARDIOLOGICA_OLD, new { @class = "form-control", tabindex = "-1", style = "width: 100%; height: 200px; overflow:auto;", @readonly = "readonly" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
