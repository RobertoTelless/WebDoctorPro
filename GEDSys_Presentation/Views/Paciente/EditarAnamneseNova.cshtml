                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Avaliação Respiratória - Consulta Atual/Revisão
                                            @Html.TextAreaFor(m => m.PAAN_NM_RESPIRATORIO_LONG, new { @class = "form-control", style = "width: 100%; height: 100px; overflow:auto;", autofocus = true })
                                            @Html.ValidationMessageFor(m => m.PAAN_NM_RESPIRATORIO_LONG, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                }
                                @if (Model.PAAM_IN_FLAG_ABDOMEM == 1)
                                {
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
