                                        Diagnóstico - Histórico
                                        @Html.TextAreaFor(m => m.PAAM_DS_DIAGNOSTICO_1_OLD, new { @class = "form-control", tabindex = "-1", style = "width: 100%; height: 200px; overflow:auto;", @readonly = "readonly"})
                                    </div>
                                </div>
