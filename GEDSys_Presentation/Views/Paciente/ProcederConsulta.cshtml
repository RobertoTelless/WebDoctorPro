    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            // Função para verificar o scroll
            function checkScroll() {
                // Verifica o scroll tanto na janela quanto no wrapper do Inspinia
                var scrollPos = $(window).scrollTop() || $('#page-wrapper').scrollTop();
            
                if (scrollPos > 300) {
                    $('.back-to-top').addClass('visible');
                } else {
                    $('.back-to-top').removeClass('visible');
                }
            }

            // Monitora o scroll em ambos os contextos possíveis no Inspinia
            $(window).on('scroll', checkScroll);
            $('#page-wrapper').on('scroll', checkScroll);

            // Clique suave
            $('.back-to-top').click(function (e) {
                e.preventDefault();
                $('html, body, #page-wrapper').animate({ scrollTop: 0 }, 600);
                return false;
            });
        
            // Executa uma vez ao carregar para garantir que comece oculto
            checkScroll();
        });
    </script>

       
