@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteConsultaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Consulta - Proceder";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Consulta - Proceder à consulta do paciente ";
    ViewBag.MetaKeywords = "WebDoctor, paciente, consulta, procedimento";
}
@{
    // Define a URL da Receita Federal
    string urlReceita = "https://cav.receita.fazenda.gov.br/autenticacao/login";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div id="top"></div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Consultas - Procedimento</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-6 col-md-6 col-xs-12">
            <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
                @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
                <details class="ajuda-contextual">
                    <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                    <div class="well well-sm">
                        <p>Essa é a página de procedimento de consultas do <b>WebDoctorPro</b>. Nela você poderá:</p>
                        <ol>
                            <li>Consultar e alterar informações na anamnese e no prontuário do paciente</li>
                            <li>Consultar e alterar informações no exame físico do paciente</li>
                            <li>Visualizar e gerenciar os anexos do paciente</li>
                            <li>Visualizar e gerenciar as fichas digitalizadas do paciente</li>
                            <li>Permite exibir para o paciente videos cadastrados</li>
                            <li>Impressão do prontuário e anamnese em formato PDF.</li>
                            <li>Impressão do exame físico em formato PDF.</li>
                            <li>Permite acessar a ficha completa do paciente</li>
                            <li>Permite encerrar a consulta, atualizar estoque (caso haja consumo) e gerar o recebimento</li>
                            <li>Permite acessar site do eCAC para emissão de recibo para o paciente</li>
                        </ol>
                    </div>
                </details>
                @* --- FIM DA AJUDA CONTEXTUAL --- *@
            </div>
        </div>
        <div class="col-lg-6 col-md-6 col-xs-12">
            <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
                @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
                <details class="ajuda-contextual">
                    <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                    <div class="well well-sm">
                        <p>Essa é a página de procedimento de consultas do <b>WebDoctorPro</b>. Nela você poderá:</p>
                        <ol>
                            <li>Permite a marcação deuma nova consulta</li>
                            <li>Permite a emissão de atestados, solicitações de exames e de prescrições para o paciente</li>
                            <li>Permite a inclusão de resultados de exames do paciente</li>
                            <li>Permite a visualização de todos os documentos vinculados ao paciente</li>
                            <li>Impressão da ficha completa do paciente em formato PDF.</li>
                            <li>Permite o envio das informações deste paciente para outro profissional.</li>
                        </ol>
                    </div>
                </details>
                @* --- FIM DA AJUDA CONTEXTUAL --- *@
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    @if (Model.PACO_DT_CONSULTA.Date == DateTime.Today.Date)
                    {
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Consulta -Procedimento</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME.ToUpper()</span>
                        </div>
                    }
                    else if (Model.PACO_DT_CONSULTA.Date < DateTime.Today.Date)
                    {
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Consulta -Revisão</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME.ToUpper()</span>
                        </div>
                    }
                </div>
                @using (Html.BeginForm("ProcederConsulta", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>
                        }
                        @*@if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }*@                    
                        <div class="row">
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">    
                                <a href="@Url.Action("VoltarAnexoPaciente", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à página de edição do paciente" class="btn btn-sm btn-success btn-loading" OnClick = "Fade()">Paciente</a>                
                                <a href="@Url.Action("MarcarProximaConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à página marcação de nova consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Nova Consulta</a>                
                                <a href="@Url.Action("VerListaPrescricaoConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à lista de precrições desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Prescrições</a>                
                                <a href="@Url.Action("VerListaAtestadoConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à lista de atestados desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Atestados</a>                
                                <a href="@Url.Action("VerListaSolicitacaoConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à lista de solicitacoes de exames desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Solicitacoes de Exames</a>                
                                <a href="@Url.Action("VerListaExameConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à lista de resultados de exames desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Resultados de Exames</a>                
                                <a href="@Url.Action("VerListaGeralConsulta", "Paciente")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à lista de todos os documentos desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Todos Documentos</a>                
                                <a href="@Url.Action("GerarRelatorioDetalheConsulta", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Geração do resumo da consulta em PDF" class="btn btn-sm btn-warning" OnClick = "Fade()">Resumo</a>                
                                <a href="@Url.Action("MontarTelaMedico", "Medico")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Repassar informações deste paciente para outro profissional" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Repassar Informações</a>                
                                <a href="@Url.Action("VoltarConsulta", "Paciente")"   data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Volta à página anterior" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Voltar</a>                
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                        <div class="row" style="width: 100%;">
                            <div class="col-lg-2 col-md-3 col-sm-4 col-xs-12">
                                @if (!String.IsNullOrEmpty(Model.PACIENTE.PACI_AQ_FOTO))
                                {
                                    <img src="@Url.Content(Model.PACIENTE.PACI_AQ_FOTO)" 
                                         class="img-responsive thumbnail" 
                                         style="max-height: 270px; margin: 0 auto;">
                                }
                                else
                                {
                                    <img src="~/Images/icon_morador.png" 
                                         class="img-responsive thumbnail" 
                                         style="max-height: 230px; margin: 0 auto;">
                                }
                            </div>
                            <div class="col-lg-10 col-md-10 col-xs-12">
                                <div class="row">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Nome do Paciente
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                        </div>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Data Nascimento
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                        </div>
                                        @if (Model.PACIENTE.PACI_NR_CPF != null)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                CPF
                                                @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        }
                                        @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Celular
                                                @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly"  })
                                            </div>
                                        }
                                        @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Telefone
                                                @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly"  })
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-4 col-md-4 col-xs-12">
                                            Indicado por
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_INDICACAO, new { @class = "form-control", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Informações da Consulta</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            @Html.HiddenFor(m => m.PACI_CD_ID)
                                            @Html.HiddenFor(m => m.PACO_IN_ATIVO)
                                            @Html.HiddenFor(m => m.PACO_IN_ENCERRADA)
                                            @Html.HiddenFor(m => m.USUA_CD_ID)
                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                            @Html.HiddenFor(m => m.PACO_CD_ID)
                                            @Html.HiddenFor(m => m.VACO_CD_ID)
                                            @Html.HiddenFor(m => m.VACO1_CD_ID)
                                            @Html.HiddenFor(m => m.PACO_IN_RECORRENTE)
                                            @Html.HiddenFor(m => m.PACO_IN_RECEBE)
                                            Data da Consulta
                                            @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                        </div>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Início
                                            @Html.TextBoxFor(m => m.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                                        </div>
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Final
                                            @Html.TextBoxFor(m => m.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                                        </div>
                                        @if (Model.PACO_IN_CONFIRMADA == 1)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12" style="color: ">
                                                Consulta - Status
                                                @Html.TextBoxFor(m => m.Situacao, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold; background-color: beige" })
                                            </div>
                                        }
                                        else if (Model.PACO_IN_CONFIRMADA == 3)
                                        {
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                Consulta - Status
                                                @Html.TextBoxFor(m => m.Situacao, new { @class = "form-control", @readonly = "readonly", @style = "color: darkblue; font-weight: bold; background-color: aliceblue" })
                                            </div>
                                        }
                                        @if (Model.PACO_IN_CONFIRMADA == 1)
                                        {
                                            if ((Int32)Session["Pisca"] == 0)
                                            {
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    <br />
                                                    <a href="@Url.Action("EncerrarConsulta", "Paciente2")" 
                                                       class="btn btn-sm btn-success btn-loading" 
                                                       onclick="return confirm('Confirma o encerramento dessa consulta?');">
                                                        Encerrar Consulta
                                                    </a>
                                                </div>



                                            }
                                            else
                                            {
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    <br />
                                                    <a href="@Url.Action("EncerrarConsulta", "Paciente2")" 
                                                       class="btn btn-sm btn-success pisca btn-loading" 
                                                       onclick="return confirm('Confirma o encerramento dessa consulta?');">
                                                        Encerrar Consulta
                                                    </a>
                                                </div>
                                            }
                                            if ((Int32)Session["SRF"] == 1)
                                            {
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    <br />
                                                    <button type="button" 
                                                            onclick="window.open('@urlReceita', '_blank')" 
                                                            class="btn btn-sm btn-primary" 
                                                            title="Abrir Portal e-CAC (Receita Federal)">
                                                            Abrir e-CAC
                                                    </button>  
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>                 
                        
                        <div class="row">
                            @if ((Int32)Session["BlocoAnamnese"] == 1)
                            {
                                if (ViewBag.FlagEdt == 1)
                                {
                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                        <h4 style="margin-left: -15px; color:green; background-color: beige; font-weight:bold">Anamnese/Prontuário Atualizado</h4>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">    
                                                <a href="@Url.Action("EditarAnamneseCompletaFormProcesso", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Preencher/Revisar a anamnese/prontuário do paciente" class="btn btn-sm btn-primary btn-loading" OnClick = "Fade()">Preencher/Revisar</a>                
                                                <a href="@Url.Action("VerAnamneseCompletaChamada", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Visualizar a anamnese/prontuário do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Visualizar</a>                
                                                <a href="@Url.Action("VerAnexoPacienteConsulta", "Paciente2")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Gerenciar/Visualizar os anexos do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Anexos</a>                
                                                <a href="@Url.Action("VerInformacaoPreviaPacienteBase", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Visualizar os avisos de informações prévias do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Prévias</a>                
                                                @if (ViewBag.TemFicha == 1)
                                                {
                                                    <a href="@Url.Action("VerFichaPacienteConsulta", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Consultar as fichas digitalizadas do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Fichas</a>                
                                                }
                                                @*<a href="@Url.Action("VerAnotacaoAnamneseBase", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Gerenciar/Visualizar as anotações desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Acompanhamento</a>*@                
                                                <a href="@Url.Action("GerarAnamnesePDFNova", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Imprimir a anamnese/prontuário completa" class="btn btn-sm btn-warning" OnClick = "Fade()">Imprimir</a>                
                                            </div>
                                        </div>
                                        <h5 style="margin-left: -15px; color:brown; background-color: beige; font-weight:bold">São exibidas apenas algumas informações da anamnese/prontuário. Para ver tudo selecione Preencher/Revisar</h5>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Prontuário
                                                    @Html.TextAreaFor(m => m.PAAM_TX_TEXTO_LIVRE, new { @class = "form-control", style = "width: 98%; height: 400px; overflow:auto", @readonly="readonly", id="prontuario"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Motivo da Consulta
                                                    @Html.TextAreaFor(m => m.PAAN_DS_MOTIVO_CONSULTA, new { @class = "form-control", style = "width: 98%; height: 150px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Queixa Principal
                                                    @Html.TextAreaFor(m => m.PAAN_DS_QUEIXA_PRINCIPAL, new { @class = "form-control", style = "width: 98%; height: 150px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    História Familiar
                                                    @Html.TextAreaFor(m => m.PAAN_DS_HISTORIA_FAMILIAR, new { @class = "form-control", style = "width: 98%; height: 150px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    História da Doença Atual
                                                    @Html.TextAreaFor(m => m.PAAN_DS_HISTORIA_DOENCA_ATUAL, new { @class = "form-control", style = "width: 98%; height: 150px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Diagnóstico
                                                    @Html.TextAreaFor(m => m.PAAN_DS_DIAGNOSTICO_1, new { @class = "form-control", style = "width: 98%; height: 200px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Conduta Adotada
                                                    @Html.TextAreaFor(m => m.PAAN_DS_CONDUTA, new { @class = "form-control", style = "width: 98%; height: 200px; overflow:auto", @readonly="readonly"  })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                        <h4 style="margin-left: -15px; color:green; background-color: beige; font-weight:bold">Anamnese/Pontuário Atualizado</h4>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">    
                                                <a href="@Url.Action("EditarAnamneseCompletaFormContinua", "Paciente2")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Preencher/Revisar a anamnese/prontuário do paciente" class="btn btn-sm btn-primary btn-loading" OnClick = "Fade()">Preencher/Revisar</a>                
                                                <a href="@Url.Action("VerAnexoPacienteConsulta", "Paciente2")"  data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Gerenciar/Visualizar os anexos desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Anexos</a>                
                                                <a href="@Url.Action("VerInformacaoPreviaPacienteBase", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Visualizar os avisos de informações prévias do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Prévias</a>                
                                                @if (ViewBag.TemFicha == 1)
                                                {
                                                    <a href="@Url.Action("VerFichaPacienteConsulta", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Consultar as fichas digitalizadas do paciente" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Fichas</a>                
                                                }
                                                @*<a href="@Url.Action("VerAnotacaoAnamneseBase", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Gerenciar/Visualiazar as anotações desta consulta" class="btn btn-sm btn-warning btn-loading" OnClick = "Fade()">Acompanhamento</a>*@                
                                                <a href="@Url.Action("GerarAnamnesePDFNovaContinua", "Paciente2")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Imprimir a anamnese/prontuário completa" class="btn btn-sm btn-warning" OnClick = "Fade()">Imprimir</a>                
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
