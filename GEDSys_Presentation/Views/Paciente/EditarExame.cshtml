@using Presentation.Extensions
@using EntitiesServices.Model
@model ERP_Condominios_Solution.ViewModels.PacienteExameViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Exames";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Exames - Edição de resultado de exame do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, resultado, exame";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal inmodal fade" id="modalConfirmacaoExclusaoAnexo" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content animated bounceInRight">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-trash-o modal-icon text-danger" style="display: block;"></i>
                    <h4 class="modal-title">Confirmação de Exclusão de Anexo</h4>
                    <small class="font-bold">WebDoctorPro - Gestão de Anexos</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3>Deseja realmente excluir este anexo?</h3>
                    <p>Esta ação removerá o arquivo permanentemente do prontuário do paciente.</p>
                    <input type="hidden" id="urlExclusaoTemp" value="" />
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmarExclusaoAnexo">Confirmar Exclusão</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if ((String)Session["ModuloAtual"] == "Dashboard Inicial")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaExames", "Paciente")">Exames</a>
                </li>
                <li class="active">
                    <strong>Exame - Alteração</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Central de Pacientes")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaExames", "Paciente")">Exames</a>
                </li>
                <li class="active">
                    <strong>Exame - Alteração</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Paciente - Edição")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("EditarPaciente", "Paciente")">Paciente - Alteração</a>
                </li>
                <li class="active">
                    <strong>Exame - Alteração</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página de alteração de resultados de exames do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Permite alterar algumas informações de um resultado de exame de um paciente</li>
                        <li>Permite acessar o site do laboratório que produziu o exame </li>
                        <li>Permite incluir anotações de texto ao resultado do exame</li>
                        <li>Permite a visualização dos arquivos anexados ao resultado de exame</li>
                        <li>Permite a incluir ou excluir arquivos anexados ao resultado de exame</li>
                        <li>Impressão do resultado de exame em formato PDF.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Resultados de Exames - Alteração</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-group" style=" margin-left: 5px; margin-right: 5px;"> 
                        @Html.ButtonLinkIndex(text: "Imprimir Resultados", action: "GerarResultadoExamePDFNova", controller: "Paciente")
                        @if ((Int32)Session["VoltarPesquisa"] == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "PesquisarTudo", controller: "BaseAdmin", htmlAttributes: new { @class = "btn-loading" })
                        }
                        else
                        {
                            if (ViewBag.VoltaConsulta == 1)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VerListaExameConsulta", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                            }
                            else
                            {
                                if ((Int32)Session["TipoSolicitacao"] == 1)
                                {
                                    if ((Int32)Session["ModoConsulta"] == 1)
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", action: "VerListaExameConsulta", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                    }
                                    else
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                    }
                                }
                                else
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaExames", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                            }

                        }
                        <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                        <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                            <i class="fa fa-spinner fa-spin"></i> Processando...
                        </span>
                    </div>
                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            @if ((Int32)Session["NivelExame"] == 1)
                            {
                                <li class="active"><a data-toggle="tab" href="#tab-1">Resultado do Exame</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                            @if ((Int32)Session["NivelExame"] == 2)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Resultado do Exame</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                            @if ((Int32)Session["NivelExame"] == 3)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Resultado do Exame</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                            }
                        </ul>

                        <div class="tab-content">
                            @*Dados Gerais*@
                            @if ((Int32)Session["NivelExame"] == 1)
                            {
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        @using (Html.BeginForm("EditarExame", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Nome do Paciente
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Data Nascimento
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                    @if (Model.PACIENTE.PACI_NR_CPF != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            CPF
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                    @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Celular
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                    @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                                    {
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Telefone
                                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="row" style="width: 100%;">
                                                <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">                
                                                    @Html.ButtonActionSubmit(text: "Confirma alteração de Resultado de Exame", htmlAttributes: new { id = "basictoast", @class = "btn-loading1"})
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-xs-12">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Resultado de Exame</h4>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                            @Html.HiddenFor(m => m.USUA_CD_ID)
                                                            @Html.HiddenFor(m => m.PAEX_IN_ATIVO)
                                                            @Html.HiddenFor(m => m.PAEX_CD_ID)
                                                            @Html.HiddenFor(m => m.PACO_CD_ID)
                                                            @Html.HiddenFor(m => m.PACI_CD_ID)
                                                            @Html.HiddenFor(m => m.TIEX_CD_ID)
                                                            @Html.HiddenFor(m => m.LABS_CD_ID)
                                                            Tipo de Exame
                                                            @Html.TextBoxFor(m => m.TIPO_EXAME.TIEX_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                        </div>
                                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                                            Data do Exame
                                                            @Html.TextBoxFor(m => m.PAEX_DT_DATA, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                        @if (Model.PACIENTE_CONSULTA != null)
                                                        {
                                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                                Data de Consulta
                                                                @Html.TextBoxFor(m => m.PACIENTE_CONSULTA.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                            </div>
                                                        }
                                                    </div>
                                                    @if (Model.LABORATORIO != null)
                                                    {
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-9 col-md-9 col-xs-12">
                                                                Laboratório
                                                                @Html.TextBoxFor(m => m.LABORATORIO.LABS_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                            </div>
                                                            <div class="col-lg-3 col-md-3 col-xs-12">
                                                                <br />
                                                                <button style="margin-left: -15px;" class="btn btn-sm btn-primary" id="buttonLab" type="button">Acessar Site do Laboratório</button>
                                                            </div>
                                                        </div>
                                                    }
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                                            Nome do Exame
                                                            @Html.TextBoxFor(m => m.PAEX_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                                            Resultados do Exame*
                                                            @Html.TextAreaFor(m => m.PAEX_DS_COMENTARIOS, new { @class = "form-control", style = "width: 100%; height: 300px; overflow:auto;"})
                                                            @Html.ValidationMessageFor(m => m.PAEX_DS_COMENTARIOS, "", new { @style = "color:red" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-xs-12">
                                                    <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right: -40px">Anexos</h4>
                                                    <br />
                                                    <div class="form-group" style=" margin-left: 15px; margin-right: -35px;">

                                                        @using (Html.BeginForm("UploadFileExamePaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id = "pwd-container2" }))
                                                        {
                                                            var listaAnexos = Model.PACIENTE_EXAME_ANEXO.Where(p => p.PAEO_IN_ATIVO == 1).ToList();

                                                            <div class="text-center" style="margin-top: 15px;">
                                                                <div class="toggle-container" id="viewToggle">
                                                                    <div class="toggle-option active" data-target="sectionList">
                                                                        <i class="fa fa-list"></i> Ver lista
                                                                    </div>
                                                                    <div class="toggle-option" data-target="sectionIcons">
                                                                        <i class="fa fa-th"></i> Ver ícones
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            if (listaAnexos.Count > 0)
                                                            {
                                                                <div id="sectionList" class="view-section active">
                                                                    <table class="table table-striped table-bordered table-hover dataTables-example">
                                                                        <thead style="background-color:lightsteelblue">
                                                                            <tr>
                                                                                <th>Título</th>
                                                                                <th>Data</th>
                                                                                <th>Tipo</th>
                                                                                <th class="td-one-action">Ações</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            @foreach (var cond in listaAnexos)
                                                                            {
                                                                                <tr>
                                                                                    <td style="width: auto">
                                                                                        @if (cond.PAEO_IN_TIPO == 1 || cond.PAEO_IN_TIPO == 2)
                                                                                        {
                                                                                            <a href="@Url.Action("VerAnexoExamePaciente", "Paciente", new { id = cond.PAEO_CD_ID })">@cond.PAEO_NM_TITULO</a>
                                                                                        }
                                                                                        else if (cond.PAEO_IN_TIPO == 4)
                                                                                        {
                                                                                            <a href="@Url.Action("VerAnexoExamePacienteAudio", "Paciente", new { id = cond.PAEO_CD_ID })">@cond.PAEO_NM_TITULO</a>
                                                                                        }
                                                                                        else if (cond.PAEO_IN_TIPO == 3)
                                                                                        {
                                                                                            @*<a href="~/PdfViewer/web/viewer.html?file=@(cond.PAEO_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank">@cond.PAEO_NM_TITULO</a>*@

                                                                                            // Monta a URL direta do Azure
                                                                                            var caminhoPdf = cond.PAEO_AQ_ARQUIVO.Replace("~/", "").Replace("~", "");
                                                                                            var urlAzurePdf = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + caminhoPdf;

                                                                                            <td style="width: auto">
                                                                                                <a href="@urlAzurePdf" target="_blank">@cond.PAEO_NM_TITULO</a>
                                                                                            </td>
                                                                                        }
                                                                                        else { @cond.PAEO_NM_TITULO }
                                                                                    </td>
                                                                                    <td>@cond.PAEO_DT_ANEXO.Value.ToShortDateString()</td>
                                                                                    <td>@(cond.PAEO_IN_TIPO == 1 ? "Imagem" : cond.PAEO_IN_TIPO == 2 ? "Vídeo" : cond.PAEO_IN_TIPO == 3 ? "PDF" : "Outros")</td>
                                                                                    <td class="td-one-action">
                                                                                        <span class="fa fa-trash-o" onclick="PrepararExclusaoAnexo('/Paciente/ExcluirAnexoExame/@cond.PAEO_CD_ID')" style="cursor:pointer; color:#337ab7"></span>
                                                                                        @Html.TableLinkDetails(cond.PAEO_CD_ID, "DownloadPacienteExame", "fa-download", "Download")
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>

                                                                <div id="sectionIcons" class="view-section">
                                                                    <div class="row" style="display: flex; flex-wrap: wrap; justify-content: flex-start; margin-bottom: 20px;">
                                                                        @foreach (var cond in listaAnexos)
                                                                        {
                                                                            <div class="col-lg-2 col-md-2 col-sm-3 col-xs-4 text-center" style="margin-bottom: 25px; min-width: 130px;">
                                                                                <div style="display: flex; flex-direction: column; align-items: center; justify-content: space-between; height: 100%;">
                    
                                                                                    @* Container de Mídia (Altura fixa para alinhamento) *@
                                                                                    <div style="height: 80px; display: flex; align-items: center; justify-content: center; width: 100%;">
                        
                                                                                        @if (cond.PAEO_IN_TIPO == 1) // IMAGEM - Abre na mesma aba
                                                                                        {
                                                                                            <a href="@Url.Action("VerAnexoExamePaciente", "Paciente", new { id = cond.PAEO_CD_ID })" title="Visualizar Imagem">
                                                                                                <img src="@Url.Content(cond.PAEO_AQ_ARQUIVO)" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; border: 1px solid #ddd;" />
                                                                                            </a>
                                                                                        }
                                                                                        else if (cond.PAEO_IN_TIPO == 2) // VÍDEO - Abre na mesma aba (Ícone comum)
                                                                                        {
                                                                                            <a href="@Url.Action("VerAnexoExamePaciente", "Paciente", new { id = cond.PAEO_CD_ID })" title="Visualizar Vídeo">
                                                                                                <i class="fa fa-video-camera fa-4x text-navy"></i>
                                                                                            </a>
                                                                                        }
                                                                                        else if (cond.PAEO_IN_TIPO == 3) // PDF - ÚNICO QUE ABRE EM NOVA ABA
                                                                                        {
                                                                                            // REMOVIDO O "@" ANTES DA CHAVE ABAIXO
                                                                                            {
                                                                                                // 1. Limpa o caminho do banco (remove ~/ e deixa Imagens/...)
                                                                                                var blobPath = cond.PAEO_AQ_ARQUIVO.Replace("~/", "").Replace("~", "");

                                                                                                // 2. Monta a URL direta para o Azure
                                                                                                var urlAzurePdf = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + blobPath;

                                                                                                // O Razor entende que deve voltar para HTML quando encontra a tag <a>
                                                                                                <a href="@urlAzurePdf" target="_blank" title="Visualizar PDF">
                                                                                                    <i class="fa fa-file-pdf-o fa-5x text-danger"></i>
                                                                                                </a>
                                                                                            }
                                                                                        }
                                                                                        else if (cond.PAEO_IN_TIPO == 4) // ÁUDIO - Abre na mesma aba
                                                                                        {
                                                                                            <a href="@Url.Action("VerAnexoExamePacienteAudio", "Paciente", new { id = cond.PAEO_CD_ID })" title="Ouvir Áudio">
                                                                                                <i class="fa fa-volume-up fa-4x text-info"></i>
                                                                                            </a>
                                                                                        }
                                                                                        else // PADRÃO PARA OUTROS
                                                                                        {
                                                                                            <i class="fa fa-file-o fa-4x text-muted"></i>
                                                                                        }
                                                                                    </div>

                                                                                    @* Nome do Arquivo *@
                                                                                    <div style="font-size: 11px; margin-top: 8px; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%;" title="@cond.PAEO_NM_TITULO">
                                                                                        @cond.PAEO_NM_TITULO
                                                                                    </div>

                                                                                    @* Botões de Ação (Excluir e Download) *@
                                                                                    <div style="margin-top: 5px; display: flex; gap: 12px; justify-content: center;">
                                                                                        <span style="cursor:pointer;" onclick="PrepararExclusaoAnexo('/Paciente/ExcluirAnexoExame/@cond.PAEO_CD_ID')" title="Excluir">
                                                                                            <i class="fa fa-trash-o fa-lg text-navy"></i>
                                                                                        </span>
                                                                                        <a href="@Url.Action("DownloadPacienteExame", "Paciente", new { id = cond.PAEO_CD_ID })" title="Download">
                                                                                            <i class="fa fa-download fa-lg text-navy"></i>
                                                                                        </a>
                                                                                    </div>

                                                                                </div>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            </div>                                        
                                        }
                                    </div>
