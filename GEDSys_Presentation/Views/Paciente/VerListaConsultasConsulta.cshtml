                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data da Consulta</th>
                                                    <th style="width: auto">Hora de Início</th>
                                                    <th style="width: auto">Hora de Término</th>
                                                    <th style="width: auto">Nome do Paciente </th>
                                                    <th style="width: auto">Tipo de Consulta</th>
                                                    <th class="td-one-action">Ações</th>
                                                    <th style="width: 0.01px"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_CONSULTA>).OrderByDescending(p => p.PACO_DT_CONSULTA.Date))
                                                {   
                                                    if (cond.PACO_DT_CONSULTA > DateTime.Today.Date)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                                {
                                                                    if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date)
                                                                    {
                                                                        <a href="@Url.Action("EditarConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" />@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                    }
                                                                    else
                                                                    {
                                                                        <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" />@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <a href="@Url.Action("VerConsultaCompleta", "Paciente", new { id = cond.PACO_CD_ID })" />@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                }
                                                            </td>
                                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                            <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                            @if (cond.PACO_IN_TIPO == 1)
                                                            {
                                                                <td style="width: auto"><span class="badge badge-primary">Presencial</span></td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto"><span class="badge badge-success">Remota</span></td>
                                                            }
                                                            <td style="width: auto" class="td-one-action">
                                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                                {
                                                                    if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date)
                                                                    {
                                                                        @Html.TableLinkDetails(cond.PACO_CD_ID, "EditarConsultaCompleta", "fa-edit", "Editar")
                                                                    }
                                                                    else
                                                                    {
                                                                        @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search", "Ver")
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    @Html.TableLinkDetails(cond.PACO_CD_ID, "VerConsultaCompleta", "fa-search", "Ver")
