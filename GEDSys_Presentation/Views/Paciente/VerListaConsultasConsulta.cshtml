                                                                        {
                                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-history", "Rever Consulta")
                                                                        }
                                                                    }
                                                                }
                                                            </td>
                                                            <td style="width: 0.05px"></td>
                                                        </tr>
                                                    }
                                                    else if (cond.PACO_DT_CONSULTA < DateTime.Today.Date)
                                                    {
                                                        <tr style="background-color: beige">
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
