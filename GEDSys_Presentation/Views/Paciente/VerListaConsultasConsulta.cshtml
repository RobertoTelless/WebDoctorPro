                                                                {
                                                                    if (cond.PACO_IN_ATIVO == 1)
                                                                    {
                                                                        if (cond.PACO_DT_CONSULTA.Date > DateTime.Today.Date)
                                                                        {
                                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o" onclick="ShowModalExcluirConsulta('/Paciente/ExcluirConsulta/@cond.PACO_CD_ID')" title="Excluir"></span>
                                                                        }
                                                                    }
	                                                            }
                                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                                {
                                                                    if (cond.PACO_IN_ATIVO == 1)
                                                                    {
                                                                        if (cond.PACO_DT_CONSULTA.Date == DateTime.Today.Date)
                                                                        {
                                                                            @Html.TableLinkDetails(cond.PACO_CD_ID, "ProcederConsulta", "fa-clock-o", "Proceder Consulta")
                                                                        }
