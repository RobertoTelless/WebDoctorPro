@using Presentation.Extensions
@using EntitiesServices.Model
@using Humanizer; 
@model ERP_Condominios_Solution.ViewModels.PacienteViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Edição";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Edição de pacientes";
    ViewBag.MetaKeywords = "WebDoctor, paciente";
}

<style>
    /* Estilos baseados na imagem */
    .question-group {
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
        background-color: #f7fafc; /* Cor de fundo suave */
    }
    .question-title {
        color: #008000; /* Verde */
        font-weight: bold;
        font-size: 1.5em;
        margin-bottom: 5px;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 5px;
    }
    .question-description {
        margin-bottom: 15px;
        color: #333;
    }
    .select-control {
        width: 100px; /* Largura padrão para o DDL */
    }
    .response-area {
        float: right;
        margin-top: -5px; /* Ajuste fino do alinhamento */
    }
</style>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal fade" id="modalCancelar" tabindex="-1" role="dialog" aria-labelledby="modalCancelarLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalCancelarLabel">Justificar Cancelamento</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="textoJustificativa">Justificativa do Cancelamento:</label>
                        <textarea class="form-control" id="textoJustificativa" rows="5" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmarCancelamento">Confirmar Cancelamento</button>
                </div>
            </div>
        </div>
    </div>    
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
            </li>
            <li class="active">
                <strong>Pacientes - Alteração</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div class="row">
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Ficha do Paciente - Alteração</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACI_NM_NOME.ToUpper()</span>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    } 
                   
                    <div class="form-group">
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                        {
                            if (ViewBag.EMail == 1)
                            {
                                if (Model.PACI_NM_EMAIL != null)
                                {
                                    @Html.ButtonLinkIndex(text: "Enviar E-Mail", action: "EnviarEMailPacienteForm", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                            }
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                        {
                            if (ViewBag.SMS == 1)
                            {
                                if (Model.PACI_NR_CELULAR != null)
                                {
                                    @Html.ButtonLinkIndex(text: "Enviar SMS", action: "EnviarSMSPacienteForm", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                            }
                        }
                        @Html.ButtonLinkIndex(text: "Vídeos", action: "MontarTelaVideo", controller: "Video",  htmlAttributes: new { @class = "btn-loading" })
                        @Html.ButtonLinkIndex(text: "Histórico de Atividades", action: "MontarTelaPacienteHistorico", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                        @Html.ButtonLinkIndex(text: "Resumo do Paciente", action: "GerarRelatorioDetalheGeral", controller: "Paciente2")
                        @if ((Int32)Session["VoltarPesquisa"] == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "PesquisarTudo", controller: "BaseAdmin",  htmlAttributes: new { @class = "btn-loading" })
                        }
                        else
                        {
                            if ((Int32)Session["VoltarProceder"] == 1)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarProcederConsulta", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                            }
                            else
                            {
                                if ((Int32)Session["TipoSolicitacao"] == 2)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaSolicitacoes", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 3)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAtestados", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 4)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaExames", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 5)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPrescricoes", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 8)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VerMedicamentosPacienteForm", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 9)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaEncerrarConsulta", controller: "Financeiro",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 12)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaHistoricoGeral", controller: "Paciente",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 99)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAusencias", controller: "Paciente2",  htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if ((Int32)Session["TipoSolicitacao"] == 98)
