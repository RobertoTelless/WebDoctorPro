                            @*Consultas*@
                            @if ((Int32)Session["NivelPaciente"] == 3)
                            {
                                <div id="tab-4" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Consultas</h4>
                                                    <br />
                                                    @if (Model.PACIENTE_CONSULTA.Where(p => p.PACO_IN_ATIVO == 1).ToList().Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-consulta">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th style="width: auto">Data da Consulta</th>
                                                                    <th style="width: auto">Hora de Início</th>
                                                                    <th style="width: auto">Hora de Término </th>
                                                                    <th style="width: auto">Tipo de Consulta</th>
                                                                    <th style="width: auto">Situação</th>
                                                                    <th style="width: auto">Profissional</th>
                                                                    <th class="td-one-action">Ações</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.PACIENTE_CONSULTA.Where(p => p.PACO_IN_ATIVO == 1).OrderByDescending(p => p.PACO_DT_CONSULTA)))
                                                                {
                                                                    if (cond.PACO_DT_CONSULTA > DateTime.Today.Date)
                                                                    {
                                                                        <tr>
                                                                            <td>
                                                                                <span style="display:none; width: auto">@cond.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                                                {
                                                                                    if (cond.PACO_DT_CONSULTA.Date >= DateTime.Today.Date & cond.PACO_IN_CONFIRMADA < 2)
                                                                                    {
                                                                                        <a href="@Url.Action("EditarConsultaCompletaEdt", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading2" />@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <a href="@Url.Action("VerConsultaCompletaEdt", "Paciente", new { id = cond.PACO_CD_ID })"  class="btn-loading2" />@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                                    }
                                                                                }
                                                                                else
                                                                                {
                                                                                    <a href="@Url.Action("VerConsultaCompletaEdt", "Paciente", new { id = cond.PACO_CD_ID })" class="btn-loading2"/>@cond.PACO_DT_CONSULTA.ToShortDateString()
                                                                                }
                                                                            </td>
                                                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                                            @if (cond.VALOR_CONSULTA != null)
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-primary">@cond.VALOR_CONSULTA.VACO_NM_NOME</span></td>
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-primary">-</span></td>
