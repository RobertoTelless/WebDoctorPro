@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacientePrescricaoItemViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Prescrição - Item";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Prescrição - Item - Inclusão de item em uma prescrição do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, prescricao, item";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarAnexoPaciente", "Paciente")">Pacientes - Alteração</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarEditarPrescricao", "Paciente")">Prescrição - Alteração</a>
            </li>
            <li class="active">
                <strong>Inclusão de Itens</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Prescrição - Inclusão de Itens</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME</span>
                    </div>
                </div>
                @using (Html.BeginForm("IncluirPrescricaoItem", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div> 

                        @*Identificação*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação da Prescrição Médica</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Identificador
                                    @Html.TextBoxFor(m => m.PACIENTE_PRESCRICAO.PAPR_GU_GUID, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PAPR_CD_ID)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PAPI_IN_ATIVO)
                                    Data de Emissão
                                    @Html.TextBoxFor(m => m.PACIENTE_PRESCRICAO.PAPR_DT_EMISSAO_COMPLETA, new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Controle
                                    @Html.TextBoxFor(m => m.PACIENTE_PRESCRICAO.TIPO_CONTROLE.TICO_NM_NOME, new { @class = "form-control", @readonly = "readonly"  })
                                </div>
                                <div class="col-lg-5 col-md-5 col-xs-12">
                                    <br />
                                    <a href="@Url.Action("VoltarEditarPrescricaoItem", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Confirma todas as inclusões de itens na prescrição" class="btn btn-sm btn-success  btn-loading" id="emp" OnClick = "Fade()">Encerrar Inclusão de Itens da Prescrição</a>                
                                    <a href="@Url.Action("IncluirMedicamento", "Medicamento")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessa a página de inclusão de medicamentos no cadastro" class="btn btn-sm btn-primary btn-loading" id="emp" OnClick = "Fade()">Incluir Novo Medicamento no Cadastro</a>                
                                    <a href="@Url.Action("VoltarAnexoPrescricao", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Voltando sem Encerrar, as alreações/inclusões da prescrição NÃO serão gravadas" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Voltar</a>                
                                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                        <i class="fa fa-spinner fa-spin"></i> Processando...
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-lg-4 col-md-4 col-xs-12"  style="margin-left: 10px">
                                @*Novo Item*@
                                <div class="row">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Novo Item da Prescrição</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-12 col-md-12 col-xs-12"> 
                                            Selecione o medicamento ou preencha as informações abaixo
                                            @Html.DropDownListFor(m => m.MEDI_CD_ID, (SelectList)ViewBag.Medicamentos, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione um medicamento já cadastrado na lista de medicamentos pré-definidos. Todas as informações do medicamento serão retornadas, podendo ser alteradas, ou preencha manualmente as informações abaixo", data_trigger="hover", data_placement="top", @id = "med", onchange = "GetMedicamento($(this).val())"   })
                                            @Html.ValidationMessageFor(m => m.MEDI_CD_ID, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                            Forma de Uso*
                                            @Html.DropDownListFor(m => m.TIFO_CD_ID, (SelectList)ViewBag.TipoForma, "Selecionar", new { @class = "form-control", autofocus = true, @id = "forma"  })
                                            @Html.ValidationMessageFor(m => m.TIFO_CD_ID, "", new { @style = "color:red" })
                                        </div>
                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                            Quantidade
                                            @Html.TextBoxFor(m => m.PAPI_NR_QUANTIDADE, new { @class = "form-control", autofocus = true  })
                                            @Html.ValidationMessageFor(m => m.PAPI_NR_QUANTIDADE, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Medicamento*
                                            @Html.TextBoxFor(m => m.PAPI_NM_REMEDIO, new { @class = "form-control", autofocus = true, @id = "nome", data_toggle = "popover", data_content = "O medicamento será incluído automaticamente no cadastro de medicamentos prescritos, caso não ainda esteja cadastrado", data_trigger="hover", data_placement="top"  })
                                            @Html.ValidationMessageFor(m => m.PAPI_NM_REMEDIO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Nome Genérico
                                            @Html.TextBoxFor(m => m.PAPI_NM_GENERICO, new { @class = "form-control", autofocus = true, @id = "gene"   })
                                            @Html.ValidationMessageFor(m => m.PAPI_NM_GENERICO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Forma de Apresentação
                                            @Html.TextAreaFor(m => m.PAPI_NM_APRESENTACAO, new { @class = "form-control", style = "width: 100%; height: 50px; overflow:auto;", autofocus = true, @id = "apr" })
                                            @Html.ValidationMessageFor(m => m.PAPI_NM_APRESENTACAO, "", new { @style = "color:red" })
                                        </div>
                                    </div>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            Posologia*
                                            @Html.TextAreaFor(m => m.PAPI_DS_POSOLOGIA, new { @class = "form-control", style = "width: 100%; height: 50px; overflow:auto;", autofocus = true, @id = "poso" })
                                            @Html.ValidationMessageFor(m => m.PAPI_DS_POSOLOGIA, "",new { @style="color:red" })
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    @Html.ButtonActionSubmit(text: "Confirma a inclusão deste item e prossegue com inclusões", htmlAttributes: new { id = "basictoast", @class = "btn-loading1" })
                                </div>
                            </div>

                            <div class="col-lg-7 col-md-8 col-xs-12" style="margin-left: 10px">
                                <div class="row">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Itens já Incluídos</h4>
                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                            @if (ViewBag.Itens != null &&(ViewBag.Itens as List<EntitiesServices.Model.PACIENTE_PRESCRICAO_ITEM>).Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover dataTables-example1">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th style="width: auto">Forma de Uso</th>
                                                            <th style="width: auto">Medicamento</th>
                                                            <th style="width: auto">Nome Genérico</th>
                                                            <th style="width: auto">Posologia</th>
                                                            <th style="width: auto" class="td-one-action">Ações</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (ViewBag.Itens as List<EntitiesServices.Model.PACIENTE_PRESCRICAO_ITEM>).OrderBy(p => p.PAPI_NM_REMEDIO))
                                                        {
                                                            <tr>
                                                                <td style="width: auto">@cond.TIPO_FORMA.TIFO_NM_NOME</td>
                                                                <td style="width: auto">@cond.PAPI_NM_REMEDIO</td>
                                                                <td style="width: auto">@cond.PAPI_NM_GENERICO</td>
                                                                <td style="width: auto">@cond.PAPI_DS_POSOLOGIA</td>
                                                                <td class="td-one-action">
                                                                    @Html.TableLinkDetails(cond.PAPI_CD_ID, "EditarItemPrescricao", "fa-edit", "Editar")
                                                                    @if (cond.PAPI_IN_ATIVO == 1)
                                                                    {
                                                                        <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluirItemPrescricao('/Paciente/ExcluirItemPrescricao/@cond.PAPI_CD_ID')" title="Excluir"></span>
	                                                                }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="row">
                                                    <div class="col-lg-2 col-md-2 col-xs-2">

                                                    </div>
                                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                                        <h2 style="font-weight: bold">Nenhum item incluído nessa prescrição</h2>
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-2">

                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    
    <script src="~/Scripts/uploadAnexo.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirItemPrescricao(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Item?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }

    </script>
    <script>
        function GetMedicamento(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente/GetMedicamento'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nome').val(r.nome);
                    $('#gene').val(r.generico);
                    $('#apr').val(r.apresentacao);
                    $('#poso').val(r.posologia);
                    $('#forma').val(r.forma);

                    $('#nome').show();
                    $('#gene').show();
                    $('#apr').show();
                    $('#poso').show();
                    $('#forma').show();
                }
            });
        }
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Inclusão em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;  
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
