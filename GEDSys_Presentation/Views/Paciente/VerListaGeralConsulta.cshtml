@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteConsultaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Consulta";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Consultas - Lista de consultas";
    ViewBag.MetaKeywords = "WebDoctor, paciente, consulta";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("ProcederConsulta", "Paciente")">Consulta</a>
            </li>
            <li class="active">
                <strong>Documentos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Paciente - Todos os Documentos</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("VerListaGeralConsulta", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta", htmlAttributes: new { @class = "btn-loading" })
                                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                        <i class="fa fa-spinner fa-spin"></i> Processando...
                                    </span>
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>
                        @*<br />*@
                        @*<div class="row">
                            <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Dados da Consulta</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Consulta
                                    @Html.TextBoxFor(m => m.TipoConsulta, new { @class = "form-control", @readonly = "readonly"})
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_IN_ATIVO)
                                    @Html.HiddenFor(m => m.PACO_IN_ENCERRADA)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_CD_ID)
                                    Data da Consulta
                                    @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Início
                                    @Html.TextBoxFor(m => m.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Final
                                    @Html.TextBoxFor(m => m.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                                </div>
                            </div>
                        </div>*@
                        @*<br />*@

                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Atestados</h4>
                                    @*<br />*@
                                    @if (ViewBag.Atestados != null &&(ViewBag.Atestados as List<EntitiesServices.Model.PACIENTE_ATESTADO>).Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-atestado">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data da Emissão</th>
                                                    <th style="width: auto">Identificador</th>
                                                    <th style="width: auto">Tipo de Atestado</th>
                                                    <th style="width: auto">Finalidade</th>
                                                    <th style="width: auto">Data da Consulta</th>
                                                    <th style="width: auto">Enviado</th>
                                                    <th style="width: auto">Data de Envio</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Atestados as List<EntitiesServices.Model.PACIENTE_ATESTADO>).OrderByDescending(p => p.PAAT_DT_DATA.Value.Date))
                                                {
                                                    <tr>
                                                        <td>
                                                            <span style="display:none; width: auto">@cond.PAAT_DT_DATA.Value.ToString("yyyyMMdd")</span>
                                                            @cond.PAAT_DT_DATA.Value.ToShortDateString()
                                                        </td>
                                                        <td style="width: auto">@cond.PAAT_GU_GUID</td>
                                                        <td style="width: auto">@cond.TIPO_ATESTADO.TIAT_NM_NOME</td>
                                                        <td style="width: auto">@cond.PAAT_NM_TITULO</td>
                                                        @if (cond.PACIENTE_CONSULTA != null)
                                                        {
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToShortDateString()
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                        @if (cond.PAAT__IN_ENVIADO == 1)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                        }
                                                        @if (cond.PAAT_DT_ENVIO != null)
                                                        {
                                                            <td style="width: auto">@cond.PAAT_DT_ENVIO.Value.ToShortDateString()</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum atestado emitido para esse paciente</h2>
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Solicitações de Exames</h4>
                                    @*<br />*@
                                    @if (ViewBag.Solicitacoes != null &&(ViewBag.Solicitacoes as List<EntitiesServices.Model.PACIENTE_SOLICITACAO>).Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-atestado">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data da Emissão</th>
                                                    <th style="width: auto">Identificador</th>
                                                    <th style="width: auto">Tipo de Exame</th>
                                                    <th style="width: auto">Nome do Exame</th>
                                                    <th style="width: auto">Data da Consulta</th>
                                                    <th style="width: auto">Enviado</th>
                                                    <th style="width: auto">Último Envio</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Solicitacoes as List<EntitiesServices.Model.PACIENTE_SOLICITACAO>).OrderByDescending(p => p.PASO_DT_EMISSAO_COMPLETA.Value.Date))
                                                {
                                                    <tr>
                                                        <td>
                                                            <span style="display:none; width: auto">@cond.PASO_DT_EMISSAO.Value.ToString("yyyyMMdd")</span>
                                                            @cond.PASO_DT_EMISSAO.Value.ToShortDateString() @cond.PASO_DT_EMISSAO.Value.ToShortTimeString()
                                                        </td>
                                                        <td style="width: auto">@cond.PASO_GU_GUID</td>
                                                        <td style="width: auto">@cond.TIPO_EXAME.TIEX_NM_NOME</td>
                                                        <td style="width: auto">@cond.PASO_NM_TITULO</td>
                                                        @if (cond.PACIENTE_CONSULTA != null)
                                                        {
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToShortDateString()
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                        @if (cond.PASO_IN_ENVIADO == 1)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                        }
                                                        @if (cond.PASO_DT_ENVIO != null)
                                                        {
                                                            <td style="width: auto">@cond.PASO_DT_ENVIO.Value.ToShortDateString()</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhuma Solicitacao de Exame emitida para esse paciente</h2>
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                   
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Resultados de Exames</h4>
                                    <br />
                                    @if (ViewBag.Exames != null &&(ViewBag.Exames as List<EntitiesServices.Model.PACIENTE_EXAMES>).Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-exame">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data do Exame</th>
                                                    <th style="width: auto">Tipo de Exame</th>
                                                    <th style="width: auto">Nome do Exame</th>
                                                    <th style="width: auto">Laboratório</th>
                                                    <th style="width: auto">Data da Consulta</th>
                                                    <th style="width: auto">Anexos</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Exames as List<EntitiesServices.Model.PACIENTE_EXAMES>).OrderByDescending(p => p.PAEX_DT_DATA.Value.Date))
                                                {
                                                    <tr>
                                                        <td>
                                                            <span style="display:none; width: auto">@cond.PAEX_DT_DATA.Value.ToString("yyyyMMdd")</span>
                                                            @cond.PAEX_DT_DATA.Value.ToShortDateString()
                                                        </td>
                                                        <td style="width: auto">@cond.TIPO_EXAME.TIEX_NM_NOME</td>                                                      
                                                        <td style="width: auto">@cond.PAEX_NM_NOME</td>                                                      
                                                        @if (cond.LABS_CD_ID != null)
                                                        {
                                                            <td style="width: auto"><a href="@Url.Action("AcessarLaboratorio", "Paciente", new { id = cond.LABS_CD_ID })" target="_blank" />@cond.LABORATORIO.LABS_NM_NOME</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">Não informado</td>
                                                        }
                                                        @if (cond.PACIENTE_CONSULTA != null)
                                                        {
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToShortDateString()
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                        @if (cond.PACIENTE_EXAME_ANEXO.Count > 0)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">@cond.PACIENTE_EXAME_ANEXO.Count</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">0</span></td>

                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum resultado de exame cadastrado para esse paciente</h2>
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Prescrições</h4>
                            @if (ViewBag.Prescricoes != null &&(ViewBag.Prescricoes as List<EntitiesServices.Model.PACIENTE_PRESCRICAO>).Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Data da Emissão</th>
                                            <th style="width: auto">Tipo de Controle</th>
                                            <th style="width: auto">Nome do Paciente</th>
                                            <th style="width: auto">Identificador</th>
                                            <th style="width: auto">Data da Consulta</th>
                                            <th style="width: auto">Enviada</th>
                                            <th style="width: auto">Último Envio</th>
                                            <th style="width: auto">Num. Envios</th>
                                            <th style="width: auto">Num. Itens</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (ViewBag.Prescricoes as List<EntitiesServices.Model.PACIENTE_PRESCRICAO>).OrderByDescending(p => p.PAPR_DT_EMISSAO.Value.Date))
                                        {
                                            <tr>
                                                <td>
                                                    <span style="display:none; width: auto">@cond.PAPR_DT_EMISSAO.Value.ToString("yyyyMMdd")</span>
                                                    @cond.PAPR_DT_EMISSAO.Value.ToShortDateString() @cond.PAPR_DT_EMISSAO.Value.ToShortTimeString()
                                                </td>
                                                @if (cond.TICO_CD_ID == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">@cond.TIPO_CONTROLE.TICO_NM_NOME</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">@cond.TIPO_CONTROLE.TICO_NM_NOME</td>
                                                }
                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                <td style="width: auto">@cond.PAPR_GU_GUID</td>
                                                @if (cond.PACIENTE_CONSULTA != null)
                                                {
                                                    <td>
                                                        <span style="display:none; width: auto">@cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                        @cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToShortDateString()
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }
                                                @if (cond.PAPR_IN_ENVIADO == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                @if (cond.PAPR_DT_ENVIO != null)
                                                {
                                                    <td style="width: auto">@cond.PAPR_DT_ENVIO.Value.ToShortDateString()</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }
                                                <td style="width: auto">@cond.PAPR_NR_ENVIOS</td>
                                                <td style="width: auto">@cond.PACIENTE_PRESCRICAO_ITEM.Count()</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-3 col-md-3 col-xs-2">
                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                        <h2 style="font-weight: bold">Nenhuma prescrição emitida para este paciente</h2>
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-2">
                                    </div>
                                </div>
                            }
                        </div>                  
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-atestado').DataTable({
                pageLength: 10,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
                columnDefs: [
                    {
                        // Altera o tipo de ordenação para a primeira coluna (índice 0)
                        //"type": "datetime-moment", // Se você incluiu o momento.js
                        // OU
                         "type": "date-eu", // Para o formato DD/MM/AAAA
                        "targets": 0 // Aplica à coluna "Data da Transação"
                    }
                ],
                // ---------------------------------       
                buttons: [
                    { extend: 'excel', title: 'Atestado_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Edição em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
