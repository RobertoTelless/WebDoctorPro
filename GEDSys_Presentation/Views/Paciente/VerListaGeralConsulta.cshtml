@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteConsultaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Consulta";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Consultas - Lista de consultas";
    ViewBag.MetaKeywords = "WebDoctor, paciente, consulta";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("ProcederConsulta", "Paciente")">Consulta</a>
            </li>
            <li class="active">
                <strong>Documentos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Paciente - Todos os Documentos</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("VerListaGeralConsulta", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta")
                                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>
                        @*<br />*@
                        <div class="row">
                            <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Dados da Consulta</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Consulta
                                    @Html.TextBoxFor(m => m.TipoConsulta, new { @class = "form-control", @readonly = "readonly"})
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_IN_ATIVO)
                                    @Html.HiddenFor(m => m.PACO_IN_ENCERRADA)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_CD_ID)
                                    Data da Consulta
                                    @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Início
                                    @Html.TextBoxFor(m => m.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Final
                                    @Html.TextBoxFor(m => m.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                                </div>
                            </div>
                        </div>
                        @*<br />*@

                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Atestados da Consulta</h4>
                                    @*<br />*@
                                    @if (Model.PACIENTE_ATESTADO.Where(p => p.PAAT_IN_ATIVO == 1).ToList().Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-atestado">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Identificador</th>
                                                    <th style="width: auto">Data da Emissão</th>
                                                    <th style="width: auto">Tipo de Atestado</th>
                                                    <th style="width: auto">Finalidade</th>
                                                    <th style="width: auto">Enviado</th>
                                                    <th style="width: auto">Data de Envio</th>
                                                    <th style="width: 0.01px"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (Model.PACIENTE_ATESTADO.Where(p => p.PAAT_IN_ATIVO == 1).OrderByDescending(p => p.PAAT_DT_DATA)))
                                                {
                                                    <tr>
                                                        <td style="width: auto">@cond.PAAT_GU_GUID</td>
                                                        <td style="width: auto">@cond.PAAT_DT_DATA.Value.ToShortDateString()</td>
                                                        <td style="width: auto">@cond.TIPO_ATESTADO.TIAT_NM_NOME</td>
                                                        <td style="width: auto">@cond.PAAT_NM_TITULO</td>
                                                        @if (cond.PAAT__IN_ENVIADO == 1)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                        }
                                                        @if (cond.PAAT_DT_ENVIO != null)
                                                        {
                                                            <td style="width: auto">@cond.PAAT_DT_ENVIO.Value.ToShortDateString()</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum atestado cadastrado para esse paciente nessa consulta</h2>
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Solicitações de Exames da Consulta</h4>
                                    @*<br />*@
                                    @if (Model.PACIENTE_SOLICITACAO.Where(p => p.PASO_IN_ATIVO == 1).ToList().Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-atestado">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Identificador</th>
                                                    <th style="width: auto">Data da Emissão</th>
                                                    <th style="width: auto">Tipo de Exame</th>
                                                    <th style="width: auto">Nome do Exame</th>
                                                    <th style="width: auto">Enviado</th>
                                                    <th style="width: auto">Último Envio</th>
                                                    <th style="width: 0.01px"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (Model.PACIENTE_SOLICITACAO.Where(p => p.PASO_IN_ATIVO == 1).OrderByDescending(p => p.PASO_DT_EMISSAO)))
                                                {
                                                    <tr>
                                                        <td style="width: auto">@cond.PASO_GU_GUID</td>
                                                        <td style="width: auto">@cond.PASO_DT_EMISSAO.Value.ToShortDateString() @cond.PASO_DT_EMISSAO.Value.ToShortTimeString()</td>
                                                        <td style="width: auto">@cond.TIPO_EXAME.TIEX_NM_NOME</td>
                                                        <td style="width: auto">@cond.PASO_NM_TITULO</td>
                                                        @if (cond.PASO_IN_ENVIADO == 1)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                        }
                                                        @if (cond.PASO_DT_ENVIO != null)
                                                        {
                                                            <td style="width: auto">@cond.PASO_DT_ENVIO.Value.ToShortDateString()</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhuma Solicitacao de Exame cadastrada para esse paciente nessa consulta</h2>
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                   
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Resultados de Exames da Consulta</h4>
                                    <br />
                                    @if (Model.PACIENTE_EXAMES.Where(p => p.PAEX_IN_ATIVO == 1).ToList().Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-exame">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data do Exame</th>
                                                    <th style="width: auto">Tipo de Exame</th>
                                                    <th style="width: auto">Nome do Exame</th>
                                                    <th style="width: auto">Laboratório</th>
                                                    <th style="width: auto">Anexos</th>
                                                    <th style="width: 0.01px"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (Model.PACIENTE_EXAMES.Where(p => p.PAEX_IN_ATIVO == 1).OrderByDescending(p => p.PAEX_DT_DATA)))
                                                {
                                                    <tr>
                                                        <td style="width: auto">@cond.PAEX_DT_DATA.Value.ToShortDateString()</td>                                                                       
                                                        <td style="width: auto">@cond.TIPO_EXAME.TIEX_NM_NOME</td>                                                      
                                                        <td style="width: auto">@cond.PAEX_NM_NOME</td>                                                      
                                                        @if (cond.LABS_CD_ID != null)
                                                        {
                                                            <td style="width: auto"><a href="@Url.Action("AcessarLaboratorio", "Paciente", new { id = cond.LABS_CD_ID })" target="_blank" />@cond.LABORATORIO.LABS_NM_NOME</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">Não informado</td>
                                                        }
                                                        @if (cond.PACIENTE_EXAME_ANEXO.Count > 0)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">@cond.PACIENTE_EXAME_ANEXO.Count</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">0</span></td>

                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum resultado de exame cadastrado para esse paciente nessa consulta</h2>
                                            </div>
                                            <div class="col-lg-2 col-md-2 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Prescrições da Consulta</h4>
                            @if (Model.PACIENTE_PRESCRICAO.Where(p => p.PAPR_IN_ATIVO == 1).ToList().Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Data da Emissão</th>
                                            <th style="width: auto">Tipo de Controle</th>
                                            <th style="width: auto">Nome do Paciente</th>
                                            <th style="width: auto">Identificador</th>
                                            <th style="width: auto">Enviada</th>
                                            <th style="width: auto">Último Envio</th>
                                            <th style="width: auto">Num. Envios</th>
                                            <th style="width: auto">Num. Itens</th>
                                            <th style="width: 0.01px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (Model.PACIENTE_PRESCRICAO.Where(p => p.PAPR_IN_ATIVO == 1).OrderByDescending(p => p.PAPR_DT_EMISSAO_COMPLETA)))
                                        {
                                            <tr>
                                                <td style="width: auto">@cond.PAPR_DT_EMISSAO.Value.Date.ToShortDateString() @cond.PAPR_DT_EMISSAO.Value.ToShortTimeString()</td>
                                                @if (cond.TICO_CD_ID == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">@cond.TIPO_CONTROLE.TICO_NM_NOME</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">@cond.TIPO_CONTROLE.TICO_NM_NOME</td>
                                                }
                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                <td style="width: auto">@cond.PAPR_GU_GUID</td>
                                                @if (cond.PAPR_IN_ENVIADO == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                @if (cond.PAPR_DT_ENVIO != null)
                                                {
                                                    <td style="width: auto">@cond.PAPR_DT_ENVIO.Value.ToShortDateString()</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }
                                                <td style="width: auto">@cond.PAPR_NR_ENVIOS</td>
                                                <td style="width: auto">@cond.PACIENTE_PRESCRICAO_ITEM.Count()</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-3 col-md-3 col-xs-2">
                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                        <h2 style="font-weight: bold">Nenhuma prescrição cadastrada para essa consulta</h2>
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-2">
                                    </div>
                                </div>
                            }
                        </div>                  
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    <link href="~/Content/jquery.datetimepicker.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Styles.Render("~/Content/plugins/iCheck/iCheckStyles")
    @Styles.Render("~/plugins/touchSpinStyles")
    @Styles.Render("~/plugins/sweetAlertStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    <script src="~/Scripts/jquery.datetimepicker.full.min.js"></script>
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.datetimepicker"></script>

    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    @Scripts.Render("~/plugins/sparkline")
    @Scripts.Render("~/plugins/switchery")
    @Scripts.Render("~/plugins/touchSpin")
    @Scripts.Render("~/plugins/iCheck")
    @Scripts.Render("~/plugins/sweetAlert")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script> 
   
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirAtestado(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Atestado?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }

        function ShowModalConfirmarEnvioAtestado(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary" href="' + url + '" target="_self" title="Reativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma envio da Atestado?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Envio</h5>');
            $('#modal').modal('show');
        }
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $('.time-picker').datetimepicker({
                datepicker: false,
                format: 'H:i'
            });
            $('.time-picker1').datetimepicker({
                datepicker: false,
                format: 'H:i'
            });
        });
    </script>
    <script type="text/javascript">
