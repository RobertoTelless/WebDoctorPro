@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteExameViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Exames";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Exames - Inclusão de resultado de exame do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, resultado, exame";
}

<div class="wrapper wrapper-content animated fadeInRight">
    @if ((String)Session["ModuloAtual"] == "Dashboard Inicial")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaExames", "Paciente")">Exames</a>
                </li>
                <li class="active">
                    <strong>Exame - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Central de Pacientes")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaExames", "Paciente")">Exames</a>
                </li>
                <li class="active">
                    <strong>Exame - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Paciente - Edição")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("EditarPaciente", "Paciente")">Paciente - Alteração</a>
                </li>
                <li class="active">
                    <strong>Exame - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página de inclusão de resultados de exames do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Incluir um novo resultado de exame para um paciente cadastrado</li>
                        <li>Poderá selecionar o laboratório que produziu esse ezame</li>
                        <li>Poderá incluir anexos (laudos ou imagens)</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Resultado de Exame - Inclusão</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("IncluirExame", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        @if ((Int32)Session["TipoSolicitacao"] == 1)
                        {
                            <div class="row">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Nome do Paciente
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data de Nascimento
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    @if (Model.PACIENTE.PACI_NR_CPF != null)
                                    {
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            CPF
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                    }
                                    @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                    {
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Celular
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                    }
                                    @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                    {
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            Telefone
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Nome do Paciente*
                                        @Html.DropDownListFor(m => m.PACI_CD_ID, (SelectList)ViewBag.Paciente, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Selecione um paciente ou digite as primeiras letras do nome para acelerar a busca", data_trigger="hover", data_placement="top", autofocus = true, onchange = "GetPaciente($(this).val())" })
                                        @Html.ValidationMessageFor(m => m.PACI_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                    <div style="display: none;" id="dataNasc" class="col-lg-2 col-md-2 col-xs-12">
                                        Data de Nascimento
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="cpf" class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="cel" class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="tel" class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-lg-8 col-md-8 col-xs-12">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Resultado de Exame</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    @Html.ButtonActionSubmit(text: "BtnSubmit", htmlAttributes: new { id = "submit", style = "display: none;" })
                                    <button style="margin-left: 15px;" class="btnSubmit btn btn-sm btn-success btn-loading1" id="basictoast" type="button">Confirmar inclusão de Resultado de Exame</button>
                                    @if ((Int32)Session["TipoSolicitacao"] == 1)
                                    {
                                        if ((Int32)Session["ModoConsulta"] == 1)
                                        {
                                            @Html.ButtonLinkIndex(text: "Voltar", action: "VerListaExameConsulta", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                        }
                                        else
                                        {
                                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                        }
                                    }
                                    else
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaExames", controller: "Paciente", htmlAttributes: new { @class = "btn-loading" })
                                    }
                                    <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                        <i class="fa fa-spinner fa-spin"></i> Processando...
                                    </span>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        @Html.HiddenFor(m => m.ASSI_CD_ID)
                                        @Html.HiddenFor(m => m.USUA_CD_ID)
                                        @Html.HiddenFor(m => m.PAEX_IN_ATIVO)
                                        @Html.HiddenFor(m => m.PACO_CD_ID)
                                        @Html.HiddenFor(m => m.PACI_CD_ID)
                                        Tipo de Exame*
                                        @Html.DropDownListFor(m => m.TIEX_CD_ID, (SelectList)ViewBag.TipoExame, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Para incluir novo tipo de exame use o menu lateral acessando Tabelas Auxiliares no bloco Administração", data_trigger="hover", data_placement="top", autofocus = true, @id = "tipo", onchange = "GetExame($(this).val())"  })
                                        @Html.ValidationMessageFor(m => m.TIEX_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Data do Exame*
                                        @Html.TextBoxFor(m => m.PAEX_DT_DATA, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                        @Html.ValidationMessageFor(m => m.PAEX_DT_DATA, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-5 col-md-5 col-xs-12">
                                        Laboratório
                                        @Html.DropDownListFor(m => m.LABS_CD_ID, (SelectList)ViewBag.Labs, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Para incluir novo laboratório use o menu lateral acessando Tabelas Auxiliares no bloco Administração", data_trigger="hover", data_placement="top", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.LABS_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Nome do Exame*
                                        @Html.TextBoxFor(m => m.PAEX_NM_NOME, new { @class = "form-control", autofocus = true, @id = "nomeExame" })
                                        @Html.ValidationMessageFor(m => m.PAEX_NM_NOME, "", new { @style = "color:red" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Resultados do Exame*
                                        @Html.TextAreaFor(m => m.PAEX_DS_COMENTARIOS, new { @class = "form-control", style = "width: 100%; height: 280px; overflow:auto;", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.PAEX_DS_COMENTARIOS, "", new { @style = "color:red" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-4 col-xs-12">
                                <input class="btn btn-sm btn-warning" style="margin-left: -15px;" id="inputFile" type="file" multiple data-toggle="popover" data-trigger="hover" data-placement="top" data-content="ATENÇÃO - Antes de anexar arquivos certifique-se de que eles estejam livres de vírus e outras ameaças. Anexe aqui os arquivos referentes a este pagamento. As notas fiscais NF-e em formato XML da SRF devem ser anexadas em local próprio na página de edição de pagamentos"/>
                                <br />
                                <div class="form-group" style="margin-left: -15px;">
                                    <div>
                                        <table style="width: 100%;" class="table table-striped table-bordered table-hover dataTables-example" id="myFiles">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <td>Nome</td>
                                                    <td>Tipo</td>
                                                    <td>Ações</td>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script>
        function GetExame(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente2/GetTipoExame'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nomeExame').val(r.desc);
                }
            });
        }
    </script>

    <script>
        function GetPaciente(id) {
            var data = {
                id: id
            }
            var solicitacao = $('select#solic1');

            $.ajax({
                url: '../Paciente/GetPaciente'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#dataNasc > input').val(r.dataNasc);
                    $('#cpf > input').val(r.cpf);
                    $('#cel > input').val(r.cel);
                    $('#tel > input').val(r.tel);

                    $('#dataNasc').show();
                    $('#cpf').show();
                    $('#cel').show();
                    $('#tel').show();
                }
            });

            $.ajax({
                url: '../Paciente/FiltrarSolicitacaoPaciente'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    solicitacao.children('option').remove();
                    solicitacao.append('<option>Selecionar</option>');

                    r.forEach(function (e) {
                        solicitacao.append('<option value="' + e.PASO_CD_ID + '">' + e.PASO_NM_TITULO + '</option>');
                    });
                }
            });
        }
    </script>

    <script>
        function GetSolicitacao(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente/GetSolicitacaoPaciente'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nomeExame > input').val(r.nome);

                    $('#nomeExame').show();
                }
            });
        }
    </script>
    <script>
        function GetSolicitacao1(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente/GetSolicitacaoPaciente'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nomeExame > input').val(r.nome);

                    $('#nomeExame').show();
                }
            });
        }
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>

    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
        });
    </script>

    <script>
        SendFilesV2('imgCliente', 'Paciente', 'UploadFileToSession');
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Inclusão em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                    + shortCutFunction
                    + "](\""
                    + msg
                    + (title ? "\", \"" + title : '')
                    + "\")\n\ntoastr.options = "
                    + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
