@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteAtestadoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Atestados - Inclusão";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Atestados - Criar novo atestado do paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, atestado";
}

<div class="wrapper wrapper-content animated fadeInRight">
    @if ((String)Session["ModuloAtual"] == "Dashboard Inicial")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaAtestados", "Paciente")">Atestados</a>
                </li>
                <li class="active">
                    <strong>Atestados - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Central de Pacientes")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaAtestados", "Paciente")">Atestados</a>
                </li>
                <li class="active">
                    <strong>Atestados - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else if ((String)Session["ModuloAtual"] == "Paciente - Edição")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li>
                    <a href="@Url.Action("EditarPaciente", "Paciente")">Paciente - Edição</a>
                </li>
                <li class="active">
                    <strong>Atestados - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Atestado - Criação</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("IncluirAtestado", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        @if ((Int32)Session["TipoSolicitacao"] == 1)
                        {
                            <div class="row">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Nome do Paciente
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data de Nascimento
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    @if (Model.PACIENTE.PACI_NR_CPF != null)
                                    {
                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                            CPF
                                            @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                        </div>
                                    }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Nome do Paciente*
                                        @Html.DropDownListFor(m => m.PACI_CD_ID, (SelectList)ViewBag.Paciente, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Selecione um paciente ou digite as primeiras letras do nome para acelerar a busca", data_trigger="hover", data_placement="top", autofocus = true, onchange = "GetPaciente($(this).val())" })
                                        @Html.ValidationMessageFor(m => m.PACI_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                    <div style="display: none;" id="dataNasc" class="col-lg-2 col-md-2 col-xs-12">
                                        Data de Nascimento
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="cpf" class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="cel" class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                    <div style="display: none;" id="tel" class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                    </div>
                                </div>
                            </div>
                        }
                        @if ((Int32)Session["ModoConsulta"] == 1)
                        {
                            <div class="row">
                                <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Dados da Consulta</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data da Consulta
                                        @Html.TextBoxFor(m => m.PACIENTE_CONSULTA.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Início
                                        @Html.TextBoxFor(m => m.PACIENTE_CONSULTA.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Final
                                        @Html.TextBoxFor(m => m.PACIENTE_CONSULTA.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Atestado</h4>
                            <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">                
                                @Html.ButtonActionSubmit(text: "Confirma Criação de Atestado", htmlAttributes: new { id = "basictoast" })
                                @if ((Int32)Session["TipoSolicitacao"] == 1)
                                {
                                    if ((Int32)Session["ModoConsulta"] == 1)
                                    {
                                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarProcederConsulta", controller: "Paciente")
                                    }
                                    else
                                    {
                                        if ((Int32)Session["VoltarCentral"] == 2)
                                        {
                                            @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaCentralPaciente", controller: "Paciente")
                                        }
                                        else
                                        {
                                            @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente")
                                        }
                                    }
                                }
                                else
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAtestados", controller: "Paciente")
                                }
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Identificador
                                    @Html.TextBoxFor(m => m.PAAT_GU_GUID, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Identificador único do atestado gerado pelo WebDoctor", data_trigger="hover", data_placement="top", @style = "color: darkblue; font-weight: bold"  })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Token
                                    @Html.TextBoxFor(m => m.PAAT_TK_TOKEN, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Token de validação do atestado gerado pelo WebDoctor", data_trigger="hover", data_placement="top", @style = "color: brown; font-weight: bold"  })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PAAT_IN_ATIVO)
                                    @Html.HiddenFor(m => m.PAAT_GU_GUID)
                                    @Html.HiddenFor(m => m.PAAT_DT_DATA)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PAAT_DT_ENVIO)
                                    @Html.HiddenFor(m => m.PAAT_GU_GUID_ENVIO)
                                    @Html.HiddenFor(m => m.PAAT_IN_PDF)
                                    @Html.HiddenFor(m => m.PAAT_NR_ENVIOS)
                                    @Html.HiddenFor(m => m.PACO_CD_ID)
                                    @Html.HiddenFor(m => m.PAAT_DT_EMISSAO_COMPLETA)
                                    @Html.HiddenFor(m => m.PAAT_TK_TOKEN)
                                    @Html.HiddenFor(m => m.PAAT_NR_VALIDACAO)
                                    @Html.HiddenFor(m => m.PAAT_IN_VALIDACAO)
                                    @Html.HiddenFor(m => m.PAAT_NR_DENUNCIA)
                                    @Html.HiddenFor(m => m.PAAT_IN_DENUNCIA)
                                    Data/Hora de Emissão
                                    @Html.TextBoxFor(m => m.PAAT_DT_EMISSAO_COMPLETA, new { @class = "form-control", @readonly = "readonly", @tabindex = "-1" })
                                </div>
                                @if (ViewBag.Perfil == "ADM")
                                {
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Tipo de Atestado
                                        @Html.DropDownListFor(m => m.TIAT_CD_ID, (SelectList)ViewBag.TipoAtestado, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Para incluir novos tipos de atestados acesse Tabelas Auxiliares no menu lateral no bloco Administração", data_trigger="hover", data_placement="top", autofocus = true, @id = "tipo", onchange = "GetAtestado($(this).val())"  })
                                        @Html.ValidationMessageFor(m => m.TIAT_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                }
                                else
                                {
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Tipo de Atestado
                                        @Html.DropDownListFor(m => m.TIAT_CD_ID, (SelectList)ViewBag.TipoAtestado, "Selecionar", new { @class = "form-control", autofocus = true, @id = "tipo", onchange = "GetAtestado($(this).val())"   })
                                        @Html.ValidationMessageFor(m => m.TIAT_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                }




                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Finalidade do Atestado
                                    @Html.TextBoxFor(m => m.PAAT_NM_TITULO, new { @class = "form-control", autofocus = true, @id = "finalidade", data_toggle = "popover", data_content = "Informe a finalidade do atestado se for diferente do tipo de atestado definido", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.PAAT_NM_TITULO, "",new { @style="color:red" })
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Destinatário do Atestado*
                                    @Html.TextBoxFor(m => m.PAAT_NM_DESTINO, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe para quem esse atestado deverá ser entregue pelo paciente", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.PAAT_NM_DESTINO, "",new { @style="color:red" })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    Texto do Atestado*
                                    @Html.TextAreaFor(m => m.PAAT_TX_TEXTO, new { @class = "form-control", style = "width: 100%; height: 380px; overflow:auto;", autofocus = true, @id = "texto", data_toggle = "popover", data_content = "Informe apenas o texto do atestado. Cabeçalho e rodapé serão montados automaticamente", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.PAAT_TX_TEXTO, "", new { @style = "color:red" })
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
   
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script>
        function GetPaciente(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente/GetPaciente'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#dataNasc > input').val(r.dataNasc);
                    $('#cpf > input').val(r.cpf);
                    $('#cel > input').val(r.cel);
                    $('#tel > input').val(r.tel);

                    $('#dataNasc').show();
                    $('#cpf').show();
                    $('#cel').show();
                    $('#tel').show();
                }
            });
        }
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Inclusão em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>

    <script>
        function GetAtestado(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../Paciente2/GetTipoAtestado'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#finalidade').val(r.desc);
                    $('#texto').val(r.texto);
                }
            });
        }
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
