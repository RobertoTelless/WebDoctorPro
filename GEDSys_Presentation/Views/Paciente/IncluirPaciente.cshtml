    <script type="text/javascript">
        var video = document.getElementById('video');
        var canvas = document.getElementById('canvas');
        var stream = null;

        function startCamera() {
            $('#camera-area').show();
            $('#upload-controls').hide();
        
            navigator.mediaDevices.getUserMedia({ video: true, audio: false })
                .then(function(s) {
                    stream = s;
                    video.srcObject = stream;
                    video.play();
                })
                .catch(function(err) {
                    alert("Erro ao acessar a câmera: " + err);
                    stopCamera();
                });
        }

        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
            $('#camera-area').hide();
            $('#upload-controls').show();
        }

        function takeSnapshot() {
            var context = canvas.getContext('2d');
            context.drawImage(video, 0, 0, 320, 240);
        
            // Converter o canvas para Blob (formato de arquivo)
            canvas.toBlob(function(blob) {
                // Criar um arquivo a partir do blob
                var file = new File([blob], "foto_paciente.jpg", { type: "image/jpeg" });
            
                // Mostrar preview
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#captured-image').attr('src', e.target.result).show();
                };
                reader.readAsDataURL(file);

                // GATILHO IMPORTANTE:
                // Envia para o seu método existente de Session que você já usa no input file
                uploadCapturedPhoto(file);
            
                stopCamera();
            }, 'image/jpeg');
        }

        function uploadCapturedPhoto(file) {
            var formData = new FormData();
            // 1. O nome deve ser 'files' para coincidir com o IEnumerable no C#
            formData.append('files', file);
            // 2. Garanta que o parâmetro 'profile' seja enviado
            formData.append('profile', 'foto_paciente.jpg'); 

            $.ajax({
                url: '@Url.Action("UploadFileToSession", "Paciente")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(r) {
                    toastr.success("Foto capturada e preparada para salvar!");
                },
                error: function(xhr, status, error) {
                    // Instrumentação para ver o erro real no console (F12)
                    console.error("Erro detalhado:", xhr.responseText);
                    toastr.error("Erro ao processar captura na sessão: " + error);
                }
            });
        }
    </script>




    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
