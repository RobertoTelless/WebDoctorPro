@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Inclusão de paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div id="top"></div>
    @if ((String)Session["ModuloAtual"] == "Dashboard Inicial")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
                </li>
                <li class="active">
                    <strong>Pacientes - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    else
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
                </li>
                <li class="active">
                    <strong>Pacientes - Inclusão</strong>
                </li>
            </ol>
            <br />
        </div>
    }

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Pacientes - Inclusão</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }                    
                    <div class="tabs-container">
                        @using (Html.BeginForm("IncluirPaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                        {
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <br />
                                @Html.ButtonActionSubmit(text: "BtnSubmit", htmlAttributes: new { id = "submit", style = "display: none;" })
                                <button style="margin-left: 15px;" class="btnSubmit btn btn-sm btn-success btn-loading" id="basictoast" type="button">Confirmar inclusão do Paciente</button>
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBasePaciente", controller: "Paciente")
                                <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#tab-1">Informações do Paciente</a></li>
                            </ul>
                            <div class="tab-content">
                                @*Dados Gerais*@
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Identificação</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                    @Html.HiddenFor(m => m.PACI_DT_CADASTRO)
                                                    @Html.HiddenFor(m => m.PACI_IN_ATIVO)
                                                    @Html.HiddenFor(m => m.PACI_GU_GUID)
                                                    @Html.HiddenFor(m => m.PACI_DT_ALTERACAO)
                                                    @Html.HiddenFor(m => m.PACI_IN_MENSAGEM_ATRASO)
                                                    @Html.HiddenFor(m => m.PACI_IN_NUMERO_ENVIO)
                                                    @Html.HiddenFor(m => m.PACI_IN_FIM_ENVIO)
                                                    @Html.HiddenFor(m => m.PACI_IN_PADRAO_ANAMNESE)
                                                    @Html.HiddenFor(m => m.PACI_IN_PADRAO_CONTINUA)
                                                    Tipo de Paciente*
                                                    @Html.DropDownListFor(m => m.TIPA_CD_ID, (SelectList)ViewBag.Tipos, "Selecionar", new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.TIPA_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Tipo Padrão de Consulta*
                                                    @Html.DropDownListFor(m => m.VACO_CD_ID, (SelectList)ViewBag.TipoConsulta, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione o tipo de consulta que será o padrão deste paciente", data_trigger="hover", data_placement="top" })
                                                    @Html.ValidationMessageFor(m => m.VACO_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Convênio
                                                    @Html.DropDownListFor(m => m.CONV_CD_ID, (SelectList)ViewBag.Convenio, "Selecionar", new { @class = "form-control", autofocus = true, @id = "convenio", onchange = "ValidaConvenio($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.CONV_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="matricula" style="display: none">
                                                    Matrícula do Convênio
                                                    @Html.TextBoxFor(m => m.PACI_NR_MATRICULA, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_MATRICULA, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Menor de Idade*
                                                    @Html.DropDownListFor(m => m.PACI_IN_MENOR, (SelectList)ViewBag.Menor, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Se o paciente for menor de idade será solicitado o nome de um responsável", data_trigger="hover", data_placement="top", autofocus = true, @id = "menor", onchange = "ValidaMenor($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.PACI_IN_MENOR, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12" id="resp" style="display: none">
                                                    Nome do Responsável
                                                    @Html.TextBoxFor(m => m.PACI_NM_RESPONSAVEL, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o nome do responsável pelo paciente menor de idade", data_trigger="hover", data_placement="top" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_RESPONSAVEL, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12" id="usuarioConsulta" style="color:brown">
                                                    Profissional - Consulta
                                                    @Html.DropDownListFor(m => m.USUA_CD_ID, (SelectList)ViewBag.Usuarios, "Selecionar", new { @class = "form-control", autofocus = true, @id = "usuario", data_toggle = "popover", data_content = "Profissional para o qual a nova consulta será criada", data_trigger="hover", data_placement="top", @style = "color: brown; background-color: antiquewhite"  })
                                                    @Html.ValidationMessageFor(m => m.USUA_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Criar Consulta?
                                                    @Html.DropDownListFor(m => m.CRIA_CONSULTA, (SelectList)ViewBag.Consulta, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Para marcar uma consulta para esse novo paciente preencha as informações de data/hora", data_trigger="hover", data_placement="top", autofocus = true, @id = "consulta", onchange = "ValidaConsulta($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.CRIA_CONSULTA, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12" id="tipoConsulta">
                                                    Tipo de Consulta*
                                                    @Html.DropDownListFor(m => m.VACO_CD_ID_1, (SelectList)ViewBag.TipoConsulta, "Selecionar", new { @class = "form-control", autofocus = true, @id = "tc"  })
                                                    @Html.ValidationMessageFor(m => m.VACO_CD_ID_1, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="dataConsulta">
                                                    Data da Consulta*
                                                    @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", data_toggle = "popover", data_content = "Caso a data/hora solicitada não esteja disponível a consulta não será marcada e deverá ser posteriormente marcada manualmente", data_trigger="hover", data_placement="top", autofocus = true, @id = "dc" })
                                                    @Html.ValidationMessageFor(m => m.PACO_DT_CONSULTA, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="inicioHora">
                                                    Início*
                                                    <div class='input-group date' id='datetimepicker3'>
                                                        @Html.TextBoxFor(m => m.HORA_INICIO, new { @class = "form-control time-picker", autofocus = true, @id = "hora" })
                                                        @Html.ValidationMessageFor(m => m.HORA_INICIO, "", new { @style = "color:red" })
                                                        <span class="input-group-addon">
                                                            <span style="cursor: pointer;" class="glyphicon glyphicon-time"></span>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="finalHora">
                                                    Final*
                                                    <div class='input-group date' id='datetimepicker3'>
                                                        @Html.TextBoxFor(m => m.HORA_FINAL, new { @class = "form-control time-picker1", autofocus = true, @id = "hora1" })
                                                        @Html.ValidationMessageFor(m => m.HORA_FINAL, "", new { @style = "color:red" })
                                                        <span class="input-group-addon">
                                                            <span style="cursor: pointer;" class="glyphicon glyphicon-time"></span>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;" id="PF">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Nome*
                                                    @Html.TextBoxFor(m => m.PACI_NM_NOME, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_NOME, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-4 col-md-4 col-xs-12" id="RS">
                                                    Nome Social
                                                    @Html.TextBoxFor(m => m.PACI_NM_SOCIAL, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_SOCIAL, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="cpf">
                                                    CPF*
                                                    @Html.TextBoxFor(m => m.PACI_NR_CPF, new { @class = "form-control", @id = "cpf1", autofocus = true, data_toggle = "popover", data_content = "Caso o paciente seja menor de idade deverá ser informado o CPF do responsável", data_trigger="hover", data_placement="top" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_CPF, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    RG
                                                    @Html.TextBoxFor(m => m.PACI_NR_RG, new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_RG, "", new { @style = "color:red" })
                                                </div>
                                            </div>

                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12" id="RS">
                                                    Indicado Por
                                                    @Html.TextBoxFor(m => m.PACI_NM_INDICACAO, new { @class = "form-control", autofocus = true, @id = "txtIndicado" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_INDICACAO, "", new { @style = "color:red" })
                                                </div>
                                                @if ((Int32)Session["BlocoAnamnese"] == 1)
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Padrão da Anamnese*
                                                        @Html.DropDownListFor(m => m.PACI_IN_PADRAO_ANAMNESE, (SelectList)ViewBag.Anamnese, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Selecione o padrão de anamnese deste paciente. Segmentada em tópicos ou texto contínuo", data_trigger="hover", data_placement="top", autofocus = true, @id = "padrao", onchange = "ValidaPadrao($(this).val())" })
                                                        @Html.ValidationMessageFor(m => m.PACI_IN_PADRAO_ANAMNESE, "", new { @style = "color:red" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12" id="formato">
                                                        Padrão da Anamnese Contínua*
                                                        @Html.DropDownListFor(m => m.PACI_IN_PADRAO_CONTINUA, (SelectList)ViewBag.Formato, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione se a anamnese será um texto livre o cada inclusão de texto receberá um carimbo de data/hora", data_trigger="hover", data_placement="top" })
                                                        @Html.ValidationMessageFor(m => m.PACI_IN_PADRAO_CONTINUA, "", new { @style = "color:red" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Fichas Digitalizadas*
                                                        @Html.DropDownListFor(m => m.PACI_IN_FICHAS, (SelectList)ViewBag.Ficha, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione se este paciente tem fichas digitalizadas externas ao sistema", data_trigger="hover", data_placement="top" })
                                                        @Html.ValidationMessageFor(m => m.PACI_IN_FICHAS, "", new { @style = "color:red" })
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Fichas Digitalizadas*
                                                        @Html.DropDownListFor(m => m.PACI_IN_FICHAS, (SelectList)ViewBag.Ficha, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione se este paciente tem fichas digitalizadas externas ao sistema", data_trigger="hover", data_placement="top" })
                                                        @Html.ValidationMessageFor(m => m.PACI_IN_FICHAS, "", new { @style = "color:red" })
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="row">
                                            @*<div style="margin-left: 0px;" class="col-lg-6 col-md-6 col-xs-12">
                                                <div class="form-group">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Fotografia</h4><input type="file" accept=".jpg, .png, .jpeg, .gif|images/*" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="ATENÇÃO - Antes de anexar fotografia certifique-se de que ela esteja livre de vírus e outras ameaças.  " name="file" id="imgCliente" class="btn btn-sm btn-warning" multiple />
                                                    <br />
                                                </div>
                                            </div>*@

                                            @* Localize a div de Fotografia e substitua por esta estrutura *@
                                            <div style="margin-left: 0px;" class="col-lg-6 col-md-6 col-xs-12">
                                                <div class="form-group">
                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Fotografia do Paciente</h4>
        
                                                    <!-- Área de Preview da Câmera -->
                                                    <div id="camera-area" style="display:none; margin-bottom: 10px;">
                                                        <video id="video" width="320" height="240" autoplay style="border: 1px solid #ccc; border-radius: 5px;"></video>
                                                        <canvas id="canvas" width="320" height="240" style="display:none;"></canvas>
                                                        <br />
                                                        <button type="button" class="btn btn-sm btn-primary" onclick="takeSnapshot()">Capturar Foto</button>
                                                        <button type="button" class="btn btn-sm btn-danger" onclick="stopCamera()">Cancelar</button>
                                                    </div>

                                                    <!-- Controles de Upload/Câmera -->
                                                    <div id="upload-controls">
                                                        <input type="file" accept="image/*" name="file" id="imgCliente" class="btn btn-sm btn-warning" style="display:inline-block" />
                                                        <button type="button" class="btn btn-sm btn-info" onclick="startCamera()"><i class="fa fa-camera"></i> Usar Câmera</button>
                                                    </div>
        
                                                    <!-- Preview da foto capturada -->
                                                    <div id="photo-preview" style="margin-top:10px;">
                                                        <img id="captured-image" src="#" alt="Preview" style="display:none; width: 150px; border-radius: 5px;" />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-lg-6 col-md-6 col-xs-12">
                                                <h4 style="margin-left: -15px; color:green; background-color: beige; font-weight:bold">Anexos</h4>
                                                <input class="btn btn-sm btn-warning" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="ATENÇÃO - Antes de anexar arquivos certifique-se de que eles estejam livres de vírus e outras ameaças.  " style="margin-left: -15px;" id="inputFile" type="file" multiple />
                                                <br />
                                                <div class="form-group" style="margin-left: -15px;">
                                                    <div>
                                                        <table style="width: 100%;" class="table table-striped table-bordered table-hover dataTables-example" id="myFiles">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <td>Nome</td>
                                                                    <td>Tipo</td>
                                                                    <td>Ações</td>
                                                                </tr>
                                                            </thead>
                                                            <tbody></tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Endereço</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    CEP
                                                    <div class="input-group">
                                                        @Html.TextBoxFor(m => m.PACI_NR_CEP, new { @class = "form-control", @id = "cep", autofocus = true })
                                                        @Html.ValidationMessageFor(m => m.PACI_NR_CEP, "", new { @style = "color:red" })
                                                        <span class="input-group-btn">
                                                            <span class="btn btn-warning btn-sm" id="btnBuscaCep" data_toggle = "popover" data_content = "Pesquisar o CEP informado" data_trigger="hover" data_placement="top" onclick="PesquisaCep($('#cep').val(), $(this), 1)">Buscar CEP</span>
                                                        </span>
                                                    </div>
                                                    <div class="col-lg-12 col-md-12 col-xs-12" style="display:none" id="cepval">
                                                        <h5>CEP inválido</h5>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Endereço
                                                    @Html.TextBoxFor(m => m.PACI_NM_ENDERECO, new { @class = "form-control", @id = "endereco", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_ENDERECO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Número
                                                    @Html.TextBoxFor(m => m.PACI_NR_NUMERO, new { @class = "form-control", @id = "nmr", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_NUMERO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Complemento
                                                    @Html.TextBoxFor(m => m.PACI_NR_COMPLEMENTO, new { @class = "form-control", autofocus = true, @id = "complemento" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_COMPLEMENTO, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Bairro
                                                    @Html.TextBoxFor(m => m.PACI_NM_BAIRRO, new { @class = "form-control", @id = "bairro", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_BAIRRO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Cidade
                                                    @Html.TextBoxFor(m => m.PACI_NM_CIDADE, new { @class = "form-control", @id = "cidade", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_CIDADE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    UF
                                                    @Html.DropDownListFor(m => m.UF_CD_ID, (SelectList)ViewBag.UF, "UF", new { @class = "form-control", @id = "uf", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.UF_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Contatos</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    E-Mail
                                                    @Html.TextBoxFor(m => m.PACI_NM_EMAIL, new { @class = "form-control", autofocus = true, id = "email" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NM_EMAIL, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Telefone
                                                    @Html.TextBoxFor(m => m.PACI_NR_TELEFONE, new { @class = "form-control", autofocus = true, @id = "tel" })
                                                    @Html.ValidationMessageFor(m => m.PACI_NR_TELEFONE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
