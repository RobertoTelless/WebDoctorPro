@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacienteConsultaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Atestados";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Atestados - Lista de Atestados ";
    ViewBag.MetaKeywords = "WebDoctor, paciente, atestado";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard Inicial</a>
            </li>
            <li>
                <a href="@Url.Action("VoltarProcederConsulta", "Paciente")">Consulta</a>
            </li>
            <li class="active">
                <strong>Atestados</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Paciente - Atestados</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("VerListaAtestadoConsulta", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Mensagens:", new { @class = "text-danger" })
                            </div>
                        }
                        @*@if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }*@                    
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @if (ViewBag.Classe == 0)
                                    {
                                        @Html.ButtonLinkIndex(text: "Novo Atestado", controller: "Paciente", action: "IncluirAtestado", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })
                                    }
                                    @Html.ButtonLinkIndex(text: "Ver Todos Atestados", controller: "Paciente", action: "MontarTelaAtestados", htmlAttributes: new { @class = "btn-loading" })
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "VoltarProcederConsulta")
                                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                        <i class="fa fa-spinner fa-spin"></i> Processando...
                                    </span>
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>
                        @*<br />*@
                        @*<div class="row">
                            <h4 style="margin-left: 0px; color: green; background-color: beige; font-weight:bold">Dados da Consulta</h4>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Consulta
                                    @Html.TextBoxFor(m => m.TipoConsulta, new { @class = "form-control", @readonly = "readonly"})
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_IN_ATIVO)
                                    @Html.HiddenFor(m => m.PACO_IN_ENCERRADA)
                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.PACO_CD_ID)
                                    Data da Consulta
                                    @Html.TextBoxFor(m => m.PACO_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Início
                                    @Html.TextBoxFor(m => m.PACO_HR_INICIO, new { @class = "form-control", @id = "hora", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Final
                                    @Html.TextBoxFor(m => m.PACO_HR_FINAL, new { @class = "form-control", @id = "hora1", @readonly = "readonly" })
                                </div>
                            </div>
                        </div>*@
                        @*<br />*@

                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Atestados</h4>
                                    @*<br />*@
                                    @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_ATESTADO>).Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-atestado">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Data da Emissão</th>
                                                    <th style="width: auto">Identificador</th>
                                                    <th style="width: auto">Tipo de Atestado</th>
                                                    <th style="width: auto">Finalidade</th>
                                                    <th style="width: auto">Data da Consulta</th>
                                                    <th style="width: auto">Enviado</th>
                                                    <th style="width: auto">Data de Envio</th>
                                                    <th style="width: auto" class="td-one-action">Ações</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_ATESTADO>).OrderByDescending(p => p.PAAT_DT_DATA.Value.Date))
                                                {
                                                    <tr>
                                                        <td>
                                                            <span style="display:none; width: auto">@cond.PAAT_DT_DATA.Value.ToString("yyyyMMdd")</span>
                                                            @cond.PAAT_DT_DATA.Value.ToShortDateString()
                                                        </td>

                                                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ALTERAR == 1)
                                                        {
                                                            if (cond.PAAT__IN_ENVIADO == 0)
                                                            {
                                                                <td style="width: auto"><a href="@Url.Action("EditarAtestado", "Paciente", new { id = cond.PAAT_CD_ID })" class="btn-loading" />@cond.PAAT_GU_GUID</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto"><a href="@Url.Action("VerAtestado", "Paciente", new { id = cond.PAAT_CD_ID })" class="btn-loading" />@cond.PAAT_GU_GUID</td>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><a href="@Url.Action("VerAtestado", "Paciente", new { id = cond.PAAT_CD_ID })" class="btn-loading" />@cond.PAAT_GU_GUID</td>
                                                        }
                                                        <td style="width: auto">@cond.TIPO_ATESTADO.TIAT_NM_NOME</td>
                                                        <td style="width: auto">@cond.PAAT_NM_TITULO</td>
                                                        @if (cond.PACIENTE_CONSULTA != null)
                                                        {
                                                            <td>
                                                                <span style="display:none; width: auto">@cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToString("yyyyMMdd")</span>
                                                                @cond.PACIENTE_CONSULTA.PACO_DT_CONSULTA.ToShortDateString()
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }
                                                        @if (cond.PAAT__IN_ENVIADO == 1)
                                                        {
                                                            <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                        }
                                                        @if (cond.PAAT_DT_ENVIO != null)
                                                        {
                                                            <td style="width: auto">@cond.PAAT_DT_ENVIO.Value.ToShortDateString()</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">-</td>
                                                        }

                                                        <td style="width: auto" class="td-one-action">
                                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ALTERAR == 1)
                                                            {
                                                                if (cond.PAAT__IN_ENVIADO == 0)
                                                                {
                                                                        @Html.TableLinkDetails(cond.PAAT_CD_ID, "EditarAtestado", "fa-edit btn-loading", "Editar")
                                                                }
                                                                else
                                                                {
                                                                    @Html.TableLinkDetails(cond.PAAT_CD_ID, "VerAtestado", "fa-search btn-loading", "Consultar")
                                                                }
                                                            }
                                                            else
                                                            {
                                                                @Html.TableLinkDetails(cond.PAAT_CD_ID, "VerAtestado", "fa-search btn-loading", "Consultar")
                                                            }
                                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ENVIAR == 1)
                                                            {
                                                                if (cond.PAAT_IN_ATIVO == 1 )
                                                                {
                                                                    @Html.TableLinkDetails(cond.PAAT_CD_ID, "EnviarAtestadoEMail", "fa-send-o btn-loading", "Enviar Atestado")
                                                                }
	                                                        }
                                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ENVIAR == 1)
                                                            {
                                                                if (cond.PAAT_IN_ATIVO == 1 )
                                                                {
                                                                    @Html.TableLinkDetails(cond.PAAT_CD_ID, "ImprimirAtestado", "fa-print", "Imprimir")
                                                                }
	                                                        }
                                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_EXCLUIR == 1)
                                                            {
                                                                if (cond.PAAT_IN_ATIVO == 1)
                                                                {
                                                                    if (cond.PAAT__IN_ENVIADO == 0)
                                                                    {
                                                                        <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluirAtestado('/Paciente/ExcluirAtestado/@cond.PAAT_CD_ID')" title="Excluir"></span>
                                                                    }
                                                                }
	                                                        }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum atestado cadastrado para esse paciente nessa consulta</h2>
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>

}
@section Scripts {
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            // Configurações globais do Toastr
            toastr.options = {
                "closeButton": true,
                //"debug": false,
                "progressBar": true,
                "preventDuplicates": false,
                "positionClass": "toast-top-right",
                "onclick": null,
                "showDuration": "400",
                "hideDuration": "1000",
                "timeOut": "15000",
                "extendedTimeOut": "5000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            //    "iconClass": "customer-toast-info", // Se quiser remover o ícone padrão totalmente
            //    "titleClass": "toast-title",
            //    "messageClass": "toast-message"
            };

            // Verifica se existe mensagem de sucesso no TempData (vinda do Redirect)
            var msgSucesso = '@TempData["MensagemAcerto"]';
            if (msgSucesso != '') {
                toastr.success(msgSucesso, 'Sucesso!');
            }

            // Verifica se existe mensagem de erro
            var msgErro = '@TempData["MensagemErro"]';
            if (msgErro != '') {
                toastr.error(msgErro, 'Erro!');
            }
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
   
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluirAtestado(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Atestado?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }

        function ShowModalConfirmarEnvioAtestado(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Reativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma envio da Atestado?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Envio</h5>');
            $('#modal').modal('show');
        }
    </script>
