@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.MensagemViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Envio";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Enviar e-mail ao paciente";
    ViewBag.MetaKeywords = "WebDoctor, paciente, e-mail";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
            </li>
            <li class="active">
                <strong>Pacientes - Mensagens</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Paciente - Envio de E-Mail</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.NomePaciente</span>
                    </div>
                </div>
                @using (Html.BeginForm("EnviarEMailPaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="ibox-content">
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    @Html.HiddenFor(m => m.ID)
                                    @Html.HiddenFor(m => m.MENS_DT_CRIACAO)
                                    @Html.HiddenFor(m => m.MENS_IN_TIPO)
                                    @Html.HiddenFor(m => m.MENS_NM_CAMPANHA)
                                    @Html.HiddenFor(m => m.MENS_NM_NOME)
                                    @Html.HiddenFor(m => m.PACI_CD_ID)
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.NOME, new { @class = "form-control", @readonly="readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    E-Mail
                                    @Html.TextBoxFor(m => m.MODELO, new { @class = "form-control", @readonly="readonly" })
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Link a Anexar
                                    @Html.TextBoxFor(m => m.MENS_NM_LINK, new { @class = "form-control", autofocus = true })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;"> 
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    <h4 style="margin-left: -15px; color:green; background-color: beige; font-weight:bold">Anexos</h4>
                                    <input class="btn btn-sm btn-warning" style="margin-left: -15px;" id="inputFile" type="file" multiple data-toggle="popover" data-trigger="hover" data-placement="top" data-content="ATENÇÃO - Antes de anexar arquivos certifique-se de que eles estejam livres de vírus e outras ameaças.  "/>
                                    <br />
                                    @*<div class="row" style="display: none">
                                        <div style="margin-left: 15px;" class="col-lg-12 col-md-12 col-xs-12">
                                            <div class="form-group">
                                                <h4>Logotipo/Foto</h4><input type="file" accept=".jpg, .png, .jpeg, .gif|images/*" name="file" id="imgPaciente" class="btn btn-sm btn-warning" multiple />
                                                <br />
                                            </div>
                                        </div>
                                    </div>*@
                                    <div class="form-group">
                                        <div>
                                            <hr />
                                            <table style="width: 100%;" class="table table-striped table-bordered table-hover dataTables-example" id="myFiles">
                                                <thead style="background-color:lightsteelblue">
                                                    <tr>
                                                        <td>Nome</td>
                                                        <td>Tipo</td>
                                                        <td>Ações</td>
                                                    </tr>
                                                </thead>
                                                <tbody></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Texto da Mensagem*
                                    @Html.TextAreaFor(m => m.MENS_TX_TEXTO, new { @class = "form-control", style = "width: 100%; height: 300px; overflow:auto;", autofocus = true, @id = "texto" })
                                    @Html.ValidationMessageFor(m => m.MENS_TX_TEXTO, "", new { @style = "color:red" })
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            @Html.ButtonActionSubmit(text: "BtnSubmit", htmlAttributes: new { id = "submit", style = "display: none;" })
                            <button style="margin-left: 15px;" class="btnSubmit btn btn-sm btn-success" id="basictoast" type="button">Confirmar Envio do E-Mail</button>
                            @if ((Int32)Session["VoltaConfirmar"] == 1)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "ConfirmarCancelarConsulta", controller: "Paciente")
                            }
                            else
                            {
                                if ((Int32)Session["VoltaMensagem"] == 0)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBasePaciente", controller: "Paciente")
                                }
                                else if ((Int32)Session["VoltaMensagem"] == 99)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAusencias", controller: "Paciente2")
                                }
                                else
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAnexoPaciente", controller: "Paciente")
                                }
                            }
                            <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                        </div>
                    </div>
                }
            </div>
         </div>
    </div>
</div>

