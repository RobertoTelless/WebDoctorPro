    <script type="text/javascript">
        $(document).ready(function () {
            var $modal = $('#modalConfirmacao');
            var idParaConfirmar = 0;

            // 1. Captura o ID ao clicar no botão da tabela e abre a modal
            $('body').on('click', '.btn-disparar-modal-confirma', function () {
                idParaConfirmar = $(this).data('id');
                $modal.modal('show');
            });

            // 2. Ação de confirmar DENTRO da modal via AJAX
            $('#btnConfirmarSubmit').click(function (e) {
                e.preventDefault();
                var $btn = $(this);

                // Trava o botão e mostra spinner
                $btn.prop('disabled', true).addClass('disabled');
                var originalText = $btn.html();
                $btn.html('<i class="fa fa-spinner fa-spin"></i> Processando...');

                $.ajax({
                    url: '@Url.Action("ConfirmarConsultaJson", "Paciente")',
                    type: 'POST',
                    data: { id: idParaConfirmar },
                    success: function (response) {
                        if (response.success) {
                            $modal.modal('hide');
                            // Redireciona para a URL enviada pelo Controller baseada nas Sessions
                            window.location.href = response.redirectUrl;
                        } else {
                            $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                            toastr.error(response.message, "Erro no Processamento");
                        }
                    },
                    error: function (xhr, status, error) {
                        $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                        alert("Erro crítico na comunicação com o servidor: " + error);
                    }
                });
            });

            // Limpeza de segurança ao fechar modal
            $modal.on('hidden.bs.modal', function () {
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            var idConsultaParaConfirmar = 0;
            var $modalJustificativa = $('#modalCancelar');

            // 1. Captura o clique no botão da tabela e abre a modal
            $('body').on('click', '.btn-disparar-modal-cancelar', function () {
                idConsultaParaConfirmar = $(this).data('id');
                $modalJustificativa.modal('show');
            });

            // 2. Ação de confirmar DENTRO da modal via AJAX
            $('#btnCancelarSubmit').off('click').on('click', function (e) {
                e.preventDefault();
                var $btn = $(this);
                var justificativa = $('#textoJustificativaConfirmar').val();

                // Feedback visual de carregamento
                $btn.prop('disabled', true).addClass('disabled');
                var originalText = $btn.html();
                $btn.html('<i class="fa fa-spinner fa-spin"></i> Processando...');

                $.ajax({
                    url: '@Url.Action("CancelarConsultaJson", "Paciente")', // Garante que a Action aceite 'id' e 'justificativa'
                    type: 'POST',
                    data: { 
                        id: idConsultaParaConfirmar,
                        justificativa: justificativa 
                    },
                    success: function (response) {
                        if (response.success) {
                            $modalJustificativa.modal('hide');
                            // Redireciona conforme a lógica de Session do Controller
                            window.location.href = response.redirectUrl;
                        } else {
                            $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                            toastr.error(response.message, "Erro no Processamento");
                        }
                    },
                    error: function (xhr, status, error) {
                        $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                        alert("Erro crítico na comunicação com o servidor: " + error);
                    }
                });
            });

            // 3. Limpeza ao fechar a modal (Reset do campo de texto)
            $modalJustificativa.on('hidden.bs.modal', function () {
                $('#textoJustificativaConfirmar').val('');
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            var idParaEnvio = 0;
            var $modalEnvio = $('#modalEnviarConfirmacao');

            // 1. Captura o clique e abre a modal
            $('body').on('click', '.btn-disparar-modal-envio', function () {
                idParaEnvio = $(this).data('id');
                $modalEnvio.modal('show');
            });

            // 2. Ação do botão de "Sim, Enviar Agora" dentro da modal
            $('#btnEnviarSubmit').off('click').on('click', function (e) {
                e.preventDefault();
                var $btn = $(this);

                // Bloqueia o botão e mostra spinner
                $btn.prop('disabled', true).addClass('disabled');
                var originalText = $btn.html();
                $btn.html('<i class="fa fa-spinner fa-spin"></i> Enviando...');

                $.ajax({
                    url: '@Url.Action("EnviarEMailConfirmacaoJson", "Paciente2")',
                    type: 'POST',
                    data: { id: idParaEnvio },
                    success: function (response) {
                        if (response.success) {
                            $modalEnvio.modal('hide');
                            // Redireciona conforme as regras de Session do seu Controller
                            window.location.href = response.redirectUrl;
                        } else {
                            // Caso o Controller retorne erro (ex: paciente sem e-mail)
                            $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                            toastr.error(response.message, "Falha no Envio");
                        }
                    },
                    error: function (xhr, status, error) {
                        $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                        alert("Erro técnico na comunicação: " + error);
                    }
                });
            });
        });
    </script>
