@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.PACIENTE
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Lista de Pacientes ";
    ViewBag.MetaKeywords = "WebDoctor, paciente";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Central de Pacientes</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página da central de pacientes do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Consultar pacientes cadastrados</li>
                        <li>Localizar (filtrar) um paciente pelo nome e acessar a sua página principal.</li>
                        <li>Imprimir a relação de pacientes</li>
                        <li>Enviar mensagens de e-mail para pacientes.</li>
                        <li>Enviar mensagens de SMS para pacientes.</li>
                        <li>Acessar a página de inclusão de pacientes.</li>
                        <li>Acessar a central de consultas.</li>
                        <li>Acessar a central de atestados.</li>
                        <li>Acessar a central de prescrições.</li>
                        <li>Acessar a central de solicitações de exames.</li>
                        <li>Acessar a central de resultados de exames.</li>
                        <li>Acessar o histórico dos pacientes.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>

    <div class="row">
        <div class="col-lg-10 col-md-10 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarPaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Paciente
                                @Html.DropDownListFor(m => m.TIPA_CD_ID, (SelectList)ViewBag.Tipos, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Nome
                                @Html.TextBoxFor(m => m.PACI_NM_NOME, new { @class = "form-control", autofocus = true, @id = "txtNomePaciente" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                CPF
                                @Html.TextBoxFor(m => m.PACI_NR_CPF, new { @class = "form-control", @id = "cpf", autofocus = true })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Convênio
                                @Html.DropDownListFor(m => m.CONV_CD_ID, (SelectList)ViewBag.Convenios, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Gênero
                                @Html.DropDownListFor(m => m.SEXO_CD_ID, (SelectList)ViewBag.Sexo, "Selecionar", new { @class = "form-control" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-1 col-xs-12">
                                Celular
                                @Html.TextBoxFor(m => m.PACI_NR_CELULAR, new { @class = "form-control", autofocus = true, @id = "cel" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                E-Mail
                                @Html.TextBoxFor(m => m.PACI_NM_EMAIL, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Cidade
                                @Html.TextBoxFor(m => m.PACI_NM_CIDADE, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                UF
                                @Html.DropDownListFor(m => m.UF_CD_ID, (SelectList)ViewBag.UF, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Menor
                                @Html.DropDownListFor(m => m.PACI_IN_MENOR, (SelectList)ViewBag.Menor, "Selecionar", new { @class = "form-control" })
                            </div>
                        </div>

                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUIR_PACIENTE == 1)
                                {
                                    <a href="@Url.Action("IncluirPaciente", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de inclusão de novo paciente" class="btn btn-sm btn-primary btn-loading" id="emp" OnClick = "Fade()">Novo Paciente</a>                
                                }
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Paciente", action: "RetirarFiltroPaciente")
                                @Html.ButtonLinkIndex(text: "Ver Todos", controller: "Paciente", action: "MostrarTudoPaciente")
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ACESSO == 1)
                                {
                                    <a href="@Url.Action("MontarTelaConsultas", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Consultas" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Consultas</a>                
                                }
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ACESSO == 1)
                                {
                                    <a href="@Url.Action("MontarTelaPrescricoes", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Prescrições para todos os pacientes" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Prescrições</a>                
                                }
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ACESSO == 1)
                                {
                                    <a href="@Url.Action("MontarTelaAtestados", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Atestados para todos os pacientes" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Atestados</a>                
                                }
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_SOLICITACAO_ACESSO == 1)
                                {
                                    <a href="@Url.Action("MontarTelaSolicitacoes", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Solicitações de Exames para todos os pacientes" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Solicitações de Exames</a>                
                                }
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EXAME_ACESSO == 1)
                                {
                                    <a href="@Url.Action("MontarTelaExames", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Resultados de Exames para todos os pacientes" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Resultados de Exames</a>                
                                }
                                @if (ViewBag.ListaClienteAnivDiaConta > 0)
                                {
                                    <a href="@Url.Action("EnviarMailAniversario", "Paciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Aniversariantes" class="btn btn-sm btn-success btn-loading" id="emp" OnClick = "Fade()">Aniversariantes</a>                
                                }
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente")
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-2 col-md-2 col-xs-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: cornsilk; color:darkgreen">
                    <h5>Relatórios</h5>
                </div>
                <div class="ibox-content">
                    @using (Html.BeginForm("ProcessaRelatorioPaciente", "Paciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", autofocus = true }))
                    {
                        @Html.DropDownList("TIPO_RELATORIO", (SelectList)ViewBag.Relatorio, "Selecionar", new { @class = "form-control", autofocus = true })
                        <small>Selecione o Relatório</small>
                        <br />
                        <small>(*) Sensivel ao filtro especificado</small>
                        <br />
                        <br />
                        @Html.ButtonActionSubmit(text: "Gerar Relatório")
                    }
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Pacientes</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Nome</th>
                                        <th style="width: auto">CPF</th>
                                        <th style="width: auto">E-Mail</th>
                                        <th style="width: auto">Celular</th>
                                        <th style="width: auto">Cidade</th>
                                        <th style="width: auto">UF</th>
                                        <th style="width: auto">Menor</th>
                                        <th style="width: auto">Última Consulta</th>
                                        <th style="width: auto">Retorno Previsto</th>
                                        <th style="width: auto"></th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE>).OrderBy(p => p.PACI_NM_NOME))
                                    {
                                        if (cond.PACI_IN_ATIVO == 1)
                                        {
                                            if (cond.PACI__CD_ID != (Int32)Session["LinhaAlterada"])
                                            {
                                                <tr>
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                    {
                                                        <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EditarPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de Editar/Consultar paciente"/>@cond.PACI_NM_NOME</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("VerPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de Ver paciente"/>@cond.PACI_NM_NOME</td>
                                                    }

                                                    <td style="width: auto">@cond.PACI_NR_CPF</td>

                                                    @if (ViewBag.EMail == 1)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EnviarEMailPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de envio de e-mail ao paciente"/>@cond.PACI_NM_EMAIL</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">@cond.PACI_NM_EMAIL</td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">@cond.PACI_NM_EMAIL</td>
                                                    }

                                                    @if (ViewBag.SMS == 1)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EnviarSMSPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de envio de SMS ao paciente"/>@cond.PACI_NR_CELULAR</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">@cond.PACI_NR_CELULAR</td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">@cond.PACI_NR_CELULAR</td>
                                                    }

                                                    <td style="width: auto">@cond.PACI_NM_CIDADE</td>
                                                    @if (cond.UF != null)
                                                    {
                                                        <td style="width: auto">@cond.UF.UF_SG_SIGLA</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">-</td>
                                                    }

                                                    <td style="width: auto">
                                                        @if (cond.PACI_IN_MENOR == 1) // ATIVA
                                                        {
                                                            <span class="status-badge status-active">Sim</span>
                                                        }
                                                        else 
                                                        {
                                                            <span class="status-badge status-pending">Não</span>
                                                        }
                                                    </td>

                                                    @if (cond.PACI_DT_CONSULTA != null)
                                                    {
                                                        <td style="width: auto">@cond.PACI_DT_CONSULTA.Value.ToShortDateString()</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">-</td>
                                                    }

                                                    @if (cond.PACI_DT_PREVISAO_RETORNO != null)
                                                    {
                                                        <td style="width: auto">@cond.PACI_DT_PREVISAO_RETORNO.Value.ToShortDateString()</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">-</td>
                                                    }

                                                    @if (!String.IsNullOrEmpty(cond.PACI_AQ_FOTO))
                                                    {
                                                        // Tratamento manual da URL dentro do loop
                                                        var caminhoLimpo = cond.PACI_AQ_FOTO.Replace("~/", "").Replace("~", "");
                                                        var urlFinal = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + caminhoLimpo;

                                                        <td style="width: auto">
                                                            <img src="@urlFinal" 
                                                                    style="width: auto; height: auto; max-height: 75px; max-width: 65px;" 
                                                                    data-toggle="popover" data-trigger="hover" data-placement="top" 
                                                                    data-content="Clique Ctrl+Ctrl para ampliar a fotografia"
                                                                    onerror="this.onerror=null;this.src='@Url.Content("~/Images/icon_morador.png")';">
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">
                                                            <img src="~/Images/icon_morador.png" style="width: auto; height: auto; max-height: 65px; max-width: 55px;">
                                                        </td>
                                                    }

                                                    <td class="td-one-action">
                                                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACI__CD_ID, "EditarPaciente", "fa-edit", "Editar/Consultar Paciente")
                                                        }
                                                        else
                                                        {
                                                            @Html.TableLinkDetails(cond.PACI__CD_ID, "VerPaciente", "fa-search", "Consultar Paciente")
                                                        }
                                                        @if (cond.PACI_IN_ATIVO == 1)
                                                        {
                                                            if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EXCLUIR_PACIENTE == 1)
                                                            {
                                                                <span style="color: #337ab7; cursor:pointer;" alt="Excluir" class="tbl-link fa-lg fa fa-trash-o" onclick="ShowModalExcluir('/Paciente/ExcluirPaciente/@cond.PACI__CD_ID')" title="Excluir Paciente"></span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_REATIVA_CLIENTE == 1)
                                                            {
                                                                <span style="color: #337ab7; cursor:pointer;" alt="Reativar" class="tbl-link fa-lg fa fa-refresh" onclick="ShowModalReativar('/Paciente/ReativarPaciente/@cond.PACI__CD_ID')" title="Reativar Paciente"></span>
                                                            }
                                                        }
                                                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_INCLUIR == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACI__CD_ID, "IncluirPrescricaoDireto", "fa-file-powerpoint-o", "Nova Prescricao")
                                                        }
                                                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_INCLUIR == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACI__CD_ID, "IncluirAtestadoDireto", "fa-external-link", "Novo Atestado")
                                                        }
                                                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_SOLICITACAO_INCLUIR == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.PACI__CD_ID, "IncluirSolicitacaoDireto", "fa-certificate", "Nova Solicitação de Exame")
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                <tr style="background-color: beige">
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                    {
                                                        <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EditarPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de Editar/Consultar paciente"/>@cond.PACI_NM_NOME</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("VerPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de Ver paciente"/>@cond.PACI_NM_NOME</td>
                                                    }

                                    <td style="width: auto">@cond.PACI_NR_CPF</td>

                                                    @if (ViewBag.EMail == 1)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EnviarEMailPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de envio de e-mail ao paciente"/>@cond.PACI_NM_EMAIL</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">@cond.PACI_NM_EMAIL</td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">@cond.PACI_NM_EMAIL</td>
                                                    }

                                                    @if (ViewBag.SMS == 1)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EnviarSMSPaciente", "Paciente", new { id = cond.PACI__CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Abre a página de envio de SMS ao paciente"/>@cond.PACI_NR_CELULAR</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto">@cond.PACI_NR_CELULAR</td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto">@cond.PACI_NR_CELULAR</td>
                                                    }

                                    <td style="width: auto">@cond.PACI_NM_CIDADE</td>
                                    @if (cond.UF != null)
                                    {
                                        <td style="width: auto">@cond.UF.UF_SG_SIGLA</td>
                                    }
                                    else
                                    {
                                        <td style="width: auto">-</td>
                                    }
                                    <td style="width: auto">
                                        @if (cond.PACI_IN_MENOR == 1) // ATIVA
                                        {
                                            <span class="status-badge status-active">Sim</span>
                                        }
                                        else 
                                        {
                                            <span class="status-badge status-pending">Não</span>
                                        }
                                    </td>


                                    @*@if (cond.PACI_IN_MENOR == 1)
                                    {
                                        <td style="width: auto"><span class="badge badge-primary">Sim</span></td>
                                    }
                                    else
                                    {
                                        <td style="width: auto"><span class="badge badge-warning">Não</span></td>
                                    }*@

                                    @if (cond.PACI_DT_CONSULTA != null)
                                    {
                                        <td style="width: auto">@cond.PACI_DT_CONSULTA.Value.ToShortDateString()</td>
                                    }
                                    else
                                    {
                                        <td style="width: auto">-</td>
                                    }

                                    @if (cond.PACI_DT_PREVISAO_RETORNO != null)
                                    {
