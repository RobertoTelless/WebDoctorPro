@using Presentation.Extensions
@using EntitiesServices.Model
@model ERP_Condominios_Solution.ViewModels.PacienteViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Paciente - Visualização";
    ViewBag.MetaDescription = "WebDoctor - Paciente - Visualização de pacientes";
    ViewBag.MetaKeywords = "WebDoctor, paciente";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaCentralPaciente", "Paciente")">Central de Pacientes</a>
            </li>
            <li class="active">
                <strong>Pacientes - Consulta</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div class="row">
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Paciente - Consulta</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACI_NM_NOME</span>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-group">
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                        {
                            if (ViewBag.EMail == 1)
                            {
                                if (Model.PACI_NM_EMAIL != null)
                                {
                                    @Html.ButtonLinkIndex(text: "Enviar E-Mail", action: "EnviarEMailPacienteForm", controller: "Paciente")
                                }
                            }
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PAERF_IN_PACIENTE_MENSAGEM == 1)
                        {
                            if (ViewBag.SMS == 1)
                            {
                                if (Model.PACI_NR_CELULAR != null)
                                {
                                    @Html.ButtonLinkIndex(text: "Enviar SMS", action: "EnviarSMSPacienteForm", controller: "Paciente")
                                }
                            }
                        }
                        @Html.ButtonLinkIndex(text: "Histórico de Atividades", action: "MontarTelaPacienteHistorico", controller: "Paciente")
                        @Html.ButtonLinkIndex(text: "Informações do Paciente", action: "GerarRelatorioDetalhe", controller: "Paciente")
                        @if ((Int32)Session["VoltarPesquisa"] == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "PesquisarTudo", controller: "BaseAdmin")
                        }
                        else
                        {
                            if ((Int32)Session["IncluirConsultaArea"] == 2)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAreaPacienteVer", controller: "AreaPaciente",  htmlAttributes: new { @class = "btn-loading" })
                            }

                            if ((Int32)Session["TipoSolicitacao"] == 2)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaSolicitacoes", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 3)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAtestados", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 4)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaExames", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 5)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPrescricoes", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 8)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VerMedicamentosPacienteForm", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 12)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaHistoricoGeral", controller: "Paciente")
                            }
                            else if ((Int32)Session["TipoSolicitacao"] == 99)
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaAusencias", controller: "Paciente2")
                            }
                            else
                            {
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBasePaciente", controller: "Paciente")
                            }
                        }
