                                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Consultas</h4>
                                                    <br />
                                                    @if (Model.PACIENTE_CONSULTA.Where(p => p.PACO_IN_ATIVO == 1).ToList().Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-consulta">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th style="width: auto">Data da Consulta</th>
                                                                    <th style="width: auto">Hora de Início</th>
                                                                    <th style="width: auto">Hora de Término </th>
                                                                    <th style="width: auto">Tipo</th>
                                                                    <th style="width: 0.01px"></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.PACIENTE_CONSULTA.Where(p => p.PACO_IN_ATIVO == 1).OrderByDescending(p => p.PACO_DT_CONSULTA)))
                                                                {
                                                                    if (cond.PACO_DT_CONSULTA > DateTime.Today.Date)
                                                                    {
                                                                        <tr>
                                                                            <td style="width: auto">@cond.PACO_DT_CONSULTA.ToShortDateString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                                            @if (cond.PACO_IN_TIPO == 1)
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-primary">Presencial</span></td>
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-success">Remota</span></td>
                                                                            }
                                                                        </tr>
                                                                    }
                                                                    else if (cond.PACO_DT_CONSULTA < DateTime.Today.Date)
                                                                    {
                                                                        <tr style="background-color: beige">
                                                                            <td style="width: auto">@cond.PACO_DT_CONSULTA.ToShortDateString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                                            @if (cond.PACO_IN_TIPO == 1)
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-primary">Presencial</span></td>
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-success">Remota</span></td>
                                                                            }
                                                                        </tr>
                                                                    }
                                                                    else
                                                                    {
                                                                        <tr style="background-color: aliceblue">
                                                                            <td style="width: auto">@cond.PACO_DT_CONSULTA.ToShortDateString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>
                                                                            @if (cond.PACO_IN_TIPO == 1)
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-primary">Presencial</span></td>
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="width: auto"><span class="badge badge-success">Remota</span></td>
                                                                            }
                                                                        </tr>
                                                                    }

                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                    else
                                                    {
                                                        <div class="row">
                                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                                            </div>
                                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                                                <h2 style="font-weight: bold">Nenhuma consulta cadastrada para esse paciente</h2>
                                                            </div>
                                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
