@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.NoticiaViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title"> 
        <h3 class="title">Notícias</h3> 
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaNoticia", "Noticia")">Notícias</a>
            </li>
            <li class="active">
                <strong>Notícias - Alteração</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Notícias - Alteração</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        <div class="col-lg-10 col-md-10 col-xs-12">   
                            <div class="form-group">
                                <h4>Foto</h4>
                                @using (Html.BeginForm("UploadFotoNoticia", "Noticia", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { enctype = "multipart/form-data", @id="pwd-container3" }))
                                {
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        <input style="float: left; margin-right: 5px;" type="file" accept=".jpg, .png, .jpeg, .gif|images/*" name="file" id="file" class="btn btn-sm btn-warning"/>
                                        <input style="float: left;" type="submit" value="Incluir Foto da Notícia" class="btn btn-sm btn-success" />
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-xs-12">
                            <div class="form-group">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <br />
                                    @*@if (!String.IsNullOrEmpty(Model.NOTC_AQ_FOTO))
	                                {
                                        <img src="@Url.Content(Model.NOTC_AQ_FOTO)" style = "width: auto; height: auto; max-height: 190px; max-width: 120px;">
                                    }
                                    else
                                    {
                                        <img src="~/Images/p_big2.jpg" style = "width: auto; height: auto; max-height: 110px; max-width: 90px;">
                                    }*@

                                    @if (Model.NOTC_AQ_FOTO.Contains("p_big2.png"))
	                                {
                                        <img src="~/Images/p_big2.jpg" 
                                                class="img-responsive thumbnail" 
                                                style="max-height: 230px; margin: 0 auto;">
                                    }
                                    else
                                    {
                                        if (!String.IsNullOrEmpty(Model.NOTC_AQ_FOTO))
                                        {
                                            <img src="@Model.FotoAzureUrl" 
                                                    class="img-responsive thumbnail" 
                                                    style="max-height: 270px; margin: 0 auto;">
                                        }
                                        else
                                        {
                                            <img src="~/Images/icon_morador.png" 
                                                    class="img-responsive thumbnail" 
                                                    style="max-height: 230px; margin: 0 auto;">
                                        }
                                    }
                                </div>                       
                            </div>
                        </div>
                    </div>
                    <hr />
                    @Html.AntiForgeryToken()
                    @using (Html.BeginForm("EditarNoticia", "Noticia", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                    {
                        <div class="form-group">
                            @Html.ButtonActionSubmit(text: "Confirma Alteração da Notícia", htmlAttributes: new { id = "basictoast", @class = "btn-loading1"})
                            @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaNoticia", controller: "Noticia", htmlAttributes: new { @class = "btn-loading" })
                            <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                <i class="fa fa-spinner fa-spin"></i> Processando...
                            </span>
                        </div>
                        <div class="row">
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-8 col-md-8 col-xs-12">
                                    @Html.HiddenFor(m => m.NOTC_CD_ID)
                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                    @Html.HiddenFor(m => m.NOTC_IN_ATIVO)
                                    @Html.HiddenFor(m => m.NOTC_NR_ACESSO)
                                    @Html.HiddenFor(m => m.NOTC_IN_SISTEMA)
                                    @Html.HiddenFor(m => m.NOTC_AQ_FOTO)
                                    Título*
                                    @Html.TextBoxFor(m => m.NOTC_NM_TITULO, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o título da notícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_NM_TITULO, "", new { @style = "color:red" })
                                </div>
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Autor*
                                    @Html.TextBoxFor(m => m.NOTC_NM_AUTOR, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o autor da nptícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_NM_AUTOR, "", new { @style = "color:red" })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data de Emissão*
                                    @Html.TextBoxFor(m => m.NOTC_DT_EMISSAO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", @id = "dn", autofocus = true, data_toggle = "popover", data_content = "Informe a data de publicação da notícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_DT_EMISSAO, "",new { @style="color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data de Validade*
                                    @Html.TextBoxFor(m => m.NOTC_DT_VALIDADE, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", @id = "dn1", autofocus = true, data_toggle = "popover", data_content = "Informe a data limite de validade da notícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_DT_VALIDADE, "",new { @style="color:red" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data de Autoria
                                    @Html.TextBoxFor(m => m.NOTC_DT_DATA_AUTOR, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", @id = "dn2", autofocus = true, data_toggle = "popover", data_content = "Informe a data da autoria da notícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_DT_DATA_AUTOR, "",new { @style="color:red" })
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Origem
                                    @Html.TextBoxFor(m => m.NOTC_NM_ORIGEM, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe a origem da notícia, caso seja externa", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_NM_ORIGEM, "",new { @style="color:red" })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    Link Externo
                                    @Html.TextBoxFor(m => m.NOTC_LK_LINK, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o link (URL) para o site original da notícia", data_trigger="hover", data_placement="top" })
                                    @Html.ValidationMessageFor(m => m.NOTC_LK_LINK, "",new { @style="color:red" })
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    Conteúdo da Notícia
                                    @Html.TextAreaFor(m => m.NOTC_TX_TEXTO, new { @class = "form-control", style = "width: 100%; height: 500px; overflow:auto;", autofocus = true, data_toggle = "popover", data_content = "Informe o conteúdo da notícia", data_trigger="hover", data_placement="top"})
                                    @Html.ValidationMessageFor(m => m.NOTC_TX_TEXTO, "", new { @style = "color:red" })
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-3.1.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
            .css("display", "normal")
            .next("button").button({
                icons: { primary: "ui-icon-calendar" },
                label: "Selecione uma data",
                text: false 
            });
        });
    </script>  

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Alteração em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                        + shortCutFunction
                        + "](\""
                        + msg
                        + (title ? "\", \"" + title : '')
                        + "\")\n\ntoastr.options = "
                        + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
