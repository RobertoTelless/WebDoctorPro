    <script>
        function GetFornecedor(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '/Estoque/GetFornecedor'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nomeForn > input').val(r.nome);
                    $('#cidadeForn > input').val(r.cidade);
                    $('#ufForn > input').val(r.uf);

                    $('#nomeForn').show();
                    $('#cidadeForn').show();
                    $('#ufForn').show();
                }
            });
        }
    </script>
