@using Presentation.Extensions
@using CrossCutting;
@using EntitiesServices.Work_Classes;
@model ERP_Condominios_Solution.ViewModels.MovimentoEstoqueProdutoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Estoques</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaEstoque", "Estoque")">Central de Estoque</a>
            </li>
            <li class="active">
                <strong>Estoque - Movimentação</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página da de inclusão de movimentação de estoque de produtos do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Permite a inclusão de uma movimentação de estoque para um produto cadastrado.</li>
                        <li>Permite a inclusão de movimentações de entrada ou de saída.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    @if (ViewBag.TipoInclusao == 1)
                    {
                        <div class="row">
                            <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                                <h5>Material/Produto - Nova Movimentação de Estoque</h5>
                                <span style="color:green; font-weight: 500; font-size: 20px;">@ViewBag.Nome</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <h5>Material/Produto - Nova Movimentação de Estoque</h5>
                    }
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="tabs-container">
                        @using (Html.BeginForm("IncluirMovimentacaoProduto", "Estoque", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                        {

                            <div class="form-group">
                                <br />
                                @Html.ButtonActionSubmit(text: "Confirmar inclusão da movimentação", htmlAttributes: new { @class = "btn-loading1" })
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBaseEstoque", controller: "Estoque", htmlAttributes: new { @class = "btn-loading" })
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>

                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#tab-1">Informações da Movimentação</a></li>
                            </ul>

                            <div class="tab-content">
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                    @if (ViewBag.TipoInclusao == 1)
                                                    {
                                                        @Html.HiddenFor(m => m.PROD_CD_ID)
                                                    }
                                                    @Html.HiddenFor(m => m.EMPR_CD_ID)
                                                    @Html.HiddenFor(m => m.EMFI_CD_ID)
                                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                                    @Html.HiddenFor(m => m.MOEP_VL_QUANTIDADE_ANTERIOR)
                                                    @Html.HiddenFor(m => m.MOEP_IN_ORIGEM)
                                                    @Html.HiddenFor(m => m.MOEP_IN_ATIVO)
                                                    Tipo de Movimento*
                                                    @Html.DropDownListFor(m => m.MOEP_IN_TIPO_MOVIMENTO, (SelectList)ViewBag.ES, "Selecionar", new { @class = "form-control", autofocus = true, @id = "es", onchange = "ValidaDiv($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_TIPO_MOVIMENTO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="entrada">
                                                    Tipo de Entrada*
                                                    @Html.DropDownListFor(m => m.MOEP_IN_TIPO, (SelectList)ViewBag.Entradas, "Selecionar", new { @class = "form-control", autofocus = true, @id = "ent", onchange = "ValidaEntrada($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_TIPO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="saida">
                                                    Tipo de Saída*
                                                    @Html.DropDownListFor(m => m.MOEP_IN_TIPO_1, (SelectList)ViewBag.Saidas, "Selecionar", new { @class = "form-control", autofocus = true, @id = "sai", onchange = "ValidaSaida($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_TIPO_1, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Responsável*
                                                    @Html.DropDownListFor(m => m.USUA_CD_ID, (SelectList)ViewBag.Usuarios, "Selecionar", new { @class = "form-control", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.USUA_CD_ID, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data da Movimentação*
                                                    @Html.TextBoxFor(m => m.MOEP_DT_MOVIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_DT_MOVIMENTO, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>                                    

                                        @if (ViewBag.TipoInclusao == 2)
                                        {
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Material/Produto</h4>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                                        Nome do Material/Produto*
                                                        <select name="PROD_CD_ID" id="lstCliente" class="form-control" data-val="true" style="display: none;">
                                                        </select>
                                                        @Html.ValidationMessageFor(m => m.PROD_CD_ID, "", new { @style = "color:red" })
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="row">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Material/Produto</h4>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                                        @Html.TextBoxFor(m => m.MOEP_DS_PRODUTO, new { @class = "form-control", autofocus = true, @readonly = "readonly", style = "color: brown; font-weight: bold;" })
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Movimentação</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-1 col-md-1 col-xs-12">
                                                    Quantidade*
                                                    @Html.TextBoxFor(m => m.MOEP_QN_QUANTIDADE, new { @class = "form-control", autofocus = true, onfocus="this.select();" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_QN_QUANTIDADE, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12" id="forn">
                                                    Fornecedor
                                                    @Html.TextBoxFor(m => m.MOEP_NM_FORNECEDOR, new { @class = "form-control", autofocus = true, onfocus="this.select();" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_NM_FORNECEDOR, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="valor">
                                                    Valor (R$)
                                                    @Html.TextBoxFor(m => m.MOEP_VL_VALOR_MOVIMENTO, new { @class = "form-control", autofocus = true, onfocus="this.select();" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_VL_VALOR_MOVIMENTO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="pag">
                                                    Gera Pagamento*
                                                    @Html.DropDownListFor(m => m.MOEP_IN_OPERACAO, (SelectList)ViewBag.CP, "Selecionar", new { @class = "form-control", autofocus = true, @id = "gera", onchange = "ValidaPag($(this).val())" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_OPERACAO, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="tipo">
                                                    Tipo de Pagamento
                                                    @Html.DropDownListFor(m => m.MOEP_IN_AUTORIZADOR_T, (SelectList)ViewBag.TipoPag, "Selecionar", new { @class = "form-control", autofocus = true, @id = "tipo" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_AUTORIZADOR_T, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" id="quita">
                                                    Pagamento Quitado
                                                    @Html.DropDownListFor(m => m.MOEP_IN_AUTORIZADOR, (SelectList)ViewBag.Quitado, "Selecionar", new { @class = "form-control", autofocus = true, @id = "quita" })
                                                    @Html.ValidationMessageFor(m => m.MOEP_IN_AUTORIZADOR, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>    
                                        
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Justificativa</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Justificativa*
                                                    @Html.TextAreaFor(m => m.MOEP_DS_JUSTIFICATIVA, new { @class = "form-control", style = "width: 100%; height: 200px;", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.MOEP_DS_JUSTIFICATIVA, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
