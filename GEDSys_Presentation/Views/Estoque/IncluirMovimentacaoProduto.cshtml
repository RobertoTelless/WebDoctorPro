                $("#valor").hide();
                $("#venda").hide();
                $("#pag").hide();
                $("#pag").hide();
                $("#tipo").hide();
                $("#quita").hide();
            } else if (valTipo == '8') { 
                $("#forn").hide();
                $("#valor").hide();
                $("#venda").hide();
                $("#pag").hide();
                $("#pag").hide();
                $("#tipo").hide();
                $("#quita").hide();
            }
        }

        $(document).ready(function () {
            ValidaSaida($('#sai').val());
        });
    </script>

