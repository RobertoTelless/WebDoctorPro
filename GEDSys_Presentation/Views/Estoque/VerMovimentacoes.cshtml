@using Presentation.Extensions
@using CrossCutting;
@using EntitiesServices.Work_Classes;
@model EntitiesServices.Model.MOVIMENTO_ESTOQUE_PRODUTO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="containerModalDesc">
        <div class="modal fade" id="modalDesc" tabindex="-1" role="dialog" aria-labelledby="modalDesc" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalDesc">Justificativa da Movimentação</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div id="modalDescBody" class="modal-body">

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Estoques</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaEstoque", "Estoque")">Central de Estoque</a>
            </li>
            <li class="active">
                <strong>Movimentação de Estoque</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarMovimento", "Estoque", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Movimento
                                @Html.DropDownListFor(m => m.MOEP_IN_TIPO_MOVIMENTO, (SelectList)ViewBag.ES, "Selecionar", new { @class = "form-control", autofocus = true, @id = "es", onchange = "ValidaDiv($(this).val())" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12" id="entrada">
                                Tipo de Entrada
                                @Html.DropDownListFor(m => m.MOEP_IN_TIPO, (SelectList)ViewBag.Entradas, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12" id="saida">
                                Tipo de Saída
                                @Html.DropDownListFor(m => m.MOEP_IN_OPERACAO, (SelectList)ViewBag.Saidas, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Responsável
                                @Html.DropDownListFor(m => m.USUA_CD_ID, (SelectList)ViewBag.Usuarios, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-5 col-md-5 col-xs-12">
                                Nome do Material/Produto
                                @Html.TextBoxFor(m => m.MOEP_DS_JUSTIFICATIVA, new { @class = "form-control", autofocus = true, @id = "txtNomeProduto" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Início
                                @Html.TextBoxFor(m => m.MOEP_DT_DATA_DUMMY_1, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data1", data_toggle = "popover", data_content = "Informe a data inicial da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.MOEP_DT_DATA_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data2", data_toggle = "popover", data_content = "Informe a data final da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">                                     
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Estoque", action: "RetirarFiltroMovimento", htmlAttributes: new { @class = "btn-loading" })
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUIR_MOVIMENTACAO_ESTOQUE == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Nova Movimentação", controller: "Estoque", action: "IncluirMovimentacaoGeral", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })
                                }
                                @Html.ButtonLinkIndex(text: "Imprimir", controller: "Estoque", action: "GerarListagemMovimentacaoProduto")
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaEstoque", controller: "Estoque", htmlAttributes: new { @class = "btn-loading" })                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12"  id="Lista">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div class="row">
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Movimentações de Estoque</h5>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.MOVIMENTO_ESTOQUE_PRODUTO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Tipo</th>
                                        <th style="width: auto">Classe</th>
                                        <th style="width: auto">Data</th>
                                        <th style="width: auto">Material/Produto</th>
                                        <th style="width: auto">Código</th>
                                        <th style="width: auto">Quantidade</th>
                                        <th style="width: auto">Identificador</th>
                                        <th style="width: auto">Responsável</th>
                                        <th style="width: auto" class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.MOVIMENTO_ESTOQUE_PRODUTO>).OrderByDescending(p => p.MOEP_DT_MOVIMENTO))
                                    {
                                        <tr>  
                                            <td style="width: auto">
                                                @if (cond.MOEP_IN_TIPO_MOVIMENTO == 1) // ATIVA
                                                {
                                                    <span class="status-badge status-active">Entrada</span>
                                                }
                                                else 
                                                {
                                                    <span class="status-badge status-pending">Saída</span>
                                                }
                                            </td>
                                          
                                            @*@if (cond.MOEP_IN_TIPO_MOVIMENTO == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Entrada</span></td>
                                            }
                                            else
                                            {
                                                <td style="width: auto"><span class="badge badge-warning">Saída</span></td>
                                            }*@
                                            <td style="width: auto">
                                                @if (cond.MOEP_IN_TIPO == 1) // ATIVA
                                                {
                                                    <span class="status-badge status-active">Compra</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 2)
                                                {
                                                    <span class="status-badge status-active">Devolução de venda</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 3)
                                                {
                                                    <span class="status-badge status-active">Retorno de manutenção</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 4)
                                                {
                                                    <span class="status-badge status-active">Acerto Manual</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 5)
                                                {
                                                    <span class="status-badge status-finish">Descarte</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 6)
                                                {
                                                    <span class="status-badge status-finish">Perda</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 7)
                                                {
                                                    <span class="status-badge status-finish">Envio para Manutenção</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 8)
                                                {
                                                    <span class="status-badge status-finish">Acerto Manual</span>
                                                }
                                                else  if (cond.MOEP_IN_TIPO == 9)
                                                {
                                                    <span class="status-badge status-finish">Material de Consulta</span>
                                                }
                                                else 
                                                {
                                                    <span class="status-badge status-overdue">-</span>
                                                }
                                            </td>

                                            @*<td style="cursor: pointer; text-decoration: underline; color: #337ab7; width: auto" onclick="mostrarDesc('@cond.MOEP_DS_JUSTIFICATIVA')" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Ver a justificativa da movimentação de estoque">*@
                                            <td style="cursor: pointer; text-decoration: underline; color: #337ab7; width: auto"  onclick="mostrarDesc('@cond.MOEP_DS_JUSTIFICATIVA')" >
                                                <span style="display:none; width: auto">@cond.MOEP_DT_MOVIMENTO.ToString("yyyyMMdd")</span>
                                                @cond.MOEP_DT_MOVIMENTO.ToString("dd/MM/yyyy")
                                            </td>
                                            <td style="width: auto">@cond.PRODUTO.PROD_NM_NOME</td>
                                            <td style="width: auto">@cond.PRODUTO.PROD_CD_CODIGO</td>
                                            <td style="width: auto">@cond.MOEP_QN_QUANTIDADE</td>
                                            <td style="width: auto">@cond.MOEP_GU_GUID</td>
                                            <td style="width: auto">@cond.USUARIO.USUA_NM_NOME</td>

                                            <td style="width: auto" class="td-one-action">
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_VER_MOVIMENTACAO_ESTOQUE == 1)
                                                {
                                                    @Html.TableLinkDetails(cond.MOEP_CD_ID, "VerMovimentacaoEstoque", "fa-search btn-loading", "Ver Movimentação")
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Nenhuma movimentação atendeu ao filtro especificado ou nenhuma movimentação de estoque registrada</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Estoque", action: "RetirarFiltroMovimento", htmlAttributes: new { @class = "btn-loading" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

        <style>
        /* Estilo Base */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-badge::before {
            content: "";
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-right: 6px;
        }

        /* PENDING (Gold) - Status 0 */
        .status-pending { background-color: #fef9c3; color: #a16207; }
        .status-pending::before { background-color: #ca8a04; }

        /* ACTIVE (Green) - Status 1 */
        .status-active { background-color: #dcfce7; color: #15803d; }
        .status-active::before { background-color: #16a34a; }

        /* CANCEL (Red) - Status 4 */
        .status-cancel { background-color: #fee2e2; color: #b91c1c; }
        .status-cancel::before { background-color: #dc2626; }

        /* FINISH (Dark Blue) - Status 2 */
        .status-finish { background-color: #dbeafe; color: #1e40af; }
        .status-finish::before { background-color: #2563eb; }

        /* OVERDUE (Gray) - Status 3 */
        .status-overdue { background-color: #f3f4f6; color: #4b5563; }
        .status-overdue::before { background-color: #6b7280; }
    </style>

}

@section Scripts {

    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script>
        function mostrarDesc(desc) {
            $('#modalDescBody').html(desc);
            $('#modalDesc').modal('show');
        }
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtNomeProduto').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetProdutoNome", "Produto")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>

    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluir(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Movimentação?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                columnDefs: [
                    {
                        // Altera o tipo de ordenação para a primeira coluna (índice 0)
                        //"type": "datetime-moment", // Se você incluiu o momento.js
                        // OU
                         "type": "date-eu", // Para o formato DD/MM/AAAA
                        "targets": 2 // Aplica à coluna "Data da Transação"
                    }
                ],
                // ---------------------------------       
                buttons: [
                    { extend: 'excel', title: 'MovEstoque_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });      
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#data1").mask("99/99/9999");
            $("#data2").mask("99/99/9999");
        });
    </script>

    <script type="text/javascript">
        function ValidaDiv(valTipo) {
            if (valTipo == '1') {
                $("#entrada").show();
                $("#saida").hide();
            } else if (valTipo == '2') { 
                $("#entrada").hide();
                $("#saida").show();
            } else { 
                $("#entrada").hide();
                $("#saida").hide();
            }
        }

        $(document).ready(function () {
            ValidaDiv($('#es').val());
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

