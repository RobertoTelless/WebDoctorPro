@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.LOG
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Auditoria";
    ViewBag.MetaDescription = "WebDoctor - Registros de Auditoria";
    ViewBag.MetaKeywords = "WebDoctor, Auditoria, Log";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title"> 
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Auditoria</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Registros de Auditoria</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.LogsDataCorrente</h1>
                    <small>Data Corrente</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Mensal</span>
                    <h5>Registros de Auditoria</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.LogsMesCorrente</h1>
                    <small>Mês Corrente</small>
                </div>
            </div>
        </div>

        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Mensal</span>
                    <h5>Registros de Auditoria</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.LogsMesAnterior</h1>
                    <small>Mês Anterior</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>           
            
                @using (Html.BeginForm("FiltrarLog", "Auditoria", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger">
                                    <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                                </div>
                            }
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-3 col-md-3 col-xs-12">
                                    Operação
                                    @Html.TextBoxFor(m => m.LOG_NM_OPERACAO, new { @class = "form-control", autofocus = true })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Inicial
                                    @Html.TextBoxFor(m => m.LOG_DT_DATA, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Final
                                    @Html.TextBoxFor(m => m.LOG_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn1" })
                                </div>
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Usuário
                                    @Html.DropDownListFor(m => m.USUA_CD_ID, (SelectList)ViewBag.Usuarios, "Selecionar", new { @class = "form-control" , autofocus = true })                            
                                </div>
                            </div>
                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @Html.ButtonActionSubmit(text: "Filtrar")
                                    @Html.ButtonLinkIndex(text: "Ver Mês Corrente", controller: "Auditoria", action: "RetirarFiltroLog")
                                    @Html.ButtonLinkIndex(text: "Ver Mês Anterior", controller: "Auditoria", action: "VerMesAnterior")
                                    @Html.ButtonLinkIndex(text: "Ver Últimos 12 Meses", controller: "Auditoria", action: "VerTodosLog")
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente")
                                </div>
                            </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9 col-md-9 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Auditoria - Registros de Log</h5>
                </div>
                <div class="ibox-content">
                    <div class="row">
                        @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.LOG>).Count > 0)                                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style ="background-color:lightsteelblue">
                                    <tr>
                                        <th>Data da Transação</th>
                                        <th>Sigla da Operação</th>   
                                        <th>Usuário</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.LOG>).OrderByDescending(p => p.LOG_DT_DATA))
                                    {
                                        <tr>
                                            <td style="width: 120px" data-order="@cond.LOG_DT_DATA.Value.ToString("yyyy-MM-dd HH:mm:ss")">
                                                @cond.LOG_DT_DATA.Value.ToShortDateString() @cond.LOG_DT_DATA.Value.ToShortTimeString()
                                            </td>
                                            <td>@cond.LOG_DT_DATA</td>
                                            <td>@cond.LOG_NM_OPERACAO</td>
                                            <td>@cond.USUARIO.USUA_NM_NOME</td>
                                            <td class="td-one-action">
                                                @Html.TableLinkDetails(cond.LOG_CD_ID, "VerLog","fa-search", "Ver Registro de Auditoria")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhum registro de auditoria disponível</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Log", action: "RetirarFiltroLog")
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                            </div>
                        }
                     </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-3 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="row">
                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Registros de Auditoria</h4>
                    <ul style="margin:0; padding-left:20px; list-style-type:disc;">
                        <li style="margin-bottom:2px; line-height:1.1;">Todas as transações executadas dentro do <b>WebDoctor</b> são registradas para verificação e auditoria.</li>
                        <li style="margin-bottom:2px; line-height:1.1;">Entende-se por transação, toda a operação executada pelo <b>WebDoctor</b> que cause alteração de algum valor na base de dados, como por exemplo a inclusão de qualquer informação.</li>
                        <li style="margin-bottom:2px; line-height:1.1;">As transações executadas nos últimos 365 dias estarão sempre disponíveis para consulta</li>
                        <li style="margin-bottom:2px; line-height:1.1;">Inicialmente são sempre exibidas as transações executadas no mês corrente</li>
                        <li style="margin-bottom:2px; line-height:1.1;">A exibição das transações executadas nos últimos 365 dias poderá demorar alguns instantes para carregar</li>
                    </ul>                                                               
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
}

@section Scripts {
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
    
    <script type="text/javascript">
        $(function () {
            $('.date-picker').mask('99/99/9999');
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
        });
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
            .css("display", "normal")
            .next("button").button({
                icons: { primary: "ui-icon-calendar" },
                label: "Selecione uma data",
                text: false 
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
                columnDefs: [
                    {
                        // Altera o tipo de ordenação para a primeira coluna (índice 0)
                        "type": "datetime-moment", // Se você incluiu o momento.js
                        // OU
                        // "type": "date-eu", // Para o formato DD/MM/AAAA
                        "targets": 0 // Aplica à coluna "Data da Transação"
                    }
                ],
                // ---------------------------------       

                buttons: [
                    { extend: 'excel', title: 'Auditoria_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

