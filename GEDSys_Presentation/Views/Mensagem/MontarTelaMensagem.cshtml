@using Presentation.Extensions
@using CrossCutting;
@using EntitiesServices.Work_Classes;
@model EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Mensagens</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Central de Mensagens</strong>
            </li>
        </ol>
        <br />
    </div>

    @*Widgets*@
    <br />
    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: cornflowerblue; color: darkgreen">
                    <span class="label label-success pull-right">Hoje</span>
                    <h5>Mensagens</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.TotalMails</h1>
                    <small>E_Mails - Total</small>
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: cornflowerblue; color: darkgreen">
                    <span class="label label-success pull-right">Hoje</span>
                    <h5>Mensagens</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.TotalSMS</h1>
                    <small>SMS - Total</small>
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: cornflowerblue; color: darkgreen">
                    <span class="label label-success pull-right">Hoje</span>
                    <h5>Mensagens</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.TotalWhatsApp</h1>
                    <small>WhatsApp - Total</small>
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div style="display: none; z-index:1000" class="dotContainer">
                <div class="spiner-example">
                    <div class="sk-spinner sk-spinner-three-bounce">
                        <div class="sk-bounce1"></div>
                        <div class="sk-bounce2"></div>
                        <div class="sk-bounce3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarMensagem", "Mensagem", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Paciente
                                @Html.DropDownListFor(m => m.PACI_CD_ID, (SelectList)ViewBag.Pacientes, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.MEEN_DT_DATA_ENVIO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "data2" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.MEEN_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "data3" })
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Título
                                @Html.TextBoxFor(m => m.MEEN_NM_TITULO, new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @Html.ButtonLinkIndex(text: "Ver Hoje", controller: "Mensagem", action: "MostrarMensagemHoje", buttonClass: "warning", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                                @Html.ButtonLinkIndex(text: "Ver Mês Corrente", controller: "Mensagem", action: "RetirarFiltroMensagem", buttonClass: "warning", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                                @Html.ButtonLinkIndex(text: "Ver Todos os Meses", controller: "Mensagem", action: "MostrarMesesMensagem", buttonClass: "warning", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", buttonClass: "warning", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <button type="button" class="close" data-dismiss="alert">Fechar</button>
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Central de Mensagens</h5>
                </div>
                <div class="ibox-content">
                    <div class="col-lg-6 col-md-6 col-xs-12">
                        <div class="col-lg-12 col-md-12 col-xs-12">
                            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                <div class="ibox-title">
                                    <h4>Mensagens Enviadas - E-Mails</h4>
                                </div>
                                <div class="ibox-content">
                                    <div class="row">
                                        @if (ViewBag.Mails != null && (ViewBag.Mails as List<EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA>).Count > 0)
                                        {
                                            <table class="table table-striped table-bordered table-hover dataTables-mail">
                                                <thead style="background-color:lightsteelblue">
                                                    <tr>
                                                        <th style="width: auto">Data Criação</th>
                                                        <th style="width: auto">Nome da Mensagem</th>
                                                        <th style="width: auto">Destino</th>
                                                        <th style="width: auto">E-Mail</th>
                                                        <th style="width: auto">Envio/Rec.</th>
                                                        <th style="width: auto">Identificador</th>
                                                        <th class="td-one-action">Ações</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var cond in (ViewBag.Mails as List<EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA>))
                                                    {
                                                        <tr>
                                                            <td style="width: auto">@cond.MEEN_DT_DATA_ENVIO.Value.ToShortDateString() @cond.MEEN_DT_DATA_ENVIO.Value.ToShortTimeString()</td>
                                                            <td style="width: auto">@cond.MEEN_NM_TITULO</td>
                                                            @if (cond.PACIENTE != null)
                                                            {
                                                                <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                                                <td style="width: auto">@cond.MEEN_EM_EMAIL_DESTINO</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">-</td>
                                                                <td style="width: auto">-</td>
                                                            }
                                                            @if (cond.MEEN_IN_ESCOPO == 1)
                                                            {
                                                                <td style="width: auto">Recebimento</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="width: auto">Envio</td>
                                                            }
                                                            <td style="width: auto">@cond.MEEN_ID_IDENTIFICADOR</td>
                                                            <td style="width: auto" class="td-one-action">
                                                                @Html.TableLinkDetails(cond.MEEN_CD_ID, "VerMensagemEnviada", "fa-search", "Ver Mensagem")
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div class="row">
                                                <div class="col-lg-1 col-md-1 col-xs-12">
                                                </div>
                                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                    <h4 style="font-weight: bold">Nenhuma mensagem de E-Mail selecionada</h4>
                                                </div>
                                                <div class="col-lg-1 col-md-1 col-xs-12">
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>                          
                    </div>

                    <div class="col-lg-6 col-md-6 col-xs-12">

                    </div>








                </div>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    <link href="~/Content/jquery.datetimepicker.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    <link href="~/Content/jquery-ui-timepicker-addon.min.css" rel="stylesheet" />
}

@section Scripts {

    <script src="~/Scripts/jquery.datetimepicker.full.min.js"></script>
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.datetimepicker"></script>
    <script src="~/Scripts/jquery-ui-timepicker-addon.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    @Scripts.Render("~/plugins/sparkline")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>

    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-mail').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'MensagemEMail_Planilha' },

                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                .addClass('compact')
                                .css('font-size', 'inherit');
                        }
                    }
                ]
            });
        });

    </script>
    <script type="text/javascript">
        $(function () {
            $("#data1").mask("99/99/9999");
            $("#data2").mask("99/99/9999");
            $("#data3").mask("99/99/9999");
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

