                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }*@
                                                <td style="width: auto" class="td-one-action">
                                                    @if (cond.COPA_IN_PAGO == 0)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                        {
                                                                @Html.TableLinkDetails(cond.COPA_CD_ID, "EditarPagamento", "fa-edit btn-loading", "Alterar/Quitar")
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.COPA_CD_ID, "VerPagamento", "fa-search btn-loading", "Ver")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_EXCLUIR == 1)
                                                    {
                                                        if (cond.COPA_IN_ATIVO == 1 & cond.COPA_IN_PAGO == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Financeiro/ExcluirPagamento/@cond.COPA_CD_ID')" title="Excluir"></span>
                                                        }
	                                                }
                                                </td>
                                            </tr>
                                        }
                                        else if (cond.COPA_DT_VENCIMENTO < DateTime.Today.Date & cond.COPA_IN_PAGO == 0)
                                        {
                                            <tr style="background-color: antiquewhite">
                                                <td>
