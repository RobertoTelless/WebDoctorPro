                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.COPA_CD_ID, "EditarPagamento", "fa-edit btn-loading", "Alterar/Quitar")
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.COPA_CD_ID, "VerPagamento", "fa-search btn-loading", "Ver")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_EXCLUIR == 1)
                                                    {
                                                        if (cond.COPA_IN_ATIVO == 1 & cond.COPA_IN_PAGO == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Financeiro/ExcluirPagamento/@cond.COPA_CD_ID')" title="Excluir"></span>
                                                        }
	                                                }
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>
                                                    <span style="display:none; width: auto">@cond.COPA_DT_VENCIMENTO.Value.ToString("yyyyMMdd")</span>
                                                    @cond.COPA_DT_VENCIMENTO.Value.ToString("dd/MM/yyyy")
                                                </td>
                                                @if (cond.COPA_DT_PAGAMENTO != null)
                                                {
                                                    <td style="width: auto">@cond.COPA_DT_PAGAMENTO.Value.ToShortDateString()</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">Em Aberto</td>
                                                }
                                                <td style="width: auto">@cond.TIPO_PAGAMENTO.TIPA_NM_PAGAMENTO</td>
                                                @if (cond.COPA_IN_PAGO == 0)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                    {
                                                        <td style="width: auto"><a href="@Url.Action("EditarPagamento", "Financeiro", new { id = cond.COPA_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição/quitação do pagamento"/>@cond.COPA_GU_GUID</td>
                                                    }
                                                    else
                                                    {
                                                        <td style="width: auto"><a href="@Url.Action("VerPagamento", "Financeiro", new { id = cond.COPA_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de consulta do pagamento"/>@cond.COPA_GU_GUID</td>
                                                    }
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><a href="@Url.Action("VerPagamento", "Financeiro", new { id = cond.COPA_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de consulta do pagamento"/>@cond.COPA_GU_GUID</td>
                                                }
                                                <td style="width: auto">@cond.COPA_NM_NOME</td>
                                                <td style="width: auto">@cond.COPA_NM_FAVORECIDO</td>
                                                @if (cond.COPA_IN_PAGO == 0)
                                                {
                                                    <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.COPA_VL_VALOR.Value)</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.COPA_VL_PAGO.Value)</td>
                                                }
                                                <td style="width: auto">
                                                    @if (cond.COPA_IN_PAGO == 1) // ATIVA
                                                    {
                                                        <span class="status-badge status-active">Sim</span>
                                                    }
                                                    else 
                                                    {
                                                        <span class="status-badge status-pending">Não</span>
                                                    }
                                                </td>
                                                <td style="width: auto">
                                                    @if (cond.PAGAMENTO_NOTA_FISCAL.Count > 0)
                                                    {
                                                        <span class="status-badge status-active">Sim</span>
                                                    }
                                                    else 
                                                    {
                                                        <span class="status-badge status-pending">Não</span>
                                                    }
                                                </td>
                                                <td style="width: auto" class="td-one-action">
                                                    @if (cond.COPA_IN_PAGO == 0)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.COPA_CD_ID, "EditarPagamento", "fa-edit btn-loading", "Alterar/Quitar")
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.COPA_CD_ID, "VerPagamento", "fa-search btn-loading", "Ver")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_EXCLUIR == 1)
                                                    {
                                                        if (cond.COPA_IN_ATIVO == 1 & cond.COPA_IN_PAGO == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Financeiro/ExcluirPagamento/@cond.COPA_CD_ID')" title="Excluir"></span>
                                                        }
	                                                }
                                                </td>
                                            </tr>
                                        }

                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhum pagamento cadastrado</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Financeiro", action: "RetirarFiltroPagamento")
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>
    <style>
        /* Estilo Base */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-badge::before {
            content: "";
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-right: 6px;
        }

        /* PENDING (Gold) - Status 0 */
        .status-pending { background-color: #fef9c3; color: #a16207; }
        .status-pending::before { background-color: #ca8a04; }

        /* ACTIVE (Green) - Status 1 */
        .status-active { background-color: #dcfce7; color: #15803d; }
        .status-active::before { background-color: #16a34a; }

        /* CANCEL (Red) - Status 4 */
        .status-cancel { background-color: #fee2e2; color: #b91c1c; }
        .status-cancel::before { background-color: #dc2626; }

        /* FINISH (Dark Blue) - Status 2 */
        .status-finish { background-color: #dbeafe; color: #1e40af; }
        .status-finish::before { background-color: #2563eb; }

        /* OVERDUE (Gray) - Status 3 */
        .status-overdue { background-color: #f3f4f6; color: #4b5563; }
        .status-overdue::before { background-color: #6b7280; }
    </style>

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtNomeFavorecido').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetFavorecidoNome", "Financeiro")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>


    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
        });
    </script>

    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluir(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Pagamento?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
        function ShowModalConsolidar(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma consolidação de Pagamento?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Consolidação</h5>');
            $('#modal').modal('show');
        }
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
