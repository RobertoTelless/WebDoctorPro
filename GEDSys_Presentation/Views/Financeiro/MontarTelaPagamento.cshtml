@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.CONSULTA_PAGAMENTO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Pagamento";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Pagamento - Lista de pagamentos";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, pagamento";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaFinanceiro", "Financeiro")">Dashboard Financeiro</a>
            </li>
            <li class="active">
                <strong>Pagamentos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-10 col-md-10 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarPagamento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Pagamento
                                @Html.DropDownListFor(m => m.TIPA_CD_ID, (SelectList)ViewBag.Tipo, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Pagamento
                                @Html.TextBoxFor(m => m.COPA_NM_NOME, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Favorecido
                                @Html.TextBoxFor(m => m.COPA_NM_FAVORECIDO, new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Venc. Inicial
                                @Html.TextBoxFor(m => m.COPA_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Venc. Final
                                @Html.TextBoxFor(m => m.COPA_DT_VENCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn1" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Quitação
                                @Html.DropDownListFor(m => m.COPA_IN_PAGO, (SelectList)ViewBag.Quitacao, "Selecionar", new { @class = "form-control" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @if (ViewBag.PagtoPode == 1)
                                {
                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_INCLUIR == 1)
                                    {
                                        @Html.ButtonLinkIndex(text: "Novo Pagamento", controller: "Financeiro", action: "IncluirPagamento", buttonClass: "primary")
                                    }
                                }
                                @*@if (ViewBag.PagtoPode == 1)
                                {
                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_INCLUIR == 1)
                                    {
                                        @Html.ButtonLinkIndex(text: "Importar Nota Fiscal e Criar Pagamento", controller: "Financeiro", action: "IncluirNotaFiscalPagamento", buttonClass: "primary")
                                    }
                                }*@
                                @Html.ButtonLinkIndex(text: "Vencendo Hoje", controller: "Financeiro", action: "RetirarFiltroPagamento")
                                @Html.ButtonLinkIndex(text: "Vencendo no Mês Corrente", controller: "Financeiro", action: "VerPagamentoMes")
                                @Html.ButtonLinkIndex(text: "Quitados Hoje", controller: "Financeiro", action: "VerPagamentosFeitosHoje")
                                @Html.ButtonLinkIndex(text: "Quitados no Mês Corrente", controller: "Financeiro", action: "VerPagamentoFeitosMes")
                                @Html.ButtonLinkIndex(text: "Ver Todos", controller: "Financeiro", action: "VerTodosPagamento")
                                @Html.ButtonLinkIndex(text: "Calendário", controller: "Financeiro", action: "VerPagamentoCalendario")
                                @if ((Int32)Session["VoltaFinanceiro"] == 0)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente")
                                }
                                else
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Financeiro", action: "MontarTelaFinanceiro")
                                }
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-2 col-md-2 col-xs-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: cornsilk; color:darkgreen">
                    <h5>Relatórios</h5>
                </div>
                <div class="ibox-content">
                    @using (Html.BeginForm("ProcessaRelatorioPagamento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", autofocus = true }))
                    {
                        @Html.DropDownList("TIPO_RELATORIO", (SelectList)ViewBag.Relatorio, "Selecionar", new { @class = "form-control", autofocus = true })
                        <small>Selecione o Relatório</small>
                        <br />
                        <small>(*) Sensivel ao filtro especificado</small>
                        <br />
                        <br />
                        @Html.ButtonActionSubmit(text: "Gerar Relatório")
                    }
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Central de Pagamentos</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if ((Int32)Session["TipoExibicaoPagamento"] == 1)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Pagamentos em Aberto com Vencimento da Data Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoPagamento"] == 2)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Pagamentos em Aberto com Vencimento no Mês Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoPagamento"] == 3)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Pagamentos Quitados na Data Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoPagamento"] == 4)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Pagamentos Quitados no Mês Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoPagamento"] == 3)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Todos os Pagamentos Cadastrados</h4>
                        }
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.CONSULTA_PAGAMENTO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Vencimento</th>
                                        <th style="width: auto">Pagamento</th>
                                        <th style="width: auto">Tipo</th>
                                        <th style="width: auto">Identificador</th>
                                        <th style="width: auto">Descrição</th>
                                        <th style="width: auto">Favorecido</th>
                                        <th style="width: auto">Valor (R$)</th>
                                        <th style="width: auto">Quitado</th>
                                        <th style="width: auto">Nota Fiscal</th>
                                        <th class="td-one-action">Ações</th>
                                        <th style="width: 0.01px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.CONSULTA_PAGAMENTO>).OrderByDescending(p => p.COPA_DT_VENCIMENTO.Value.Date))
                                    {
                                        if (cond.COPA_DT_VENCIMENTO == DateTime.Today.Date & cond.COPA_IN_PAGO == 0)
                                        {
                                            <tr style="background-color: palegoldenrod">
                                                <td style="width: auto">@cond.COPA_DT_VENCIMENTO.Value.ToShortDateString()</td>
                                                @if (cond.COPA_DT_PAGAMENTO != null)
                                                {
                                                    <td style="width: auto">@cond.COPA_DT_PAGAMENTO.Value.ToShortDateString()</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">Em Aberto</td>
                                                }
                                                <td style="width: auto">@cond.TIPO_PAGAMENTO.TIPA_NM_PAGAMENTO</td>
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                {
                                                    <td style="width: auto"><a href="@Url.Action("EditarPagamento", "Financeiro", new { id = cond.COPA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição/quitação do pagamento"/>@cond.COPA_GU_GUID</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">@cond.COPA_GU_GUID</td>
                                                }
                                                <td style="width: auto">@cond.COPA_NM_NOME</td>
                                                <td style="width: auto">@cond.COPA_NM_FAVORECIDO</td>
                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.COPA_VL_VALOR.Value)</td>
                                                @if (cond.COPA_IN_PAGO == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                @if (cond.PAGAMENTO_NOTA_FISCAL.Count > 0)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                <td style="width: auto" class="td-one-action">
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.COPA_CD_ID, "EditarPagamento", "fa-edit", "Alterar/Quitar")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_EXCLUIR == 1)
                                                    {
                                                        if (cond.COPA_IN_ATIVO == 1)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o" onclick="ShowModalExcluir('/Financeiro/ExcluirPagamento/@cond.COPA_CD_ID')" title="Excluir"></span>
                                                        }
	                                                }
                                                    @*@if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_PAG_ALTERAR == 1)
                                                    {
                                                        if (cond.COPA_IN_ATIVO == 1 & cond.COPA_IN_CONFERIDO == 0)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Consolidar" class="tbl-link fa-lg fa fa-check" onclick="ShowModalConsolidar('/Financeiro/ConsolidarPagamento/@cond.COPA_CD_ID')" title="Consolidar Pagamento"></span>
                                                        }
                                                    }*@
                                                </td>
                                                <td style="width: 0.01px"></td>
                                            </tr>
                                        }
                                        else if (cond.COPA_DT_VENCIMENTO < DateTime.Today.Date & cond.COPA_IN_PAGO == 0)
                                        {
                                            <tr style="background-color: navajowhite">
                                                <td style="width: auto">@cond.COPA_DT_VENCIMENTO.Value.ToShortDateString()</td>
