@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.CONSULTA_RECEBIMENTO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Recebimento";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Recebimento - Lista de recebimentos";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, recebimento";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaFinanceiro", "Financeiro")">Dashboard Financeiro</a>
            </li>
            <li class="active">
                <strong>Recebimentos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-10 col-md-10 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarRecebimento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Consulta
                                @Html.DropDownListFor(m => m.VACO_CD_ID, (SelectList)ViewBag.TipoConsulta, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Informe o tipo de consulta a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-5 col-md-5 col-xs-12">
                                Nome do Paciente
                                @Html.DropDownListFor(m => m.PACI_CD_ID, (SelectList)ViewBag.Paciente, "Selecionar", new { @class = "form-control" , data_toggle = "popover", data_content = "Selecione um paciente ou digite as primeiras letras do nome para acelerar a busca", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Forma de Recebimento
                                @Html.DropDownListFor(m => m.FORE_CD_ID, (SelectList)ViewBag.Forma, "Selecionar", new { @class = "form-control", data_toggle = "popover", data_content = "Informe a forma de recebimento a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-5 col-md-5 col-xs-12">
                                Nome do Recebimento
                                @Html.TextBoxFor(m => m.CORE_NM_RECEBIMENTO, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Especifique o nome (ou um fragmento) associado a um pagamento", data_trigger="hover", data_placement="top"  })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.CORE_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn", data_toggle = "popover", data_content = "Informe a data inicial da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.CORE_DT_RECEBIMENTO, new { @class = "form-control date-picker", autofocus = true, @id = "dn1", data_toggle = "popover", data_content = "Informe a data final da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                        </div>

                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @if (ViewBag.RectoPode == 1)
                                {
                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_INCLUIR == 1)
                                    {
                                        <a href="@Url.Action("IncluirRecebimento", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Informação de novo recebimento" class="btn btn-sm btn-primary btn-loading" id="emp" OnClick = "Fade()">Novo Recebimento</a>                
                                    }
                                }
                                <a href="@Url.Action("RetirarFiltroRecebimento", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Exibe recebimentos na data corrente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Recebimentos de Hoje</a>                
                                <a href="@Url.Action("VerRecebimentoMes", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Exibe recebimentos do mês corrente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Recebimentos do Mês Corrente</a>                
                                <a href="@Url.Action("VerTodosRecebimento", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Exibe recebimentos do mês corrente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Todos os Recebimentos</a>                
                                @if ((Int32)Session["VoltaFinanceiro"] == 0)
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                                else
                                {
                                    @Html.ButtonLinkIndex(text: "Voltar", controller: "Financeiro", action: "MontarTelaFinanceiro", htmlAttributes: new { @class = "btn-loading" })
                                }
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-2 col-md-2 col-xs-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: cornsilk; color:darkgreen">
                    <h5>Relatórios</h5>
                </div>
                <div class="ibox-content">
                    @using (Html.BeginForm("ProcessaRelatorioRecebimento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", autofocus = true }))
                    {
                        @Html.DropDownList("TIPO_RELATORIO", (SelectList)ViewBag.Relatorio, "Selecionar", new { @class = "form-control", autofocus = true })
                        <small>Selecione o Relatório</small>
                        <br />
                        <small>(*) Sensivel ao filtro especificado</small>
                        <br />
                        <br />
                        @Html.ButtonActionSubmit(text: "Gerar Relatório")
                    }
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Central de Recebimentos</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if ((Int32)Session["TipoExibicaoRecebimento"] == 1)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Recebimentos na Data Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoRecebimento"] == 2)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Recebimentos no Mês Corrente</h4>
                        }
                        else if ((Int32)Session["TipoExibicaoRecebimento"] == 3)
                        {
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold;">Todos os Recebimentos</h4>
                        }
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.CONSULTA_RECEBIMENTO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Recebimento</th>
                                        <th style="width: auto">Forma de Recebimento</th>
                                        <th style="width: auto">Identificador</th>
                                        <th style="width: auto">Paciente</th>
                                        <th style="width: auto">Descrição</th>
                                        <th style="width: auto">Tipo de Consulta</th>
                                        <th style="width: auto">Valor (R$)</th>
                                        <th style="width: auto">Recibo</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.CONSULTA_RECEBIMENTO>).OrderByDescending(p => p.CORE_DT_RECEBIMENTO.Value.Date))
                                    {
                                        <tr>
                                            <td>
                                                <span style="display:none; width: auto">@cond.CORE_DT_RECEBIMENTO.Value.ToString("yyyyMMdd")</span>
                                                @cond.CORE_DT_RECEBIMENTO.Value.ToShortDateString()
                                            </td>
                                            @*<td style="width: auto">@cond.CORE_DT_RECEBIMENTO.Value.ToShortDateString()</td>*@
                                            <td style="width: auto">@cond.FORMA_RECEBIMENTO.FORE_NM_FORMA</td>
                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_ALTERAR == 1)
                                            {
                                                <td style="width: auto"><a href="@Url.Action("EditarRecebimento", "Financeiro", new { id = cond.CORE_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição do recebimento"/>@cond.CORE_GU_GUID</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto"><a href="@Url.Action("VerRecebimento", "Financeiro", new { id = cond.CORE_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de consulta do recebimento"/>@cond.CORE_GU_GUID</td>
                                            }
                                            <td style="width: auto">@cond.PACIENTE.PACI_NM_NOME</td>
                                            <td style="width: auto">@cond.CORE_NM_RECEBIMENTO</td>
                                            <td style="width: auto">@cond.VALOR_CONSULTA.VACO_NM_NOME</td>
                                            <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.CORE_VL_VALOR.Value)</td>
                                            @if (cond.RECEBIMENTO_RECIBO.Count > 0)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                            }
                                            else
                                            {
                                                <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                            }
                                            <td style="width: auto" class="td-one-action">
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_ALTERAR == 1)
                                                {
                                                    @Html.TableLinkDetails(cond.CORE_CD_ID, "EditarRecebimento", "fa-edit btn-loading", "Editar")
                                                }
                                                else
                                                {
                                                    @Html.TableLinkDetails(cond.CORE_CD_ID, "VerRecebimento", "fa-search btn-loading", "Ver")
                                                }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_EXCLUIR == 1)
                                                {
                                                    if (cond.CORE_IN_ATIVO == 1)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Financeiro/ExcluirRecebimento/@cond.CORE_CD_ID')" title="Excluir Recebimento"></span>
                                                    }
	                                            }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhum recebimento cadastrado</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Financeiro", action: "RetirarFiltroRecebimento")
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
        });
    </script>

    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluir(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Recebimento?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
        function ShowModalConsolidar(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma consolidação de Recebimento?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Consolidação</h5>');
            $('#modal').modal('show');
        }
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
                columnDefs: [
                    {
                        // Altera o tipo de ordenação para a primeira coluna (índice 0)
                        //"type": "datetime-moment", // Se você incluiu o momento.js
                        // OU
                         "type": "date-eu", // Para o formato DD/MM/AAAA
                        "targets": 0 // Aplica à coluna "Data da Transação"
                    }
                ],
                // ---------------------------------       
                buttons: [
                    { extend: 'excel', title: 'Recebimento_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });         
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

