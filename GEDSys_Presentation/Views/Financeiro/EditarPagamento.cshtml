                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Data do Pagamento
                                                                @Html.TextBoxFor(m => m.COPA_DT_PAGAMENTO, new { @class = "form-control", @readonly = "readonly", tabindex = "-1" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Valor Original (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_VALOR, "{0:n2}", new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold", tabindex = "-1" })
                                                            </div>
