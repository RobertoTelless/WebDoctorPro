                                                            <div class="col-lg-2 col-md-2  col-xs-12" style="color:brown; font-weight:bold">
                                                                Valor Pago (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_PAGO, "{0:n2}", new { @class = "form-control", @readonly="readonly" })
