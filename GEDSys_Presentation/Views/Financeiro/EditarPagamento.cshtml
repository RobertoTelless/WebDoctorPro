                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Descontos(-) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_DESCONTO, new { @class = "form-control", autofocus = true, @id = "desc", onfocus = "this.select();", onblur = "CalculaTotal()", tabindex = "3" })
                                                                @Html.ValidationMessageFor(m => m.COPA_VL_DESCONTO, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Multas(+) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_MULTA, new { @class = "form-control", autofocus = true, @id = "multa", onfocus = "this.select();", onblur = "CalculaTotal()", tabindex = "4" })
                                                                @Html.ValidationMessageFor(m => m.COPA_VL_MULTA, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2  col-xs-12" style="color:brown; font-weight:bold">
                                                                Valor Pago (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_PAGO, "{0:n2}", new { @class = "form-control", @readonly="readonly", @id = "total", tabindex = "-1" })
                                                            </div>
                                                        </div>
                                                    }
                                                    else
