    <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
        /* Container externo (o fundo da "pílula") */
        .toggle-container {
            background-color: #ebf9eb; /* Verde bem claro */
            border-radius: 20px;
            display: inline-flex;
            padding: 4px;
            margin-bottom: 20px;
            border: 1px solid #d0e9d0; /* Borda verde suave */
        }

        /* Opções de texto */
        .toggle-option {
            padding: 6px 20px;
            border-radius: 18px;
            cursor: pointer;
            font-weight: bold;
            color: #5cb85c; /* Verde padrão (Success) */
            transition: all 0.3s ease;
            user-select: none;
        }

        /* Opção selecionada (a "pílula" branca que corre) */
        .toggle-option.active {
            background-color: #ffffff; /* Fundo branco para destacar a opção ativa */
            color: #28a745; /* Verde mais escuro para o texto ativo */
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        /* Efeito de hover para melhorar a UX */
        .toggle-option:not(.active):hover {
            background-color: rgba(255, 255, 255, 0.5);
            color: #1e7e34;
        }
        .view-section {
            display: none !important;
        }

        .view-section.active {
            display: block !important;
        }


    </style>
}
