    <script>
        function CalculaTotal() {
            // Função auxiliar para tratar a string e converter em número real
            function parseMoeda(valor) {
                if (!valor || valor === "") return 0;
            
                // 1. Remove pontos de milhar: "3.500,00" -> "3500,00"
                // 2. Troca a vírgula decimal por ponto: "3500,00" -> "3500.00"
                var limpo = valor.toString().replace(/\./g, '').replace(',', '.');
            
                var num = parseFloat(limpo);
                return isNaN(num) ? 0 : num;
            }

            var valor = parseMoeda($('#valor').val());
            var desc = parseMoeda($('#desc').val());
            var multa = parseMoeda($('#multa').val());

            // Cálculo simples (as variáveis já são números agora)
            var tot = valor - desc + multa;

            // Formata de volta para o padrão brasileiro: 3000.00 -> "3.000,00"
            //$('#total').val(tot.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
            $('#total').val(parseFloat(tot).toFixed(2).replace('.', ','));
        }
    </script>

