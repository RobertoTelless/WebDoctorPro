@using Presentation.Extensions
@using EntitiesServices.Model
@model ERP_Condominios_Solution.ViewModels.PagamentoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Pagamentos - Edição";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Pagamentos - Edição de Pagamentos";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, Pagamento";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaFinanceiro", "Financeiro")">Dashboard Financeiro</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaPagamento", "Financeiro")">Pagamentos</a>
            </li>
            <li class="active">
                <strong>Pagamentos - Alteração</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div class="row">
                        <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                            <h5>Pagamento - Alteração</h5>
                            <span style="color:green; font-weight: 500; font-size: 20px;">@Model.COPA_NM_NOME</span>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">
                        @if ((Int32)Session["VoltarPesquisa"] == 11)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "PesquisarTudo", controller: "BaseAdmin", htmlAttributes: new { @class = "btn-loading" })
                        }
                        else
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPagamento", controller: "Financeiro", htmlAttributes: new { @class = "btn-loading" })
                        }
                        <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                        <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                            <i class="fa fa-spinner fa-spin"></i> Processando...
                        </span>
                    </div>

                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            @if ((Int32)Session["NivelPagamento"] == 1)
                            {
                                <li class="active"><a data-toggle="tab" href="#tab-1">Pagamento</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Notas Fiscais</a></li>
                            }
                            @if ((Int32)Session["NivelPagamento"] == 2)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Pagamento</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Notas Fiscais</a></li>
                            }
                            @if ((Int32)Session["NivelPagamento"] == 3)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Pagamento</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-4">Notas Fiscais</a></li>
                            }
                            @if ((Int32)Session["NivelPagamento"] == 4)
                            {
                                <li class=""><a data-toggle="tab" href="#tab-1">Pagamento</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-2">Anexos</a></li>
                                <li class=""><a data-toggle="tab" href="#tab-3">Anotações</a></li>
                                <li class="active"><a data-toggle="tab" href="#tab-4">Notas Fiscais</a></li>
                            }
                        </ul>
                        <div class="tab-content">
                            @*Dados Gerais*@
                            @if ((Int32)Session["NivelPagamento"] == 1)
                            {
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        @using (Html.BeginForm("EditarPagamento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <div class="row" style="width: 100%;">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Pagamento</h4>
                                                <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">
                                                    @Html.ButtonActionSubmit(text: "Confirma alteração de pagamento", htmlAttributes: new { id = "basictoast", @class = "btn-loading1" })
                                                </div>
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                                            Identificador
                                                            @Html.TextBoxFor(m => m.COPA_GU_GUID, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                            @Html.HiddenFor(m => m.USUA_CD_ID)
                                                            @Html.HiddenFor(m => m.COPA_IN_ATIVO)
                                                            @Html.HiddenFor(m => m.COPA_GU_GUID)
                                                            @Html.HiddenFor(m => m.COPA_CD_ID)
                                                            @Html.HiddenFor(m => m.TIPA_CD_ID)
                                                            @Html.HiddenFor(m => m.COPA_VL_VALOR)
                                                            @Html.HiddenFor(m => m.COPA_DT_CADASTRO)
                                                            Data do Vencimento
                                                            @Html.TextBoxFor(m => m.COPA_DT_VENCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                        </div>
                                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                                            Tipo de Pagamento
                                                            @Html.TextBoxFor(m => m.TIPO_PAGAMENTO.TIPA_NM_PAGAMENTO, new { @class = "form-control", @readonly = "readonly"})
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Quitado
                                                            @if (Model.COPA_IN_PAGO == 1)
                                                            {
                                                                @Html.TextBoxFor(m => m.Quitado, new { @class = "form-control", @readonly = "readonly" , @style = "color: green; font-weight: bold" })
                                                            }
                                                            else
                                                            {
                                                                @Html.TextBoxFor(m => m.Quitado, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                            }
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Data de Cadastro
                                                            @Html.TextBoxFor(m => m.COPA_DT_CADASTRO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: palegold; font-weight: bold" })
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                                            Nome do Pagamento
                                                            @Html.TextBoxFor(m => m.COPA_NM_NOME, new { @class = "form-control", @readonly = "readonly"  })
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                                            Nome do Favorecido
                                                            @Html.TextBoxFor(m => m.COPA_NM_FAVORECIDO, new { @class = "form-control", @readonly = "readonly" })
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row" style="width: 100%;">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Quitação do Pagamento</h4>
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    @if (Model.COPA_IN_PAGO == 0)
                                                    {
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Quitar Pagamento?
                                                                @Html.DropDownListFor(m => m.QUITA_PAGAMENTO, (SelectList)ViewBag.Quitar, "Selecionar", new { @class = "form-control", autofocus = true, @id = "quita", onchange = "ValidaQuita($(this).val())" })
                                                                @Html.ValidationMessageFor(m => m.QUITA_PAGAMENTO, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Data do Pagamento
                                                                @Html.TextBoxFor(m => m.COPA_DT_PAGAMENTO, new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                                                @Html.ValidationMessageFor(m => m.COPA_DT_PAGAMENTO, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Valor Original (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_VALOR, "{0:n2}", new { @class = "form-control", @id = "valor", autofocus = true, @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Descontos(-) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_DESCONTO, new { @class = "form-control", autofocus = true, @id = "desc", onfocus = "this.select();", onblur = "CalculaTotal()" })
                                                                @Html.ValidationMessageFor(m => m.COPA_VL_DESCONTO, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Multas(+) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_MULTA, new { @class = "form-control", autofocus = true, @id = "multa", onfocus = "this.select();", onblur = "CalculaTotal()" })
                                                                @Html.ValidationMessageFor(m => m.COPA_VL_MULTA, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2  col-xs-12" style="color:brown; font-weight:bold">
                                                                Valor Pago (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_PAGO, "{0:n2}", new { @class = "form-control", @readonly="readonly", @id = "total" })
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Data do Pagamento
                                                                @Html.TextBoxFor(m => m.COPA_DT_PAGAMENTO, new { @class = "form-control", @readonly = "readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Valor Original (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_VALOR, "{0:n2}", new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Descontos(-) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_DESCONTO, "{0:n2}", new { @class = "form-control", @readonly = "readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Multas(+) (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_MULTA, "{0:n2}", new { @class = "form-control", @readonly = "readonly" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2  col-xs-12" style="color:brown; font-weight:bold">
                                                                Valor Pago (R$)
                                                                @Html.TextBoxFor(m => m.COPA_VL_PAGO, "{0:n2}", new { @class = "form-control", @readonly="readonly" })
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div id="tab-1" class="tab-pane">
                                    <div class="panel-body">
                                        @using (Html.BeginForm("EditarPagamento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <div class="row" style="width: 100%;">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Pagamento</h4>
                                                <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">
                                                    @Html.ButtonActionSubmit(text: "Confirma alteração de pagamento", htmlAttributes: new { id = "basictoast", @class = "btn-loading1" })
                                                </div>
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                                            Identificador
                                                            @Html.TextBoxFor(m => m.COPA_GU_GUID, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                            @Html.HiddenFor(m => m.USUA_CD_ID)
                                                            @Html.HiddenFor(m => m.COPA_IN_ATIVO)
                                                            @Html.HiddenFor(m => m.COPA_GU_GUID)
                                                            @Html.HiddenFor(m => m.COPA_CD_ID)
                                                            @Html.HiddenFor(m => m.TIPA_CD_ID)
                                                            @Html.HiddenFor(m => m.COPA_VL_VALOR)
                                                            @Html.HiddenFor(m => m.COPA_DT_CADASTRO)
                                                            Data do Vencimento
                                                            @Html.TextBoxFor(m => m.COPA_DT_VENCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                        </div>
                                                        <div class="col-lg-3 col-md-3 col-xs-12">
                                                            Tipo de Pagamento
                                                            @Html.TextBoxFor(m => m.TIPO_PAGAMENTO.TIPA_NM_PAGAMENTO, new { @class = "form-control", @readonly = "readonly"})
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Quitado
                                                            @if (Model.COPA_IN_PAGO == 1)
                                                            {
                                                                @Html.TextBoxFor(m => m.Quitado, new { @class = "form-control", @readonly = "readonly" , @style = "color: green; font-weight: bold" })
                                                            }
                                                            else
                                                            {
                                                                @Html.TextBoxFor(m => m.Quitado, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                            }
                                                        </div>
                                                        <div class="col-lg-2 col-md-2 col-xs-12">
                                                            Data de Cadastro
                                                            @Html.TextBoxFor(m => m.COPA_DT_CADASTRO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @style = "color: palegold; font-weight: bold" })
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                                            Nome do Pagamento
                                                            @Html.TextBoxFor(m => m.COPA_NM_NOME, new { @class = "form-control", @readonly = "readonly"  })
                                                            @Html.ValidationMessageFor(m => m.COPA_NM_NOME, "", new { @style = "color:red" })
                                                        </div>
                                                        <div class="col-lg-6 col-md-6 col-xs-12">
                                                            Nome do Favorecido
                                                            @Html.TextBoxFor(m => m.COPA_NM_FAVORECIDO, new { @class = "form-control", @readonly = "readonly" })
                                                            @Html.ValidationMessageFor(m => m.COPA_NM_FAVORECIDO, "", new { @style = "color:red" })
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row" style="width: 100%;">
                                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Quitação do Pagamento</h4>
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    @if (Model.COPA_IN_PAGO == 0)
                                                    {
                                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Quitar Pagamento?
                                                                @Html.DropDownListFor(m => m.QUITA_PAGAMENTO, (SelectList)ViewBag.Quitar, "Selecionar", new { @class = "form-control", autofocus = true })
                                                                @Html.ValidationMessageFor(m => m.QUITA_PAGAMENTO, "", new { @style = "color:red" })
                                                            </div>
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
