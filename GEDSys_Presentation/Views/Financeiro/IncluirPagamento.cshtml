@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PagamentoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Pagamentos - Inclusão";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Pagamentos - Inclusão de pagamento";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, Pagamento";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaFinanceiro", "Financeiro")">Dashboard Financeiro</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaPagamento", "Financeiro")">Pagamentos</a>
            </li>
            <li class="active">
                <strong>Pagamentos - Inclusão</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Pagamentos - Inclusão</h5>
                </div>
                @using (Html.BeginForm("IncluirPagamento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        <div class="row">
                            <div class="col-lg-8 col-md-8 col-xs-12">
                                <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Pagamento</h4>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    @Html.ButtonActionSubmit(text: "BtnSubmit", htmlAttributes: new { id = "submit", style = "display: none;", @class = "btn-loading1" })
                                    <button style="margin-left: 15px;" class="btnSubmit btn btn-sm btn-success" id="basictoast" type="button">Confirmar inclusão do Pagamento</button>
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPagamento", controller: "Financeiro", htmlAttributes: new { @class = "btn-loading" })
                                    <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                        <i class="fa fa-spinner fa-spin"></i> Processando...
                                    </span>
                                </div>

                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação do Pagamento</h4>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Identificador
                                        @Html.TextBoxFor(m => m.COPA_GU_GUID, new { @class = "form-control", @readonly = "readonly", @style = "color: brown; font-weight: bold"  })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Tipo de Pagamento*
                                        @Html.DropDownListFor(m => m.TIPA_CD_ID, (SelectList)ViewBag.Tipo, "Selecionar", new { @class = "form-control", autofocus = true, id = "pag", onchange = "GetPagamento($(this).val())" })
                                        @Html.ValidationMessageFor(m => m.TIPA_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Valor (R$)*
                                        @Html.TextBoxFor(m => m.COPA_VL_VALOR, new { @class = "form-control", autofocus = true, @style = "color: green; font-weight: bold", @id = "valor", onblur = "CalculaTotal()" })
                                        @Html.ValidationMessageFor(m => m.COPA_VL_VALOR, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        @Html.HiddenFor(m => m.ASSI_CD_ID)
                                        @Html.HiddenFor(m => m.USUA_CD_ID)
                                        @Html.HiddenFor(m => m.COPA_IN_ATIVO)
                                        @Html.HiddenFor(m => m.COPA_GU_GUID)
                                        @Html.HiddenFor(m => m.COPA_IN_CONFERIDO)
                                        @Html.HiddenFor(m => m.COPA_IN_PAGO)
                                        @Html.HiddenFor(m => m.COPA_DT_CADASTRO)
                                        Data do Vencimento*
                                        @Html.TextBoxFor(m => m.COPA_DT_VENCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                                        @Html.ValidationMessageFor(m => m.COPA_DT_VENCIMENTO, "", new { @style = "color:red" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Favorecido</h4>
                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                        Nome do Pagamento
                                        @Html.TextBoxFor(m => m.COPA_NM_NOME, new { @class = "form-control", autofocus = true, id = "nomePag", data_toggle = "popover", data_content = "O WebDoctor gera um nome para o pagamento baseado nas informações fornecidas. Esse nome poderá ser alterado se necessário", data_trigger="hover", data_placement="top" })
                                        @Html.ValidationMessageFor(m => m.COPA_NM_NOME, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                        Nome do Favorecido
                                        @Html.TextBoxFor(m => m.COPA_NM_FAVORECIDO, new { @class = "form-control", autofocus = true, id = "nomeFav", data_toggle = "popover", data_content = "Nome do favorecido deste pagamento", data_trigger="hover", data_placement="top" })
                                        @Html.ValidationMessageFor(m => m.COPA_NM_FAVORECIDO, "", new { @style = "color:red" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Quitação</h4>
                                    <h5 style="margin-left: 0px; color:darkblue; background-color: beige; font-weight:bold">Na criação de pagamento recursivo a informação de quitação será aplicada apenas na primeira ocorrência</h5>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Pagamento já Quitado*
                                        @Html.DropDownListFor(m => m.QUITA_PAGAMENTO, (SelectList)ViewBag.Quitar, "Selecionar", new { @class = "form-control", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.QUITA_PAGAMENTO, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12" id="Data">
                                        Data do Pagamento
                                        @Html.TextBoxFor(m => m.COPA_DT_PAGAMENTO, new { @class = "form-control date-picker", autofocus = true, @id = "dn1" })
                                        @Html.ValidationMessageFor(m => m.COPA_DT_PAGAMENTO, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Descontos(-) (R$)
                                        @Html.TextBoxFor(m => m.COPA_VL_DESCONTO, new { @class = "form-control", autofocus = true, @id = "desc", onfocus = "this.select();", onblur = "CalculaTotal()" })
                                        @Html.ValidationMessageFor(m => m.COPA_VL_DESCONTO, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Multas(+) (R$)
                                        @Html.TextBoxFor(m => m.COPA_VL_MULTA, new { @class = "form-control", autofocus = true, @id = "multa", onfocus = "this.select();", onblur = "CalculaTotal()" })
                                        @Html.ValidationMessageFor(m => m.COPA_VL_MULTA, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2  col-xs-12" style="color:brown; font-weight:bold">
                                        Valor Pago (R$)
                                        @Html.TextBoxFor(m => m.COPA_VL_PAGO, new { @class = "form-control", @readonly="readonly", @id = "total" })
                                    </div>
                                </div>
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                    <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Pagamento Recursivo</h4>
                                    <h5 style="margin-left: 0px; color:darkblue; background-color: beige; font-weight:bold">Na criação de pagamento recursivo NÃO serão considerados os arquivos anexados</h5>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Pagamento Recursivo?*
                                        @Html.DropDownListFor(m => m.RECURSIVO, (SelectList)ViewBag.Recursivo, "Selecionar", new { @class = "form-control", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.RECURSIVO, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Periodicidade*
                                        @Html.DropDownListFor(m => m.PETA_CD_ID, (SelectList)ViewBag.Periodicidade, "Selecionar", new { @class = "form-control", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.PETA_CD_ID, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data Final
                                        @Html.TextBoxFor(m => m.DATA_FINAL, new { @class = "form-control date-picker", autofocus = true, @id = "dn3" })
                                        @Html.ValidationMessageFor(m => m.DATA_FINAL, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Num.Ocorrências
                                        @Html.TextBoxFor(m => m.NUMERO_VEZES, new { @class = "form-control", autofocus = true })
                                        @Html.ValidationMessageFor(m => m.NUMERO_VEZES, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Vencimento Fixo?*
                                        @Html.DropDownListFor(m => m.DIA_FIXO, (SelectList)ViewBag.Fixo, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "No caso de periodicidade baseada em mês, define que o dia do vencimento será mantido ao longo das ocorrências", data_trigger="hover", data_placement="top" })
                                        @Html.ValidationMessageFor(m => m.DIA_FIXO, "", new { @style = "color:red" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-4 col-xs-12">
                                <h4 style="margin-left: -15px; color:green; background-color: beige; font-weight:bold">Anexos</h4>
                                <input class="btn btn-sm btn-warning" style="margin-left: -15px;" id="inputFile" type="file" multiple data-toggle="popover" data-trigger="hover" data-placement="top" data-content="ATENÇÃO - Antes de anexar arquivos certifique-se de que eles estejam livres de vírus e outras ameaças. Anexe aqui os arquivos referentes a este pagamento. As notas fiscais NF-e em formato XML da SRF devem ser anexadas em local próprio na página de edição de pagamentos"/>
                                <br />
                                <div class="form-group" style="margin-left: -15px;">
                                    <div>
                                        <table style="width: 100%;" class="table table-striped table-bordered table-hover dataTables-example" id="myFiles">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <td>Nome</td>
                                                    <td>Tipo</td>
                                                    <td>Ações</td>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    
    <script src="~/Scripts/uploadAnexo.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script>
        function GetPagamento(id) {
            var data = {
                id: id
            }
            $.ajax({
                url: '../Financeiro/GetPagamento'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#nomePag').val(r.pagamento);
                    $('#nomePag').show();
                }
            });
        }
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>

    <script>
        function CalculaTotal() {
            var valor = $('#valor').val() == "" ? 0 : $('#valor').val();
            var desc = $('#desc').val() == "" ? 0 : $('#desc').val();
            var multa = $('#multa').val() == "" ? 0 : $('#multa').val();
            valor = (parseFloat(valor.replace(',', '.')));
            desc = (parseFloat(desc.replace(',', '.')));
            multa = (parseFloat(multa.replace(',', '.')));
            var tot = 0;
            if (valor != "")
            {
                tot = tot + valor;
            }
            if (desc != "")
            {
                tot = tot - desc;
            }
            if (multa != "")
            {
                tot = tot + multa;
            }
            $('#total').val(parseFloat(tot).toFixed(2).replace('.', ','));
        }
    </script>


    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
            $("#dn2").mask("99/99/9999");
            $("#dn3").mask("99/99/9999");
        });
    </script>

    <script>
        SendFilesV2('imgCliente', 'Financeiro', 'UploadFileToSession');
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            var i = -1;
            var toastCount = 0;
            var $toastlast;
            var getMessage = function () {
                var msg = 'Hi, welcome to Inspinia. This is example of Toastr notification box.';
                return msg;
            };

            $('#basictoast').click(function () {
                // Display a success toast, with a title
                toastr.success('Inclusão em andamento!')
            });
            $('#showtoast').click(function () {
                var shortCutFunction = $("#toastTypeGroup input:radio:checked").val();
                var msg = $('#message').val();
                var title = $('#title').val() || '';
                var $showDuration = $('#showDuration');
                var $hideDuration = $('#hideDuration');
                var $timeOut = $('#timeOut');
                var $extendedTimeOut = $('#extendedTimeOut');
                var $showEasing = $('#showEasing');
                var $hideEasing = $('#hideEasing');
                var $showMethod = $('#showMethod');
                var $hideMethod = $('#hideMethod');
                var toastIndex = toastCount++;
                toastr.options = {
                    closeButton: $('#closeButton').prop('checked'),
                    debug: $('#debugInfo').prop('checked'),
                    progressBar: $('#progressBar').prop('checked'),
                    positionClass: $('#positionGroup input:radio:checked').val() || 'toast-top-right',
                    onclick: null
                };
                if ($('#addBehaviorOnToastClick').prop('checked')) {
                    toastr.options.onclick = function () {
                        alert('You can perform some custom action after a toast goes away');
                    };
                }
                if ($showDuration.val().length) {
                    toastr.options.showDuration = $showDuration.val();
                }
                if ($hideDuration.val().length) {
                    toastr.options.hideDuration = $hideDuration.val();
                }
                if ($timeOut.val().length) {
                    toastr.options.timeOut = $timeOut.val();
                }
                if ($extendedTimeOut.val().length) {
                    toastr.options.extendedTimeOut = $extendedTimeOut.val();
                }
                if ($showEasing.val().length) {
                    toastr.options.showEasing = $showEasing.val();
                }
                if ($hideEasing.val().length) {
                    toastr.options.hideEasing = $hideEasing.val();
                }
                if ($showMethod.val().length) {
                    toastr.options.showMethod = $showMethod.val();
                }
                if ($hideMethod.val().length) {
                    toastr.options.hideMethod = $hideMethod.val();
                }
                if (!msg) {
                    msg = getMessage();
                }
                $("#toastrOptions").text("Command: toastr["
                    + shortCutFunction
                    + "](\""
                    + msg
                    + (title ? "\", \"" + title : '')
                    + "\")\n\ntoastr.options = "
                    + JSON.stringify(toastr.options, null, 2)
                );
                var $toast = toastr[shortCutFunction](msg, title); // Wire up an event handler to a button in the toast, if it exists
                $toastlast = $toast;
                if ($toast.find('#okBtn').length) {
                    $toast.delegate('#okBtn', 'click', function () {
                        alert('you clicked me. i was toast #' + toastIndex + '. goodbye!');
                        $toast.remove();
                    });
                }
                if ($toast.find('#surpriseBtn').length) {
                    $toast.delegate('#surpriseBtn', 'click', function () {
                        alert('Surprise! you clicked me. i was toast #' + toastIndex + '. You could perform an action here.');
                    });
                }
            });
            function getLastToast() {
                return $toastlast;
            }
            $('#clearlasttoast').click(function () {
                toastr.clear(getLastToast());
            });
            $('#cleartoasts').click(function () {
                toastr.clear();
            });

        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
