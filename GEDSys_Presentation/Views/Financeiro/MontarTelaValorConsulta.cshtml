@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.VALOR_CONSULTA
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Valores";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Valores - Lista de valores de consultas";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, valor, consulta";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Tipos de Consultas</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Tipos de Consultas</h5>
                </div>
                <br />
                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                    <div class="col-lg-12 col-md-12 col-xs-12">
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_INCLUIR == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Novo Tipo de Consulta", controller: "Financeiro", action: "IncluirValorConsulta", buttonClass: "primary", htmlAttributes: new { @class = "btn-loading" })
                        }
                        @Html.ButtonLinkIndex(text: "Imprimir", controller: "Financeiro", action: "GerarRelatorioValorConsulta")
                        @if ((Int32)Session["VoltaFinanceiro"] == 0)
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", htmlAttributes: new { @class = "btn-loading" })
                        }
                        else
                        {
                            @Html.ButtonLinkIndex(text: "Voltar", controller: "Financeiro", action: "MontarTelaFinanceiro", htmlAttributes: new { @class = "btn-loading" })
                        }
                        <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                        <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                            <i class="fa fa-spinner fa-spin"></i> Processando...
                        </span>
                    </div>
                </div>
                <br />
                <br />
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }                    
                    <div class="row">
                        <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                            @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.VALOR_CONSULTA>).Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Tipo de Consulta</th>
                                            <th style="width: auto">Data de Referência</th>
                                            <th style="width: auto">Descrição</th>
                                            <th style="width: auto">Valor da Consulta (R$)</th>
                                            <th style="width: auto">Padrão</th>
                                            <th style="width: auto">Gasta material</th>
                                            <th class="td-one-action">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.VALOR_CONSULTA>).OrderByDescending(p => p.VACO_NM_NOME))
                                        {
                                            <tr>
                                                <td style="width: auto">@cond.TIPO_VALOR_CONSULTA.TIVL_NM_TIPO</td>
                                                <td>
                                                    <span style="display:none; width: auto">@cond.VACO_DT_REFERENCIA.Value.ToString("yyyyMMdd")</span>
                                                    @cond.VACO_DT_REFERENCIA.Value.ToString("dd/MM/yyyy")
                                                </td>
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_ALTERAR == 1)
                                                {
                                                    <td style="width: auto"><a href="@Url.Action("EditarValorConsulta", "Financeiro", new { id = cond.VACO_CD_ID})" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição de tipos/valores de consultas"/>@cond.VACO_NM_NOME</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">@cond.VACO_NM_NOME</td>
                                                }
                                                <td style="width: auto">@CrossCutting.Formatters.DecimalFormatter(cond.VACO_NR_VALOR.Value)</td>
                                                @if (cond.VACO_IN_PADRAO == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                @if (cond.VACO_IN_MATERIAL == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>

                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Não</span></td>

                                                }
                                                <td style="width: auto" class="td-one-action">
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.VACO_CD_ID, "EditarValorConsulta", "fa-edit btn-loading", "Editar Tipo de Consulta")
                                                    }
                                                    @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FINANCEIRO_REC_EXCLUIR == 1)
                                                    {
                                                        if (cond.VACO_IN_ATIVO == 1)
                                                        {
                                                            <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o btn-loading" onclick="ShowModalExcluir('/Financeiro/ExcluirValorConsulta/@cond.VACO_CD_ID')" title="Excluir Tipo de Consulta"></span>
                                                        }
	                                                }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-2 col-md-2 col-xs-2">
                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                        <h2 style="font-weight: bold">Nenhum tipo de consulta cadastrado</h2>
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-2">
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>
    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluir(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de Tipo de Consulta?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
                columnDefs: [
                    {
                        // Altera o tipo de ordenação para a primeira coluna (índice 0)
                        //"type": "datetime-moment", // Se você incluiu o momento.js
                        // OU
                         "type": "date-eu", // Para o formato DD/MM/AAAA
                        "targets": 1 // Aplica à coluna "Data da Transação"
                    }
                ],
                // ---------------------------------       
                buttons: [
                    { extend: 'excel', title: 'ValorConsulta_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });         
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

