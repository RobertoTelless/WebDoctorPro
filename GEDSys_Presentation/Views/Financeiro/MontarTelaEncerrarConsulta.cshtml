@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.PACIENTE_CONSULTA
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro - Consulta - Encerramento";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Consulta - Encerramento de consulta";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, Consulta, Encerramento";
}
@{
    // Define a URL da Receita Federal
    string urlReceita = "https://cav.receita.fazenda.gov.br/autenticacao/login";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal inmodal fade" id="modalEncerramento" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Encerramento de Consulta</h4>
                    <small class="font-bold">WebDoctorPro - Consultas</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3>Tem certeza que deseja encerrar essa consulta?</h3>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnEncerrarSubmit">Encerrar Consulta</button>
                </div>
            </div>
        </div>
    </div>


    @if ((String)Session["ModuloAtual"] == "Consultas")
    {
        <div class="page-title">
            <ol class="breadcrumb">
                <li>
                    <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
                </li>
                <li>
                    <a href="@Url.Action("MontarTelaConsultas", "Paciente")">Consultas</a>
                </li>
                <li class="active">
                    <strong>Consultas - Encerramento</strong>
                </li>
            </ol>
            <br />
        </div>
    }
    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página de encerramento de consultas do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Visualizar todas as consultas ainda não encerradas.</li>
                        <li>Selecionar consultas através de filtros.</li>
                        <li>Selecionar e encerrar uma consulta.</li>
                        <li>Abrir o portal do eCAC (Receita Federal) para a geração de recibos.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarConsultasEncerramento", "Financeiro", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Consulta
                                @Html.DropDownListFor(m => m.VACO_CD_ID, (SelectList)ViewBag.TipoConsulta, "Selecionar", new { @class = "form-control" })
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                Nome do Paciente
                                @Html.TextBoxFor(m => m.PACO_TX_RESUMO, new { @class = "form-control", autofocus = true, @id = "txtNomePaciente"   })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.PACO_DT_DUMMY, new { @class = "form-control date-picker", autofocus = true, @id = "dn" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.PACO_DT_PROXIMA, new { @class = "form-control date-picker", autofocus = true, @id = "dn1" })
                            </div>
                        </div>

                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Financeiro", action: "RetirarFiltroConsultasEncerramento", htmlAttributes: new { @class = "btn-loading" })
                                @Html.ButtonLinkIndex(text: "Imprimir Consultas", controller: "Financeiro", action: "GerarRelatorioConsultasEncerramento")
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Financeiro", action: "VoltarEncerramento", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action((String)Session["AjudaNivel"])" class="btn btn-sm btn-danger" target="_blank">Ajuda</a>
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Consultas - Encerramento</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_CONSULTA>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Nome do Paciente </th>
                                        <th style="width: auto">Data da Consulta</th>
                                        <th style="width: auto">Hora de Início</th>
                                        <th style="width: auto">Hora de Término</th>
                                        <th style="width: auto">Tipo de Consulta</th>
                                        <th style="width: auto">Situação</th>
                                        <th style="width: auto">Recebimento</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.PACIENTE_CONSULTA>).OrderBy(p => p.PACIENTE.PACI_NM_NOME).ThenBy(p => p.PACO_DT_CONSULTA.Date))
                                    {   
                                        <tr>
                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_PACIENTE == 1)
                                            {
                                                <td style="width: auto"><a href="@Url.Action("EditarPacienteEncerra", "Paciente", new { id = cond.PACIENTE.PACI__CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição de dados do paciente"/>@cond.PACIENTE.PACI_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto"><a href="@Url.Action("VerPacienteEncerra", "Paciente", new { id = cond.PACIENTE.PACI__CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de visualização de dados do paciente" />@cond.PACIENTE.PACI_NM_NOME</td>
                                            }
                                            <td style="width: auto">@cond.PACO_DT_CONSULTA.ToShortDateString()</td>
                                            <td style="width: auto">@cond.PACO_HR_INICIO.ToString()</td>
                                            <td style="width: auto">@cond.PACO_HR_FINAL.ToString()</td>

                                            <td style="width: auto">
                                                @if (cond.VALOR_CONSULTA != null)
                                                {
                                                    <span class="status-badge status-finish">@cond.VALOR_CONSULTA.VACO_NM_NOME</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-pending">Não Definido</span>
                                                }
                                            </td>

                                            <td style="width: auto">
                                                @if (cond.PACO_IN_CONFIRMADA == 1) 
                                                {
                                                    <span class="status-badge status-active">Confirmada</span>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 2) 
                                                {
                                                    <span class="status-badge status-cancel">Cancelada</span>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 0) 
                                                {
                                                    <span class="status-badge status-pending">Pendente</span>
                                                }
                                                else if (cond.PACO_IN_CONFIRMADA == 3) 
                                                {
                                                    <span class="status-badge status-finish">Encerrada</span>
                                                }
                                            </td>

                                            <td style="width: auto">
                                                @if (cond.PACO_IN_RECEBE == 1)
                                                {
                                                    <span class="status-badge status-active">Na Consulta</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-pending">Mensal</span>
                                                }
                                            </td>

                                            <td style="width: auto" class="td-one-action">
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PACIENTE_CONSULTA_ALTERAR == 1)
                                                {
                                                    if (cond.PACO_IN_ATIVO == 1 & cond.PACO_IN_CONFIRMADA == 1)
                                                    {
                                                        <button type="button" 
                                                                class="btn btn-xs btn-link btn-disparar-modal-encerra" 
                                                                data-id="@cond.PACO_CD_ID" 
                                                                title="Encerrar Consulta"
                                                                id="btnEncerrarSubmit"
                                                                style="padding: 3px; color: #337ab7;">
                                                                <i class="fa fa-check" style="font-size: 17px; margin-left: -5px;"></i>
                                                        </button>
                                                    }
                                                    if (ViewBag.SRF != null && ViewBag.SRF == 1)
                                                    {
                                                        <a href="@urlReceita" 
                                                            target="_blank" 
                                                            style="color: #337ab7; cursor: pointer;" 
                                                            title="Abrir Portal e-CAC (Receita Federal)"
                                                            class="fa fa-external-link-square fa-lg">
                                                        </a>            
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-12">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhuma consulta para encerramento</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Paciente", action: "VerConsultasHoje", htmlAttributes: new { @class = "btn-loading" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

        <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>
    <style>
        /* Estilo Base */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-badge::before {
            content: "";
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-right: 6px;
        }

        /* PENDING (Gold) - Status 0 */
        .status-pending { background-color: #fef9c3; color: #a16207; }
        .status-pending::before { background-color: #ca8a04; }

        /* ACTIVE (Green) - Status 1 */
        .status-active { background-color: #dcfce7; color: #15803d; }
        .status-active::before { background-color: #16a34a; }

        /* CANCEL (Red) - Status 4 */
        .status-cancel { background-color: #fee2e2; color: #b91c1c; }
        .status-cancel::before { background-color: #dc2626; }

        /* FINISH (Dark Blue) - Status 2 */
        .status-finish { background-color: #dbeafe; color: #1e40af; }
        .status-finish::before { background-color: #2563eb; }

        /* OVERDUE (Gray) - Status 3 */
        .status-overdue { background-color: #f3f4f6; color: #4b5563; }
        .status-overdue::before { background-color: #6b7280; }
    </style>

}
