        }; 
    </script>

        <script type="text/javascript">
        $(document).ready(function () {
            // Configurações globais do Toastr
            toastr.options = {
                "closeButton": true,
                //"debug": false,
                "progressBar": true,
                "preventDuplicates": false,
                "positionClass": "toast-top-right",
                "onclick": null,
                "showDuration": "400",
                "hideDuration": "1000",
                "timeOut": "15000",
                "extendedTimeOut": "5000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            //    "iconClass": "customer-toast-info", // Se quiser remover o ícone padrão totalmente
            //    "titleClass": "toast-title",
            //    "messageClass": "toast-message"
            };

            // Verifica se existe mensagem de sucesso no TempData (vinda do Redirect)
            var msgSucesso = '@TempData["MensagemAcerto"]';
            if (msgSucesso != '') {
                toastr.success(msgSucesso, 'Sucesso!');
            }

            // Verifica se existe mensagem de erro
            var msgErro = '@TempData["MensagemErro"]';
            if (msgErro != '') {
                toastr.error(msgErro, 'Erro!');
            }
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            var $modal = $('#modalEncerramento');
            var idParaConfirmar = 0;

            // 1. Captura o ID ao clicar no botão da tabela e abre a modal
            $('body').on('click', '.btn-disparar-modal-encerra', function () {
                idParaConfirmar = $(this).data('id');
                $modal.modal('show');
            });

            // 2. Ação de confirmar DENTRO da modal via AJAX
            $('#btnEncerrarSubmit').click(function (e) {
                e.preventDefault();
                var $btn = $(this);

                // Trava o botão e mostra spinner
                $btn.prop('disabled', true).addClass('disabled');
                var originalText = $btn.html();
                $btn.html('<i class="fa fa-spinner fa-spin"></i> Processando...');

                $.ajax({
                    url: '@Url.Action("EncerrarConsultaJson", "Financeiro")',
                    type: 'POST',
                    data: { id: idParaConfirmar },
                    success: function (response) {
                        if (response.success) {
                            $modal.modal('hide');
                            // Redireciona para a URL enviada pelo Controller baseada nas Sessions
                            window.location.href = response.redirectUrl;
                        } else {
                            $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                            toastr.error(response.message, "Erro no Processamento");
                        }
                    },
                    error: function (xhr, status, error) {
                        $btn.prop('disabled', false).removeClass('disabled').html(originalText);
                        alert("Erro crítico na comunicação com o servidor: " + error);
                    }
                });
            });

            // Limpeza de segurança ao fechar modal
            $modal.on('hidden.bs.modal', function () {
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
            });
        });
    </script>


}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

