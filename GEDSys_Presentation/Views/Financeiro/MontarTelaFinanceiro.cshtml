@using Presentation.Extensions
@using CrossCutting
@model EntitiesServices.Model.CONSULTA_PAGAMENTO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Financeiro";
    ViewBag.MetaDescription = "WebDoctor - Financeiro - Dashhboard Financeiro";
    ViewBag.MetaKeywords = "WebDoctor, Financeiro, dashboard";
}
<div id="content" class="wraper container-fluid">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-12 col-md-12 col-sm-12">
        @*Atalhos*@
        <div class="row">
            <h3 style="color:olivedrab; font-weight:bold">Dashboard Financeiro</h3>
        </div>

        @*Widgets*@
        <br />
        <div class="row">
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Pagamentos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.DecimalFormatter(ViewBag.VencimentoHoje)</h1>
                        <small>Vencimento Hoje (R$)</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Pagamentos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.DecimalFormatter(ViewBag.PagtosMes)</h1>
                        <small>Pagamentos Mês Corrente (R$)</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Pagamentos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.DecimalFormatter(ViewBag.PagtosAno)</h1>
                        <small>Pagamentos Ano Corrente (R$)</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Recebimentos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.DecimalFormatter(ViewBag.RectosMes)</h1>
                        <small>Recebimentos Mês Corrente (R$)</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Recebimentos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.DecimalFormatter(ViewBag.RectosAno)</h1>
                        <small>Recebimentos Ano Corrente (R$)</small>
                    </div>
                </div>
            </div>
        </div>

        @*Atalhos*@
        <div class="row">
            <div class="form-group">
                <div class="col-lg-12 col-md-12 col-xs-12">
                    <a href="@Url.Action("MontarTelaPagamento", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Pagamentos" class="btn btn-sm btn-success btn-loading" id="emp" OnClick = "Fade()">Central de Pagamentos</a>                
                    <a href="@Url.Action("MontarTelaRecebimento", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Central de Recebimentos" class="btn btn-sm btn-success btn-loading" id="emp" OnClick = "Fade()">Central de Recebimentos</a>                
                    <a href="@Url.Action("MontarTelaValorConsulta", "Financeiro")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acesso à Consultas - Valores" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Consultas - Valores</a>                
                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPaciente", controller: "Paciente", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                    <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                        <i class="fa fa-spinner fa-spin"></i> Processando...
                    </span>
                </div>
                <br /><br />
            </div>
        </div>  

        @*Corpo*@
