                                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                                            Informações do Envio
                                                            @Html.TextAreaFor(m => m.AREA_TX_CONTEUDO, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", @tabindex = "-1", @readonly = "readonly"})
                                                        </div>
                                                    </div>
                                                }
                                                if (Model.AREA_IN_TIPO_EXAME == 4)
                                                {
                                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                                        <div class="form-group" style=" margin-left: -30px; margin-right: -30px;">
                                                            <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right:15px">Envio de Documento</h4>
                                                            <div class="col-lg-12 col-md-12 col-xs-12">
                                                                Informações do Envio
                                                                @Html.TextAreaFor(m => m.AREA_TX_CONTEUDO, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", @tabindex = "-1", @readonly = "readonly"})
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-6 col-md-6 col-xs-12">
                                                        <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold; margin-right:-45px">Anexos</h4>
                                                        <br />
                                                        <div class="form-group" style="margin-left: 0px;margin-right:-45px">
                                                            @if (Model.AREA_PACIENTE_ANEXO.Count > 0)
                                                            {
                                                                <table class="table table-striped table-bordered table-hover">
                                                                    <thead style="background-color:lightsteelblue">
                                                                        <tr>
                                                                            <th>Título</th>
                                                                            <th>Data</th>
                                                                            <th>Tipo</th>
                                                                            <th class="td-one-action">Ações</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var cond in (Model.AREA_PACIENTE_ANEXO.Where(p => p.APAN_IN_ATIVO == 1).ToList()))
                                                                        {
                                                                            <tr>
                                                                                <td style="width: auto">@cond.APAN_NM_TITULO</td>
                                                                                <td>@cond.APAN_DT_ANEXO.Value.ToShortDateString()</td>
                                                                                @if (cond.APAN_IN_TIPO == 1)
                                                                                {
                                                                                    <td>Imagem</td>
                                                                                }
                                                                                else if (cond.APAN_IN_TIPO == 2)
                                                                                {
                                                                                    <td>Vídeo</td>
                                                                                }
                                                                                else if (cond.APAN_IN_TIPO == 3)
                                                                                {
                                                                                    <td>PDF</td>
                                                                                }
                                                                                else if (cond.APAN_IN_TIPO == 4)
                                                                                {
                                                                                    <td>Audio</td>
                                                                                }
                                                                                else if (cond.APAN_IN_TIPO == 5)
                                                                                {
                                                                                    <td>Documento/Word</td>
                                                                                }
                                                                                else if (cond.APAN_IN_TIPO == 6)
                                                                                {
                                                                                    <td>Planilha/Excel</td>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <td>Outros</td>
                                                                                }
                                                                                <td class="td-one-action">
                                                                                    @if (cond.APAN_IN_TIPO == 1 || cond.APAN_IN_TIPO == 2)
                                                                                    {
                                                                                        @Html.TableLinkDetails(cond.APAN_CD_ID, "VerAnexoArea", "fa-camera", "Visualizar")
                                                                                    }
                                                                                    @if (cond.APAN_IN_TIPO == 4)
	                                                                                {
                                                                                        @Html.TableLinkDetails(cond.APAN_CD_ID, "VerAnexoAreaAudio","fa-volume-up", "Visualizar")
	                                                                                }
                                                                                    @if (cond.APAN_IN_TIPO == 3)
                                                                                    {
                                                                                        <a title="Visualizar" class="fa fa-camera fa-lg" href="~/PdfViewer/web/viewer.html?file=@(cond.APAN_AQ_ARQUIVO.Replace("~", ""))&ReturnUrl=@Request.Url.AbsolutePath" target="_blank"></a>
                                                                                    }
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>                                        
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>    
    
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}

