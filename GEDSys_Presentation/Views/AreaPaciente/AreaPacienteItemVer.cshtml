                                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                                            Nome do Arquivo
                                                            @Html.TextBoxFor(m => m.AREA_PACIENTE_ANEXO.First().APAN_NM_TITULO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
