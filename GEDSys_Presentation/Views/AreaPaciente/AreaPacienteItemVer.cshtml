@using Presentation.Extensions
@using EntitiesServices.Model
@model ERP_Condominios_Solution.ViewModels.AreaPacienteViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Area Paciente";
    ViewBag.MetaDescription = "WebDoctor - Area Paciente - Consulta";
    ViewBag.MetaKeywords = "WebDoctor, Area Paciente";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Área do Paciente</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaAreaPacienteVer", "AreaPaciente")">Área do Paciente</a>
            </li>
            <li class="active">
                <strong>Área do Paciente - Visualização</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Área do Paciente - Visualização</h5>
                        <span style="color:green; font-weight: 500; font-size: 20px;">@Model.PACIENTE.PACI_NM_NOME</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }  
                    @if (TempData["TemMensagem1"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto1"]</span>
                        </div>
                    }  

                    <div class="row">
                        <div class="col-lg-3">
                            <div class="widget style1 navy-bg">
                                <div class="row vertical-align">
                                    <div class="col-xs-2">
                                        <i class="fa fa-check fa-3x"></i>
                                    </div>
                                    <div class="col-xs-9 text-right">
                                        @if (Model.AREA_IN_TIPO == 1)
	                                    {
                                            <h3 class="font-normal">Marcação de Consulta</h3>
                                        }
                                        else if (Model.AREA_IN_TIPO == 2)
                                        {
                                            <h3 class="font-normal">Envio de Informação</h3>
                                        }
                                        else if (Model.AREA_IN_TIPO == 3)
                                        {
                                            <h3 class="font-normal">Envio de Documento</h3>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="widget style1 yellow-bg">
                                <div class="row vertical-align">
                                    <div class="col-xs-3">
                                        <i class="fa fa-calendar fa-3x"></i>
                                    </div>
                                    <div class="col-xs-9 text-right">
                                        <h3 class="font-normal">Criada em : @Model.AREA_DT_ENTRADA.Value.ToShortDateString()</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="widget style1 blue-bg">
                                <div class="row vertical-align">
                                    <div class="col-xs-3">
                                        <i class="fa fa-search fa-3x"></i>
                                    </div>
                                    <div class="col-xs-9 text-right">
                                        @if (Model.AREA_IN_VISTA == 1)
	                                    {
                                            <h3 class="font-normal">Visualizada</h3>
                                        }
                                        else
                                        {
                                            <h3 class="font-normal">Não Visualizada</h3>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="widget style1 red-bg">
                                <div class="row vertical-align">
                                    <div class="col-xs-3">
                                        <i class="fa fa-gear fa-3x"></i>
                                    </div>
                                    <div class="col-xs-9 text-right">
                                        @if (Model.AREA_IN_PROCESSADA == 1)
	                                    {
                                            <h3 class="font-normal">Processada</h3>
                                        }
                                        else
                                        {
                                            <h3 class="font-normal">Pendente</h3>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group" style=" margin-left: 5px; margin-right: 5px;"> 
                        @if (Model.AREA_IN_TIPO == 1)
                        {
                            if (Model.AREA_DT_CONSULTA.Value.Date < DateTime.Today.Date)
                            {
                                <h4 style="margin-left: 0px; color:brown; background-color: lavenderblush; font-weight:bold">ATENÇÃO: Esta solicitação não pode ser concluída. A data solicitada para a consulta é inferior à data corrente</h4>
                            }
                        }
                    </div>

                    <div class="form-group" style=" margin-left: 5px; margin-right: 5px;"> 
                        @*@if (Model.AREA_IN_TIPO == 1)
                        {
                            if (Model.AREA_IN_PROCESSADA == 0)
                            {
                                if (Model.AREA_DT_CONSULTA.Value.Date >= DateTime.Today.Date)
                                {
                                    @Html.ButtonLinkIndex(text: "Processar Marcação de Consulta", action: "ProcessarMarcacaoConsultaPlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                            }
                        } 
                        @if (Model.AREA_IN_TIPO == 2)
                        {
                            if (Model.AREA_IN_PROCESSADA == 0)
                            {
                                @Html.ButtonLinkIndex(text: "Processar Informações de Consulta", action: "ProcessarInfoConsultaPlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                            }
                        }
                        @if (Model.AREA_IN_TIPO == 3)
                        {
                            if (Model.AREA_IN_PROCESSADA == 0)
                            {
                                if (Model.AREA_IN_TIPO_EXAME == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Processar Contrato de Locação", action: "ProcessarContratoLocacaoPlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if (Model.AREA_IN_TIPO_EXAME == 2)
                                {
                                    @Html.ButtonLinkIndex(text: "Processar Distrato de Locação", action: "ProcessarDistratoLocacaoPlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if (Model.AREA_IN_TIPO_EXAME == 3)
                                {
                                    @Html.ButtonLinkIndex(text: "Processar Resultado de Exame", action: "ProcessarResultadoExamePlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                                else if (Model.AREA_IN_TIPO_EXAME == 4)
                                {
                                    @Html.ButtonLinkIndex(text: "Processar Documento", action: "ProcessarDocumentoPlano", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                }
                            }
                        }*@
                        @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarAreaPacienteVer", controller: "AreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                        <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                            <i class="fa fa-spinner fa-spin"></i> Processando...
                        </span>
                    </div>

                    <div class="tabs-container">
                        <ul class="nav nav-tabs">
                            <li class="active"><a data-toggle="tab" href="#tab-1">Item da Área do Paciente</a></li>
                        </ul>

                        <div class="tab-content">
                            @*Dados Gerais*@
                            <div id="tab-1" class="tab-pane active">
                                <div class="panel-body">
                                    @using (Html.BeginForm("AreaPacienteItemVer", "AreaPaciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <div class="row">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Paciente</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Nome do Paciente
                                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", autofocus = true, @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data Nascimento
                                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                </div>
                                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        CPF
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                }
                                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Celular
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                }
                                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                                {
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Telefone
                                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="row" style="width: 100%;">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right:-15px">Informações do Item</h4>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data de Criação
                                                    @Html.TextBoxFor(m => m.AREA_DT_ENTRADA, "{0:dd/MM/yyyy HH:mm}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Identificador
                                                    @Html.TextBoxFor(m => m.AREA_GU_IDENTIFICADOR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Visualizada
                                                    @Html.TextBoxFor(m => m.Vista, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Processada
                                                    @Html.TextBoxFor(m => m.Processada, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data de Processo
                                                    @Html.TextBoxFor(m => m.AREA_DT_PROCESSO, "{0:dd/MM/yyyy HH:mm}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Título
                                                    @Html.TextBoxFor(m => m.AREA_NM_TITULO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                                </div>
                                            </div>
                                            @if (Model.AREA_IN_TIPO == 1)
                                            {
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right:-15px">Solicitação de Marcação de Consulta</h4>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Data da Consulta
                                                        @Html.TextBoxFor(m => m.AREA_DT_CONSULTA, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                                        Hora
                                                        @Html.TextBoxFor(m => m.AREA_HR_INICIO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Tipo de Consulta
                                                        @Html.TextBoxFor(m => m.TipoConsulta, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                                        Informações da Solicitação
                                                        @Html.TextAreaFor(m => m.AREA_TX_CONTEUDO, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", @tabindex = "-1", @readonly = "readonly"})
                                                    </div>
                                                </div>
                                            }
                                            @if (Model.AREA_IN_TIPO == 2)
                                            {
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right:-15px">Envio de Informações para Consulta</h4>
                                                </div>
                                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                                        Informações prévias para consultas
                                                        @Html.TextAreaFor(m => m.AREA_TX_CONTEUDO, new { @class = "form-control", style = "width: 100%; height: 200px; overflow:auto;", @tabindex = "-1", @readonly = "readonly"})
                                                    </div>
                                                </div>
                                            }
                                            @if (Model.AREA_IN_TIPO == 3)
                                            {
                                                if (Model.AREA_IN_TIPO_EXAME == 1)
                                                {
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <h4 style="margin-left: 15px; color:green; background-color: beige; font-weight:bold; margin-right:-15px">Envio de Contrato de Locação</h4>
                                                        <div class="col-lg-10 col-md-10 col-xs-12">
                                                            Locação
                                                            @Html.TextBoxFor(m => m.LOCACAO.LOCA_NM_TITULO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                                        </div>
                                                        @if (Model.LOCACAO.LOCA_IN_STATUS == 1)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Ativa", "Ativa", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                             </div>
                                                        }
                                                        else if (Model.LOCACAO.LOCA_IN_STATUS == 2)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Encerrada", "Encerrada", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                            </div>
                                                        }
                                                        else if (Model.LOCACAO.LOCA_IN_STATUS == 3)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Vencida", "Vencida", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                            </div>
                                                        }
                                                        else if (Model.LOCACAO.LOCA_IN_STATUS == 4)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Cancelada", "Cancelada", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                            </div>
                                                        }
                                                        else if (Model.LOCACAO.LOCA_IN_STATUS == 0)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Pendente", "Pendente", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-12 col-md-12 col-xs-12">
                                                            Nome do Arquivo
                                                            @Html.TextBoxFor(m => m.AREA_PACIENTE_ANEXO.First().APAN_NM_TITULO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                        <div class="col-lg-12 col-md-12 col-xs-12">
