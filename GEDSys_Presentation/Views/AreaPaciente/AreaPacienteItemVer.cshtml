                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
                                                                @Html.TextBox("Vencida", "Vencida", new { @class = "form-control", @readonly = "readonly" })                                                           
                                                            </div>
                                                        }
                                                        else if (Model.LOCACAO.LOCA_IN_STATUS == 4)
                                                        {
                                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                                Situação
