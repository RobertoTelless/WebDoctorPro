    <script type="text/javascript">
        $(document).ready(function () { 
    // --- 1. LÓGICA DE RESTAURAÇÃO (Executa ao carregar a página) ---
            var scrollPos = localStorage.getItem('scrollPosition');
            if (scrollPos) {
                window.scrollTo(0, scrollPos);
                localStorage.removeItem('scrollPosition'); // Limpa para não rolar em cliques comuns depois
            }
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

