    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalConfirmar(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary btn-loading1" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma marcação de consulta?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Marcação</h5>');
            $('#modal').modal('show');
        }

    </script>

    <script type="text/javascript">
        var urlDeCancelamento; // Variável global para armazenar a URL de cancelamento

        // Função chamada no evento onclick do <span>
        function ShowModalCancelar(url) {
            urlDeCancelamento = url; // Armazena a URL com o ID do paciente
            $('#modalCancelar').modal('show');
        }

        $(document).ready(function () {
            // Lógica para o botão de confirmação dentro da modal
            $('#btnConfirmarCancelamento').click(function () {
                var justificativa = $('#textoJustificativa').val();
                
                if (justificativa.trim() === "") {
                    alert("Por favor, digite uma justificativa para o cancelamento.");
                    return;
                }

                $.ajax({
                    url: urlDeCancelamento,
                    type: 'POST',
                    data: { justificativa: justificativa }, // Alterado para enviar como form data
                    success: function (response) {
                        $('#modalCancelar').modal('hide');
                        if (response.success) {
                            //alert("Consulta cancelada com sucesso!");
                            // Recarrega a página ou atualiza a tabela para refletir a mudança
                            window.location.reload(); 
                        } else {
                            //alert("Erro ao cancelar a consulta: " + response.message);
                            window.location.reload(); 
                        }
                    },
                    error: function (xhr, status, error) {
                        $('#modalCancelar').modal('hide');
                    //    alert("Ocorreu um erro na requisição AJAX: " + error);
                    }
                });
            });

            // Limpa o textarea quando a modal é fechada
            $('#modalCancelar').on('hidden.bs.modal', function () {
                $('#textoJustificativa').val('');
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.dataTables-consulta').DataTable({
                "pageLength": 5,          // Define o padrão de 5 linhas
                "lengthChange": false,    // Remove o seletoc de "Mostrar X registros"
                "searching": false,       // Remove a caixa de pesquisa
                "dom": 'rtp',             // 'r' (processing), 't' (table), 'p' (pagination)
                                          // Note que removemos o 'B' (buttons), 'f' (filter) e 'l' (length)
                "columnDefs": [
                    {
                        "type": "date-eu", 
                        "targets": 0 
                    }
                ],
                // Os botões podem permanecer definidos, mas como removemos o 'B' do 'dom', 
                // eles não serão renderizados na tela.
                "buttons": [
                    { extend: 'excel', title: 'Consultas_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');
                            $(win.document.body).find('table')
                                .addClass('compact')
                                .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });   
