@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.AREA_PACIENTE
@{ Layout = "~/Views/Shared/_Layout_Admin.cshtml"; }
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <h3 class="title">Área do Paciente</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Área do Paciente</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:darkseagreen; color:darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaConsulta</h1>
                    <small>Marcação de Consulta</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:darkseagreen; color:darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaInfo</h1>
                    <small>Informação para Consultas</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaDoc</h1>
                    <small>Envio de Documentos</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarAreaPaciente", "AreaPaciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-5 col-md-5 col-xs-12">
                                Paciente
                                @Html.TextBoxFor(m => m.AREA_NM_PACIENTE_DUMMY, new { @class = "form-control", autofocus = true, @id = "txtNomePaciente", data_toggle = "popover", data_content = "Informe o nome do paciente", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.AREA_DT_ENTRADA, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn", data_toggle = "popover", data_content = "Informe a data inicial da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.AREA_DT_DUMMY, new { @class = "form-control", autofocus = true, @id = "dn1", data_toggle = "popover", data_content = "Informe a data final da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Tipo
                                @Html.DropDownListFor(m => m.AREA_IN_TIPO, (SelectList)ViewBag.Tipo, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione o tipo de transação", data_trigger="hover", data_placement="top" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                <a href="@Url.Action("RetirarFiltroAreaPaciente", "AreaPaciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Retorna a exibição padrão da área do paciente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Retirar Filtro</a>                
                                <a href="@Url.Action("EnviarMensagemPaciente", "AreaPaciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Envia mensagem para o paciente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Enviar Mensagem</a>                
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12" id="central">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Área do Paciente - Itens</h5>
                </div>
                <div class="ibox-content">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>}
                        @if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }                    
                        <div class="row">
                            @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.AREA_PACIENTE>).Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Paciente</th>
                                            <th style="width: auto">Data de Entrada</th>
                                            <th style="width: auto">Tipo de Entrada</th>
                                            <th style="width: auto">Tipo de Documento</th>
                                            <th style="width: auto">Descrição</th>
                                            <th style="width: auto">Vista</th>
                                            <th style="width: auto">Processada</th>
                                            <th style="width: auto">Processamento</th>
                                            <th style="width: auto" class="td-one-action">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.AREA_PACIENTE>))
                                        {
                                            <tr>
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                {
                                                    <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EditarPaciente", "Paciente", new { id = cond.PACI_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Editar/Consultar paciente"/>@cond.PACIENTE.PACI_NM_NOME</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("ConsultarPaciente", "Paciente", new { id = cond.PACI_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Consultar paciente"/>@cond.PACIENTE.PACI_NM_NOME</td>
                                                }

                                                <td>
                                                    <span style="display:none; width: auto">@cond.AREA_DT_ENTRADA.Value.ToString("yyyyMMdd")</span>
                                                    @cond.AREA_DT_ENTRADA.Value.ToString("dd/MM/yyyy")
                                                </td>

                                                @if (cond.AREA_IN_TIPO == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Marcação de Consulta</span></td>
                                                }
                                                else if (cond.AREA_IN_TIPO == 2)
                                                {
                                                    <td style="width: auto"><span class="badge badge-success">Informações de Consulta</span></td>
                                                }
                                                else if (cond.AREA_IN_TIPO == 3)
                                                {
                                                    <td style="width: auto"><span class="badge badge-warning">Envio de Documento</span></td>
                                                }

                                                @if (cond.AREA_IN_TIPO == 3)
                                                {
                                                    if (cond.AREA_IN_TIPO_EXAME == 1)
                                                    {
                                                        <td style="width: auto"><span class="badge badge-primary">Contrato de Locação</span></td>
                                                    }
                                                    else if (cond.AREA_IN_TIPO_EXAME == 2)
                                                    {
                                                        <td style="width: auto"><span class="badge badge-primary">Distrato de Locação</span></td>
                                                    }
                                                    else if (cond.AREA_IN_TIPO_EXAME == 3)
                                                    {
                                                        <td style="width: auto"><span class="badge badge-success">Resultado de Exame</span></td>
                                                    }
                                                    else if (cond.AREA_IN_TIPO_EXAME == 4)
                                                    {
                                                        <td style="width: auto"><span class="badge badge-warning">Documento</span></td>
                                                    }
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }

                                                <td style="width: auto">@cond.AREA_NM_TITULO</td>

                                                @if (cond.AREA_IN_VISTA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Não</span></td>
                                                }

                                                @if (cond.AREA_IN_PROCESSADA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Não</span></td>
                                                }

                                                @if (cond.AREA_DT_PROCESSO != null)
                                                {
                                                    <td>
                                                        <span style="display:none; width: auto">@cond.AREA_DT_PROCESSO.Value.ToString("yyyyMMdd")</span>
                                                        @cond.AREA_DT_PROCESSO.Value.ToString("dd/MM/yyyy")
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }

                                                <td style="width: auto" class="td-one-action">
                                                    @Html.TableLinkDetails(cond.AREA_CD_ID, "AreaPacienteItemVer", "fa-search", "Ver Item")
                                                    @if (cond.AREA_IN_TIPO == 1 & cond.AREA_IN_PROCESSADA == 0)
                                                    {
                                                        if (cond.AREA_DT_CONSULTA.Value.Date >= DateTime.Today.Date)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarMarcacaoConsulta", "fa-gears", "Processar Consulta")
                                                        }
                                                    }
                                                    @if (cond.AREA_IN_TIPO == 2 & cond.AREA_IN_PROCESSADA == 0)
                                                    {
                                                        if (cond.AREA_DT_CONSULTA.Value.Date >= DateTime.Today.Date)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarInfoConsultaPlano", "fa-gears", "Processar Informação")
                                                        }
                                                    }
                                                    @if (cond.AREA_IN_TIPO == 3 & cond.AREA_IN_PROCESSADA == 0)
                                                    {
                                                        if (cond.AREA_IN_TIPO_EXAME == 1)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarContratoLocacao", "fa-gears", "Processar Contrato")
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 2)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarDistratoLocacao", "fa-gears", "Processar Distrato")
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 3)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarResultadoExame", "fa-gears", "Processar Resultado")
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 4)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarDocumento", "fa-gears", "Processar Documento")
                                                        }
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-2 col-md-2 col-xs-2">

                                    </div>
                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                        <h2 style="font-weight: bold">Nenhum item de área de paciente disponível ou sua pesquisa não retornou nenhum resultado</h2>
                                        @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "AreaPaciente", action: "RetirarFiltroAreaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-2">

                                    </div>
                                </div>
                            }
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
        <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>  
    
    <script type="text/javascript">
        $(document).ready(function () { 
            $('.btn-loading').on('click', function (e) {            
                $(this).prop('disabled', true);
                $(this).addClass('disabled');
                $('#loadingIndicator').show();
                var tagName = $(this).prop('tagName').toLowerCase();
                if (tagName === 'a') {
                    e.preventDefault(); 
                    var targetUrl = $(this).attr('href');
                    window.location.href = targetUrl;

                } else if (tagName === 'button' || tagName === 'input') {
                    $(this).closest('form').submit();
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.btn-loading1').on('click', function (e) {
            
                var $this = $(this);
                var tagName = $this.prop('tagName').toLowerCase();
                $this.addClass('disabled'); 
                $('#loadingIndicator').show();

                if (tagName === 'a') {
                    e.preventDefault();
                
                    var targetUrl = $this.attr('href');
                    window.location.href = targetUrl;
                
                } else if (tagName === 'button' || tagName === 'input') {               
                    $this.closest('form').submit();
                    $this.prop('disabled', true);
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtNomePaciente').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetPacienteNome", "Paciente2")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                // --- NOVO BLOCO DE CONFIGURAÇÃO ---
                columnDefs: [
                    {
                         "type": "date-eu", 
                        "targets": [1, 7] 
                    }
                ],
                // ---------------------------------       
                buttons: [
                    { extend: 'excel', title: 'AreaPaciente_Planilha' },

                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });         
        });
    </script>

    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#dn").mask("99/99/9999");
            $("#dn1").mask("99/99/9999");
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}
