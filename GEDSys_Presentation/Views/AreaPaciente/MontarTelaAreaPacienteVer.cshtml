@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.AREA_PACIENTE
@{ Layout = "~/Views/Shared/_Layout_Admin.cshtml"; }
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal inmodal fade" id="modalConfirmacaoInfo" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Informações para Consultas</h4>
                    <small class="font-bold">WebDoctorPro - Área do Paciente</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3>Tem certeza que deseja incluir essas informações no prontuário do paciente?</h3>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnConfirmarSubmit">Confirmar Informações</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal inmodal fade" id="modalConfirmacaoContrato" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Contrato de Locação</h4>
                    <small class="font-bold">WebDoctorPro - Área do Paciente</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3><span class="text-danger font-bold">ATENÇÃO:</span> Visualize o documento antes de anexar para verificar se está realmente assinado</h3>
                    <h4>Tem certeza que deseja anexar esse contrato à locação contratada pelo paciente?</h4>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</span></p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnAnexarSubmit">Confirmar Anexação</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal inmodal fade" id="modalConfirmacaoDistrato" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Distrato de Locação</h4>
                    <small class="font-bold">WebDoctorPro - Área do Paciente</small>
                </div>
            
                <div class="modal-body text-center">
                    <h3><span class="text-danger font-bold">ATENÇÃO:</span> Visualize o documento antes de anexar para verificar se está realmente assinado</h3>
                    <h4>Tem certeza que deseja anexar esse distrato à locação contratada pelo paciente?</h4>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</span></p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnDistratoSubmit">Confirmar Anexação</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal inmodal fade" id="modalConfirmacaoDocumento" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Anexação de Documentos ao Paciente</h4>
                    <small class="font-bold">WebDoctorPro - Área do Paciente</small>
                </div>
            
                <div class="modal-body text-center">
                    <h4>Tem certeza que deseja anexar esse(s) documento(s) ao paciente?</h4>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</span></p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnDocumentoSubmit">Confirmar Anexação</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal inmodal fade" id="modalConfirmacaoExame" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="position: relative; padding: 30px 15px;">
                    <img src="@Url.Content("~/Images/Prontuario/prontuario_icon_3.png?v=1.1")" 
                         style="position: absolute; left: 15px; top: 15px; width: 40px; height: auto;" 
                         alt="Ícone" />

                    <i class="fa fa-check-circle modal-icon text-primary" style="display: block;"></i>
                    <h4 class="modal-title">Resultado de Exames</h4>
                    <small class="font-bold">WebDoctorPro - Área do Paciente</small>
                </div>
            
                <div class="modal-body text-center">
                    <h4>Tem certeza que deseja incluir esse resultado de exame e seus anexos ao paciente?</h4>
                    <p>Esta ação não poderá ser desfeita e os registros serão atualizados no sistema.</span></p>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn btn-white" data-dismiss="modal">Voltar</button>
                    <button type="button" class="btn btn-primary" id="btnExameSubmit">Confirmar Anexação</button>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Área do Paciente</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Área do Paciente</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:darkseagreen; color:darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaConsulta</h1>
                    <small>Marcação de Consulta</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:darkseagreen; color:darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaInfo</h1>
                    <small>Informação para Consultas</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Área do Paciente</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.AreaDoc</h1>
                    <small>Envio de Documentos</small>
                    <br />
                    <br />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarAreaPaciente", "AreaPaciente", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <input type="hidden" name="id" id="hiddenIdLocacao" value="" />
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-5 col-md-5 col-xs-12">
                                Paciente
                                @Html.TextBoxFor(m => m.AREA_NM_PACIENTE_DUMMY, new { @class = "form-control", autofocus = true, @id = "txtNomePaciente", data_toggle = "popover", data_content = "Informe o nome do paciente", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Inicial
                                @Html.TextBoxFor(m => m.AREA_DT_ENTRADA, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id = "dn", data_toggle = "popover", data_content = "Informe a data inicial da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.AREA_DT_DUMMY, new { @class = "form-control", autofocus = true, @id = "dn1", data_toggle = "popover", data_content = "Informe a data final da faixa de datas a ser pesquisada", data_trigger="hover", data_placement="top" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Tipo
                                @Html.DropDownListFor(m => m.AREA_IN_TIPO, (SelectList)ViewBag.Tipo, "Selecionar", new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Selecione o tipo de transação", data_trigger="hover", data_placement="top" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar", htmlAttributes: new { @class = "btn-loading1" })
                                <a href="@Url.Action("RetirarFiltroAreaPaciente", "AreaPaciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Retorna a exibição padrão da área do paciente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Retirar Filtro</a>                
                                <a href="@Url.Action("EnviarEMailPaciente", "AreaPaciente")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Envia mensagem para o paciente" class="btn btn-sm btn-warning btn-loading" id="emp" OnClick = "Fade()">Enviar Mensagem</a>                
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente", htmlAttributes: new { @class = "btn-loading" })
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                                <span id="loadingIndicator" style="display: none; margin-left: 10px; color: #007bff;">
                                    <i class="fa fa-spinner fa-spin"></i> Processando...
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12" id="central">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Área do Paciente - Itens</h5>
                </div>
                <div class="ibox-content">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>}
                        @*@if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }*@                    
                        <div class="row">
                            @if (ViewBag.ListasAreas != null && (ViewBag.ListasAreas as List<EntitiesServices.Model.AREA_PACIENTE>).Count > 0)
                            {
                                <table class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead style="background-color:lightsteelblue">
                                        <tr>
                                            <th style="width: auto">Data de Entrada</th>
                                            <th style="width: auto">Paciente</th>
                                            <th style="width: auto">Tipo de Entrada</th>
                                            <th style="width: auto">Tipo de Documento</th>
                                            <th style="width: auto">Descrição</th>
                                            <th style="width: auto">Vista</th>
                                            <th style="width: auto">Processada</th>
                                            <th style="width: auto">Processamento</th>
                                            <th style="width: auto" class="td-one-action">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cond in (ViewBag.ListasAreas as List<EntitiesServices.Model.AREA_PACIENTE>).OrderByDescending(p => p.AREA_DT_ENTRADA).ToList())
                                        {
                                            <tr>
                                                <td>
                                                    <span style="display:none; width: auto">@cond.AREA_DT_ENTRADA.Value.ToString("yyyyMMdd")</span>
                                                    @cond.AREA_DT_ENTRADA.Value.ToString("dd/MM/yyyy")
                                                </td>
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                {
                                                    <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EditarPaciente", "Paciente", new { id = cond.PACI_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Editar/Consultar paciente"/>@cond.PACIENTE.PACI_NM_NOME</td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("ConsultarPaciente", "Paciente", new { id = cond.PACI_CD_ID })" class="btn-loading" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Consultar paciente"/>@cond.PACIENTE.PACI_NM_NOME</td>
                                                }
                                                <td style="width: auto">
                                                    @if (cond.AREA_IN_TIPO == 1) 
                                                    {
                                                        <span class="status-badge status-active">Marcação de Consulta</span>
                                                    }
                                                    else if (cond.AREA_IN_TIPO == 2)
                                                    {
                                                        <span class="status-badge status-pending">Informações de Consulta</span>
                                                    }
                                                    else if (cond.AREA_IN_TIPO == 3)
                                                    {
                                                        <span class="status-badge status-finish">Envio de Documento</span>
                                                    }
                                                </td>

                                                @if (cond.AREA_IN_TIPO == 3)
                                                {
                                                    <td style="width: auto">
                                                        @if (cond.AREA_IN_TIPO_EXAME == 1) 
                                                        {
                                                            <span class="status-badge status-active">Contrato de Locação</span>
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 2)
                                                        {
                                                            <span class="status-badge status-pending">Distrato de Locação</span>
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 3)
                                                        {
                                                            <span class="status-badge status-finish">Resultado de Exame</span>
                                                        }
                                                        else if (cond.AREA_IN_TIPO_EXAME == 4)
                                                        {
                                                            <span class="status-badge status-finish">Documento</span>
                                                        }
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }

                                                <td style="width: auto">@cond.AREA_NM_TITULO</td>

                                                <td style="width: auto">
                                                    @if (cond.AREA_IN_VISTA == 1) // ATIVA
                                                    {
                                                        <span class="status-badge status-active">Sim</span>
                                                    }
                                                    else 
                                                    {
                                                        <span class="status-badge status-pending">Não</span>
                                                    }
                                                </td>
                                                <td style="width: auto">
                                                    @if (cond.AREA_IN_PROCESSADA == 1) // ATIVA
                                                    {
                                                        <span class="status-badge status-active">Sim</span>
                                                    }
                                                    else 
                                                    {
                                                        <span class="status-badge status-pending">Não</span>
                                                    }
                                                </td>


                                                @*@if (cond.AREA_IN_VISTA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Não</span></td>
                                                }

                                                @if (cond.AREA_IN_PROCESSADA == 1)
                                                {
                                                    <td style="width: auto"><span class="badge badge-primary">Sim</span></td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto"><span class="badge badge-danger">Não</span></td>
                                                }*@

                                                @if (cond.AREA_DT_PROCESSO != null)
                                                {
                                                    <td>
                                                        <span style="display:none; width: auto">@cond.AREA_DT_PROCESSO.Value.ToString("yyyyMMdd")</span>
                                                        @cond.AREA_DT_PROCESSO.Value.ToString("dd/MM/yyyy")
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td style="width: auto">-</td>
                                                }

                                                <td style="width: auto" class="td-one-action">
                                                    @Html.TableLinkDetails(cond.AREA_CD_ID, "AreaPacienteItemVer", "fa-search", "Ver Item")
                                                    @if (cond.AREA_IN_TIPO == 1 & cond.AREA_IN_PROCESSADA == 0)
                                                    {
                                                        if (cond.AREA_DT_CONSULTA.Value.Date >= DateTime.Today.Date)
                                                        {
                                                            @Html.TableLinkDetails(cond.AREA_CD_ID, "ProcessarMarcacaoConsulta", "fa-gears", "Processar Consulta")
                                                        }
                                                    }
                                                    @if (cond.AREA_IN_TIPO == 2 & cond.AREA_IN_PROCESSADA == 0)
                                                    {
                                                        <button type="button" 
                                                                class="btn btn-xs btn-link btn-disparar-modal-tabela" 
                                                                data-id="@cond.AREA_CD_ID" 
                                                                title="Processar Informação"
                                                                id="btnConfirmarSubmit"
                                                                style="padding: 3px; color: #337ab7;">
                                                                <i class="fa fa-gears" style="font-size: 17px; margin-left: -5px;"></i>
                                                        </button>
                                                    }
                                                    @if (cond.AREA_IN_TIPO == 3)
                                                    {
                                                        if (cond.AREA_IN_PROCESSADA == 0)
                                                        {
                                                            if (cond.AREA_IN_TIPO_EXAME == 1)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-xs btn-link btn-disparar-modal-tabela_1" 
                                                                        data-id="@cond.AREA_CD_ID" 
                                                                        title="Processar Contrato"
                                                                        id="btnAnexarSubmit"
                                                                        style="padding: 3px; color: #337ab7;">
                                                                        <i class="fa fa-gears" style="font-size: 17px; margin-left: -5px;"></i>
                                                                </button>
                                                            }
                                                            else if (cond.AREA_IN_TIPO_EXAME == 2)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-xs btn-link btn-disparar-modal-tabela_2" 
                                                                        data-id="@cond.AREA_CD_ID" 
                                                                        title="Processar Distrato"
                                                                        id="btnDistratoSubmit"
                                                                        style="padding: 3px; color: #337ab7;">
                                                                        <i class="fa fa-gears" style="font-size: 17px; margin-left: -5px;"></i>
                                                                </button>
                                                            }
                                                            else if (cond.AREA_IN_TIPO_EXAME == 3)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-xs btn-link btn-disparar-modal-tabela_4" 
                                                                        data-id="@cond.AREA_CD_ID" 
                                                                        title="Processar Resultado de Exame"
                                                                        id="btnExameSubmit"
                                                                        style="padding: 3px; color: #337ab7;">
                                                                        <i class="fa fa-gears" style="font-size: 17px; margin-left: -5px;"></i>
                                                                </button>
                                                            }
                                                            else if (cond.AREA_IN_TIPO_EXAME == 4)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-xs btn-link btn-disparar-modal-tabela_3" 
                                                                        data-id="@cond.AREA_CD_ID" 
                                                                        title="Processar Documento"
                                                                        id="btnDocumentoSubmit"
                                                                        style="padding: 3px; color: #337ab7;">
                                                                        <i class="fa fa-gears" style="font-size: 17px; margin-left: -5px;"></i>
                                                                </button>
                                                            }
                                                        }

                                                        if (((cond.AREA_IN_TIPO_EXAME == 1 || cond.AREA_IN_TIPO_EXAME == 2) & cond.AREA_PACIENTE_ANEXO != null) && cond.AREA_PACIENTE_ANEXO.Any())
                                                        {
                                                            var arquivoPath = cond.AREA_PACIENTE_ANEXO.First().APAN_AQ_ARQUIVO.Replace("~", "");    
                                                            <a href="@Url.Content("~/PdfViewer/web/viewer.html?file=" + arquivoPath + "&ReturnUrl=" + Request.Url.AbsolutePath)" 
                                                               target="_blank" 
                                                               class="btn btn-xs btn-link" 
                                                               title="Ver Documento"
                                                               style="padding: 3px; color: #337ab7; text-decoration: none;">
                                                                <i class="fa fa-file-o" style="font-size: 17px; margin-left: -5px;"></i>
                                                            </a>
                                                        }
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-lg-2 col-md-2 col-xs-2">

                                    </div>
