<script type="text/javascript">
    $(document).ready(function () {
        var $modal = $('#modalConfirmacaoInfo');
        var $form = $('#pwd-container1');
        var $hiddenId = $('#hiddenIdLocacao');

        // 1. Captura o clique nos botões DENTRO da tabela
        // Usamos delegação (.on) caso a tabela seja dinâmica (DataTables)
        $('body').on('click', '.btn-disparar-modal-tabela', function () {
            var idDaLinha = $(this).data('id');
            $hiddenId.val(idDaLinha);
            $modal.modal('show');
        });

        // 2. Ação de confirmar DENTRO da modal (Mantivemos sua lógica, apenas ajustamos o submit)
        $('#btnConfirmarSubmit').click(function (e) {
            e.preventDefault();

            var $btn = $(this);

            // Feedback visual no botão da modal
            $btn.prop('disabled', true).addClass('disabled');
            $btn.html('<i class="fa fa-spinner fa-spin"></i> Processando...');

            // Esconde a modal
            $modal.modal('hide');

            // 3. Limpeza e Submit
            setTimeout(function () {
                // Limpeza de resíduos do template
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open').css('padding-right', '');
                
                // Submit via DOM puro do formulário que agora contém o ID correto
                document.getElementById('pwd-container1').submit();
            }, 400);
        });

        // Segurança: limpa resíduos se fechar no "X" ou clicar fora
        $modal.on('hidden.bs.modal', function () {
            // Opcional: Limpa o ID se a pessoa desistir
            $hiddenId.val(''); 
            
            $('.modal-backdrop').remove();
            $('body').removeClass('modal-open');
        });
    });

    $('#btnConfirmarSubmit').off('click').click(function (e) {
        e.preventDefault();
        var $btn = $(this);
        var idLocacao = $('#hiddenIdLocacao').val();

        $btn.prop('disabled', true).addClass('disabled');
        $btn.html('<i class="fa fa-spinner fa-spin"></i> Processando...');

        $.ajax({
            url: '@Url.Action("ProcessarInfoConsultaPlano", "AreaPaciente")',
            type: 'POST',
            data: { id: idLocacao },
            success: function () {
                $('#modalConfirmacaoInfo').modal('hide');
                // Redireciona para garantir a atualização da Session e da lista
                window.location.href = '@Url.Action("MontarTelaAreaPacienteVer", "AreaPaciente")';
            },
            error: function (xhr, status, error) {
                $btn.prop('disabled', false).removeClass('disabled').html('Confirmar Informações');
                alert("Erro ao processar informações: " + error);
            }
        });
    });

</script>

