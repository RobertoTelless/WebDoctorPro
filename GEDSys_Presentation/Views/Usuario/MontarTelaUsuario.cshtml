@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.USUARIO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Usuários";
    ViewBag.MetaDescription = "WebDoctor - Lista de usuários";
    ViewBag.MetaKeywords = "WebDoctor, usuario, usuário, acesso";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h3 class="title">Usuários</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Usuários</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="form-group" style=" margin-left: 15px; margin-right: 0px;">
            @* --- INÍCIO DA AJUDA CONTEXTUAL --- *@
            <details class="ajuda-contextual">
                <summary><i class="fa fa-info-circle text-info"></i> Resumo das funcionalidades desta página</summary>
                <div class="well well-sm">
                    <p>Essa é a página da central de usuários do <b>WebDoctorPro</b>. Nela você poderá:</p>
                    <ol>
                        <li>Exibe os usuários cadastrados.</li>
                        <li>Localizar (filtrar) um usuário e acessar a sua página principal.</li>
                        <li>Acessar a página de inclusão de usuários.</li>
                        <li>Acessar a página de alteração de usuários.</li>
                    </ol>
                </div>
            </details>
            @* --- FIM DA AJUDA CONTEXTUAL --- *@
        </div>
    </div>
    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Usuários</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.Usuarios</h1>
                    <small>Usuários Cadastrados</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Bloqueios</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.UsuariosBloqueados</h1>
                    <small>Usuários Bloqueados</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color:cornflowerblue; color:darkblue">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Usuários</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.UsuariosHoje</h1>
                    <small>Usuários com acesso hoje</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarUsuario", "Usuario", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Nome do Usuário
                                @Html.TextBoxFor(m => m.USUA_NM_NOME, new { @class = "form-control", autofocus = true, @id = "txtNomeUsuario" })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Apelido
                                @Html.TextBoxFor(m => m.USUA_NM_APELIDO, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                CPF
                                @Html.TextBoxFor(m => m.USUA_NR_CPF, new { @class = "form-control", autofocus = true, @id="cpf" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Perfil
                                @Html.DropDownListFor(m => m.PERF_CD_ID, (SelectList)ViewBag.Perfis, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Categoria
                                @Html.DropDownListFor(m => m.CAUS_CD_ID, (SelectList)ViewBag.Cats, "Selecionar", new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUSAO_USUARIO == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Novo Usuário", controller: "Usuario", action: "IncluirUsuario", buttonClass: "primary")
                                }
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Usuario", action: "RetirarFiltroUsuario")
                                @Html.ButtonLinkIndex(text: "Exibir Inativos", controller: "Usuario", action: "MostrarTudoUsuario")
                                @Html.ButtonLinkIndex(text: "Imprimir Usuários", controller: "Usuario", action: "GerarRelatorioUsuario")
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente")
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Usuários</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.USUARIO>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Nome do Usuário</th>
                                        <th style="width: auto">Apelido</th>
                                        <th style="width: auto">Especialidade</th>
                                        <th style="width: auto">E-Mail</th>
                                        <th style="width: auto">Celular</th>
                                        <th style="width: auto">Categoria</th>
                                        <th style="width: auto">Perfil</th>
                                        <th style="width: auto">CPF</th>
                                        <th style="width: auto">Bloqueado</th>
                                        <th style="width: auto">Acessos</th>
                                        <th style="width: auto"></th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.USUARIO>))
                                    {
                                        <tr>
                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EDICAO_USUARIO == 1)
                                            {
                                                <td style="width: auto"><a href="@Url.Action("EditarUsuario", "Usuario", new { id = cond.USUA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição de Usuário" />@cond.USUA_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto"><a href="@Url.Action("VerUsuario", "Usuario", new { id = cond.USUA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de visualização de Usuário"/>@cond.USUA_NM_NOME</td>
                                            }
                                            <td style="width: auto">@cond.USUA_NM_APELIDO</td>
                                            @if (cond.ESPECIALIDADE != null)
                                            {
                                                <td style="width: auto">@cond.ESPECIALIDADE.ESPE_NM_NOME</td>
                                            }
                                            else
                                            {
                                            <td style="width: auto">-</td>
                                            }
                                            <td style="width: auto"><a href="@Url.Action("EnviarEMailUsuario", "Usuario", new { id = cond.USUA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de envio de e-mail ao usuário"/>@cond.USUA_NM_EMAIL</td>
                                            <td style="width: auto"><a href="@Url.Action("EnviarSMSUsuario", "Usuario", new { id = cond.USUA_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de envio de SMS ao usuário"/>@cond.USUA_NR_CELULAR</td>
                                            <td style="width: auto">@cond.CATEGORIA_USUARIO.CAUS_NM_NOME</td>
                                            <td style="width: auto; color: green; font-weight: bold">@cond.PERFIL.PERF_NM_NOME</td>
                                            <td style="width: auto;">@cond.USUA_NR_CPF</td>
                                            @if (cond.USUA_IN_BLOQUEADO == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-danger">Sim</span></td>

                                            }
                                            else
                                            {
                                                <td style="width: auto"><span class="badge badge-success">Não</span></td>

                                            }
                                            <td style="width: auto">@cond.USUA_NR_ACESSOS</td>

                                            @if (!String.IsNullOrEmpty(cond.USUA_AQ_FOTO))
                                            {
                                                // Tratamento manual da URL dentro do loop
                                                var caminhoLimpo = cond.USUA_AQ_FOTO.Replace("~/", "").Replace("~", "");
                                                var urlFinal = "https://rtistoragemain.blob.core.windows.net/rti-datacontainer/" + caminhoLimpo;

                                                <td style="width: auto">
                                                    <img src="@urlFinal" 
                                                            style="width: auto; height: auto; max-height: 75px; max-width: 65px;" 
                                                            data-toggle="popover" data-trigger="hover" data-placement="top" 
                                                            data-content="Clique Ctrl+Ctrl para ampliar a fotografia"
                                                            onerror="this.onerror=null;this.src='@Url.Content("~/Imagens/icon_morador.png")';">
                                                </td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">
                                                    <img src="~/Imagens/icon_morador.png" style="width: auto; height: auto; max-height: 65px; max-width: 55px;">
                                                </td>
                                            }

                                            <td class="td-one-action">
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EDICAO_USUARIO == 1)
                                                {
                                                    @Html.TableLinkDetails(cond.USUA_CD_ID, "EditarUsuario", "fa-edit", "Editar Usuário")
                                                }
                                                else
                                                {
                                                    @Html.TableLinkDetails(cond.USUA_CD_ID, "VerUsuario", "fa-edit", "Ver Usuário")
                                                }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_BLOQUEIO_USUARIO == 1)
                                                {
                                                    if (cond.USUA_IN_BLOQUEADO == 1)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Desbloquear" class="tbl-link fa-lg fa fa-thumbs-o-up" onclick="ShowModalDesbloquear('/Usuario/DesbloquearUsuario/@cond.USUA_CD_ID', '@cond.USUA_NM_NOME')" title="Desbloquear Usuário"></span>
                                                    }
                                                    else
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Bloquear" class="tbl-link fa-lg fa fa-thumbs-o-down" onclick="ShowModalBloquear('/Usuario/BloquearUsuario/@cond.USUA_CD_ID', '@cond.USUA_NM_NOME')" title="Bloquear Usuário"></span>
                                                    }
                                                }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EXCLUSAO_USUARIO == 1)
                                                {
                                                    if (cond.USUA_IN_ATIVO == 1)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Desativar" class="tbl-link fa-lg fa fa-trash-o" onclick="ShowModalExcluir('/Usuario/DesativarUsuario/@cond.USUA_CD_ID')" title="Desativar Usuário"></span>
                                                    }
                                                }
                                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_REATIVACAO_USUARIO == 1)
                                                {
                                                    if (cond.USUA_IN_ATIVO == 0)
                                                    {
                                                        <span style="color: #337ab7; cursor:pointer;" alt="Reativar" class="tbl-link fa-lg fa fa-refresh" onclick="ShowModalReativar('/Usuario/ReativarUsuario/@cond.USUA_CD_ID')" title="Reativar Usuário"></span>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhum usuário cadastrado</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "Usuario", action: "RetirarFiltroUsuario")
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                            </div>
                        }
                </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")

        <style>
        /* 1. Aumenta a largura e garante o espaço interno */
        #toast-container > .toast {
            width: 500px !important; 
            max-width: 500px !important;
            opacity: 0.95 !important;
        }

        /* 2. Remove o ícone nativo do Toastr (Background Image) */
        #toast-container > .toast-success {
            background-image: none !important;
        }

        /* 3. Remove ícones do FontAwesome/Inspinia injetados via ::before no Título */
        .toast-success .toast-title::before, 
        .toast-success .toast-title::after,
        .toast-success::before {
            content: none !important;
            display: none !important;
        }

        /* 4. Ajusta o recuo do texto já que removemos o ícone */
        .toast-success .toast-title, 
        .toast-success .toast-message {
            padding-left: 10px !important;
        }
    </style>

}

@section Scripts {

    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalExcluir(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma exclusão de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Exclusão</h5>');
            $('#modal').modal('show');
        }

        function ShowModalReativar(url) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary" href="' + url + '" target="_self" title="Reativar">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma reativação de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">Confimar Reativação</h5>');
            $('#modal').modal('show');
        }

        function ShowModalBloquear(url, nome) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Bloquear">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma bloqueio de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">'+nome+'</h5>');
            $('#modal').modal('show');
        }

        function ShowModalDesbloquear(url, nome) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desbloquear">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma desbloqueio de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">'+nome+'</h5>');
            $('#modal').modal('show');
        }
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#txtNomeUsuario').autocomplete({
                minLength: 2, 
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetUsuarios", "Usuario")', 
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            term: request.term 
                        },
                        success: function (data) {
                            response(data); 
                        },
                        error: function () {
                            console.log("Erro ao buscar dados para autocomplete.");
                        }
                    });
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Usuario_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });          
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#cpf").mask("999.999.999-99");
        });
    </script>
        <script type="text/javascript">
        $(document).ready(function () {
            // Configurações globais do Toastr
            toastr.options = {
                "closeButton": true,
                //"debug": false,
                "progressBar": true,
                "preventDuplicates": false,
                "positionClass": "toast-top-right",
                "onclick": null,
                "showDuration": "400",
                "hideDuration": "1000",
                "timeOut": "15000",
                "extendedTimeOut": "5000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            //    "iconClass": "customer-toast-info", // Se quiser remover o ícone padrão totalmente
            //    "titleClass": "toast-title",
            //    "messageClass": "toast-message"
            };

            // Verifica se existe mensagem de sucesso no TempData (vinda do Redirect)
            var msgSucesso = '@TempData["MensagemAcerto"]';
            if (msgSucesso != '') {
                toastr.success(msgSucesso, 'Sucesso!');
            }

            // Verifica se existe mensagem de erro
            var msgErro = '@TempData["MensagemErro"]';
            if (msgErro != '') {
                toastr.error(msgErro, 'Erro!');
            }
        });
    </script>

}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

