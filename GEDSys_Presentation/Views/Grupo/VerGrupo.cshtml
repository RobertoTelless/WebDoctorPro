@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.GrupoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Grupos - Visualização";
    ViewBag.MetaDescription = "WebDoctor - Grupos - Visualização de grupos de pacientes";
    ViewBag.MetaKeywords = "WebDoctor, Grupo";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Grupos de Pacientes - Visualização</strong>
            </li>
        </ol>
        <br />
    </div>
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Grupos de Pacientes - Visualização</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="tabs-container">
                        @using (Html.BeginForm("VerGrupo", "Grupo", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                        {
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                <br />
                                @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBaseGrupo", controller: "Grupo")
                            </div>
                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#tab-1">Informações do Grupo</a></li>
                            </ul>

                            <div class="tab-content">
                                @*Dados Gerais*@
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            <h4 style="color:green; background-color: beige">Identificação</h4>                                                
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    @Html.HiddenFor(m => m.ASSI_CD_ID)
                                                    @Html.HiddenFor(m => m.GRUP_DT_CADASTRO)
                                                    @Html.HiddenFor(m => m.GRUP_IN_ATIVO)
                                                    @Html.HiddenFor(m => m.USUA_CD_ID)
                                                    @Html.HiddenFor(m => m.GRUP_CD_ID)
                                                    @Html.HiddenFor(m => m.TIPA_CD_ID)
                                                    @Html.HiddenFor(m => m.SEXO_CD_ID)
                                                    @Html.HiddenFor(m => m.UF_CD_ID)
                                                    Nome do Grupo*
                                                    @Html.TextBoxFor(m => m.GRUP_NM_NOME, new { @class = "form-control", @id = "nome", @readonly="readonly", @style = "color: green; font-weight: bold" })
                                                    @Html.ValidationMessageFor(m => m.GRUP_NM_NOME, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data de Inclusão
                                                    @Html.TextBoxFor(m => m.GRUP_DT_CADASTRO, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Responsável
                                                    @Html.TextBoxFor(m => m.USUARIO.USUA_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                            </div>
                                            <h4 style="color:green; background-color: beige">Parâmetros de seleção usados neste grupo</h4>                                                
                                            <h5 style="color: brown; font-weight:bold">Filtros Genéricos</h5>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Gênero
                                                    @Html.TextBoxFor(m => m.SEXO.SEXO_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Categoria do Paciente
                                                    @Html.TextBoxFor(m => m.TIPO_PACIENTE.TIPA_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Cidade
                                                    @Html.TextBoxFor(m => m.GRUP_NM_CIDADE, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    UF
                                                    @Html.TextBoxFor(m => m.UF.UF_NM_NOME, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Data Nascimento
                                                    @Html.TextBoxFor(m => m.GRUP_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @id = "dn", @readonly="readonly" })
                                                </div>
                                            </div>
                                            <h5 style="color: brown; font-weight:bold">Data de Nascimento (Parcial)</h5>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Dia
                                                    @Html.TextBoxFor(m => m.GRUP_NR_DIA, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Mês
                                                    @Html.TextBoxFor(m => m.MesInteiro, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Ano
                                                    @Html.TextBoxFor(m => m.GRUP_NR_ANO, new { @class = "form-control", @readonly="readonly" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    <h4 style="color:green; background-color: beige">Pacientes do Grupo</h4>                                                
                                                    @if (Model.GRUPO_PACIENTE.Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover dataTables-example">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th style="width: auto">Nome</th>
                                                                    <th style="width: auto">CPF</th>
                                                                    <th style="width: auto">Identificador</th>
                                                                    <th style="width: auto">Data Nascimento</th>
                                                                    <th style="width: auto">Gênero</th>
                                                                    <th style="width: auto">Categoria</th>
                                                                    <th style="width: auto">Cidade</th>
                                                                    <th style="width: auto">UF</th>
                                                                    <th></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (Model.GRUPO_PACIENTE.Where(p => p.GRCL_IN_ATIVO == 1)))
                                                                {
                                                                    <tr>
                                                                        <td>@cond.PACIENTE.PACI_NM_NOME</td>
                                                                        <td style="width: auto">@cond.PACIENTE.PACI_NR_CPF</td>
                                                                        <td style="width: auto">@cond.PACIENTE.PACI_GU_GUID</td>
                                                                        <td style="width: auto">@cond.PACIENTE.PACI_DT_NASCIMENTO.Value.ToShortDateString()</td>
                                                                        @if (cond.PACIENTE.SEXO != null)
                                                                        {
                                                                            <td style="width: auto">@cond.PACIENTE.SEXO.SEXO_NM_NOME</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto"></td>
                                                                        }
                                                                        <td style="width: auto">@cond.PACIENTE.TIPO_PACIENTE.TIPA_NM_NOME</td>
                                                                        <td style="width: auto">@cond.PACIENTE.PACI_NM_CIDADE</td>
                                                                        @if (cond.PACIENTE.UF != null)
                                                                        {
                                                                            <td style="width: auto">@cond.PACIENTE.UF.UF_SG_SIGLA</td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto">-</td>
                                                                        }
                                                                        @if (!String.IsNullOrEmpty(cond.PACIENTE.PACI_AQ_FOTO))
                                                                        {
                                                                            <td style="width: auto"><img src="@Url.Content(cond.PACIENTE.PACI_AQ_FOTO)" style="width: auto; height: auto; max-height: 75px; max-width: 65px;" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Clique Ctrl+Ctrl para ampliar a fotografia"></td>
                                                                        }
                                                                        else
                                                                        {
                                                                            <td style="width: auto"><img src="~/Images/icon_morador.png" style="width: auto; height: auto; max-height: 65px; max-width: 55px;"  ></td>
                                                                        }
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'GrupoPaciente_Planilha' },

                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]

            });          
        });
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
