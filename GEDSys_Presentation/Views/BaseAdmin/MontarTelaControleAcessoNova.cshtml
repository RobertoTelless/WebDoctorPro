@using Presentation.Extensions
@using CrossCutting
@model EntitiesServices.Model.ACESSO_METODO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Acessos";
    ViewBag.MetaDescription = "WebDoctor - Acessos - Lista de acessos";
    ViewBag.MetaKeywords = "WebDoctor, acesso, ip";
}
<div id="content" class="wraper container-fluid">
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Acessos - Resumos</strong>
            </li>
        </ol>
        <br />
    </div>  
    
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-12 col-md-12 col-sm-12">
        @*Atalhos*@
        <div class="row">
            <h3 style="color:olivedrab; font-weight:bold">Acessos - Resumos</h3>
        </div>

        @*Widgets*@
        <br />
        <div class="row">
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Acessos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.IntegerFormatter(ViewBag.AcessosConta)</h1>
                        <small>@Html.ActionLink("Total de Acessos", "VerTotalAcessos", "BaseAdmin")</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Acessos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.IntegerFormatter(ViewBag.AcessosMesConta)</h1>
                        <small>@Html.ActionLink("Acessos - Mês Corrente", "VerTotalAcessosMes", "BaseAdmin")</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="ibox float-e-margins">
                    <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                        <span class="label label-primary pull-right">Hoje</span>
                        <h5>Acessos</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">@CrossCutting.Formatters.IntegerFormatter(ViewBag.AcessosDiaConta)</h1>
                        <small>@Html.ActionLink("Acessos - Data Corrente", "VerTotalAcessosData", "BaseAdmin")</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div style="display: none; z-index:1000" class="dotContainer">
                    <div class="spiner-example">
                        <div class="sk-spinner sk-spinner-three-bounce">
                            <div class="sk-bounce1"></div>
                            <div class="sk-bounce2"></div>
                            <div class="sk-bounce3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @*Atalhos*@
        <div class="row">
            <div class="form-group">
                <div class="col-lg-12 col-md-12 col-xs-12">
                    @Html.ButtonLinkIndex(text: "Ver Todos Acessos", action: "MontarTelaTodosAcessos", controller: "BaseAdmin", buttonClass: "primary", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    @Html.ButtonLinkIndex(text: "Ver Todos Usuários", action: "MontarTelaTodosAcessosUsuarios", controller: "BaseAdmin", buttonClass: "primary", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    @Html.ButtonLinkIndex(text: "Ver Todas Funções", action: "MontarTelaTodosAcessosFuncoes", controller: "BaseAdmin", buttonClass: "primary", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    @Html.ButtonLinkIndex(text: "Ver Todas Faixas", action: "MontarTelaTodosAcessosFaixas", controller: "BaseAdmin", buttonClass: "primary", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPaciente", controller: "Paciente", htmlAttributes: new { @id = "emp", OnClick = "Fade()" })
                    </div>
                <br /><br />
            </div>
        </div>  

        @*Corpo*@
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox float-e-margins">
                    <div class="ibox-title">
                        <h5>Acessos - Resumos</h5>
                    </div>
                    <div class="ibox-content" style="height: 2100px">

                        @*Graficos*@
                        <div class="col-lg-7 col-md-7 col-xs-12">
                            <div class="row">                           
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>@Html.ActionLink("Acessos por Data - Mês Corrente", "VerTotalAcessosMes", "BaseAdmin")</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="lineChartAcessoData" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>@Html.ActionLink("Acessos por Mês - Últimos 12 meses", "MontarTelaTodosAcessos", "BaseAdmin")</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="lineChartAcessoMes" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @*Listas*@
                        <div class="col-lg-5 col-md-5 col-xs-12">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                    <div class="ibox-title">
                                        <h4>@Html.ActionLink("Usuários com mais Acessos - Mês Corrente", "MontarTelaTodosAcessosUsuarios", "BaseAdmin")</h4>
                                    </div>
                                    <div class="ibox-content">
                                        <div class="row">
                                            @if (ViewBag.ListaUsuarioMais != null && (ViewBag.ListaUsuarioMais as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th>Usuário</th>
                                                            <th>Acessos</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (ViewBag.ListaUsuarioMais as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderByDescending(p => p.Valor).Take(5))
                                                        {
                                                            <tr>
                                                                <td>@cond.Nome</td>
                                                                <td>@CrossCutting.Formatters.IntegerFormatter(cond.Valor)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="row">
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                        <h4 style="font-weight: bold">Nenhum acesso registrado</h4>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>                          

                            <div class="col-lg-12 col-md-12 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                    <div class="ibox-title">
                                        <h4>@Html.ActionLink("Funções com mais Acessos - Mês Corrente", "MontarTelaTodosAcessosFuncoes", "BaseAdmin")</h4>
                                    </div>
                                    <div class="ibox-content">
                                        <div class="row">
                                            @if (ViewBag.ListaPaginaMais != null && (ViewBag.ListaPaginaMais as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th>Funcionalidade</th>
                                                            <th>Acessos</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (ViewBag.ListaPaginaMais as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderByDescending(p => p.Valor).Take(5))
                                                        {
                                                            <tr>
                                                                <td>@cond.Nome</td>
                                                                <td>@CrossCutting.Formatters.IntegerFormatter(cond.Valor)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="row">
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                        <h4 style="font-weight: bold">Nenhum acesso registrado</h4>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>                          
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                    <div class="ibox-title">
                                        <h4>@Html.ActionLink("Acessos por Faixa Horária - Mês Corrente", "MontarTelaTodosAcessosFaixas", "BaseAdmin")</h4>
                                    </div>
                                    <div class="ibox-content">
                                        <div class="row">
                                            @if (ViewBag.ListaHora != null && (ViewBag.ListaHora as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th>Faixa</th>
                                                            <th>Acessos</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (ViewBag.ListaHora as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderByDescending(p => p.Valor).Take(5))
                                                        {
                                                            <tr>
                                                                <td>@cond.Nome</td>
                                                                <td>@cond.Valor</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="row">
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                        <h4 style="font-weight: bold">Nenhum acesso registrado</h4>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>                          
                       
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                    <div class="ibox-title">
                                        <h4>Acessos por IP do Usuário - Mês Corrente</h4>
                                    </div>
                                    <div class="ibox-content">
                                        <div class="row">
                                            @if (ViewBag.ListaIP != null && (ViewBag.ListaIP as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                            {
                                                <table class="table table-striped table-bordered table-hover">
                                                    <thead style="background-color:lightsteelblue">
                                                        <tr>
                                                            <th>IP</th>
                                                            <th>Acessos</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cond in (ViewBag.ListaIP as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderByDescending(p => p.Valor).Take(5))
                                                        {
                                                            <tr>
                                                                <td>@cond.Nome</td>
                                                                <td>@cond.Valor</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else
                                            {
                                                <div class="row">
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                    <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                        <h4 style="font-weight: bold">Nenhum acesso registrado</h4>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-xs-12">
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>                          

                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</div>


@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Scripts.Render("~/plugins/wow")
    @Scripts.Render("~/bundles/inspinia")
    @Styles.Render("~/Content/css")
    @Styles.Render("~/font-awesome/css")
}

@section Scripts {

    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
    @Scripts.Render("~/plugins/switchery")
    @Scripts.Render("~/plugins/chartjs")
    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/BaseAdmin/GetAcessosData'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Acessos",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valores
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartAcessoData").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $.ajax({
                url: '/BaseAdmin/GetAcessosMes'
                , type: 'POST'
                , success: function (result) {
                    var lineData = {
                        labels: result.dias,
                        datasets: [

                            {
                                label: "Acessos",
                                backgroundColor: 'rgba(26,179,148,0.5)',
                                borderColor: "rgba(26,179,148,0.7)",
                                pointBackgroundColor: "rgba(26,179,148,1)",
                                pointBorderColor: "#fff",
                                data: result.valores
                            }
                        ]
                    };

                    var lineOptions = {
                        responsive: true
                    };
                    var ctx = document.getElementById("lineChartAcessoMes").getContext("2d");
                    new Chart(ctx, { type: 'line', data: lineData, options: lineOptions });
              }
            });
        });
    </script>
    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}

