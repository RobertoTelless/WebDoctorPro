@using Presentation.Extensions
@using CrossCutting;
@model ERP_Condominios_Solution.ViewModels.MensagemWidgetViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Pesquisa";
    ViewBag.MetaDescription = "WebDoctor - Pesquisa genérica";
    ViewBag.MetaKeywords = "WebDoctor, pesquisa";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Pesquisa Genérica</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "BaseAdmin")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Pesquisa Genérica</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("PesquisarTudo", "BaseAdmin", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                Buscar no WebDoctor por..
                                @Html.TextBoxFor(m => m.Descrição, new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Pesquisar")
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "BaseAdmin", action: "VoltaPesquisa")
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Resultado da Pesquisa</h5>
                </div>
                <div class="ibox-content">
                    <div class="row">
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.VOLTA_PESQUISA>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Entidade</th>
                                        <th style="width: 250px">Nome do Paciente</th>
                                        <th style="width: 100px">Informação #2</th>
                                        <th style="width: auto">Informação #3</th>
                                        <th style="width: auto">Informação #4</th>
                                        <th style="width: auto">Informação #5</th>
                                        <th style="width: auto">Informação #6</th>
                                        <th style="width: auto">Data</th>
                                        <th style="width: auto">Identificador</th>
                                        <th class="td-one-action">Ações</th>
                                        <th style="width: 0.001px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.VOLTA_PESQUISA>))
                                    {
                                        <tr>
                                            @if (cond.PEGR_IN_TIPO ==  1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Pacientes</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  2)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Prescrições</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  3)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Anamneses</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  4)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Exames</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  5)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Exames Físicos</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  6)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Atestados</span></td>
                                            }
                                            else if (cond.PEGR_IN_TIPO ==  7)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Solicitações</span></td>
                                            }

                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                            {
                                                <td style="width: 250px"><a href="@Url.Action("EditarPaciente", "Paciente", new { id = cond.PEGR_CD_PACIENTE.Value })" />@cond.PEGR_NM_NOME1</td>
                                            }
                                            else
                                            {
                                                <td style="width: 250px"><a href="@Url.Action("VerPaciente", "Paciente", new { id = cond.PEGR_CD_PACIENTE.Value })" />@cond.PEGR_NM_NOME1</td>
                                            }

                                            <td style="width: 100px">@cond.PEGR_NM_NOME2</td>
                                            <td style="width: auto">@cond.PEGR_NM_NOME3</td>
                                            <td style="width: auto">@cond.PEGR_NM_NOME4</td>
                                            <td style="width: auto">@cond.PEGR_NM_NOME5</td>
                                            <td style="width: auto">@cond.PEGR_NM_NOME6</td>

                                            @if (cond.PEGR_DT_DATA != null)
                                            {
                                                <td style="width: auto">@cond.PEGR_DT_DATA.Value.ToShortDateString()</td>
                                            }
                                            else
                                            {
                                                <td style="width: auto">-</td>
                                            }
                                            <td style="width: auto">@cond.PEGR_GU_GUID</td>
                                            <td style="width: auto" class="td-one-action">
                                                @if (cond.PEGR_IN_TIPO ==  1)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ALTERAR_PACIENTE == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarPacienteBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerPacienteBase", "fa-search", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  2)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_PRESCRICAO_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarItemPrescricaoBase", "fa-edit", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  3)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ANAMNESE_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarAnamneseBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerAnamneseBase", "fa-search", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  4)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_EXAME_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarExameBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerExameBase", "fa-search", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  5)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_FISICO_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarExameFisicoBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerExameFisicoBase", "fa-search", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  6)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ATESTADO_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarAtestadoBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerAtestadoBase", "fa-search", "Editar")
                                                    }
                                                }
                                                @if (cond.PEGR_IN_TIPO ==  7)
                                                {
                                                    if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_SOLICITACAO_ALTERAR == 1)
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "EditarSolicitacaoBase", "fa-edit", "Editar")
                                                    }
                                                    else
                                                    {
                                                        @Html.TableLinkDetails(cond.PEGR_CD_ITEM.Value, "VerSolicitacaoBase", "fa-search", "Editar")
                                                    }
                                                }
                                            </td>
                                            <td style="width: 0.01px"></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-3 col-md-3 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado</h2>
                                    @Html.ButtonLinkIndex(text: "Retornar", controller: "BaseAdmin", action: "PesquisarTudo")
                                </div>
                                <div class="col-lg-3 col-md-3 col-xs-2">

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
}

@section Scripts {

    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Pesquisa_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]

            });

           

        });

    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

