@using Presentation.Extensions
@using CrossCutting;
@model ERP_Condominios_Solution.ViewModels.FaleConoscoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Limpo.cshtml";
    ViewBag.Title = "WebDoctor - Contratação";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h3>Contratação - Planos de Assinatura</h3>
                </div>
                <br />
                <div class="form-group">
                    @Html.ButtonLinkIndex(text: "Voltar", controller: "BaseAdmin", action: "CarregarLandingPage")
                    <br />
                </div>
                <div class="ibox-content ibox-heading">
                    <h3><i class="fa fa-credit-card"></i> Selecione o plano de assinantura que melhor atende às suas necessidades</h3>
                </div>

                <div class="ibox-content" style="height: 2100px">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-primary" })
                        </div>
                    }
                    <div class="col-lg-12 col-md-12 col-xs-12">
                        <div class="col-lg-12 col-md-12 col-xs-12">
                            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkblue; border-bottom-width: 2px; border-left: solid; border-left-color: darkblue; border-left-width: 1px; border-right: solid; border-right-color: darkblue; border-right-width: 1px; border-top: solid; border-top-color: darkblue; border-top-width: 1px">
                                <div class="ibox-title">
                                    <h4>Contratação de Assinatura - Informações</h4>
                                </div>
                                <div class="ibox-content">
                                    @using (Html.BeginForm("MontarTelaCompraBasicoNova", "BaseAdmin", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                                    {
                                        <div class="row">
                                            <h5 style="color: green; font-weight: bold">Preencha os campos abaixo com as suas informações e confirme os dados.</h5>
                                        </div> 
                                        <div class="row" id="Planos">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Seleção do Plano de Assinatura</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">   
                                                @if (Session["CompraState"] == null)
                                                {
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Plano de Assinatura*
                                                        @Html.DropDownListFor(m => m.Plano, (SelectList)ViewBag.PlanosAss, "Selecionar", new { @class = "form-control", autofocus = true, @id = "plano", onchange = "ValidaPlano($(this).val())"  })
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Plano de Assinatura
                                                        @Html.TextBoxFor(m => m.NomePlano, new { @class = "form-control", @readonly = "readonly" })
                                                    </div>
                                                }
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Início
                                                    @Html.TextBoxFor(m => m.Comeco, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Término
                                                    @Html.TextBoxFor(m => m.Fim, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                <div style="display: none;" id="precoPlano" class="col-lg-2 col-md-2 col-xs-12">
                                                    Valor (R$)
                                                    <input class="form-control" type="text" readonly="readonly" tabindex="-1"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row" id="Ident">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Identificação</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                                <div class="col-lg-3 col-md-3 col-xs-12" id="tipoAss">
                                                    Tipo de Assinante*
                                                    @Html.DropDownListFor(m => m.Tipo, (SelectList)ViewBag.Assunto, "Selecionar", new { @class = "form-control", autofocus = true, @id = "tipo", onchange = "ValidaTipo($(this).val())"  })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" style="display: none" id="CPF">
                                                    CPF*
                                                    @Html.TextBoxFor(m => m.CPF, new { @class = "form-control", autofocus = true, @id="cpf"  })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12" style="display: none" id="CNPJ">
                                                    CNPJ*
                                                    @Html.TextBoxFor(m => m.CPF, new { @class = "form-control", autofocus = true, @id="cnpj"  })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;" id="Nomes">                
                                                <div class="col-lg-6 col-md-6 col-xs-12">
                                                    Nome do Assinante*
                                                    @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", autofocus = true, @id="nome"  })
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-xs-12" style="display: none" id="Razao">
                                                    Razão Social*
                                                    @Html.TextBoxFor(m => m.Razao, new { @class = "form-control", autofocus = true, @id="razao"  })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row" id="Contatos">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Informações de Contato</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    E-Mail*
                                                    @Html.TextBoxFor(m => m.Resposta, new { @class = "form-control", autofocus = true, @id="mail" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Telefone
                                                    @Html.TextBoxFor(m => m.TelefoneFixo, new { @class = "form-control", autofocus = true, @id="tel"  })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Celular*
                                                    @Html.TextBoxFor(m => m.Celular, new { @class = "form-control", autofocus = true, @id="cel"  })
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="row" id="Login">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Login e Senha</h4>
                                            <div class="col-lg-8 col-md-8 col-xs-8">
                                                <div class="form-group" style=" margin-left: -30px; margin-right: -30px;">                
                                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                                        Login*
                                                        @Html.TextBoxFor(m => m.LoginBase, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o login para o usuário master do novo assinante. Pode ter até 10 caracteres sem espaços", data_trigger="hover", data_placement="top" })
                                                        @Html.ValidationMessageFor(m => m.Login, "", new { @style = "color:red" })
                                                    </div>
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Senha*
                                                        @Html.TextBoxFor(m => m.SenhaBase, new { @class = "form-control pwd1", autofocus = true, @type = "password", @id = "Password1" })
                                                        @Html.ValidationMessageFor(m => m.SenhaBase, "", new { @style = "color:red" })
                                                    </div>
                                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                                        Confirmação da Senha*
                                                        @Html.TextBoxFor(m => m.SenhaBaseConfirma, new { @class = "form-control", autofocus = true, @type = "password" })
                                                        @Html.ValidationMessageFor(m => m.SenhaBaseConfirma, "", new { @style = "color:red" })
                                                    </div>
                                                </div>                                            
                                                <div class="form-group" style=" margin-left: -30px; margin-right: -30px;">
                                                    <div class="col-lg-11 col-md-11 col-xs-12">
                                                        <div class="pwstrength_viewport_progress"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-lg-4 col-md-4 col-xs-4">
                                                <div class="ibox float-e-margins" style="background-color:beige">
                                                    <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                                                        <h5>Regras para Formação de Senha</h5>
                                                    </div>
                                                    <div class="ibox-content" style="background-color:beige">
                                                        <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">  
                                                            <br />
                                                            <ul style="margin:0; padding-left:20px; list-style-type:disc;">
                                                                <li style="margin-bottom:2px; line-height:1.1;">Não pode ser igual a anterior</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter no mínimo 3 caracteres</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter pelo menos uma letra maiúscula</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter pelo menos uma letra minúscula</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter pelo menos um dígito (0-9)</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter no mínimo 3 caracteres</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Tem que ter pelo menos um caractere especial (# $ % &)</li>
                                                                <li style="margin-bottom:2px; line-height:1.1;">Não pode conter os caracteres especiais (+ - * / =)</li>
                                                            </ul>                                                               
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row" id="Enderecos">
                                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Endereço</h4>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    CEP*
                                                    <div class="input-group">
                                                        @Html.TextBoxFor(m => m.CEP, new { @class = "form-control", @id = "cep", autofocus = true, @onblur = "PesquisaCep($('#cep').val(), $(this), 1)" })
                                                        @Html.ValidationMessageFor(m => m.CEP, "", new { @style = "color:red" })
                                                        <span class="input-group-btn">
                                                            <span class="btn btn-warning btn-sm" id="btnBuscaCep" data_toggle = "popover" data_content = "Pesquisar o CEP informado" data_trigger="hover" data_placement="top" onclick="PesquisaCep($('#cep').val(), $(this), 1)">Buscar CEP</span>
                                                        </span>
                                                    </div>
                                                    <div class="col-lg-12 col-md-12 col-xs-12" style="display:none" id="cepval">
                                                        <h5>CEP inválido</h5>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-4 col-md-4 col-xs-12">
                                                    Endereço*
                                                    @Html.TextBoxFor(m => m.Endereco, new { @class = "form-control", @id = "endereco", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.Endereco, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Número*
                                                    @Html.TextBoxFor(m => m.Numero, new { @class = "form-control", @id = "nmr", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.Numero, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Complemento
                                                    @Html.TextBoxFor(m => m.Complemento, new { @class = "form-control", autofocus = true, @id = "complemento" })
                                                    @Html.ValidationMessageFor(m => m.Complemento, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Bairro*
                                                    @Html.TextBoxFor(m => m.Bairro, new { @class = "form-control", @id = "bairro", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.Bairro, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-3 col-md-3 col-xs-12">
                                                    Cidade*
                                                    @Html.TextBoxFor(m => m.Cidade, new { @class = "form-control", @id = "cidade", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.Cidade, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    UF*
                                                    @Html.DropDownListFor(m => m.UF, (SelectList)ViewBag.UF, "UF", new { @class = "form-control", @id = "uf", autofocus = true })
                                                    @Html.ValidationMessageFor(m => m.UF, "", new { @style = "color:red" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    CEP
                                                    @Html.TextBoxFor(m => m.CEPBase, new { @class = "form-control", @id = "cepBase", @readonly = "readonly" })
                                                    @Html.ValidationMessageFor(m => m.CEPBase, "", new { @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                            <div class="col-lg-2 col-md-2 col-xs-12">
                                                @Html.ButtonActionSubmit(text: "Confirmar as informações da assinatura e prosseguir para pagamento", htmlAttributes: new { id = "basictoast" })
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>                          
                            
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,300,600,700' rel='stylesheet' type='text/css'>
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Styles.Render("~/Content/css")
    @Styles.Render("~/font-awesome/css")
    <link href="@Url.Content("~/Scripts/plugins/jquery-ui/jquery-ui.min.css")" rel="stylesheet" type="text/css" />
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/passwordMeter")
    
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            var options1 = {};
            options1.ui = {
                container: "#pwd-container1",
                showVerdictsInsideProgressBar: true,
                viewports: {
                    progress: ".pwstrength_viewport_progress"
                }
            };
            options1.common = {
                debug: false,
            };
            $('.pwd1').pwstrength(options1);

        });
    </script>

    <script>
        function GetPlanoAssinatura(id) {
            var data = {
                id: id
            }

            $.ajax({
                url: '../BaseAdmin/GetPlanoAssinatura'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    $('#precoPlano > input').val(r.preco);
                    $('#precoPlano').show();
                }
            });
        }
    </script>

   
    <script type="text/javascript">
        $(function () {
            $("#tel").mask("(99)9999-9999");
            $("#cel").mask("(99)99999-9999");
            $("#cpf").mask("999.999.999-99");
            $("#cnpj").mask("99.999.999/9999-99");
            $("#cep").mask("99999-999");
        });
    </script>

    <script type="text/javascript">
        function ValidaTipo(valTipo) {
            if (valTipo == '1') {
                $("#CPF").show();
                $("#CNPJ").hide();
            } else {
                $("#CPF").hide();
                $("#CNPJ").show();
            }
        }
        $(document).ready(function () {
            ValidaTipo($('#tipo').val());
        });
    </script>
    <script type="text/javascript">
        function ValidaPlano(valTipo) {
            if (valTipo == '18') {
                $("#Basico").show();
                $("#Super").hide();
                $("#SuperFinanceiro").hide();
            } else if (valTipo == '20'){
                $("#Basico").hide();
                $("#Super").show();
                $("#SuperFinanceiro").hide();
            } else if (valTipo == '24'){
                $("#Basico").hide();
                $("#Super").hide();
                $("#SuperFinanceiro").show();
            }
        }
        $(document).ready(function () {
            ValidaPlano($('#plano').val());
        });
    </script>   
    
    <script>
        function PesquisaCep(cep, btn, tipoEnd) {
            data = {
                cep: cep
                , tipoEnd: tipoEnd
            }

            //$(btn).attr("disabled", "disabled");

            $.ajax({
                url: '../Paciente/PesquisaCEP_Javascript'
                , type: 'POST'
                , data: data
                , success: function (r) {
                    if (r.Sucesso == 0) {
                        if (tipoEnd == 1) {
                            $("#cepval").show();
                        //    $('#btnBuscaCep').removeAttr("disabled");
                        }

                    }
                    else {
                        $("#cepval").hide();
                        $("#cepval1").hide();
                        if (tipoEnd == 1) {
                            $('#endereco').val(r.PACI_NM_ENDERECO);
                            $('#nmr').val(r.PACI_NR_NUMERO);
                            $('#bairro').val(r.PACI_NM_BAIRRO);
                            $('#cidade').val(r.PACI_NM_CIDADE);
                            $('#cepBase').val(r.PACI_NR_CEP);
                            $('#uf option[value="' + r.UF_CD_ID + '"]').attr("selected", "selected");
                            $('#btnBuscaCep').removeAttr("disabled");
                        }
                    }
                }
            });
        }
    </script>

    <script>
        function GetLogin(id) {
            if (id == '1') {
                var data = {
                    id: id
                }

                $.ajax({
                    url: '../BaseAdmin/GetLogin'
                    , type: 'POST'
                    , data: data
                    , success: function (r) {
                        $('#cpf').val(r.CPF);
                        $('#cnpj').val(r.CNPJ);
                        $('#nome').val(r.Nome);
                        $('#razao').val(r.Razao);
                        $('#mail').val(r.Resposta);
                        $('#tel').val(r.Telefone);
                        $('#cel').val(r.Celular);
                        $('#cep').val(r.CEP);
                        $('#endereco').val(r.Endereco);
                        $('#nmr').val(r.Numero);
                        $('#complemento').val(r.Complemento);
                        $('#bairro').val(r.Bairro);
                        $('#cidade').val(r.Cidade);
                        $('#uf option[value="' + r.UF + '"]').attr("selected", "selected");

                        $('#novo').show();
                        $('#tipo').hide();
                        $('#existe').hide();
                    }
                });
            } 
        }
    </script>


}
@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

