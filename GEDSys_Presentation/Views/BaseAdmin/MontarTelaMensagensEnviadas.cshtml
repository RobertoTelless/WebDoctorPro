@using Presentation.Extensions
@using CrossCutting;
@model EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Mensagens Enviadas";
    ViewBag.MetaDescription = "WebDoctor - Lista de mensagens enviadas pelo sistema";
    ViewBag.MetaKeywords = "WebDoctor, mensagem, automatica, sistema";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Mensagens</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Mensagens Automáticas Enviadas</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    @if ((Int32)Session["EscopoMensagem"] == 0)
                    {
                        <span class="label label-primary pull-right">Hoje</span>
                    }
                    else
                    {
                        <span class="label label-success pull-right">Todas</span>
                    }
                    <h5>Mensagens Automáticas</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.Mensagens</h1>
                    <small>Total Enviado</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    @if ((Int32)Session["EscopoMensagem"] == 0)
                    {
                        <span class="label label-primary pull-right">Hoje</span>
                    }
                    else
                    {
                        <span class="label label-success pull-right">Todas</span>
                    }
                    <h5>Mensagens Automáticas</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.EMails</h1>
                    <small>Total de E-Mails</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    @if ((Int32)Session["EscopoMensagem"] == 0)
                    {
                        <span class="label label-primary pull-right">Hoje</span>
                    }
                    else
                    {
                        <span class="label label-success pull-right">Todas</span>
                    }
                    <h5>Mensagens Automáticas</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.SMS</h1>
                    <small>Total de SMS</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    @if ((Int32)Session["EscopoMensagem"] == 0)
                    {
                        <span class="label label-primary pull-right">Hoje</span>
                    }
                    else
                    {
                        <span class="label label-success pull-right">Todas</span>
                    }
                    <h5>Mensagens Automáticas</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.Entregue</h1>
                    <small>Total Entregue</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                    @if ((Int32)Session["EscopoMensagem"] == 0)
                    {
                        <span class="label label-primary pull-right">Hoje</span>
                    }
                    else
                    {
                        <span class="label label-success pull-right">Todas</span>
                    }
                    <h5>Mensagens Automáticas</h5>
                </div>
                <div class="ibox-content">
                    <h1 class="no-margins">@ViewBag.Falha</h1>
                    <small>Total de Falhas</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarMensagensEnviadas", "BaseAdmin", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Tipo de Mensagem
                                @Html.DropDownListFor(m => m.MEEN_IN_TIPO, (SelectList)ViewBag.Tipos, "Selecionar", new { @class = "form-control" , autofocus = true})
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Início
                                @Html.TextBoxFor(m => m.MEEN_DT_DATA_ENVIO, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data1" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.MEEN_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data2" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                E-Mail
                                @Html.TextBoxFor(m => m.MEEN_EM_EMAIL_DESTINO, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Celular
                                @Html.TextBoxFor(m => m.MEEN_NR_CELULAR_DESTINO, new { @class = "form-control", autofocus = true, @id="cel" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Destinatário
                                @Html.TextBoxFor(m => m.MEEN_NM_ORIGEM, new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @Html.ButtonLinkIndex(text: "Exibir Mensagens de Hoje", controller: "BaseAdmin", action: "RetirarFiltroMensagensEnviadas")
                                @Html.ButtonLinkIndex(text: "Exibir Mês Corrente", controller: "BaseAdmin", action: "ExibirMesCorrente")
                                @Html.ButtonLinkIndexShort("Exibir Todas as Mensagens", null, "warning", new { @id = "todos", onclick = "ProcessaTodos()" })
                                @Html.ButtonLinkIndex(text: "Voltar", controller: "BaseAdmin", action: "VoltarMensagensEnviadas")
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Mensagens Automáticas Enviadas pelo WebDoctor</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="row">
                        @if ((Int32)Session["MostraTodasMensagens"] == 0)
                        {
                            <h4 style="color:green; font-weight: bold; background-color:beige">ATENÇÃO - Estão sendo exibidas apenas mensagens enviadas na data corrente</h4>
                        }
                        else
                        {
                            <h4  style="color:green; font-weight: bold; background-color:beige">ATENÇÃO - Estão sendo exibidas todas as mensagens enviadas</h4>
                        }
                        @if (ViewBag.Listas != null &&(ViewBag.Listas as List<EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Emissão</th>
                                        <th style="width: auto">Situação</th>
                                        <th style="width: auto">Tipo</th>
                                        <th style="width: auto">Assunto</th>
                                        <th style="width: auto">E-Mail Destino</th>
                                        <th style="width: auto">Celular Destino</th>
                                        <th style="width: auto">Destinatário</th>
                                        <th style="width: auto">Identificador</th>
                                        <th class="td-one-action">Ações</th>
                                        <th style="width: 0.01px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.MENSAGENS_ENVIADAS_SISTEMA>).OrderByDescending(p => p.MEEN_DT_DATA_ENVIO))
                                    {
                                        <tr>
                                            <td>@cond.MEEN_DT_DATA_ENVIO.Value.ToShortDateString()</td>
                                            @if (cond.MEEN_IN_ENTREGUE == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">Entregue</span></td>
                                            }
                                            else
                                            {
                                                <td style="width: auto"><span class="badge badge-danger">Falha</span></td>
                                            }

                                            @if (cond.MEEN_IN_TIPO == 1)
                                            {
                                                <td style="width: auto"><span class="badge badge-primary">E-Mail</span></td>
                                            }
                                            else if (cond.MEEN_IN_TIPO == 2)
                                            {
                                                <td style="width: auto"><span class="badge badge-success">SMS</span></td>
                                            }

                                            <td>@cond.MEEN_NM_TITULO</td>                                            
                                            @if (cond.MEEN_IN_TIPO == 1)
                                            {
                                                <td>@cond.MEEN_EM_EMAIL_DESTINO</td>
                                            }
                                            else
                                            {
                                                <td>-</td>
                                            }

                                            @if (cond.MEEN_IN_TIPO == 2 || cond.MEEN_IN_TIPO == 3)
                                            {
                                                <td>@cond.MEEN_NR_CELULAR_DESTINO</td>
                                            }
                                            else
                                            {
                                                <td>-</td>
                                            }

                                            @if (cond.PACI_CD_ID != null)
                                            {
                                                <td>@cond.PACIENTE.PACI_NM_NOME</td>
                                            }
                                            else
                                            {
                                                <td>@cond.USUARIO.USUA_NM_NOME</td>
                                            }
                                            <td>@cond.MEEN_ID_IDENTIFICADOR</td>
                                            <td class="td-one-action">
                                                @Html.TableLinkDetails(cond.MEEN_CD_ID, "VerMensagemEnviada", "fa-search", "Visualizar")
                                            </td>
                                            <td style="width: 0.05px"></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="row">
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                                <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-8 col-md-8 col-xs-8">
                                    <h2 style="font-weight: bold">Sua pesquisa não retornou nenhum resultado ou nenhuma mensagem enviada</h2>
                                    @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "BaseAdmin", action: "RetirarFiltroMensagensEnviadas")
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-2">

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Styles.Render("~/plugins/sweetAlertStyles")
    @Styles.Render("~/plugins/toastrStyles")
}
@section Scripts {
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.datetimepicker"></script>

    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    @Scripts.Render("~/plugins/sweetAlert")

    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'MensagensEnviadas_Planilha' },

                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]
            });         
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#data1").mask("99/99/9999");
            $("#data2").mask("99/99/9999");
            $("#cel").mask("(99)99999-9999");
        });
    </script>
    <script>
        function ProcessaTodos() {
            var t = confirm("A exibição de todas as mensagens enviadas pode demorar algum tempo. Confirma?");
            if(t == true)
            {
                $.ajax({
                    url: '../BaseAdmin/MostrarTodasMensagensEnviadas'
                    , type: 'POST'
                });
            }
        }
    </script>
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

