    <script>
        $.ajax({
            url: '../BaseAdmin/GetRefreshTime'
            , type: 'POST'
            , success: function (r) {
                window.setInterval(function () {
                    window.location.href = "../BaseAdmin/CarregarBase"
                }, r * 1000);

                //clearInterval()
            }
        });
    </script>


    @*Notification Sound*@
    <script>
        $.ajax({
            url: '../BaseAdmin/GetConfigNotificacoes'
            , type: 'POST'
            , success: function (e) {
                console.log(e);

                var audio = {};
                audio["msg"] = new Audio();
                audio["msg"].src = "../Sounds/" + e.CONF_NM_ARQUIVO_ALARME;

                function PlayNotificationChime() {
                    audio["msg"].play();
                }

                if (e.NOTIFICACAO) {
                    PlayNotificationChime();
                }
            }
        });
    </script>
    <script>
        $.ajax({
            url: '../BaseAdmin/GetLembrete'
            , type: 'POST'
            , success: function (e) {
                console.log(e);

                var audio = {};
                audio["msg"] = new Audio();
                audio["msg"].src = "../Sounds/" + e.CONF_NM_ARQUIVO_ALARME;

                function PlayNotificationChime() {
                    audio["msg"].play();
                }

                if (e.LEMBRETE) {
                    PlayNotificationChime();
                }
            }
        });
    </script>
    <script>
