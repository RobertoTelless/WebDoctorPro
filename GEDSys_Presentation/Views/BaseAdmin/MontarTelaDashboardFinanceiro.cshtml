@using Presentation.Extensions
@using CrossCutting
@model EntitiesServices.Model.USUARIO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "Dashboard Financeiro";
}
<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div id="content" class="wraper container-fluid">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="col-lg-12 col-md-12 col-sm-12">

            @*Atalhos*@
            <div class="row">
                <h3 style="color:olivedrab; font-weight:bold">Dashboard - Financeiro</h3>
                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                    <br />
                    <div class="col-lg-12 col-md-12 col-xs-12">
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_BANCO == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Bancos & Contas", action: "MontarTelaBanco", controller: "Banco", buttonClass: "primary", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_CC == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Centros de Custo", action: "MontarTelaCC", controller: "CentroCusto", buttonClass: "primary", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_CUSTO_FIXO == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Custos Fixos", action: "MontarTelaCustoFixo", controller: "CustoFixo", buttonClass: "primary", htmlAttributes: new { @id = "cli", OnClick = "Fade()" })
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_CP == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Pagamentos", action: "MontarTelaCP", controller: "ContaPagar", buttonClass: "primary", htmlAttributes: new { @id = "cp", OnClick = "Fade()" })
                        }
                        @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_ACESSO_CR == 1)
                        {
                            @Html.ButtonLinkIndex(text: "Recebimentos", action: "MontarTelaCR", controller: "ContaReceberNova", buttonClass: "primary", htmlAttributes: new { @id = "cr", OnClick = "Fade()" })
                        }
                        @Html.ButtonLinkIndex(text: "Dashboard Gerencial", action: "MontarTelaDashboardGerencial", controller: "BaseAdmin", buttonClass: "success", htmlAttributes: new { @id = "cr", OnClick = "Fade()" })
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "BaseAdmin", action: "CarregarBase")
                    </div>
                    <br /><br />
                </div>
            </div>

            @*Estatísticas*@
            <div class="row">
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Contas Bancárias</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ContaNegativa</h1>
                            <small>Saldo Negativo</small>
                            <br />
                            <br />
                            <br />
                            <br />
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Pagamentos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ContaCPVencHoje</h1>
                            <small>Para Hoje</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "ContaPagar", action: "VerPagamentosHoje", buttonClass: "white")
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Pagamentos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ContaCPAtraso</h1>
                            <small>Em Atraso</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "ContaPagar", action: "VerPagamentosAtraso", buttonClass: "white")
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Recebimentos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ContaCRVencHoje</h1>
                            <small>Para Hoje</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "ContaReceberNova", action: "VerRecebimentosHoje", buttonClass: "white")
                        </div>
                    </div>
                </div>
                <div class="col-lg-2">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                            <span class="label label-success pull-right">Hoje</span>
                            <h5>Recebimentos</h5>
                        </div>
                        <div class="ibox-content">
                            <h1 class="no-margins">@ViewBag.ContaCRAtraso</h1>
                            <small>Em Atraso</small>
                            <br />
                            <br />
                            @Html.ButtonLinkIndex(text: "Ver", controller: "ContaReceberNova", action: "VerLancamentosAtrasoCR", buttonClass: "white")
                        </div>
                    </div>
                </div>

                <div class="col-lg-2">
                    <div style="display: none; z-index:1000" class="dotContainer">
                        <div class="spiner-example">
                            <div class="sk-spinner sk-spinner-three-bounce">
                                <div class="sk-bounce1"></div>
                                <div class="sk-bounce2"></div>
                                <div class="sk-bounce3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        
            @*Gráficos*@
            <br />
            <div class="row">
                <div class="col-lg-12">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title">
                            <h5>Indicadores</h5>
                        </div>
                        <div class="ibox-content ibox-heading">
                            <h3><i class="fa fa-line-chart"></i> Indicadores</h3>
                            <small><i class="fa fa-tim"></i> Valores acumulados/atualizados até hoje</small>
                        </div>

                        <div class="ibox-content" style="height: 4100px">
                            <div class="col-lg-4 col-md-4 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos/Dia - Mês Corrente</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartCPData" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos/Mês - 12 últimos meses</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartCPMes" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos/Dia - Mês Corrente</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartCRData" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos/Mês - 12 últimos meses</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartCRMes" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Lançamentos Bancários/Dia - Mês Corrente</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartLancData" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Lançamentos Bancários/Mês - 12 últimos meses</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="barChartLancMes" height="150"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-4 col-xs-12">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos por Situação</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="doughnutChartCPSituacao" height="200"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos por Modo</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="doughnutChartCPModo" height="200"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos por Situação</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="doughnutChartCRSituacao" height="200"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos por Modo</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="doughnutChartCRModo" height="200"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Contas Bancárias por Tipo</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <canvas id="doughnutChartContaTipo" height="200"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-4 col-xs-12">
                                @if ((ViewBag.Usuario as EntitiesServices.Model.USUARIO).PERFIL.PERF_IN_ACESSO_CONTA_BANCO == 1)
                                {
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                            <div class="ibox-title">
                                                <h4>Contas Bancárias</h4>
                                            </div>
                                            <div class="ibox-content">
                                                <div class="row">
                                                    @if ((ViewBag.ListaConta as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                                    {
                                                        <table class="table table-striped table-bordered table-hover">
                                                            <thead style="background-color:lightsteelblue">
                                                                <tr>
                                                                    <th>Nome</th>
                                                                    @if (ViewBag.Perfil == "ADM" || ViewBag.Perfil == "GER")
                                                                    {
                                                                        <th>Saldo (R$)</th> 
                                                                    }
                                                                    @if ((ViewBag.Usuario as EntitiesServices.Model.USUARIO).PERFIL.PERF_IN_ALTERACAO_CONTA == 1)
                                                                    {
                                                                        <th class="td-one-action">Ações</th>
                                                                    }
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var cond in (ViewBag.ListaConta as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderBy(p => p.Nome).Take(10))
                                                                {
                                                                    <tr>
                                                                        <td>@cond.Nome</td>
                                                                        @if (ViewBag.Perfil == "ADM" || ViewBag.Perfil == "GER")
                                                                        {
                                                                            if (cond.ValorDec < 0)
                                                                            {
                                                                                <td style="color: red; font-weight: bold">@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                            }
                                                                            else
                                                                            {
                                                                                <td style="color: green; font-weight: bold">@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                            }
                                                                        }
                                                                        @if ((ViewBag.Usuario as EntitiesServices.Model.USUARIO).PERFIL.PERF_IN_ALTERACAO_CONTA == 1)
                                                                        {
                                                                            <td class="td-one-action">
                                                                                @Html.TableLinkDetails(cond.Valor, "VerContaBancaria", "fa-search", "Ver")
                                                                            </td>
                                                                        }
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos - Vencimento Hoje</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                @if ((ViewBag.ListaCPVencHoje as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                                {
                                                    <table class="table table-striped table-bordered table-hover">
                                                        <thead style="background-color:lightsteelblue">
                                                            <tr>
                                                                <th>Fornecedor</th>
                                                                <th>Valor ($)</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var cond in (ViewBag.ListaCPVencHoje as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderBy(p => p.Valor).Take(10))
                                                            {
                                                                <tr>
                                                                    <td>@cond.Nome</td>
                                                                    <td>@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }
                                                else
                                                {
                                                    <div class="row">
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                        <div style=" border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                            <h4 style="font-weight: bold">Nenhum pagamento para hoje</h4>
                                                        </div>
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Pagamentos em Atraso</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                @if ((ViewBag.ListaCPAtraso as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                                {
                                                    <table class="table table-striped table-bordered table-hover">
                                                        <thead style="background-color:lightsteelblue">
                                                            <tr>
                                                                <th>Fornecedor</th>
                                                                <th>Valor ($)</th>
                                                                <th>Vencimento</th>
                                                                <th>Atraso</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var cond in (ViewBag.ListaCPAtraso as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderBy(p => p.Valor).Take(10))
                                                            {
                                                                <tr>
                                                                    <td>@cond.Nome</td>
                                                                    <td>@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                    <td>@cond.DataEmissao.ToShortDateString()</td>
                                                                    <td>@cond.Valor</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }
                                                else
                                                {
                                                    <div class="row">
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                        <div style=" border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                            <h4 style="font-weight: bold">Nenhum pagamento em atraso</h4>
                                                        </div>
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos - Vencimento Hoje</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                @if ((ViewBag.ListaCRVencHoje as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                                {
                                                    <table class="table table-striped table-bordered table-hover">
                                                        <thead style="background-color:lightsteelblue">
                                                            <tr>
                                                                <th>Cliente</th>
                                                                <th>Valor ($)</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var cond in (ViewBag.ListaCRVencHoje as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderBy(p => p.Valor).Take(10))
                                                            {
                                                                <tr>
                                                                    <td>@cond.Nome</td>
                                                                    <td>@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }
                                                else
                                                {
                                                    <div class="row">
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                        <div style=" border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                            <h4 style="font-weight: bold">Nenhum recebimento para hoje</h4>
                                                        </div>
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins" style="border-bottom: solid; border-bottom-color: darkgreen; border-bottom-width: 2px; border-left: solid; border-left-color: darkgreen; border-left-width: 1px; border-right: solid; border-right-color: darkgreen; border-right-width: 1px; border-top: solid; border-top-color: darkgreen; border-top-width: 1px">
                                        <div class="ibox-title">
                                            <h4>Recebimentos em Atraso</h4>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                @if ((ViewBag.ListaCRAtraso as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).Count > 0)
                                                {
                                                    <table class="table table-striped table-bordered table-hover">
                                                        <thead style="background-color:lightsteelblue">
                                                            <tr>
                                                                <th>Cliente</th>
                                                                <th>Valor ($)</th>
                                                                <th>Vencimento</th>
                                                                <th>Atraso</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var cond in (ViewBag.ListaCRAtraso as List<ERP_Condominios_Solution.ViewModels.ModeloViewModel>).OrderBy(p => p.Valor).Take(10))
                                                            {
                                                                <tr>
                                                                    <td>@cond.Nome</td>
                                                                    <td>@CrossCutting.Formatters.DecimalFormatter(cond.ValorDec)</td>
                                                                    <td>@cond.DataEmissao.ToShortDateString()</td>
                                                                    <td>@cond.Valor</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }
                                                else
                                                {
                                                    <div class="row">
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                        <div style=" border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-10 col-md-10 col-xs-8">
                                                            <h4 style="font-weight: bold">Nenhum recebimento em atraso</h4>
                                                        </div>
                                                        <div class="col-lg-1 col-md-1 col-xs-12">
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>     
        </div>
    </div>
</div>

