@using Presentation.Extensions
@using CrossCutting;
@using EntitiesServices.Work_Classes;
@model EntitiesServices.Model.USUARIO_LOGIN
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Acessos";
    ViewBag.MetaDescription = "WebDoctor - Acessos - Lista de acessos";
    ViewBag.MetaKeywords = "WebDoctor, acesso, ip";
}

<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*Titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button onclick="limpaModal()" type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <h3 class="title">Administração</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaDashboardAdministracao", "BaseAdmin")">Dashboard - Administração</a>
            </li>
            <li class="active">
                <strong>Administração - Controle de Acessos</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                    <span class="label label-primary pull-right">Hoje</span>
                    <h5>Acessos</h5>
                </div>
                <div class="ibox-content">
                    <h3 class="no-margins">@ViewBag.TotalDia</h3>
                    <small>Total do Dia</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                    <span class="label label-primary pull-right">Mês</span>
                    <h5>Acessos</h5>
                </div>
                <div class="ibox-content">
                    <h3 class="no-margins">@ViewBag.TotalMes</h3>
                    <small>Total do Mês</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="background-color: darkseagreen; color: darkgreen">
                    <span class="label label-primary pull-right">Mês</span>
                    <h5>Acessos</h5>
                </div>
                <div class="ibox-content">
                    <h3 class="no-margins">@ViewBag.TotalGeral</h3>
                    <small>Total Geral</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2">
            <div style="display: none; z-index:1000" class="dotContainer">
                <div class="spiner-example">
                    <div class="sk-spinner sk-spinner-three-bounce">
                        <div class="sk-bounce1"></div>
                        <div class="sk-bounce2"></div>
                        <div class="sk-bounce3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>





    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarAcesso", "BaseAdmin", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Início
                                @Html.TextBoxFor(m => m.USLO_DT_LOGIN, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data1" })
                            </div>
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Data Final
                                @Html.TextBoxFor(m => m.USLO_DT_DUMMY, "{0:dd/MM/yyyy}", new { @class = "form-control date-picker", autofocus = true, @id="data2" })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">                                     
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "BaseAdmin", action: "RetirarFiltroAcesso")
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaDashboardAdministracao", controller: "BaseAdmin")                
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
            <div class="ibox-title">
                <div class="row">
                    <div style="text-align: center;" class="col-lg-12 col-md-12 col-xs-12">
                        <h5>Administração - Controle de Acessos</h5>
                    </div>
                </div>
            </div>
            <div class="ibox-content">
                <div class="row">
                    @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.USUARIO_LOGIN>).Count > 0)
                    {
                        <table class="table table-striped table-bordered table-hover dataTables-example">
                            <thead style="background-color:lightsteelblue">
                                <tr>
                                    <th style="width: auto">Início da Sessão</th>
                                    <th style="width: auto">Término da Sessão</th>
                                    <th style="width: auto">Duração da Sessão</th>
                                    <th style="width: auto">Nome do Usuário</th>
                                    <th style="width: auto">Status do Usuário</th>
                                    <th class="td-one-action">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.USUARIO_LOGIN>).OrderByDescending(p => p.USLO_CD_ID))
                                {
                                    <tr>                                            
                                        <td style="width: auto">@cond.USLO_DT_LOGIN.ToShortDateString() @cond.USLO_DT_LOGIN.ToShortTimeString()</td>
                                        @if (cond.USLO_DT_LOGOUT != null)
                                        {
                                            <td style="width: auto">@cond.USLO_DT_LOGOUT.Value.ToShortDateString() @cond.USLO_DT_LOGOUT.Value.ToShortTimeString()</td>
                                        }
                                        else
                                        {
                                            <td style="width: auto; color: brown; font-weight: bold">Sessão não encerrada</td>
                                        }
                                        <td style="width: auto">@cond.USLO_TM_DURACAO</td>
                                        <td style="width: auto">@cond.USUARIO.USUA_NM_NOME</td>
                                        @if (cond.USUARIO.USUA_IN_BLOQUEADO == 0)
                                        {
                                            <td style="width: auto"><span class="badge badge-primary">Normal</span></td>
                                        }
                                        else
                                        {
                                            <td style="width: auto"><span class="badge badge-danger">Bloqueado</span></td>
                                        }
                                        <td class="td-one-action">
                                            @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_BLOQUEIO_USUARIO == 1)
                                            {
                                                if (cond.USUARIO.USUA_IN_BLOQUEADO == 0)
                                                {
                                                    <span style="color: #337ab7; cursor:pointer;" alt="Bloquear" class="tbl-link fa-lg fa fa-thumbs-o-down" onclick="ShowModalBloquear('/BaseAdmin/BloquearUsuario/@cond.USUA_CD_ID', '@cond.USUARIO.USUA_NM_NOME')" title="Bloquear Usuário"></span>
                                                }
                                                else
                                                {
                                                    <span style="color: #337ab7; cursor:pointer;" alt="Desbloquear" class="tbl-link fa-lg fa fa-thumbs-o-up" onclick="ShowModalDesbloquear('/BaseAdmin/DesbloquearUsuario/@cond.USUA_CD_ID', '@cond.USUARIO.USUA_NM_NOME')" title="Desbloquear Usuário"></span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="row">
                            <div class="col-lg-3 col-md-3 col-xs-2">

                            </div>
                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                <h2 style="font-weight: bold">Nenhum acesso atendeu ao filtro especificado</h2>
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-2">

                            </div>
                        </div>
                    }
            </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}

@section Scripts {

    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>    

    <script>
        $(function () {
            limpaModal();
        });

        function limpaModal() {
            $('#btnModal').remove();
            $('#modalTitle').remove();
        }

        function ShowModalBloquear(url, nome) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Desativar" class="btn btn-primary" href="' + url + '" target="_self" title="Bloquear">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma bloqueio de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">'+nome+'</h5>');
            $('#modal').modal('show');
        }

        function ShowModalDesbloquear(url, nome) {
            $('#modal').find('.modal-footer').prepend('<a id="btnModal" alt="Reativar" class="btn btn-primary" href="' + url + '" target="_self" title="Desbloquear">Confirmar</a>');
            $('#modal').find('.modal-body').html('Confirma desbloqueio de usuario?');
            $('#modal').find('.modal-header').prepend('<h5 id="modalTitle" class="modal-title">'+nome+'</h5>');
            $('#modal').modal('show');
        }
    </script>
   
    <script type="text/javascript" language="javascript">
        $(function () {
            $('.date-picker').datepicker(
                {
                    dateFormat: 'dd/mm/yy',
                    dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                    dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                    dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                    monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                    nextText: 'Proximo',
                    prevText: 'Anterior',
                    showOn: "focus"
                }
            )
                .css("display", "normal")
                .next("button").button({
                    icons: { primary: "ui-icon-calendar" },
                    label: "Selecione uma data",
                    text: false
                });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $('.dataTables-example').DataTable({
                pageLength: 25,
                dom: '<"html5buttons"B>lTfgitp',
                buttons: [
                    { extend: 'excel', title: 'Acessos_Planilha' },
                    {
                        extend: 'print',
                        customize: function (win) {
                            $(win.document.body).addClass('white-bg');
                            $(win.document.body).css('font-size', '10px');

                            $(win.document.body).find('table')
                                    .addClass('compact')
                                    .css('font-size', 'inherit');
                        }
                    }
                ]

            });      
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $("#data1").mask("99/99/9999");
            $("#data2").mask("99/99/9999");
        });
    </script>
    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.Message");
            };
    </script>
}

