@using Presentation.Extensions
@using CrossCutting
@model EntitiesServices.Model.USUARIO
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
    ViewBag.Title = "WebDoctor - Tabelas Auxiliares";
    ViewBag.MetaDescription = "WebDoctor - Tabelas Auxiliares";
    ViewBag.MetaKeywords = "WebDoctor, tabela, auxiliar";
}
<div style="z-index: 999;" class="dotContainer">
    <div style="top: 500px" class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>

<div id="content" class="wraper container-fluid">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="col-lg-12 col-md-12 col-sm-12">
            @*Atalhos*@
            <div class="row">
                <h3 style="color:olivedrab; font-weight:bold">Tabelas Auxiliares - Administração</h3>
                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                    <br />
                    <div class="col-lg-12 col-md-12 col-xs-12">
                        @Html.ButtonLinkIndex(text: "Tipos de Paciente", action: "MontarTelaTipoPaciente", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Tipos de Consulta", action: "MontarTelaTipoValorConsulta", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Tipos de Exames", action: "MontarTelaTipoExame", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Tipos de Atestados", action: "MontarTelaTipoAtestado", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Convênios", action: "MontarTelaConvenio", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Laboratórios", action: "MontarTelaLaboratorio", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Especialidades", action: "MontarTelaEspecialidade", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Formas de Recebimento", action: "MontarTelaFormaRecebimento", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Tipos de Pagamento", action: "MontarTelaTipoPagamento", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Categorias de Produtos", action: "MontarTelaCatProduto", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Subcategorias de Produtos", action: "MontarTelaSubCatProduto", controller: "TabelasAuxiliares")
                        @Html.ButtonLinkIndex(text: "Voltar", controller: "Paciente", action: "MontarTelaPaciente")
                    </div>
                    <br /><br />
                </div>
            </div>  
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}

@section Scripts {

    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>


    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}

