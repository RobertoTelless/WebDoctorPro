@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.ModeloViewModel
@{
    Layout = "~/Views/Shared/_Layout_Limpo.cshtml";
    ViewBag.Title = "WebDoctor - Validação";
    ViewBag.MetaDescription = "WebDoctor - Validação de Documentos";
    ViewBag.MetaKeywords = "WebDoctor, Validação, Validacao, Documento";
}
<div style="display: none;" class="dotContainer">
    <div class="dotWrapper">
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="circle"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
        <div class="shadow"></div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-5 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Validação de Documentos</h5>
                </div>
                @using (Html.BeginForm("MontarTelaValidacaoDocumento", "ValidacaoDocumento", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id="pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>
                        }
                        @if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }                    
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            @Html.ButtonActionSubmit(text: "Proceder Validação do Documento", htmlAttributes: new { id = "basictoast" })
                            @Html.ButtonLinkIndex(text: "Voltar", controller: "BaseAdmin", action: "CarregarLandingPage")
                            <br />
                        </div>
                        <div class="row" id="Documento">
                            <h4 style="margin-left: 0px; color:green; background-color: beige; font-weight:bold">Documento a Validar</h4>
                            <div class="col-lg-8 col-md-8 col-xs-8">
                                <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">                
                                    <div class="col-lg-4 col-md-4 col-xs-12">
                                        Tipo de Documento*
                                        @Html.DropDownListFor(m => m.Valor, (SelectList)ViewBag.TipoDocumento, new { @class = "form-control", @id = "tipo", autofocus = true, data_toggle = "popover", data_content = "Informe o tipo de documento a consultar", data_trigger="hover", data_placement="top" })
                                        @Html.ValidationMessageFor(m => m.Valor, "", new { @style = "color:red" })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Token do Documento*
                                        @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", autofocus = true, data_toggle = "popover", data_content = "Informe o token do documento a validar", data_trigger="hover", data_placement="top" })
                                        @Html.ValidationMessageFor(m => m.Nome, "", new { @style = "color:red" })
                                    </div>
                                </div>                                            
                            </div>
                            <div class="col-lg-4 col-md-4 col-xs-4">
                                <div class="ibox float-e-margins" style="background-color:beige">
                                    <div class="ibox-title"  style="background-color: darkseagreen; color: darkgreen">
                                        <h5>Instruções para Validar Documentos</h5>
                                    </div>
                                    <div class="ibox-content" style="background-color:beige">
                                        <div class="form-group" style=" margin-left: 5px; margin-right: 5px;">  
                                            <br />
                                            <ul style="margin:0; padding-left:20px; list-style-type:disc;">
                                                <li style="margin-bottom:2px; line-height:1.1;">Selecione o tipo de documento a ser validado</li>
                                                <li style="margin-bottom:2px; line-height:1.1;">Informe o token deste documento</li>
                                                <li style="margin-bottom:2px; line-height:1.1;">O token é compoto por 6 caracteres alfanuméricos</li>
                                                <li style="margin-bottom:2px; line-height:1.1;">Está sempre localizado no rodapé do documento</li>
                                                <li style="margin-bottom:2px; line-height:1.1;">Clique em Proceder Validação do Documento</li>
                                            </ul>                                                               
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,300,600,700' rel='stylesheet' type='text/css'>
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
    @Styles.Render("~/Content/css")
    @Styles.Render("~/font-awesome/css")
    <link href="@Url.Content("~/Scripts/plugins/jquery-ui/jquery-ui.min.css")" rel="stylesheet" type="text/css" />
}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
    @Scripts.Render("~/plugins/passwordMeter")
    @Scripts.Render("~/plugins/sweetAlert")
   
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>
    <script>
        function Fade() {
            $('.dotContainer').fadeIn("fast");
            $('#login').css("filter", "blur(4px)");
        }
    </script>
    <script>
        $(window).on("load", function () {
            $('.dotContainer').fadeOut("slow");
            $('#title').css("filter", "blur(0)");
            $('#content').css("filter", "blur(0)");
        });
    </script>
}

@if (ViewBag.Message != null)
{
    <script type="text/javascript">
        window.onload = function () {
            alert("@ViewBag.Message");
        };
    </script>
}
