@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.PacientePrescricaoViewModel
@{
    Layout = "~/Views/Shared/_Layout_Limpo.cshtml";
    ViewBag.Title = "WebDoctor - prescricao - Validação";
    ViewBag.MetaDescription = "WebDoctor - Prescricoes - Validar prescricao do paciente";
    ViewBag.MetaKeywords = "WebDoctor, prescricao, validacao";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modal fade" id="meuModalDeTexto" tabindex="-1" role="dialog" aria-labelledby="meuModalDeTextoLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="meuModalDeTextoLabel">Denunciar Prescrição</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="textoDoModal">Motivo da Denuncia:</label>
                        <textarea class="form-control" id="textoDoModal" placeholder="Digite o motivo aqui..." rows="5" style="overflow: auto;" maxlength="5000"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnEnviarTextoModal">Prosseguir</button>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaValidacaoDocumento", "ValidacaoDocumento")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Prescrição - Validação</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Prescrição - Validação</h5>
                </div>
                @using (Html.BeginForm("MostraValidarPrescricao", "ValidacaoDocumento", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                {
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                @Html.ValidationSummary(false, "Erros Encontrados:", new { @class = "text-danger" })
                            </div>
                        }
                        @if (TempData["TemMensagem"] != null)
                        {
                            <div class="alert alert-success">
                                <button type="button" class="close" data-dismiss="alert">Fechar</button>
                                <span>@TempData["MensagemAcerto"]</span>
                            </div>
                        }                    
                        <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                            @if (Model.PAPR_IN_VALIDACAO != 1 & Model.PAPR_IN_DENUNCIA != 1)
                            {
                                <a href="@Url.Action("ConfirmarValidacaoPrescricao", "ValidacaoDocumento")" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Confirma a validação da Prescrição" class="btn btn-sm btn-primary" id="emp" OnClick = "Fade()">Validar Prescrição</a>                
                            }
                            @if (Model.PAPR_IN_DENUNCIA != 1 & Model.PAPR_IN_VALIDACAO != 1)
                            {
                                <button type="button" class="btn btn-danger" data-toggle="modal" data-target="#meuModalDeTexto">
                                    Denunciar Prescrição
                                </button>
                            }
                            @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaValidacaoDocumento", controller: "ValidacaoDocumento") 

                        @*Mensagem Validação*@
                        <div class="row">
                            @if (Model.PAPR_IN_VALIDACAO == 1)
                            {
                                <div class="form-group" style=" margin-left: 0px; margin-right: 30px;">                
                                    <br />
                                    <div class="col-lg-12 col-md-12 col-xs-12"style="margin-left: 15px; margin-right: 30px; color: brown; background-color: moccasin; font-weight:bold; font-size: large">
                                        @ViewBag.MensagemValida
                                    </div>
                                    <br /><br />
                                </div>
                            }
                        </div>

                        @*Denuncia Anterior*@
                        <div class="row">
                            @if (Model.PAPR_IN_DENUNCIA == 1)
                            {

                                <div class="form-group" style=" margin-left: 0px; margin-right: 30px;">                
                                    <br />
                                    <div class="col-lg-12 col-md-12 col-xs-12"style="margin-left: 15px; margin-right: 30px; color: brown; background-color: moccasin; font-weight:bold; font-size: large">
                                        @ViewBag.MensagemDenuncia
                                    </div>
                                    <br /><br />
                                </div>
                            }
                        </div>

                        @*Paciente*@
                        <div class="row">
                            <h4 style="margin-left: 15px; margin-right: 15px; color:green; background-color: beige; font-weight:bold">Identificação do Paciente</h4>
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                <div class="col-lg-4 col-md-4 col-xs-12">
                                    Nome do Paciente
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data Nascimento
                                    @Html.TextBoxFor(m => m.PACIENTE.PACI_DT_NASCIMENTO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                </div>
                                @if (Model.PACIENTE.PACI_NR_CPF != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        CPF
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CPF, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_CELULAR != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Celular
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_CELULAR, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                                @if (Model.PACIENTE.PACI_NR_TELEFONE != null)
                                {
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Telefone
                                        @Html.TextBoxFor(m => m.PACIENTE.PACI_NR_TELEFONE, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                }
                            </div>
                        </div>

                        @*Assinatura Digital*@
                        @if (Model.PAPR_IN_ASSINADO_DIGITAL == 1)
                        {
                            <div class="form-group" style=" margin-left: 0px; margin-right: 30px;"> 
                                <div class="row">
                                    <h4 style="margin-left: 15px; margin-right: -15px; color:green; background-color: beige; font-weight:bold">Assinatura Digital</h4>
                                    <div class="col-lg-12 col-md-12 col-xs-12"style="margin-left: 15px; margin-right: 30px; color: darkblue; background-color: aliceblue; font-weight:bold; font-size: medium">
                                        @ViewBag.MensagemAssina
                                    </div>
                                    <br />
                                </div>
                            </div>
                        }

                        @*Prescricao*@
                        <div class="row">
                            <h4 style="margin-left: 15px; margin-right: 15px; color:green; background-color: beige; font-weight:bold">Prescrição</h4>
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Identificador
                                    @Html.TextBoxFor(m => m.PAPR_GU_GUID, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: darkblue; font-weight: bold", data_toggle = "popover", data_content = "Identificador único da solicitação de exame gerado pelo WebDoctor", data_trigger = "hover", data_placement = "top" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Data/Hora de Emissão
                                    @Html.TextBoxFor(m => m.PAPR_DT_EMISSAO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly", @tabindex = "-1" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Tipo de Controle
                                    @Html.TextBoxFor(m => m.TIPO_CONTROLE.TICO_NM_NOME, new { @class = "form-control", @readonly = "readonly"  })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Último Envio
                                    @Html.TextBoxFor(m => m.PAPR_DT_ENVIO, "{0:dd/MM/yyyy}", new { @class = "form-control", @readonly = "readonly" })
                                </div>
                                <div class="col-lg-2 col-md-2 col-xs-12">
                                    Token de Acesso
                                    @Html.TextBoxFor(m => m.PAPR_TK_TOKEN, new { @class = "form-control", @readonly = "readonly", @style = "color: darkblue; font-weight: bold" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <h4 style="margin-left: 15px; margin-right: 15px; color:green; background-color: beige; font-weight:bold">Itens da Prescrição</h4>
                            <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @if (ViewBag.Itens != null &&(ViewBag.Itens as List<EntitiesServices.Model.PACIENTE_PRESCRICAO_ITEM>).Count > 0)
                                    {
                                        <table class="table table-striped table-bordered table-hover dataTables-example1">
                                            <thead style="background-color:lightsteelblue">
                                                <tr>
                                                    <th style="width: auto">Forma de Uso</th>
                                                    <th style="width: auto">Medicamento</th>
                                                    <th style="width: auto">Nome Genérico</th>
                                                    <th style="width: auto">Posologia</th>
                                                    <th style="width: auto">Quantidade</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cond in (ViewBag.Itens as List<EntitiesServices.Model.PACIENTE_PRESCRICAO_ITEM>).OrderBy(p => p.PAPI_NM_REMEDIO))
                                                {
                                                    <tr>
                                                        <td style="width: auto">@cond.TIPO_FORMA.TIFO_NM_NOME</td>
                                                        <td style="width: auto">@cond.PAPI_NM_REMEDIO</td>
                                                        <td style="width: auto">@cond.PAPI_NM_GENERICO</td>
                                                        <td style="width: auto">@cond.PAPI_DS_POSOLOGIA</td>
                                                        <td style="width: auto">@cond.PAPI_NR_QUANTIDADE</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                            <div style="border: 5px solid #F6A54A; padding: 10px; border-radius: 8px 8px; " class="col-lg-6 col-md-6 col-xs-8">
                                                <h2 style="font-weight: bold">Nenhum item incluído nessa prescrição</h2>
                                            </div>
                                            <div class="col-lg-3 col-md-3 col-xs-2">

                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @*Validacao*@
                        @if (Model.PAPR_IN_VALIDACAO == 1)
                        {
                            <div class="row">
                                <h4 style="margin-left: 15px; margin-right: 15px; color:green; background-color: beige; font-weight:bold">Validação</h4>
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Validado
                                        @Html.TextBoxFor(m => m.Validado, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data da Validação
                                        @Html.TextBoxFor(m => m.PAPR_DT_VALIDACAO, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Validado Por
                                        @Html.TextBoxFor(m => m.PAPR_IP_VALIDACAO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Num.Validações
                                        @Html.TextBoxFor(m => m.PAPR_NR_VALIDACAO, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>
                            </div>
                        }

                        @*Denuncia*@
                        @if (Model.PAPR_IN_DENUNCIA == 1)
                        {
                            <div class="row">
                                <h4 style="margin-left: 15px; margin-right: 15px; color:green; background-color: beige; font-weight:bold">Denuncia</h4>
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Denunciado
                                        @Html.TextBoxFor(m => m.Denuncia, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", @style = "color: brown; font-weight: bold" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Data da Denuncia
                                        @Html.TextBoxFor(m => m.PAPR_DT_DENUNCIA, "{0:dd/MM/yyyy}", new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-xs-12">
                                        Denunciado Por
                                        @Html.TextBoxFor(m => m.PAPR_IP_DENUNCIA, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                    <div class="col-lg-2 col-md-2 col-xs-12">
                                        Num.Denuncias
                                        @Html.TextBoxFor(m => m.PAPR_NR_DENUNCIA, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly" })
                                    </div>
                                </div>                            
                                <div class="form-group" style=" margin-left: 0px; margin-right: 0px;">                
                                    <div class="col-lg-12 col-md-12 col-xs-12">
                                        Motivo da Denuncia
                                        @Html.TextAreaFor(m => m.PAPR_TX_DENUNCIA, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", style = "width: 100%; height: 100px; overflow:auto;", data_toggle = "popover", data_content = "Motivos que levaram à denuncia desta prescrição", data_trigger="hover", data_placement="top"  })
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                }
         </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />  
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")
}



@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    
    @Scripts.Render("~/plugins/toastr")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            // Inicializa o popover do Bootstrap 3/4
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#btnEnviarTextoModal').click(function () {
                var textoInserido = $('#textoDoModal').val();
            
                if (textoInserido.trim() === "") {
                    alert("Por favor, digite o motivo da denuncia.");
                    return;
                }

                $.ajax({
                    url: '@Url.Action("DenunciarPrescricao", "ValidacaoDocumento")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ texto: textoInserido }),
                    success: function (response) {
                        // Fechar a modal imediatamente, independentemente do resultado
                        $('#meuModalDeTexto').modal('hide');
                    
                        if (response.success) {
                            alert(response.mensagem);
                            // Recarregar a página para atualizar o estado da interface
                            window.location.reload(); 
                        }
                        else {
                            // Mensagem de erro do servidor
                            alert("Erro ao processar a denúncia: " + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        // Fechar a modal em caso de erro
                        $('#meuModalDeTexto').modal('hide');
                        alert("Ocorreu um erro na requisição: " + error);
                    }
                });
            });
        
            $('#meuModalDeTexto').on('hidden.bs.modal', function () {
                $('#textoDoModal').val('');
            });
        });
    </script> 
    
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>
    

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                 alert("@ViewBag.Message");
            };
        </script>
    }
}