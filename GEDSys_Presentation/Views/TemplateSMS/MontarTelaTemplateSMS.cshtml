@using Presentation.Extensions
@using CrossCutting;
@using System.IO;
@using EntitiesServices.Work_Classes;
@model EntitiesServices.Model.TEMPLATE_SMS
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="modalContainer">
        <div id="modal" class="modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        @*titulo gerado dinamicamente*@
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        @*Gerado dinamicamente*@
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="page-title">
        <h3 class="title">Modelos de SMS</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li class="active">
                <strong>Modelos de SMS</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Filtros</h5>
                </div>

                @using (Html.BeginForm("FiltrarTemplateSMS", "TemplateSMS", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal" }))
                {
                    <div class="ibox-content">
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-2 col-md-2 col-xs-12">
                                Sigla do Modelo
                                @Html.TextBoxFor(m => m.TSMS_SG_SIGLA, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-3 col-md-3 col-xs-12">
                                Nome do Modelo
                                @Html.TextBoxFor(m => m.TSMS_NM_NOME, new { @class = "form-control", autofocus = true })
                            </div>
                            <div class="col-lg-7 col-md-7 col-xs-12">
                                Conteúdo do Modelo
                                @Html.TextBoxFor(m => m.TSMS_TX_CORPO, new { @class = "form-control", autofocus = true })
                            </div>
                        </div>
                        <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                            <div class="col-lg-12 col-md-12 col-xs-12">
                                @Html.ButtonActionSubmit(text: "Filtrar")
                                @if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUSAO_TEMPLATE == 1)
                                {
                                    @Html.ButtonLinkIndex(text: "Novo Modelo de SMS", controller: "TemplateSMS", action: "IncluirTemplateSMS", buttonClass: "primary")
                                }
                                @Html.ButtonLinkIndex(text: "Retirar Filtro", controller: "TemplateSMS", action: "RetirarFiltroTemplateSMS")
                                @Html.ButtonLinkIndex(text: "Voltar", action: "MontarTelaPaciente", controller: "Paciente")
                                <a href="@Url.Action((String)Session["AjudaNivel"])"  class="btn btn-sm btn-danger" target="_blank">Ajuda</a>                
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Modelos de SMS</h5>
                </div>
                <div class="ibox-content">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    @if (TempData["TemMensagem"] != null)
                    {
                        <div class="alert alert-success">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            <span>@TempData["MensagemAcerto"]</span>
                        </div>
                    }                    
                    <div class="row">
                        @if (ViewBag.Listas != null && (ViewBag.Listas as List<EntitiesServices.Model.TEMPLATE_SMS>).Count > 0)
                        {
                            <table class="table table-striped table-bordered table-hover dataTables-example">
                                <thead style="background-color:lightsteelblue">
                                    <tr>
                                        <th style="width: auto">Sigla do Modelo</th>
                                        <th style="width: auto">Nome do Modelo</th>
                                        <th style="width: auto">Fixo</th>
                                        <th style="width: auto">Editável</th>
                                        <th class="td-one-action">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cond in (ViewBag.Listas as List<EntitiesServices.Model.TEMPLATE_SMS>))
                                    {
                                        if (cond.TSMS_IN_ATIVO == 1)
                                        {
                                            if (cond.TSMS_CD_ID != (Int32)Session["LinhaAlterada"])
                                            {
                                                <tr>
                                                    <td style="width: auto">@cond.TSMS_SG_SIGLA</td>
                                                    @if (cond.TSMS_IN_EDITAVEL == 1)
                                                    {
                                                        if (((EntitiesServices.Model.PERFIL)Session["PerfilUsuario"]).PERF_IN_INCLUSAO_TEMPLATE == 1)
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("EditarTemplateSMS", "TemplateSMS", new { id = cond.TSMS_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de edição de modelos SMS"/>@cond.TSMS_NM_NOME</td>
                                                        }
                                                        else
                                                        {
                                                            <td style="width: auto; cursor: pointer; text-decoration: underline;"><a href="@Url.Action("VerTemplateSMS", "TemplateSMS", new { id = cond.TSMS_CD_ID })" data-toggle="popover" data-trigger="hover" data-placement="top" data-content="Acessar a página de visualização de modelos SMS"/>@cond.TSMS_NM_NOME</td>
                                                        }
                                                    }
                                                    else
