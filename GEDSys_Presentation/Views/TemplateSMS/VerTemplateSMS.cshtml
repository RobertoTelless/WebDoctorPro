@using Presentation.Extensions
@model ERP_Condominios_Solution.ViewModels.TemplateSMSViewModel
@{
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="page-title">
        <h3 class="title">Modelos de SMS</h3>
        <br />
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("MontarTelaPaciente", "Paciente")">Dashboard</a>
            </li>
            <li>
                <a href="@Url.Action("MontarTelaTemplateSMS", "TemplateSMS")">Modelos de SMS</a>
            </li>
            <li class="active">
                <strong>Modelos de SMS - Consulta</strong>
            </li>
        </ol>
        <br />
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12 col-xs-12">
            <div class="col-lg-12 col-md-12 col-xs-12 ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Modelos de SMS - Consulta</h5>
                </div>
                <div class="ibox-content">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <button type="button" class="close" data-dismiss="alert">Fechar</button>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="tabs-container">
                        @using (Html.BeginForm("VerTemplateSMS", "TemplateSMS", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", @id = "pwd-container1" }))
                        {
                            <div class="form-group">
                                <br />
                                <div class="col-lg-12 col-md-12 col-xs-12">
                                    @Html.ButtonLinkIndex(text: "Voltar", action: "VoltarBaseTemplateSMS", controller: "TemplateSMS")
                                </div>
                            </div>
                            
                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#tab-1">Informações do Modelo</a></li>
                            </ul>

                            <div class="tab-content">
                                @*Dados Gerais*@
                                <div id="tab-1" class="tab-pane active">
                                    <div class="panel-body">
                                        <div class="row">
                                            @Html.HiddenFor(m => m.ASSI_CD_ID)
                                            @Html.HiddenFor(m => m.TSMS_IN_ATIVO)
                                            @Html.HiddenFor(m => m.ROBOT)
                                            @Html.HiddenFor(m => m.TSMS_CD_ID)
                                            @Html.HiddenFor(m => m.EMPR_CD_ID)
                                            @Html.HiddenFor(m => m.TSMS_NR_SISTEMA)
                                            @Html.HiddenFor(m => m.TSMS_SG_SIGLA)
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Sigla do Modelo
                                                    @Html.TextBoxFor(m => m.TSMS_SG_SIGLA, new { @class = "form-control", @id = "sigla", @tabindex = "-1", @readonly = "readonly", @style = "color: green; font-weight: bold" })
                                                </div>
                                                <div class="col-lg-6 col-md-6 col-xs-12">
                                                    Nome do Modelo
                                                    @Html.TextBoxFor(m => m.TSMS_NM_NOME, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Nome que identifica este modelo de SMS", data_trigger="hover", data_placement="top" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Editável
                                                    @Html.TextBoxFor(m => m.Editavel, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Indica se este modelo pode ou não ser alterado posteriormente", data_trigger="hover", data_placement="top" })
                                                </div>
                                                <div class="col-lg-2 col-md-2 col-xs-12">
                                                    Fixo
                                                    @Html.TextBoxFor(m => m.Fixo, new { @class = "form-control", @tabindex = "-1", @readonly = "readonly", data_toggle = "popover", data_content = "Indica se este modelo pode ou não ser excluído posteriormente", data_trigger="hover", data_placement="top" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="form-group" style=" margin-left: -15px; margin-right: -15px;">
                                                <div class="col-lg-12 col-md-12 col-xs-12">
                                                    Texto da Mensagem
                                                    @Html.TextAreaFor(m => m.TSMS_TX_CORPO, new { @class = "form-control", style = "width: 100%; height: 250px;", @tabindex = "-1", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/Content/themes/base/all.css" rel="stylesheet" />
    @Styles.Render("~/Content/plugins/dataTables/dataTablesStyles")
    @Styles.Render("~/plugins/jasnyBootstrapStyles")
    @Styles.Render("~/plugins/toastrStyles")

}
@section Scripts {
    @Scripts.Render("~/plugins/toastr")
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/bundles/inputmask")
    @Scripts.Render("~/plugins/jasnyBootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
    <script src="~/Scripts/uploadAnexo.js"></script>    
    
    <script type="text/javascript" src="~/Scripts/moment.min.js"></script>
    <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
   
    <script type="text/javascript">
        $(document).ready(function () {
            $('[data-toggle="popover"]').popover();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                return new bootstrap.Popover(popoverTriggerEl);
            });
        });
    </script>

    <!-- Handler de fechamento do browser -->
    <script type="text/javascript">
        window.onbeforeunload = function ()
        {
            navigator.sendBeacon('../ControleAcesso/LogSessionTime');
        }; 
    </script>

    @if (ViewBag.Message != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                  alert("@ViewBag.Message");
            };
        </script>
    }
}
